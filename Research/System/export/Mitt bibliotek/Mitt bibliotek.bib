}

@article{wang_bioactive_2017,
	title = {Bioactive {Mushroom} {Polysaccharides}: {A} {Review} on {Monosaccharide} {Composition}, {Biosynthesis} and {Regulation}.},
	doi = {10.3390/molecules22060955},
	abstract = {Mushrooms are widely distributed around the world and are heavily consumed because of their nutritional value and medicinal properties. Polysaccharides (PSs) are an important component of mushrooms, a major factor in their bioactive properties, and have been intensively studied during the past two decades. Monosaccharide composition/combinations are important determinants of PS bioactivities. This review summarizes: (i) monosaccharide composition/combinations in various mushroom PSs, and their relationships with PS bioactivities; (ii) possible biosynthetic pathways of mushroom PSs and effects of key enzymes on monosaccharide composition; (iii) regulation strategies in PS biosynthesis, and prospects for controllable biosynthesis of PSs with enhanced bioactivities.},
	journal = {Molecules},
	author = {Wang, Qiong and Wang, Qiong and Wang, Feng and Wang, Feng and Xu, Zhenghong and Xu, Zhenghong and Xu, Zhenghong and Ding, Zhongyang and Ding, Zhongyang},
