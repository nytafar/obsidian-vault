	url = {https://www.mdpi.com/2076-3921/8/8/261},
	doi = {10.3390/antiox8080261},
	abstract = {Oxidative stress and inflammation in neuron-glia system are key factors in the pathogenesis of neurodegenerative diseases. As synthetic drugs may cause side effects, natural products have gained recognition for the prevention or management of diseases. In this study, hot water (HE-HWA) and ethanolic (HE-ETH) extracts of the basidiocarps of Hericium erinaceus mushroom were investigated for their neuroprotective and anti-inflammatory activities against hydrogen peroxide (H2O2)-induced neurotoxicity in HT22 mouse hippocampal neurons and lipopolysaccharide (LPS)-induced BV2 microglial activation respectively. HE-ETH showed potent neuroprotective activity by significantly (p {\textless} 0.0001) increasing the viability of H2O2-treated neurons. This was accompanied by significant reduction in reactive oxygen species (ROS) (p {\textless} 0.05) and improvement of the antioxidant enzyme catalase (CAT) (p {\textless} 0.05) and glutathione (GSH) content (p {\textless} 0.01). Besides, HE-ETH significantly improved mitochondrial membrane potential (MMP) (p {\textless} 0.05) and ATP production (p {\textless} 0.0001) while reducing mitochondrial toxicity (p {\textless} 0.001), Bcl-2-associated X (Bax) gene expression (p {\textless} 0.05) and nuclear apoptosis (p {\textless} 0.0001). However, gene expression of Nuclear factor erythroid 2-related factor 2 (Nrf2), heme oxygenase 1 (HO-1) and NAD(P)H quinone dehydrogenase 1 (NQO1) were unaffected (p {\textgreater} 0.05). HE-ETH also significantly (p {\textless} 0.0001) reduced nitric oxide (NO) level in LPS-treated BV2 indicating an anti-inflammatory activity in the microglia. These findings demonstrated HE-ETH maybe a potential neuroprotective and anti-inflammatory agent in neuron-glia environment.},
	language = {en},
	number = {8},
	urldate = {2025-03-18},
	journal = {Antioxidants},
	publisher = {Multidisciplinary Digital Publishing Institute},
	author = {Kushairi, Naufal and Phan, Chia Wei and Sabaratnam, Vikineswary and David, Pamela and Naidu, Murali},
	month = aug,
	year = {2019},
	note = {Number: 8},
	keywords = {\textit{Hericium erinaceus}, anti-inflammation, antioxidants, mushroom, neuroprotection},
	pages = {261},
	file = {Full Text PDF:files/653/Kushairi et al. - 2019 - Lion’s Mane Mushroom, Hericium erinaceus (Bull. Fr.) Pers. Suppresses H2O2-Induced Oxidative Damage.pdf:application/pdf},
}

@article{lai_neurotrophic_2013,
	title = {Neurotrophic properties of the {Lion}'s mane medicinal mushroom, {Hericium} erinaceus ({Higher} {Basidiomycetes}) from {Malaysia}},
	volume = {15},
	issn = {1940-4344},
	doi = {10.1615/intjmedmushr.v15.i6.30},
	abstract = {Neurotrophic factors are important in promoting the growth and differentiation of neurons. Nerve growth factor (NGF) is essential for the maintenance of the basal forebrain cholinergic system. Hericenones and erinacines isolated from the medicinal mushroom Hericium erinaceus can induce NGF synthesis in nerve cells. In this study, we evaluated the synergistic interaction between H. erinaceus aqueous extract and exogenous NGF on the neurite outgrowth stimulation of neuroblastoma-glioma cell NG108-15. The neuroprotective effect of the mushroom extract toward oxidative stress was also studied. Aqueous extract of H. erinaceus was shown to be non-cytotoxic to human lung fibroblast MRC-5 and NG108-15 cells. The combination of 10 ng/mL NGF with 1 μg/mL mushroom extract yielded the highest percentage increase of 60.6\% neurite outgrowth. The extract contained neuroactive compounds that induced the secretion of extracellular NGF in NG108-15 cells, thereby promoting neurite outgrowth activity. However, the H. erinaceus extract failed to protect NG108-15 cells subjected to oxidative stress when applied in pre-treatment and co-treatment modes. In conclusion, the aqueous extract of H. erinaceus contained neuroactive compounds which induced NGF-synthesis and promoted neurite outgrowth in NG108-15 cells. The extract also enhanced the neurite outgrowth stimulation activity of NGF when applied in combination. The aqueous preparation of H. erinaceus had neurotrophic but not neuroprotective activities.},
	language = {eng},
	number = {6},
	journal = {International Journal of Medicinal Mushrooms},
	author = {Lai, Puei-Lene and Naidu, Murali and Sabaratnam, Vikineswary and Wong, Kah-Hui and David, Rosie Pamela and Kuppusamy, Umah Rani and Abdullah, Noorlidah and Malek, Sri Nurestri A.},
	year = {2013},
	keywords = {Basidiomycota, Biological Products, Cell Line, Tumor, Drug Synergism, Fibroblasts, Humans, Malaysia, Nerve Growth Factor, Nerve Growth Factors, Neurites, Oxidative Stress},
	pages = {539--554},
	file = {Fulltekst:files/654/Lai et al. - 2013 - Neurotrophic properties of the Lion's mane medicinal mushroom, Hericium erinaceus (Higher Basidiomyc.pdf:application/pdf},
}

