23,0.01836602,0.18003307,-0.00391379,0.02220706,0.02744221,0.0195576,0.02000993,-0.01462991,0.02457174,0.00582094,-0.02063243,0.06938504,-0.00387243,0.05495863,0.12046413,-0.07203804,-0.00504214,-0.00112303,0.02810532,0.02166711,0.01263113,-0.04428501,0.01104655,0.07527897,-0.06200447,-0.06419736,-0.01947991,0.00567462,-0.02950555,-0.01970408,-0.02408105,0.00227045,-0.02206478,-0.05926552,0.01058689,0.04179034,-0.00420946,-0.04345545,0.01614342,-0.00501473,-0.0268892,-0.05556297,0.12777914,0.03133117],"last_embed":{"hash":"1llphuv","tokens":497}}},"last_read":{"hash":"1llphuv","at":1774951889074},"class_name":"SmartSource","last_import":{"mtime":1774951819811,"size":2772,"at":1774951884796,"hash":"1llphuv"},"blocks":{"#---frontmatter---":[1,61],"#GSK-3α regulates production of Alzheimer's disease amyloid-β peptides":[63,67],"#GSK-3α regulates production of Alzheimer's disease amyloid-β peptides#{1}":[65,67]},"outlinks":[{"title":"Author/Christopher J. Phiel","target":"Author/Christopher J. Phiel","line":48},{"title":"Author/Christopher J. Phiel","target":"Author/Christopher J. Phiel","line":49},{"title":"Author/Christopher Wilson","target":"Author/Christopher Wilson","line":50},{"title":"Author/Christina A. Wilson","target":"Author/Christina A. Wilson","line":51},{"title":"Author/Christina A. Wilson","target":"Author/Christina A. Wilson","line":52},{"title":"Author/Virginia M.-Y. Lee","target":"Author/Virginia M.-Y. Lee","line":53},{"title":"Author/Virginia M.-Y. Lee","target":"Author/Virginia M.-Y. Lee","line":54},{"title":"Author/Peter S. Klein","target":"Author/Peter S. Klein","line":55},{"title":"Author/Peter S. Klein","target":"Author/Peter S. Klein","line":56},{"title":"PDF","target":"biblib/phiel_gsk-3_2003/phiel_gsk-3_2003.pdf","line":58}],"metadata":{"id":"phiel_gsk-3_2003","type":"article-journal","title":"GSK-3α regulates production of Alzheimer's disease amyloid-β peptides","issued":{"date-parts":[[2003]]},"DOI":"10.1038/nature01640","container-title":"Nature","abstract":"Alzheimer's disease is associated with increased production and aggregation of amyloid-β (Aβ) peptides1. Aβ peptides are derived from the amyloid precursor protein (APP) by sequential proteolysis, catalysed by the aspartyl protease BACE2, followed by presenilin-dependent γ-secretase cleavage3. Presenilin interacts with nicastrin4,5, APH-1 and PEN-2 (ref. 6), all of which are required for γ-secretase function. Presenilins also interact with α-catenin, β-catenin7,8 and glycogen synthase kinase-3β (GSK-3β)9,10,11, but a functional role for these proteins in γ-secretase activity has not been established. Here we show that therapeutic concentrations of lithium, a GSK-3 inhibitor12, block the production of Aβ peptides by interfering with APP cleavage at the γ-secretase step, but do not inhibit Notch processing. Importantly, lithium also blocks the accumulation of Aβ peptides in the brains of mice that overproduce APP. The target of lithium in this setting is GSK-3α, which is required for maximal processing of APP. Since GSK-3 also phosphorylates tau protein, the principal component of neurofibrillary tangles, inhibition of GSK-3α offers a new approach to reduce the formation of both amyloid plaques and neurofibrillary tangles, two pathological hallmarks of Alzheimer's disease.","tags":["#literature_note"],"author":[{"family":"Phiel","given":"Christopher J.","literal":""},{"family":"Phiel","given":"Christopher J.","literal":""},{"family":"Wilson","given":"Christopher","literal":""},{"family":"Wilson","given":"Christina A.","literal":""},{"family":"Wilson","given":"Christina A.","literal":""},{"family":"Lee","given":"Virginia M.-Y.","literal":""},{"family":"Lee","given":"Virginia M.-Y.","literal":""},{"family":"Klein","given":"Peter S.","literal":""},{"family":"Klein","given":"Peter S.","literal":""}],"citation-key":"phiel_gsk-3_2003","year":"2003","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["GSK-3α regulates production of Alzheimer's disease amyloid-β peptides"],"author-links":["[[Author/Christopher J. Phiel]]","[[Author/Christopher J. Phiel]]","[[Author/Christopher Wilson]]","[[Author/Christina A. Wilson]]","[[Author/Christina A. Wilson]]","[[Author/Virginia M.-Y. Lee]]","[[Author/Virginia M.-Y. Lee]]","[[Author/Peter S. Klein]]","[[Author/Peter S. Klein]]"],"attachment":["[[biblib/phiel_gsk-3_2003/phiel_gsk-3_2003.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"1llphuv","at":1774951889064}},"smart_blocks:Research/@phiel_gsk-3_2003.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.00876549,-0.01579364,-0.01781074,-0.04523311,-0.01507958,0.00427038,0.05333615,-0.01041921,-0.0143976,-0.02956731,-0.02072405,-0.04001666,0.03601278,0.06886028,-0.01148818,-0.00453363,-0.05161367,0.03335139,-0.08632176,-0.01301285,0.06976975,-0.07227121,0.06152777,-0.02164672,0.03894785,0.03232423,-0.03253285,-0.00908883,-0.04496699,-0.22118528,-0.03181251,-0.05607755,0.00855919,-0.01033878,-0.0363497,-0.04297969,-0.01923394,0.02518644,-0.07791626,-0.02523045,0.11503705,0.05079847,-0.03717701,-0.0497429,0.01302098,-0.02699647,-0.05276664,-0.0557284,0.00405078,-0.02309415,0.00653352,0.01962123,0.02670361,0.06598958,0.00939675,0.0091926,-0.01649189,0.07541231,0.01265382,0.08101558,0.02763808,0.05040346,-0.16727813,0.07644815,0.07364734,0.04754307,-0.01049361,-0.00227348,0.0371471,0.0506027,-0.06416547,0.05439746,0.01460788,0.02587057,-0.01231868,0.02695657,-0.01877408,0.00192193,0.04715506,0.01558603,0.06275758,0.06208102,-0.00429511,0.03306947,-0.04225905,-0.0555834,0.00415123,-0.03683985,0.01619618,-0.00949978,-0.03700358,-0.04335222,-0.00473398,0.00560065,0.01442255,0.0364559,0.02072287,-0.01963527,-0.07701099,0.11135823,-0.02269893,0.02678455,-0.04823364,-0.02269222,-0.00336967,-0.04725986,-0.04444632,-0.01286526,-0.04369677,0.05536876,0.06388486,-0.00671901,0.00658622,-0.01526804,0.01526017,0.02537244,0.02479132,0.01245725,-0.030