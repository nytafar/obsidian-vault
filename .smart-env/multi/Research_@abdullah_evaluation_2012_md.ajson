1,0.02951743,0.0096318,0.1708573,0.00713276,-0.08363822,0.01811589,-0.03644828,-0.0314998,-0.06530235,0.04690343,0.00199143,0.05276395,0.11676076,-0.01640833,0.10780902,0.11088078,-0.02561086,-0.04193154,-0.02977232,-0.04482464,0.02181359,-0.05813191,-0.13709041,-0.00929109,0.11340828,-0.06497353,0.00695304,-0.03745212,-0.02609797,-0.00539872,0.00925766,-0.01089779,0.01803675,0.02561347,0.01609058,-0.03583511,-0.01659107,-0.00229213,-0.0062075,-0.01005031,0.00231971,0.02895693,0.00445014,0.09124851,0.07488576],"last_embed":{"hash":"1pl1drs","tokens":461}}},"last_read":{"hash":"1pl1drs","at":1774951892519},"class_name":"SmartSource","last_import":{"mtime":1774951824374,"size":2828,"at":1774951884814,"hash":"1pl1drs"},"blocks":{"#---frontmatter---":[1,65],"#Evaluation of Selected Culinary-Medicinal Mushrooms for Antioxidant and ACE Inhibitory Activities":[67,71],"#Evaluation of Selected Culinary-Medicinal Mushrooms for Antioxidant and ACE Inhibitory Activities#{1}":[69,71]},"outlinks":[{"title":"Author/Noorlidah Abdullah","target":"Author/Noorlidah Abdullah","line":51},{"title":"Author/Noorlidah Abdullah","target":"Author/Noorlidah Abdullah","line":52},{"title":"Author/Siti Izera Ismail","target":"Author/Siti Izera Ismail","line":53},{"title":"Author/Siti Marjiana Ismail","target":"Author/Siti Marjiana Ismail","line":54},{"title":"Author/Norhaniza Aminudin","target":"Author/Norhaniza Aminudin","line":55},{"title":"Author/Norhaniza Aminudin","target":"Author/Norhaniza Aminudin","line":56},{"title":"Author/Adawiyah Suriza Shuib","target":"Author/Adawiyah Suriza Shuib","line":57},{"title":"Author/Adawiyah Suriza Shuib","target":"Author/Adawiyah Suriza Shuib","line":58},{"title":"Author/Beng Fye Lau","target":"Author/Beng Fye Lau","line":59},{"title":"Author/Beng Fye Lau","target":"Author/Beng Fye Lau","line":60},{"title":"PDF","target":"biblib/abdullah_evaluation_2012/abdullah_evaluation_2012.pdf","line":62}],"metadata":{"id":"abdullah_evaluation_2012","type":"article-journal","title":"Evaluation of Selected Culinary-Medicinal Mushrooms for Antioxidant and ACE Inhibitory Activities","issued":{"date-parts":[[2012]]},"DOI":"10.1155/2012/464238","container-title":"Evidence-based Complementary and Alternative Medicine","abstract":"Considering the importance of diet in prevention of oxidative stress-related diseases including hypertension, this study was undertaken to evaluate the in vitro antioxidant and ACE inhibitory activities of selected culinary-medicinal mushrooms extracted by boiling in water for 30 min. Antioxidant capacity was measured using the following assays: DPPH free radical scavenging activity, -carotene bleaching, inhibition of lipid peroxidation, reducing power ability, and cupric ion reducing antioxidant capacity (CUPRAC). Antioxidant potential of each mushroom species was calculated based on the average percentages relative to quercetin and summarized as Antioxidant Index (AI). Ganoderma lucidum (30.1%), Schizophyllum commune (27.6%), and Hericium erinaceus (17.7%) showed relatively high AI. Total phenolics in these mushrooms varied between 6.19 to 63.51 mg GAE/g extract. In the ACE inhibitory assay, G. lucidum was shown to be the most potent species (IC50 = 50 g/mL). Based on our findings, culinary-medicinal mushrooms can be considered as potential source of dietary antioxidant and ACE inhibitory agents.","tags":["#literature_note"],"author":[{"family":"Abdullah","given":"Noorlidah","literal":""},{"family":"Abdullah","given":"Noorlidah","literal":""},{"family":"Ismail","given":"Siti Izera","literal":""},{"family":"Ismail","given":"Siti Marjiana","literal":""},{"family":"Aminudin","given":"Norhaniza","literal":""},{"family":"Aminudin","given":"Norhaniza","literal":""},{"family":"Shuib","given":"Adawiyah Suriza","literal":""},{"family":"Shuib","given":"Adawiyah Suriza","literal":""},{"family":"Lau","given":"Beng Fye","literal":""},{"family":"Lau","given":"Beng Fye","literal":""}],"citation-key":"abdullah_evaluation_2012","year":"2012","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Evaluation of Selected Culinary-Medicinal Mushrooms for Antioxidant and ACE Inhibitory Activities"],"author-links":["[[Author/Noorlidah Abdullah]]","[[Author/Noorlidah Abdullah]]","[[Author/Siti Izera Ismail]]","[[Author/Siti Marjiana Ismail]]","[[Author/Norhaniza Aminudin]]","[[Author/Norhaniza Aminudin]]","[[Author/Adawiyah Suriza Shuib]]","[[Author/Adawiyah Suriza Shuib]]","[[Author/Beng Fye Lau]]","[[Author/Beng Fye Lau]]"],"attachment":["[[biblib/abdullah_evaluation_2012/abdullah_evaluation_2012.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"1pl1drs","at":1774951892506}},"smart_blocks:Research/@abdullah_evaluation_2012.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.02770021,0.01228046,0.02304328,-0.0103524,0.05319826,0.0007122,0.04262278,0.02833709,-0.03399277,-0.06696139,-0.03589476,-0.03509878,0.04690948,-0.01032264,0.01218267,-0.00771757,0.05486552,-0.00799242,-0.10071137,-0.01885789,0.02770799,-0.01605226,0.02432529,-0.02221031,0.07604625,0.05107575,-0.00396982,-0.00957416,-0.04486969,-0.20240666,-0.01862918,0.00374786,0.02955933,-0.02169594,-0.04048422,-0.00146106,-0.01408433,0.0114148,-0.03111056,0.02213009,0.09314223,0.02412,0.0025158,0.04650329,-0.0065985,-0.05010005,-0.05711037,-0.00201252,0.03356503,-0.01645139,-0.03987317,-0.06386417,0.01278133,-0.02959937,0.078729,0.01378631,0.03441138,0.03957201,0.00571126,0.05650387,0.03856986,0.04985891,-0.17483938,0.0708939,-0.02787312,-0.03082606,-0.04529038,0.00614,0.08440699,-0.02239802,-0.02628541,0.04906993,0.01653398,0.04863199,0.01542765,-0.00669532,-0.02006526,-0.06638045,-0.04072311,0.01822718,0.02521525,0.06655534,0.02108859,0.01801528,-0.02020368,-0.03348403,0.00364233,-0.02999883,0.03128155,-0.03377521,0.00602632,-0.02661178,-0.01887129,-0.00339428,-0.02804468,0.00272084,-0.03949876,-0.08142117,-0.09347302,0.13332593,-0.08586793