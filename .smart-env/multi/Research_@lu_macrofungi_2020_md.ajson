32451,0.03210931,0.18245156,0.01600226,-0.02619201,0.00279456,-0.0079235,-0.00929366,-0.02728527,0.02101783,0.01688303,0.05384322,0.12037582,-0.01235653,0.04101648,0.03807061,-0.00750951,-0.08410944,-0.05232029,0.01465318,-0.01765699,0.01018978,-0.07620352,-0.01049917,0.08039631,-0.07193169,-0.02844585,-0.06613467,-0.00970826,-0.02663707,-0.03851429,0.00494914,0.0267712,0.03193827,-0.05860395,0.01013352,0.04084664,-0.02401653,-0.03932881,0.04000104,0.03217429,0.02950746,-0.10428413,0.08086883,-0.00607364],"last_embed":{"hash":"tcqdxh","tokens":397}}},"last_read":{"hash":"tcqdxh","at":1774951891194},"class_name":"SmartSource","last_import":{"mtime":1774951822086,"size":2871,"at":1774951884805,"hash":"tcqdxh"},"blocks":{"#---frontmatter---":[1,65],"#Macrofungi: A review of cultivation strategies, bioactivity, and application of mushrooms.":[67,71],"#Macrofungi: A review of cultivation strategies, bioactivity, and application of mushrooms.#{1}":[69,71]},"outlinks":[{"title":"Author/Hongyun Lu","target":"Author/Hongyun Lu","line":51},{"title":"Author/Hongyun Lu","target":"Author/Hongyun Lu","line":52},{"title":"Author/Hanghang Lou","target":"Author/Hanghang Lou","line":53},{"title":"Author/Hanghang Lou","target":"Author/Hanghang Lou","line":54},{"title":"Author/Jingjin Hu","target":"Author/Jingjin Hu","line":55},{"title":"Author/Jingjin Hu","target":"Author/Jingjin Hu","line":56},{"title":"Author/Zhengjie Liu","target":"Author/Zhengjie Liu","line":57},{"title":"Author/Zhengjie Liu","target":"Author/Zhengjie Liu","line":58},{"title":"Author/Qihe Chen","target":"Author/Qihe Chen","line":59},{"title":"Author/Qihe Chen","target":"Author/Qihe Chen","line":60},{"title":"PDF","target":"biblib/lu_macrofungi_2020/lu_macrofungi_2020.pdf","line":62}],"metadata":{"id":"lu_macrofungi_2020","type":"article-journal","title":"Macrofungi: A review of cultivation strategies, bioactivity, and application of mushrooms.","issued":{"date-parts":[[2020]]},"DOI":"10.1111/1541-4337.12602","container-title":"Comprehensive Reviews in Food Science and Food Safety","abstract":"The production of macrofungi (mushrooms) as well as their economic value have been steadily increasing globally. The use of functional foods, dietary supplements, and traditional medicines derived from macrofungi is increasing as they have numerous health benefits as well as abundant nutrients. Macrofungi are diverse with complex and highly varied growth conditions and bioactive constituents, most macrofungal resources have not yet been fully explored and applicated, leading to an urgent need for appropriate strategies to address the problem. Increasing attention has been paid to the macrofungal cultivation and application, in particular, potential prebiotics. Herein, the present review comprehensively summarizes recent progress in the cultivation, newly identified bioactive constituents, and their effects on gut microbiota as well as the potential ways in which they affect human health. Moreover, the macrofungal food development is discussed to improve food nutritional value and change the quality characteristics of food. Finally, the review addresses consumer safety concerns and the prospective genetic manipulation of macrofungi. We hope that this review can provide a comprehensive research reference for ensuring the safety and efficacy, along with maximizing the value and profitability of macrofungi production.","tags":["#literature_note"],"author":[{"family":"Lu","given":"Hongyun","literal":""},{"family":"Lu","given":"Hongyun","literal":""},{"family":"Lou","given":"Hanghang","literal":""},{"family":"Lou","given":"Hanghang","literal":""},{"family":"Hu","given":"Jingjin","literal":""},{"family":"Hu","given":"Jingjin","literal":""},{"family":"Liu","given":"Zhengjie","literal":""},{"family":"Liu","given":"Zhengjie","literal":""},{"family":"Chen","given":"Qihe","literal":""},{"family":"Chen","given":"Qihe","literal":""}],"citation-key":"lu_macrofungi_2020","year":"2020","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Macrofungi: A review of cultivation strategies, bioactivity, and application of mushrooms."],"author-links":["[[Author/Hongyun Lu]]","[[Author/Hongyun Lu]]","[[Author/Hanghang Lou]]","[[Author/Hanghang Lou]]","[[Author/Jingjin Hu]]","[[Author/Jingjin Hu]]","[[Author/Zhengjie Liu]]","[[Author/Zhengjie Liu]]","[[Author/Qihe Chen]]","[[Author/Qihe Chen]]"],"attachment":["[[biblib/lu_macrofungi_2020/lu_macrofungi_2020.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"tcqdxh","at":1774951891186}},"smart_blocks:Research/@lu_macrofungi_2020.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.03094943,-0.01814202,0.04296493,-0.03771619,0.03746058,0.00240265,0.01298711,0.00112938,-0.0248528,0.01454296,0.0113575,-0.082099,0.02113844,0.00731141,-0.00726118,-0.02771243,0.04216762,-0.01671881,-0.0842097,-0.0369957,0.05968764,-0.03637294,0.04160267,-0.04826412,0.01840834,0.01406475,0.00329117,0.01841422,-0.04066546,-0.21135849,-0.008507,0.02344522,0.06646498,-0.05782865,-0.05596061,-0.04555945,0.02262478,0.01987099,-0.03059984,0.06679923,0.10582098,0.04064321,0.02047066,0.01010171,-0.0271442,-0.03306395,-0.04051067,-0.0037198,-0.02081787,-0.05297171,-0.04197755,-0.08136239,0.00861222,-0.00173816,-0.00495823,-0.02031531,-0.00747601,0.03270729,0.04235924,0.11508046,0.09379115,0.04212989,-0.20343377,0.06395231,-0.00388627,0.00977294,-0.07301724,0.01624325,0.05373926,0.00130366,-0.03712486,0.01306516,0.10456213,0.02754999,0.06025141,0.01170168,0.05183049,-0.0734922,-0.03786191,0.02395543,0.02290445,0.08215742,-0.03031368,0.01437028,-0.06256854,-0.01299493,0.01379166,-0.01821559,0.0663904,-0.00804628,0.03635426,-0.044118,0.02367185,-0.0112757,-0.06633937,0.00073227,-0.0001638,-0.03516255,-0.07141212,0.13891788,-0.09304962,0.00029417,0.07644334,0.03866793,0.02704899,0.01397314,-0.03073852,-0.03468342,0.06081159,-0.00789133,0.02395204,0.02932034,-0.05355028,