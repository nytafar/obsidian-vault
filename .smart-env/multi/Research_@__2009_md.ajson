4,0.0345778,-0.00313573,0.02499516,0.02312957,-0.00832488,-0.02868397,0.03685838,-0.02834606,0.04009386,0.1355747,-0.03511871,0.04637458,0.06723958,-0.00548536,-0.05171169,0.00210549,0.01127102,0.01859648,0.01890433,-0.09249011,-0.06162411,0.09988468,-0.07960344,-0.057192,-0.08690366,0.02323736,-0.03571352,0.00097766,-0.00607859,-0.00125175,0.00150174,-0.05465796,0.01262529,0.00458421,-0.01382732,-0.0522995,-0.01909395,0.00414502,-0.0283499,-0.06065828,0.1221398,0.05448603],"last_embed":{"hash":"15r9n9o","tokens":479}}},"last_read":{"hash":"15r9n9o","at":1774951896144},"class_name":"SmartSource","last_import":{"mtime":1774951829287,"size":3305,"at":1774951884831,"hash":"15r9n9o"},"blocks":{"#---frontmatter---":[1,72],"#수삼추출물 첨가 배지에서 배양된 노루궁뎅이버섯 균사체 심부발효물 조다당획분의 면역 및 암전이 억제활성":[74,78],"#수삼추출물 첨가 배지에서 배양된 노루궁뎅이버섯 균사체 심부발효물 조다당획분의 면역 및 암전이 억제활성#{1}":[76,78]},"outlinks":[{"title":"Author/김훈","target":"Author/김훈","line":57},{"title":"Author/김훈","target":"Author/김훈","line":58},{"title":"Author/박창규","target":"Author/박창규","line":59},{"title":"Author/박창규","target":"Author/박창규","line":60},{"title":"Author/정재현","target":"Author/정재현","line":61},{"title":"Author/정재현","target":"Author/정재현","line":62},{"title":"Author/정헌상","target":"Author/정헌상","line":63},{"title":"Author/정헌상","target":"Author/정헌상","line":64},{"title":"Author/이현용","target":"Author/이현용","line":65},{"title":"Author/이현용","target":"Author/이현용","line":66},{"title":"Author/유광원","target":"Author/유광원","line":67},{"title":"Author/유광원","target":"Author/유광원","line":68}],"metadata":{"id":"__2009","type":"article-journal","title":"수삼추출물 첨가 배지에서 배양된 노루궁뎅이버섯 균사체 심부발효물 조다당획분의 면역 및 암전이 억제활성","issued":{"date-parts":[[2009]]},"DOI":"10.3746/jkfn.2009.38.11.1535","container-title":"Journal of The Korean Society of Food Science and Nutrition","abstract":"To find the new use of Korean ginseng and mushroom, crude polysaccharides were prepared from submerged cultures of Hericium erinaceum in the medium supplemented with Korean ginseng extracts. When we fractionated crude polysaccharides (HE-GE-CP-1, 3, and 5) from hot-water extracts of submerged cultures of H. erinaceum with ginseng extracts (1%, 3%, and 5% addition of total medium), the yields of HE-GE-CP-1, 3, and 5 were identified at 5.7, 5.1, and 4.8%, respectively. Among crude polysaccharide fractions, HE-GE-CP-5 was significantly higher (1.89-fold of the saline control) than those of HE-GE-CP-1 (1.64-fold) or HE-GE-CP-3 (1.76-fold) on mitogenic activity of splenocytes. HE-GE-CP-5 also had the more potent bone marrow cell proliferation (1.83-fold) rather than HE-CP or HE-GE-CP-1 or HE-GE-CP-3 (1.59- or 1.44- or 1.69-fold, respectively), and anti-metastatic activity as anti-cancer effect showed the highest prophylactic value (72.4% inhibition of tumor control) in 5% supplementation of ginseng extract. However, the lysosomal phosphatase of macrophage was significantly stimulated after HE-GE-CP-3 treatment (2.03-fold). In addition, the immunostimulating and anti-metastatic crude polysaccharide, HE-GE-CP-5, contained mainly neutral sugars (63.2%) with considerable amounts of uronic acid (19.3%) and a small amount of proteins (8.8%). HE-GE-CP-5 can stimulate immune system to inhibit tumor metastasis, and its anti-tumor metastasis may be associated with macrophages, splenocytes and Peyer's patch cells activation.","tags":["#literature_note"],"author":[{"family":"김훈","given":"","literal":""},{"family":"김훈","given":"","literal":""},{"family":"박창규","given":"","literal":""},{"family":"박창규","given":"","literal":""},{"family":"정재현","given":"","literal":""},{"family":"정재현","given":"","literal":""},{"family":"정헌상","given":"","literal":""},{"family":"정헌상","given":"","literal":""},{"family":"이현용","given":"","literal":""},{"family":"이현용","given":"","literal":""},{"family":"유광원","given":"","literal":""},{"family":"유광원","given":"","literal":""}],"citation-key":"__2009","year":"2009","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["수삼추출물 첨가 배지에서 