208837,0.02175613,-0.05652447,-0.01238809,-0.0261459,0.11963685,0.01976029,-0.02874668,0.00858666,0.01361121,0.05960122,-0.00943835,0.01803217,0.00356294,-0.02688287,0.0549568,-0.01402711,0.09212677,0.08926555,-0.02180864,-0.02369357,0.0143738,0.00430869,0.04098078,-0.0243258,-0.05628627,0.00345694,0.08946827,-0.02944273,-0.02150284,-0.05885401,-0.0255358,-0.01629233,0.02693547,-0.06413267,-0.00733649,0.03698729,-0.00490364,0.02080965,-0.01634828,-0.01791522,0.00988731,-0.04199803,-0.00581766,-0.01312178,-0.07332841,0.09499506,0.06852005],"last_embed":{"hash":"t26xid","tokens":486}}},"last_read":{"hash":"t26xid","at":1774951886188},"class_name":"SmartSource","last_import":{"mtime":1774951814807,"size":3927,"at":1774951884769,"hash":"t26xid"},"blocks":{"#---frontmatter---":[1,97],"#Anti-inflammatory drugs and risk of Alzheimer's disease: an updated systematic review and meta-analysis.":[99,103],"#Anti-inflammatory drugs and risk of Alzheimer's disease: an updated systematic review and meta-analysis.#{1}":[101,103]},"outlinks":[{"title":"Author/Jun Wang","target":"Author/Jun Wang","line":75},{"title":"Author/Jun Wang","target":"Author/Jun Wang","line":76},{"title":"Author/Lan Tan","target":"Author/Lan Tan","line":77},{"title":"Author/Lan Tan","target":"Author/Lan Tan","line":78},{"title":"Author/Lan Tan","target":"Author/Lan Tan","line":79},{"title":"Author/Hui-Fu Wang","target":"Author/Hui-Fu Wang","line":80},{"title":"Author/Hui-Fu Wang","target":"Author/Hui-Fu Wang","line":81},{"title":"Author/Cheng Tan","target":"Author/Cheng Tan","line":82},{"title":"Author/Chen-Chen Tan","target":"Author/Chen-Chen Tan","line":83},{"title":"Author/Xiangfei Meng","target":"Author/Xiangfei Meng","line":84},{"title":"Author/Xiang-Fei Meng","target":"Author/Xiang-Fei Meng","line":85},{"title":"Author/Xiangfei Meng","target":"Author/Xiangfei Meng","line":86},{"title":"Author/Chong Wang","target":"Author/Chong Wang","line":87},{"title":"Author/Chong Wang","target":"Author/Chong Wang","line":88},{"title":"Author/Shaowen Tang","target":"Author/Shaowen Tang","line":89},{"title":"Author/Shaowen Tang","target":"Author/Shaowen Tang","line":90},{"title":"Author/Jin-Tai Yu","target":"Author/Jin-Tai Yu","line":91},{"title":"Author/Jin-Tai Yu","target":"Author/Jin-Tai Yu","line":92},{"title":"PDF","target":"biblib/wang_anti-inflammatory_2015/wang_anti-inflammatory_2015.pdf","line":94}],"metadata":{"id":"wang_anti-inflammatory_2015","type":"article-journal","title":"Anti-inflammatory drugs and risk of Alzheimer's disease: an updated systematic review and meta-analysis.","issued":{"date-parts":[[2015]]},"DOI":"10.3233/jad-141506","container-title":"Journal of Alzheimer's Disease","abstract":"BACKGROUND: In the past 20 years, substantial evidence from laboratory and epidemiologic studies have suggested that anti-inflammatory medications could defer or prevent the occurrence of Alzheimer's disease (AD). However, several studies do not corroborate these findings. OBJECTIVE: To evaluate the association of anti-inflammatory drug use on the incidence of AD. METHODS: Pubmed, Embase, and Cochrane Library databases were searched up to March 2014. Studies evaluating the association between use of anti-inflammatory drugs and AD risk were included. Relative risks (RRs) with 95% confidence intervals (CIs) were meta-analyzed using random effects models and were grouped by anti-inflammatory type and duration of drug use. RESULTS: In observational studies, use of non-steroidal anti-inflammatory drugs (NSAIDs) was significantly associated with a reduced risk of AD (RR, 0.72; 95%CI, 0.62-0.84) compared to no use of NSAIDs, especially in long term users (RR, 0.36; 95%CI, 0.17-0.74); the risks of AD were also lower in both aspirin (RR, 0.77; 95%CI, 0.63-0.95) and non-aspirin NSAID users (RR, 0.65; 95%CI, 0.47-0.88) compared with nonusers; whereas the use of corticosteroids showed no significant association (RR, 0.62; 95%CI, 0.26-1.46). In the single randomized controlled trial (RCT), NSAID use showed no significant effect on AD risk among dementia-free individuals (p > 0.05). CONCLUSION: Observational studies support the use of NSAIDs for prevention of AD, but RCT do not. Well-designed studies and innovative approaches are required to illuminate the exact relationship between NSAID use and AD risk. The appropriate dosage and duration of use to benefit and the safety are also needed to determine.","tags":["#literature_note"],"author":[{"family":"Wang","given":"Jun","literal":""},{"family":"Wang","given":"Jun","literal":""},{"family":"Tan","given":"Lan","literal":""},{"family":"Tan","given":"Lan","literal":""},{"family":"Tan","given":"Lan","literal":""},{"family":"Wang","given":"Hui-Fu","literal":""},{"family":"Wang","given":"Hui-Fu","literal":""},{"family":"Tan","given":"Cheng","literal":""},{"family":"Tan","given":"Chen-Chen","literal":""},{"family":"Meng","given":"Xiangfei","literal":""},{"family":"Meng","given":"Xiang-Fei","literal":""},{"family":"Meng","given":"Xiangfei","literal":""},{"family":"Wang","given":"Chong","literal":""},{"family":"Wang","given":"Chong","literal":""},{"family":"Tang","given":"Shaowen","literal":""},{"family":"Tang","given":"Shaowen","literal":""},{"family":"Yu","given":"Jin-Tai","literal":""},{"family":"Yu","given":"Jin-Tai","literal":""}],"citation-key":"wang_anti-inflammatory_2015","year":"2015","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Anti-inflammatory drugs and risk of Alzheimer's disease: an updated systematic review and meta-analysis."],"author-links":["[[Author/Jun Wang]]","[[Author/Jun Wang]]","[[Author/Lan Tan]]","[[Author/Lan Tan]]","[[Author/Lan Tan]]","[[Author/Hui-Fu Wang]]","[[Author/Hui-Fu Wang]]","[[Author/Cheng Tan]]","[[Author/Chen-Chen Tan]]","[[Author/Xiangfei Meng]]","[[Author/Xiang-Fei Meng]]","[[Author/Xiangfei Meng]]","[[Author/Chong Wang]]","[[Author/Chong Wang]]","[[Author/Shaowen Tang]]","[[Author/Shaowen Tang]]","[[Author/Jin-Tai Yu]]","[[Author/Jin-Tai Yu]