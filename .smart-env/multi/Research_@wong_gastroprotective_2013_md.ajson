0.02240648,0.00057179,-0.00664409,0.17613177,0.0287965,-0.01097534,-0.01051305,0.00296852,0.01801232,0.02287481,0.01203123,0.02379187,0.00181768,0.1170648,-0.03060814,0.0569316,0.06838158,-0.05249318,-0.04139178,-0.01183227,-0.03842721,0.0326927,-0.03674432,-0.07491526,-0.06305971,0.08729808,-0.06817891,-0.02522952,-0.02440211,-0.01603628,-0.00016503,0.00632411,-0.01478126,0.03822992,0.04094588,0.01100888,-0.05285443,0.0223075,-0.01514232,-0.03883579,0.03028687,0.00386703,0.04468464,-0.05915653,0.07549994,0.08633448],"last_embed":{"hash":"126ip3g","tokens":473}}},"last_read":{"hash":"126ip3g","at":1774951886997},"class_name":"SmartSource","last_import":{"mtime":1774951816146,"size":3633,"at":1774951884776,"hash":"126ip3g"},"blocks":{"#---frontmatter---":[1,81],"#Gastroprotective Effects of Lion's Mane Mushroom Hericium erinaceus (Bull.:Fr.) Pers. (Aphyllophoromycetideae) Extract against Ethanol-Induced Ulcer in Rats.":[83,87],"#Gastroprotective Effects of Lion's Mane Mushroom Hericium erinaceus (Bull.:Fr.) Pers. (Aphyllophoromycetideae) Extract against Ethanol-Induced Ulcer in Rats.#{1}":[85,87]},"outlinks":[{"title":"Author/Jing-Yang Wong","target":"Author/Jing-Yang Wong","line":63},{"title":"Author/Jing-Yang Wong","target":"Author/Jing-Yang Wong","line":64},{"title":"Author/Mahmood Ameen Abdulla","target":"Author/Mahmood Ameen Abdulla","line":65},{"title":"Author/Mahmood Ameen Abdulla","target":"Author/Mahmood Ameen Abdulla","line":66},{"title":"Author/Jegadeesh Raman","target":"Author/Jegadeesh Raman","line":67},{"title":"Author/Jegadeesh Raman","target":"Author/Jegadeesh Raman","line":68},{"title":"Author/Chia Wei Phan","target":"Author/Chia Wei Phan","line":69},{"title":"Author/Chia-Wei Phan","target":"Author/Chia-Wei Phan","line":70},{"title":"Author/Umah Rani Kuppusamy","target":"Author/Umah Rani Kuppusamy","line":71},{"title":"Author/Umah Rani Kuppusamy","target":"Author/Umah Rani Kuppusamy","line":72},{"title":"Author/Shahram Golbabapour","target":"Author/Shahram Golbabapour","line":73},{"title":"Author/Shahram Golbabapour","target":"Author/Shahram Golbabapour","line":74},{"title":"Author/Vikineswary Sabaratnam","target":"Author/Vikineswary Sabaratnam","line":75},{"title":"Author/Vikineswary Sabaratnam","target":"Author/Vikineswary Sabaratnam","line":76},{"title":"PDF","target":"biblib/wong_gastroprotective_2013/wong_gastroprotective_2013.pdf","line":78}],"metadata":{"id":"wong_gastroprotective_2013","type":"article-journal","title":"Gastroprotective Effects of Lion's Mane Mushroom Hericium erinaceus (Bull.:Fr.) Pers. (Aphyllophoromycetideae) Extract against Ethanol-Induced Ulcer in Rats.","issued":{"date-parts":[[2013]]},"DOI":"10.1155/2013/492976","container-title":"Evidence-based Complementary and Alternative Medicine","abstract":"Hericium erinaceus is a famous tonic in oriental medicine. The gastroprotective effects of aqueous extract of H. erinaceus against ethanol-induced ulcers in Sprague Dawley rats were investigated. The possible involvements of lipid peroxidation, superoxide dismutase, and catalase were also investigated. Acute toxicity study was performed. The effects of aqueous extract of H. erinaceus on the ulcer areas, ulcer inhibition, gastric wall mucus, gross and histological gastric lesions, antioxidant levels, and malondialdehyde (MDA) contents were evaluated in ethanol-induced ulcer in vivo. In acute toxicity study, a high dose of 5g/kg did not manifest any toxicological signs in rats. The extract promoted ulcer protection as ascertained by a significant reduction of the ulcer area. Furthermore, it exhibited a significant protection activity against gastric mucosal injury by preventing the depletion of antioxidant enzymes. The level of MDA was also limited in rat stomach tissues when compared with the ulcer control group. Immunohistochemistry showed upregulation of HSP70 protein and downregulation of BAX protein in rats pretreated with the extract. The aqueous extract of H. erinaceus protected gastric mucosa in our in vivo model. It is speculated that the bioactive compounds present in the extract may play a major role in gastroprotective activity.","tags":["#literature_note"],"author":[{"family":"Wong","given":"Jing-Yang","literal":""},{"family":"Wong","given":"Jing-Yang","literal":""},{"family":"Abdulla","given":"Mahmood Ameen","literal":""},{"family":"Abdulla","given":"Mahmood Ameen","literal":""},{"family":"Raman","given":"Jegadeesh","literal":""},{"family":"Raman","given":"Jegadeesh","literal":""},{"family":"Phan","given":"Chia Wei","literal":""},{"family":"Phan","given":"Chia-Wei","literal":""},{"family":"Kuppusamy","given":"Umah Rani","literal":""},{"family":"Kuppusamy","given":"Umah Rani","literal":""},{"family":"Golbabapour","given":"Shahram","literal":""},{"family":"Golbabapour","given":"Shahram","literal":""},{"family":"Sabaratnam","given":"Vikineswary","literal":""},{"family":"Sabaratnam","given":"Vikineswary","literal":""}],"citation-key":"wong_gastroprotective_2013","year":"2013","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Gastroprotective Effects of Lion's Mane Mushroom Hericium erinaceus (Bull.:Fr.) Pers. (Aphyllophoromycetideae) Extract against Ethanol-Induced Ulcer in Rats."],"author-links":["[[Author/Jing-Yang Wong]]","[[Author/Jing-Yang Wong]]","[[Author/Mahmood Ameen Abdulla]]","[[Author/Mahmood Ameen Abdulla]]","[[Author/Jegadeesh Raman]]","[[Author/Jegadeesh Raman]]","[[Author/Chia Wei Phan]]","[[Author/Chia-Wei Phan]]","[[Author/Umah Rani Kuppusamy]]","[[Author/Umah Rani Kuppusamy]]","[[Author/Shahram Golbabapour]]","[[Author/Shahram Golbabapour]]","[[Author/Vikineswary Sabaratnam]]","[[Author/Vikineswary Sabaratnam]]"],"attachment":["[[biblib/wong_gastroprotective_2013/wong_gastroprotective_2013.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"126ip3g","at":1774951886987}},"smart_blocks:Research/@wong_gastroprotective_2013.md#---frontmatter---": {"path":null,"embe