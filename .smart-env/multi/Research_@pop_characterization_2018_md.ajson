0.00241667,-0.02374924,0.20204116,0.01926641,-0.07218939,0.00978647,-0.0650833,-0.01433106,-0.03766367,0.02515275,0.04097734,0.04916878,0.14156409,-0.07120708,0.00945382,0.10719465,-0.08156479,-0.01704705,-0.04719475,-0.01798273,0.05177426,-0.05123657,-0.15072076,-0.05204412,0.098129,-0.11068328,-0.01023424,-0.05744931,0.0101745,-0.02539545,-0.0271605,0.01438964,-0.0646718,0.01289163,-0.01090973,0.00068066,0.00625441,0.0018364,-0.04313197,0.0217844,-0.00659058,0.05929311,-0.02820901,0.11957518,0.05389417],"last_embed":{"hash":"ma1ujc","tokens":433}}},"last_read":{"hash":"ma1ujc","at":1774951889437},"class_name":"SmartSource","last_import":{"mtime":1774951820524,"size":3780,"at":1774951884798,"hash":"ma1ujc"},"blocks":{"#---frontmatter---":[1,93],"#Characterization of Trametes versicolor: Medicinal Mushroom with Important Health Benefits":[95,99],"#Characterization of Trametes versicolor: Medicinal Mushroom with Important Health Benefits#{1}":[97,99]},"outlinks":[{"title":"Author/Raluca Maria Pop","target":"Author/Raluca Maria Pop","line":72},{"title":"Author/Raluca Maria Pop","target":"Author/Raluca Maria Pop","line":73},{"title":"Author/Cosmin Puia","target":"Author/Cosmin Puia","line":74},{"title":"Author/Cosmin Puia","target":"Author/Cosmin Puia","line":75},{"title":"Author/Ion C. Puia","target":"Author/Ion C. Puia","line":76},{"title":"Author/Aida Puia","target":"Author/Aida Puia","line":77},{"title":"Author/Aida Puia","target":"Author/Aida Puia","line":78},{"title":"Author/Veronica Sanda Chedea","target":"Author/Veronica Sanda Chedea","line":79},{"title":"Author/Veronica Sanda Chedea","target":"Author/Veronica Sanda Chedea","line":80},{"title":"Author/Veronica Sanda Chedea","target":"Author/Veronica Sanda Chedea","line":81},{"title":"Author/Nicolae Leopold","target":"Author/Nicolae Leopold","line":82},{"title":"Author/Nicolae Leopold","target":"Author/Nicolae Leopold","line":83},{"title":"Author/Nicolae Leopold","target":"Author/Nicolae Leopold","line":84},{"title":"Author/Ioana Corina Bocșan","target":"Author/Ioana Corina Bocșan","line":85},{"title":"Author/Ioana Corina Bocsan","target":"Author/Ioana Corina Bocsan","line":86},{"title":"Author/Anca Dana Buzoianu","target":"Author/Anca Dana Buzoianu","line":87},{"title":"Author/Anca Dana Buzoianu","target":"Author/Anca Dana Buzoianu","line":88},{"title":"PDF","target":"biblib/pop_characterization_2018/pop_characterization_2018.pdf","line":90}],"metadata":{"id":"pop_characterization_2018","type":"article-journal","title":"Characterization of Trametes versicolor: Medicinal Mushroom with Important Health Benefits","issued":{"date-parts":[[2018]]},"DOI":"10.15835/nbha46211132","container-title":"Notulae Botanicae Horti Agrobotanici Cluj-napoca","abstract":"Trametes species represents a rich source of nutritive compounds with important pharmacological properties like antioxidant, antiinflammatory and anti-cancer properties. However, factors like genetic background, harvesting period, geographic location, climatic conditions and others are influencing the biosynthesis of bioactive compounds, their fingerprint and their concentration. The aim of this study was to determine the antioxidant capacity, total phenolic compounds and total flavonoids content of two mushroom species, namely Tramestes versicolor (TV) and Trametes gibbosa (TG), mushrooms with potential health benefits, harvested from north-west part of Romania. In order to determine the phenolic compounds profile, water, methanol, and acetone mushroom extracts were analyzed using UV-Vis spectroscopy, FTIR spectroscopy and LC-MS analysis. In total 28 compounds were tentatively identified as phenolic acids (11 compounds), flavonols (6 compounds), flavones (6 compounds), coumarins (2 compounds), flavanols, isoflavonoids and biflavonoids (1 compound). The highest antioxidant activity was determined for the methanolic extract while the highest total polyphenols content and total flavonoids content were determined for the water extract. The results obtained suggested that Trametes species can be considered important sources of bioactive compounds, their phenolics composition and content being influenced by a series of factors like geographic area origin and genetic background.","tags":["#literature_note"],"author":[{"family":"Pop","given":"Raluca Maria","literal":""},{"family":"Pop","given":"Raluca Maria","literal":""},{"family":"Puia","given":"Cosmin","literal":""},{"family":"Puia","given":"Cosmin","literal":""},{"family":"Puia","given":"Ion C.","literal":""},{"family":"Puia","given":"Aida","literal":""},{"family":"Puia","given":"Aida","literal":""},{"family":"Chedea","given":"Veronica Sanda","literal":""},{"family":"Chedea","given":"Veronica Sanda","literal":""},{"family":"Chedea","given":"Veronica Sanda","literal":""},{"family":"Leopold","given":"Nicolae","literal":""},{"family":"Leopold","given":"Nicolae","literal":""},{"family":"Leopold","given":"Nicolae","literal":""},{"family":"Bocșan","given":"Ioana Corina","literal":""},{"family":"Bocsan","given":"Ioana Corina","literal":""},{"family":"Buzoianu","given":"Anca Dana","literal":""},{"family":"Buzoianu","given":"Anca Dana","literal":""}],"citation-key":"pop_characterization_2018","year":"2018","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Characterization of Trametes versicolor: Medicinal Mushroom with Important Health Benefits"],"author-links":["[[Author/Raluca Maria Pop]]","[[Author/Raluca Maria Pop]]","[[Author/Cosmin Puia]]","[[Author/Cosmin Puia]]","[[Author/Ion C. Puia]]","[[Author/Aida Puia]]","[[Author/Aida Puia]]","[[Author/Veronica Sanda Chedea]]","[[Author/Veronica Sanda Chedea]]","[[Author/Veronica Sanda Chedea]]","[[Author/Nicolae Leopold]]","[[Author/Nicolae Leopold]]","[[Author/Nicolae Leopold]]","[[Author/Ioana Corina Bocșan]]","[[Author/Ioana Corina Bocsan]]","[[Author/Anca Dana Buzoianu]]","[[Author/Anca Dana Buzoianu]]"],"attachment":["[[biblib/pop_characterization_2018/pop_characterization_2018.