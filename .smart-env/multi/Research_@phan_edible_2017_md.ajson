.03104312,0.17457023,0.00089687,-0.03717466,-0.02569976,-0.02593848,0.02444822,-0.00740126,-0.03052201,-0.01109334,0.02561024,0.10427558,-0.00871426,0.11012028,0.11611372,-0.05525152,-0.06431002,-0.04605929,-0.01149358,0.00603511,-0.01864812,-0.09108723,-0.00779491,0.09493395,-0.06380028,-0.00713632,-0.04532511,-0.04151452,-0.01849454,-0.00141275,-0.0389823,0.00987826,0.04646178,0.01067577,-0.0232819,0.03687817,-0.0357096,-0.05129739,-0.00220898,0.00102235,0.03907138,-0.03535175,0.11082387,-0.01919371],"last_embed":{"hash":"k1vxih","tokens":442}}},"last_read":{"hash":"k1vxih","at":1774951886592},"class_name":"SmartSource","last_import":{"mtime":1774951815413,"size":2566,"at":1774951884773,"hash":"k1vxih"},"blocks":{"#---frontmatter---":[1,61],"#Edible and Medicinal Mushrooms: Emerging Brain Food for the Mitigation of Neurodegenerative Diseases":[63,67],"#Edible and Medicinal Mushrooms: Emerging Brain Food for the Mitigation of Neurodegenerative Diseases#{1}":[65,67]},"outlinks":[{"title":"Author/Chia Wei Phan","target":"Author/Chia Wei Phan","line":48},{"title":"Author/PhanChia-Wei","target":"Author/PhanChia-Wei","line":49},{"title":"Author/Chia-Wei Phan","target":"Author/Chia-Wei Phan","line":50},{"title":"Author/Pamela David","target":"Author/Pamela David","line":51},{"title":"Author/DavidPamela","target":"Author/DavidPamela","line":52},{"title":"Author/Pamela David","target":"Author/Pamela David","line":53},{"title":"Author/Vikineswary Sabaratnam","target":"Author/Vikineswary Sabaratnam","line":54},{"title":"Author/Vikineswary Sabaratnam","target":"Author/Vikineswary Sabaratnam","line":55},{"title":"Author/SabaratnamVikineswary","target":"Author/SabaratnamVikineswary","line":56},{"title":"PDF","target":"biblib/phan_edible_2017/phan_edible_2017.pdf","line":58}],"metadata":{"id":"phan_edible_2017","type":"article-journal","title":"Edible and Medicinal Mushrooms: Emerging Brain Food for the Mitigation of Neurodegenerative Diseases","issued":{"date-parts":[[2017]]},"DOI":"10.1089/jmf.2016.3740","container-title":"Journal of Medicinal Food","abstract":"Abstract There is an exponential increase in dementia in old age at a global level because of increasing life expectancy. The prevalence of neurodegenerative diseases such as dementia and Alzheimer's disease (AD) will continue to rise steadily, and is expected to reach 42 million cases worldwide in 2020. Despite the advancement of medication, the management of these diseases remains largely ineffective. Therefore, it is vital to explore novel nature-based nutraceuticals to mitigate AD and other age-related neurodegenerative disorders. Mushrooms and their extracts appear to hold many health benefits, including immune-modulating effects. A number of edible mushrooms have been shown to contain rare and exotic compounds that exhibit positive effects on brain cells both in vitro and in vivo. In this review, we summarize the scientific information on edible and culinary mushrooms with regard to their antidementia/AD active compounds and/or pharmacological test results. The bioactive components in these mushroom...","tags":["#literature_note"],"author":[{"family":"Phan","given":"Chia Wei","literal":""},{"family":"PhanChia-Wei","given":"","literal":""},{"family":"Phan","given":"Chia-Wei","literal":""},{"family":"David","given":"Pamela","literal":""},{"family":"DavidPamela","given":"","literal":""},{"family":"David","given":"Pamela","literal":""},{"family":"Sabaratnam","given":"Vikineswary","literal":""},{"family":"Sabaratnam","given":"Vikineswary","literal":""},{"family":"SabaratnamVikineswary","given":"","literal":""}],"citation-key":"phan_edible_2017","year":"2017","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Edible and Medicinal Mushrooms: Emerging Brain Food for the Mitigation of Neurodegenerative Diseases"],"author-links":["[[Author/Chia Wei Phan]]","[[Author/PhanChia-Wei]]","[[Author/Chia-Wei Phan]]","[[Author/Pamela David]]","[[Author/DavidPamela]]","[[Author/Pamela David]]","[[Author/Vikineswary Sabaratnam]]","[[Author/Vikineswary Sabaratnam]]","[[Author/SabaratnamVikineswary]]"],"attachment":["[[biblib/phan_edible_2017/phan_edible_2017.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"k1vxih","at":1774951886583}},"smart_blocks:Research/@phan_edible_2017.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.01087923,-0.00004666,0.04297939,-0.02697634,0.02358286,0.05334068,0.01597922,0.01673932,-0.05874721,0.00454543,-0.00076795,-0.0293965,0.02230266,0.05044489,0.02747106,-0.00356646,-0.00245755,-0.02109493,-0.05845862,0.05023344,0.05510746,0.00683439,0.02580307,-0.00096096,0.035221,0.04117846,-0.02583699,0.01154097,-0.03871818,-0.21966261,-0.02638162,-0.00646177,0.03889731,-0.07496839,-0.02172728,-0.00392407,0.05269297,0.03934606,0.00100454,0.01979389,0.08180318,0.02223081,-0.00142893,0.0161614,0.00928518,-0.02896649,-0.09908461,-0.06872926,0.03264903,-0.03473983,-0.05748058,0.00822411,0.05369464,0.01306239,0.02433689,-0.01774943,-0.04000485,0.00735768,0.00450418,0.07912125,0.06715049,0.00983656,-0.16431883,0.07280649,0.0239898,-0.04053824,-0.04636887,0.02294901,0.03219478,-0.01037538,-0.03386842,0.02547314,0.05915926,0.05774821,0.03638802,-0.0017416,-0.0270502,-0.08041004,-0.0405184,-0.0307904,0.07104509,0.10798708,0.01367631,-0.03723826,-0.04713736,-0.0486968,-0.0321899,-0.04570088,-0.02496833,-0.02317428,0.02213651,-0.01954863,-0.01105769,0.02240285,-0.05011408,0.00138146,-0.00256006,-0.02138284,-0.05646114,0.145794,-0.06368251,0.02936126,-0.0093082,-0.03039327,-0.00477815,-0.02440817,-0.02608227,-0.04229713,0.02733938,0.04868314,0.02677651,0.01419605,-0.02382129,0.03959566,-0.00847835,0.02737108,0.10420842,0.03940105,-0.0020698,-0.03586624,-0.02130561,0.00729427,0.06524546,0.0081132,0.04083173,-0.01423413,-0.03694789,0.08031499,0.01562753,-0.00752014,0.05921017,0.01354095,-0.01888698,-0.02706963,0.0007719,-0.01148808,0.01032345,0.01257921