00760838,0.05446182,0.19245155,0.01869301,-0.02852102,-0.03273239,-0.04689353,0.017396,0.00408753,0.00701332,0.0160918,0.02346122,0.12491541,0.00483167,0.09652816,0.07313779,-0.02263797,-0.03779123,-0.03755134,-0.00469878,0.02642287,-0.03209449,-0.116482,-0.01995703,0.11227571,-0.06912194,-0.00346091,-0.06522992,-0.03605308,-0.02365983,0.00133441,0.00457481,0.02729026,0.05858615,0.00772206,-0.04209499,0.02401714,-0.02741173,-0.03375533,0.02796744,0.00685308,0.03713477,-0.06072384,0.10470182,-0.00690131],"last_embed":{"hash":"1kye0uv","tokens":448}}},"last_read":{"hash":"1kye0uv","at":1774951892475},"class_name":"SmartSource","last_import":{"mtime":1774951824316,"size":2625,"at":1774951884814,"hash":"1kye0uv"},"blocks":{"#---frontmatter---":[1,72],"#An Overview of Culinary and Medicinal Mushrooms in Neurodegeneration and Neurotrauma Research.":[74,78],"#An Overview of Culinary and Medicinal Mushrooms in Neurodegeneration and Neurotrauma Research.#{1}":[76,78]},"outlinks":[{"title":"Author/Kah-Hui Wong","target":"Author/Kah-Hui Wong","line":57},{"title":"Author/Kah-Hui Wong","target":"Author/Kah-Hui Wong","line":58},{"title":"Author/Chai-Chee Ng","target":"Author/Chai-Chee Ng","line":59},{"title":"Author/Ng Cc","target":"Author/Ng Cc","line":60},{"title":"Author/Gowri Kanagasabapathy","target":"Author/Gowri Kanagasabapathy","line":61},{"title":"Author/Gowri Kanagasabapathy","target":"Author/Gowri Kanagasabapathy","line":62},{"title":"Author/Yoon-Yen Yow","target":"Author/Yoon-Yen Yow","line":63},{"title":"Author/Yoon-Yen Yow","target":"Author/Yoon-Yen Yow","line":64},{"title":"Author/Yow Yy","target":"Author/Yow Yy","line":65},{"title":"Author/Vikineswary Sabaratnam","target":"Author/Vikineswary Sabaratnam","line":66},{"title":"Author/Sabaratnam","target":"Author/Sabaratnam","line":67},{"title":"Author/Vikineswary Sabaratnam","target":"Author/Vikineswary Sabaratnam","line":68}],"metadata":{"id":"wong_overview_2017","type":"article-journal","title":"An Overview of Culinary and Medicinal Mushrooms in Neurodegeneration and Neurotrauma Research.","issued":{"date-parts":[[2017]]},"DOI":"10.1615/intjmedmushrooms.v19.i3.10","container-title":"International Journal of Medicinal Mushrooms","abstract":"Culinary and medicinal mushrooms have been appreciated since prehistoric times as valuable resources for food and medicine. Edible mushrooms represent an untapped source of nutraceuticals and valuable palatable food. Long considered tonics, they are now treasured as functional foods that can improve human health and quality of life. Numerous studies have provided insights into the neuroprotective effects of edible mushrooms, which are attributed to their antioxidant, antineuroinflammatory, and cholinesterase inhibitory properties, and their ability to prevent neuronal death. Here we review the recent literature on the role of culinary and medicinal mushrooms in the management of neurodegenerative diseases and neurotrauma. We highlight some of the molecular mechanisms for how these alternative medicines provide health benefits that could help us to harness their neuroprotective effects.","tags":["#literature_note"],"author":[{"family":"Wong","given":"Kah-Hui","literal":""},{"family":"Wong","given":"Kah-Hui","literal":""},{"family":"Ng","given":"Chai-Chee","literal":""},{"family":"Cc","given":"Ng","literal":""},{"family":"Kanagasabapathy","given":"Gowri","literal":""},{"family":"Kanagasabapathy","given":"Gowri","literal":""},{"family":"Yow","given":"Yoon-Yen","literal":""},{"family":"Yow","given":"Yoon-Yen","literal":""},{"family":"Yy","given":"Yow","literal":""},{"family":"Sabaratnam","given":"Vikineswary","literal":""},{"family":"Sabaratnam","given":"","literal":""},{"family":"Sabaratnam","given":"Vikineswary","literal":""}],"citation-key":"wong_overview_2017","year":"2017","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["An Overview of Culinary and Medicinal Mushrooms in Neurodegeneration and Neurotrauma Research."],"autho