4,0.17028092,0.02284174,-0.02803243,0.0017214,-0.00437429,0.00466287,0.00414378,0.03428897,0.01263308,0.0066849,0.13239399,0.00940676,0.05549852,0.07260671,-0.09201097,-0.01149688,0.00365906,-0.0164952,0.00356637,-0.02966748,-0.08579331,-0.02188977,0.07031558,-0.04707004,-0.03629474,-0.005039,0.00372557,0.01085201,-0.01910891,-0.00560467,0.02663531,0.08480013,-0.03064575,-0.02601611,0.01835184,-0.01334886,-0.0431928,0.00612202,0.02957383,0.04621474,-0.03981785,0.0757981,0.07076637],"last_embed":{"hash":"n0qy13","tokens":447}}},"last_read":{"hash":"n0qy13","at":1774951885330},"class_name":"SmartSource","last_import":{"mtime":1774951813817,"size":3436,"at":1774951884759,"hash":"n0qy13"},"blocks":{"#---frontmatter---":[1,60],"#Lion’s Mane Mushroom, Hericium erinaceus (Bull.: Fr.) Pers. Suppresses H2O2-Induced Oxidative Damage and LPS-Induced Inflammation in HT22 Hippocampal Neurons and BV2 Microglia":[62,66],"#Lion’s Mane Mushroom, Hericium erinaceus (Bull.: Fr.) Pers. Suppresses H2O2-Induced Oxidative Damage and LPS-Induced Inflammation in HT22 Hippocampal Neurons and BV2 Microglia#{1}":[64,66]},"outlinks":[{"title":"Author/Naufal Kushairi","target":"Author/Naufal Kushairi","line":51},{"title":"Author/Chia Wei Phan","target":"Author/Chia Wei Phan","line":52},{"title":"Author/Vikineswary Sabaratnam","target":"Author/Vikineswary Sabaratnam","line":53},{"title":"Author/Pamela David","target":"Author/Pamela David","line":54},{"title":"Author/Murali Naidu","target":"Author/Murali Naidu","line":55},{"title":"PDF","target":"biblib/kushairi_lions_2019/kushairi_lions_2019.pdf","line":57}],"metadata":{"id":"kushairi_lions_2019","type":"article-journal","title":"Lion’s Mane Mushroom, Hericium erinaceus (Bull.: Fr.) Pers. Suppresses H2O2-Induced Oxidative Damage and LPS-Induced Inflammation in HT22 Hippocampal Neurons and BV2 Microglia","issued":{"date-parts":[[2019,8]]},"title-short":"Lion’s Mane Mushroom, Hericium erinaceus (Bull.","page":"261","URL":"https://www.mdpi.com/2076-3921/8/8/261","DOI":"10.3390/antiox8080261","container-title":"Antioxidants","publisher":"Multidisciplinary Digital Publishing Institute","volume":8,"number":8,"language":"en","abstract":"Oxidative stress and inflammation in neuron-glia system are key factors in the pathogenesis of neurodegenerative diseases. As synthetic drugs may cause side effects, natural products have gained recognition for the prevention or management of diseases. In this study, hot water (HE-HWA) and ethanolic (HE-ETH) extracts of the basidiocarps of Hericium erinaceus mushroom were investigated for their neuroprotective and anti-inflammatory activities against hydrogen peroxide (H2O2)-induced neurotoxicity in HT22 mouse hippocampal neurons and lipopolysaccharide (LPS)-induced BV2 microglial activation respectively. HE-ETH showed potent neuroprotective activity by significantly (p < 0.0001) increasing the viability of H2O2-treated neurons. This was accompanied by significant reduction in reactive oxygen species (ROS) (p < 0.05) and improvement of the antioxidant enzyme catalase (CAT) (p < 0.05) and glutathione (GSH) content (p < 0.01). Besides, HE-ETH significantly improved mitochondrial membrane potential (MMP) (p < 0.05) and ATP production (p < 0.0001) while reducing mitochondrial toxicity (p < 0.001), Bcl-2-associated X (Bax) gene expression (p < 0.05) and nuclear apoptosis (p < 0.0001). However, gene expression of Nuclear factor erythroid 2-related factor 2 (Nrf2), heme oxygenase 1 (HO-1) and NAD(P)H quinone dehydrogenase 1 (NQO1) were unaffected (p > 0.05). HE-ETH also significantly (p < 0.0001) reduced nitric oxide (NO) level in LPS-treated BV2 indicating an anti-inflammatory activity in the microglia. These findings demonstrated HE-ETH maybe a potential neuroprotective and anti-inflammatory agent in neuron-glia environment.","tags":["#literature_note"],"author":[{"family":"Kushairi","given":"Naufal","literal":""},{"family":"Phan","given":"Chia Wei","literal":""},{"family":"Sabaratnam","given":"Vikineswary","literal":""},{"family":"David","given":"Pamela","literal":""},{"family":"Naidu","given":"Murali","literal":""}],"accessed":{"date-parts":[[2025,3,18]]},"citation-key":"kushairi_lions_2019","ISSN":"2076-3921","keyword":"<i>Hericium erinaceus</i>,anti-inflammation,antioxidants,mushroom,neuroprotection","year":"2019","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Lion’s Mane Mushroom, Hericium erinaceus (Bull.: Fr.) Pers. Suppresses H2O2-Induced Oxidative Damage and LPS-Induced Inflammation in HT22 Hippocampal Neurons and BV2 Microglia"],"author-links":["[[Author/Naufal Kushairi]]","[[Author/Chia Wei Phan]]","[[Author/Vikineswary Sabaratnam]]","[[Author/Pamela David]]","[[Author/Murali Naidu]]"],"attachment":["[[biblib/kushairi_lions_2019/kushairi_lions_2019.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"n0qy13","at":1774951885320}},"smart_blocks:Research/@kushairi_lions_2019.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[0.01406261,-0.01353238,0.00232027,-0.00046547,0.01202815,0.01932298,0.01708969,0.08565913,-0.03933804,0.01774285,-0.02742792,-0.06647285,0.08621426,-0.00374095,0.01561076,0.02751987,-0.00963128,-0.00361796,-0.13216743,0.00986224,0.01510112,-0.01704389,0.01279576,0.02550915,-0.0053365,0.06669584,-0.01515908,0.02202502,-0.06103685,-0.22163451,0.00418298,-0.05825601,0.01533433,-0.04067601,-0.01505172,0.01994163,-0.02569598,0.00836942,-0.01021113,0.02619315,0.0519222,-0.0001516,0.02260622,0.04679478,-0.00566038,-0.04914314,0.00460353,-0.07423207,0.05168765,-0.07192466,-0.000007,-0.03941273,0.03760355,0.01695116,0.05757937,0.00012735,0.02405818,0.08906253,0.00828745,0.0785519,0.03764388,0.02108048,-0.18443891,0.07615319,0.0752982,-0.01730947,-0.08217238,-0.04531335,0.06940481,0.02820089,-0.04037463,0.03653559,0.05408041,0.00105449,0.00762765,-0.01675015,-0.02299198,-0.086036,0.01625031,0.01527126,0.01375803,0.05979527,0.03545768,