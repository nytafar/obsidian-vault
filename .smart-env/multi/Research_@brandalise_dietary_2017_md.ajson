2316688,-0.01532444,0.16902933,0.03866655,-0.03782753,-0.01187831,-0.00940898,-0.02252066,0.01728946,-0.00743027,0.02082805,0.0108502,0.0997138,-0.00456089,0.0791355,0.04686164,-0.06222778,-0.02645697,-0.00300076,-0.04065851,0.03744786,0.00987941,-0.06405254,-0.02258961,0.09091057,-0.02581676,0.00031838,-0.02421052,-0.07411265,-0.01437954,0.0012167,-0.02072771,0.00316933,0.02289189,0.0169002,-0.03016895,0.0064185,-0.01871309,-0.02919284,-0.02078577,-0.00492106,-0.00922471,-0.04953282,0.12233181,0.02260267],"last_embed":{"hash":"eb7mm4","tokens":419}}},"last_read":{"hash":"eb7mm4","at":1774951887827},"class_name":"SmartSource","last_import":{"mtime":1774951817785,"size":4339,"at":1774951884784,"hash":"eb7mm4"},"blocks":{"#---frontmatter---":[1,125],"#Dietary Supplementation of Hericium erinaceus Increases Mossy Fiber-CA3 Hippocampal Neurotransmission and Recognition Memory in Wild-Type Mice.":[127,131],"#Dietary Supplementation of Hericium erinaceus Increases Mossy Fiber-CA3 Hippocampal Neurotransmission and Recognition Memory in Wild-Type Mice.#{1}":[129,131]},"outlinks":[{"title":"Author/Federico Brandalise","target":"Author/Federico Brandalise","line":96},{"title":"Author/Federico Brandalise","target":"Author/Federico Brandalise","line":97},{"title":"Author/Valentina Cesaroni","target":"Author/Valentina Cesaroni","line":98},{"title":"Author/Valentina Cesaroni","target":"Author/Valentina Cesaroni","line":99},{"title":"Author/Andrej Gregori","target":"Author/Andrej Gregori","line":100},{"title":"Author/Andrej Gregori","target":"Author/Andrej Gregori","line":101},{"title":"Author/Andrej Gregori","target":"Author/Andrej Gregori","line":102},{"title":"Author/M. L. Repetti","target":"Author/M. L. Repetti","line":103},{"title":"Author/Margherita Repetti","target":"Author/Margherita Repetti","line":104},{"title":"Author/Chiara Romano","target":"Author/Chiara Romano","line":105},{"title":"Author/Chiara Romano","target":"Author/Chiara Romano","line":106},{"title":"Author/Germano Orrù","target":"Author/Germano Orrù","line":107},{"title":"Author/Germano Orrù","target":"Author/Germano Orrù","line":108},{"title":"Author/Laura Botta","target":"Author/Laura Botta","line":109},{"title":"Author/Laura Botta","target":"Author/Laura Botta","line":110},{"title":"Author/Carolina Elena Girometta","target":"Author/Carolina Elena Girometta","line":111},{"title":"Author/Carolina Girometta","target":"Author/Carolina Girometta","line":112},{"title":"Author/M. Guglielminetti","target":"Author/M. Guglielminetti","line":113},{"title":"Author/M. Guglielminetti","target":"Author/M. Guglielminetti","line":114},{"title":"Author/Elena Savino","target":"Author/Elena Savino","line":115},{"title":"Author/Elena Savino","target":"Author/Elena Savino","line":116},{"title":"Author/Paola Rossi","target":"Author/Paola Rossi","line":117},{"title":"Author/Paola Rossi","target":"Author/Paola Rossi","line":118},{"title":"Author/Paola Rossi","target":"Author/Paola Rossi","line":119},{"title":"Author/Paola Rossi","target":"Author/Paola Rossi","line":120},{"title":"PDF","target":"biblib/brandalise_dietary_2017/brandalise_dietary_2017.pdf","line":122}],"metadata":{"id":"brandalise_dietary_2017","type":"article-journal","title":"Dietary Supplementation of Hericium erinaceus Increases Mossy Fiber-CA3 Hippocampal Neurotransmission and Recognition Memory in Wild-Type Mice.","issued":{"date-parts":[[2017]]},"DOI":"10.1155/2017/3864340","container-title":"Evidence-based Complementary and Alternative Medicine","abstract":"Hericium erinaceus (Bull.) Pers. is a medicinal mushroom capable of inducing a large number of modulatory effects on human physiology ranging from the strengthening of the immune system to the improvement of cognitive functions. In mice, dietary supplementation with H. erinaceus prevents the impairment of spatial short-term and visual recognition memory in an Alzheimer model. Intriguingly other neurobiological effects have recently been reported like the effect on neurite outgrowth and differentiation in PC12 cells. Until now no investigations have been conducted to assess the impact of this dietary supplementation on brain function in healthy subjects. Therefore, we have faced the problem by considering the effect on cognitive skills and on hippocampal neurotransmission in wild-type mice. In wild-type mice the oral supplementation with H. erinaceus induces, in behaviour test, a significant improvement in the recognition memory and, in hippocampal slices, an increase in spontaneous and evoked excitatory synaptic current in mossy fiber-CA3 synapse. In conclusion, we have produced a series of findings in support of the concept that H. erinaceus induces a boost effect onto neuronal functions also in nonpathological conditions.","tags":["#literature_note"],"author":[{"family":"Brandalise","given":"Federico","literal":""},{"family":"Brandalise","given":"Federico","literal":""},{"family":"Cesaroni","given":"Valentina","literal":""},{"family":"Cesaroni","given":"Valentina","literal":""},{"family":"Gregori","given":"Andrej","literal":""},{"family":"Gregori","given":"Andrej","literal":""},{"family":"Gregori","given":"Andrej","literal":""},{"family":"Repetti","given":"M. L.","literal":""},{"family":"Repetti","given":"Margherita","literal":""},{"family":"Romano","given":"Chiara","literal":""},{"family":"Romano","given":"Chiara","literal":""},{"family":"Orrù","given":"Germano","literal":""},{"family":"Orrù","given":"Germano","literal":""},{"family":"Botta","given":"Laura","literal":""},{"family":"Botta","given":"Laura","literal":""},{"family":"Girometta","given":"Carolina Elena","literal":""},{"family":"Girometta","given":"Carolina","literal":""},{"family":"Guglielminetti","given":"M.","literal":""},{"family":"Guglielminetti","given":"M.","literal":""},{"family":"Savino","given":"Elena","literal":""},{"family":"Savino","given":"Elena","literal":""},{"family":"Rossi","given":"Paola","literal":""},{"family":"Rossi","given":"Paola","literal":