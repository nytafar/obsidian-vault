
"smart_sources:Research/@williams_effects_2020.md": {"path":"Research/@williams_effects_2020.md","last_embed":{"hash":null},"embeddings":{},"last_read":{"hash":"8cck2d","at":1774951884830},"class_name":"SmartSource","last_import":{"mtime":1774951828985,"size":3697,"at":1774951884830,"hash":"8cck2d"},"blocks":{"#---frontmatter---":[1,105],"#The Effects of Green Tea Amino Acid L-Theanine Consumption on the Ability to Manage Stress and Anxiety Levels: a Systematic Review.":[107,111],"#The Effects of Green Tea Amino Acid L-Theanine Consumption on the Ability to Manage Stress and Anxiety Levels: a Systematic Review.#{1}":[109,111]},"outlinks":[{"title":"Author/Jackson Williams","target":"Author/Jackson Williams","line":81},{"title":"Author/Jackson Williams","target":"Author/Jackson Williams","line":82},{"title":"Author/Julian M. Everett","target":"Author/Julian M. Everett","line":83},{"title":"Author/Julian M. Everett","target":"Author/Julian M. Everett","line":84},{"title":"Author/Nathan M. D’Cunha","target":"Author/Nathan M. D’Cunha","line":85},{"title":"Author/Nathan M. D’Cunha","target":"Author/Nathan M. D’Cunha","line":86},{"title":"Author/Domenico Sergi","target":"Author/Domenico Sergi","line":87},{"title":"Author/Domenico Sergi","target":"Author/Domenico Sergi","line":88},{"title":"Author/Ekavi Georgousopoulou","target":"Author/Ekavi Georgousopoulou","line":89},{"title":"Author/Ekavi N. Georgousopoulou","target":"Author/Ekavi N. Georgousopoulou","line":90},{"title":"Author/Richard Keegan","target":"Author/Richard Keegan","line":91},{"title":"Author/Richard Keegan","target":"Author/Richard Keegan","line":92},{"title":"Author/Andrew J. McKune","target":"Author/Andrew J. McKune","line":93},{"title":"Author/Andrew J. McKune","target":"Author/Andrew J. McKune","line":94},{"title":"Author/Duane Mellor","target":"Author/Duane Mellor","line":95},{"title":"Author/Duane Mellor","target":"Author/Duane Mellor","line":96},{"title":"Author/Nicola Anstice","target":"Author/Nicola Anstice","line":97},{"title":"Author/Nicola Anstice","target":"Author/Nicola Anstice","line":98},{"title":"Author/Nenad Naumovski","target":"Author/Nenad Naumovski","line":99},{"title":"Author/Nenad Naumovski","target":"Author/Nenad Naumovski","line":100},{"title":"PDF","target":"biblib/williams_effects_2020/williams_effects_2020.pdf","line":102}],"metadata":{"id":"williams_effects_2020","type":"article-journal","title":"The Effects of Green Tea Amino Acid L-Theanine Consumption on the Ability to Manage Stress and Anxiety Levels: a Systematic Review.","issued":{"date-parts":[[2020]]},"DOI":"10.1007/s11130-019-00771-5","container-title":"Plant Foods for Human Nutrition","abstract":"The green tea amino acid, L-theanine (L-THE) is associated with several health benefits, including improvements in mood, cognition and a reduction of stress and anxiety-like symptoms. This systematic review evaluated the effect of pure L-THE intake, in the form of orally administered nutritional supplements, on stress responses and anxiety levels in human randomised controlled trials. Following the Preferred Reporting Items for Systematic Reviews and Meta-Analyses (PRISMA) checklist, 9 peer-reviewed journal articles were identified where L-THE as a supplement was compared to a control. Our findings suggest that supplementation of 200–400mg/day of L-THE may assist in the reduction of stress and anxiety in people exposed to stressful conditions. Despite this finding, longer-term and larger cohort clinical studies, including those where L-THE is incorporated into the diet regularly, are needed to clinically justify the use of L-THE as a therapeutic agent to reduce stress and anxiety in people exposed to stressful conditions.","tags":["#literature_note"],"author":[{"family":"Williams","given":"Jackson","literal":""},{"family":"Williams","given":"Jackson","literal":""},{"family":"Everett","given":"Julian M.","literal":""},{"family":"Everett","given":"Julian M.","literal":""},{"family":"D’Cunha","given":"Nathan M.","literal":""},{"family":"D’Cunha","given":"Nathan M.","literal":""},{"family":"Sergi","given":"Domenico","literal":""},{"family":"Sergi","given":"Domenico","literal":""},{"family":"Georgousopoulou","given":"Ekavi","literal":""},{"family":"Georgousopoulou","given":"Ekavi N.","literal":""},{"family":"Keegan","given":"Richard","literal":""},{"family":"Keegan","given":"Richard","literal":""},{"family":"McKune","given":"Andrew J.","literal":""},{"family":"McKune","given":"Andrew J.","literal":""},{"family":"Mellor","given":"Duane","literal":""},{"family":"Mellor","given":"Duane","literal":""},{"family":"Anstice","given":"Nicola","literal":""},{"family":"Anstice","given":"Nicola","literal":""},{"family":"Naumovski","given":"Nenad","literal":""},{"family":"Naumovski","given":"Nenad","literal":""}],"citation-key":"williams_effects_2020","year":"2020","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["The Effects of Green Tea Amino Acid L-Theanine Consumption on the Ability to Manage Stress and Anxiety Levels: a Systematic Review."],"author-links":["[[Author/Jackson Williams]]","[[Author/Jackson Williams]]","[[Author/Julian M. Everett]]","[[Author/Julian M. Everett]]","[[Author/Nathan M. D’Cunha]]","[[Author/Nathan M. D’Cunha]]","[[Author/Domenico Sergi]]","[[Author/Domenico Sergi]]","[[Author/Ekavi Georgousopoulou]]","[[Author/Ekavi N. Georgousopoulou]]","[[Author/Richard Keegan]]","[[Author/Richard Keegan]]","[[Author/Andrew J. McKune]]","[[Author/Andrew J. McKune]]","[[Author/Duane Mellor]]","[[Author/Duane Mellor]]","[[Author/Nicola Anstice]]","[[Author/Nicola Anstice]]","[[Author/Nenad Naumovski]]","[[Author/Nenad Naumovski]]"],"attachment":["[[biblib/williams_effects_2020/williams_effects_2020.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[]},
