.01905362,0.03584493,0.168193,0.02027012,-0.01923637,0.03841937,-0.05311668,-0.0129306,-0.00543565,0.01597326,-0.01434545,0.07157081,0.09140132,-0.02004291,0.0446878,0.01255322,-0.08601084,-0.02241791,0.00747239,0.01592787,0.04687639,0.04330909,-0.01009901,-0.05669349,0.09297327,-0.06927548,-0.03745322,-0.07394546,-0.04879013,-0.02463951,0.02674258,0.01778218,-0.01343497,0.03588494,-0.02509117,-0.04912367,-0.03454081,0.03134639,0.02442312,-0.05979098,-0.02871093,-0.01054736,-0.04021528,0.14213587,0.00900713],"last_embed":{"hash":"8cck2d","tokens":423}}},"last_read":{"hash":"8cck2d","at":1774951895971},"class_name":"SmartSource","last_import":{"mtime":1774951828985,"size":3697,"at":1774951884830,"hash":"8cck2d"},"blocks":{"#---frontmatter---":[1,105],"#The Effects of Green Tea Amino Acid L-Theanine Consumption on the Ability to Manage Stress and Anxiety Levels: a Systematic Review.":[107,111],"#The Effects of Green Tea Amino Acid L-Theanine Consumption on the Ability to Manage Stress and Anxiety Levels: a Systematic Review.#{1}":[109,111]},"outlinks":[{"title":"Author/Jackson Williams","target":"Author/Jackson Williams","line":81},{"title":"Author/Jackson Williams","target":"Author/Jackson Williams","line":82},{"title":"Author/Julian M. Everett","target":"Author/Julian M. Everett","line":83},{"title":"Author/Julian M. Everett","target":"Author/Julian M. Everett","line":84},{"title":"Author/Nathan M. D’Cunha","target":"Author/Nathan M. D’Cunha","line":85},{"title":"Author/Nathan M. D’Cunha","target":"Author/Nathan M. D’Cunha","line":86},{"title":"Author/Domenico Sergi","target":"Author/Domenico Sergi","line":87},{"title":"Author/Domenico Sergi","target":"Author/Domenico Sergi","line":88},{"title":"Author/Ekavi Georgousopoulou","target":"Author/Ekavi Georgousopoulou","line":89},{"title":"Author/Ekavi N. Georgousopoulou","target":"Author/Ekavi N. Georgousopoulou","line":90},{"title":"Author/Richard Keegan","target":"Author/Richard Keegan","line":91},{"title":"Author/Richard Keegan","target":"Author/Richard Keegan","line":92},{"title":"Author/Andrew J. McKune","target":"Author/Andrew J. McKune","line":93},{"title":"Author/Andrew J. McKune","target":"Author/Andrew J. McKune","line":94},{"title":"Author/Duane Mellor","target":"Author/Duane Mellor","line":95},{"title":"Author/Duane Mellor","target":"Author/Duane Mellor","line":96},{"title":"Author/Nicola Anstice","target":"Author/Nicola Anstice","line":97},{"title":"Author/Nicola Anstice","target":"Author/Nicola Anstice","line":98},{"title":"Author/Nenad Naumovski","target":"Author/Nenad Naumovski","line":99},{"title":"Author/Nenad Naumovski","target":"Author/Nenad Naumovski","line":100},{"title":"PDF","target":"biblib/williams_effects_2020/williams_effects_2020.pdf","line":102}],"metadata":{"id":"williams_effects_2020","type":"article-journal","title":"The Effects of Green Tea Amino Acid L-Theanine Consumption on the Ability to Manage Stress and Anxiety Levels: a Systematic Review.","issued":{"date-parts":[[2020]]},"DOI":"10.1007/s11130-019-00771-5","container-title":"Plant Foods for Human Nutrition","abstract":"The green tea amino acid, L-theanine (L-THE) is associated with several health benefits, including improvements in mood, cognition and a reduction of stress and anxiety-like symptoms. This systematic review evaluated the effect of pure L-THE intake, in the form of orally administered nutritional supplements, on stress responses and anxiety levels in human randomised controlled trials. Following the Preferred Reporting Items for Systematic Reviews and Meta-Analyses (PRISMA) checklist, 9 peer-reviewed journal articles were identified where L-THE as a supplement was compared to a control. Our findings suggest that supplementation of 200–400mg/day of L-THE may assist in the reduction of stress and anxiety in people exposed to stressful conditions. Despite this finding, longer-term and larger cohort clinical studies, including those where L-THE is incorporated into the diet regularly, are needed to clinically justify the use of L-THE as a therapeutic agent to reduce stress and anxiety in people exposed to stressful conditions.","tags":["#literature_note"],"author":[{"family":"Williams","given":"Jackson","literal":""},{"family":"Williams","given":"Jackson","literal":""},{"family":"Everett","given":"Julian M.","literal":""},{"family":"Everett","given":"Julian M.","literal":""},{"family":"D’Cunha","given":"Nathan M.","literal":""},{"family":"D’Cunha","given":"Nathan M.","literal":""},{"family":"Sergi","given":"Domenico","literal":""},{"family":"Sergi","given":"Domenico","literal":""},{"family":"Georgousopoulou","given":"Ekavi","literal":""},{"family":"Georgousopoulou","given":"Ekavi N.","literal":""},{"family":"Keegan","given":"Richard","literal":""},{"family":"Keegan","given":"Richard","literal":""},{"family":"McKune","given":"Andrew J.","literal":""},{"family":"McKune","given":"Andrew J.","literal":""},{"family":"Mellor","given":"Duane","literal":""},{"family":"Mellor","given":"Duane","literal":""},{"family":"Anstice","given":"Nicola","literal":""},{"family":"Anstice","given":"Nicola","literal":""},{"family":"Naumovski","given":"Nenad","literal":""},{"family":"Naumovski","given":"Nenad","literal":""}],"citation-key":"williams_effects_2020","year":"2020","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["The Effects of Green Tea Amino Acid L-Theanine Consumption on the Ability to Manage Stress and Anxiety Levels: a Systematic Review."],"author-links":["[[Author/Jackson Williams]]","[[Author/Jackson Williams]]","[[Author/Julian M. Everett]]","[[Author/Julian M. Everett]]","[[Author/Nathan M. D’Cunha]]","[[Author/Nathan M. D’Cunha]]","[[Author/Domenico Sergi]]","[[Author/Domenico Sergi]]","[[Author/Ekavi Georgousopoulou]]","[[Author/Ekavi N. Georgousopoulou]]","[[Author/Richard Keegan]]","[[Author/Richard Keegan]]","[[Author/Andrew J. McKune]]","[[Author/Andrew J. McKune]]","[[Author/Duane Mellor]]","[[Author/Duane Mellor]]","[[Au