,0.16948688,-0.0143732,-0.02698829,0.01461295,-0.03768087,0.03390101,-0.04122701,0.03694262,0.01260136,0.07089543,0.12751684,-0.01842886,0.07364183,0.1277578,-0.03354864,-0.07960464,-0.06523548,0.01831049,-0.02439195,-0.04447001,-0.11864603,0.01019355,0.09501006,-0.08778605,-0.03124745,-0.0730345,0.01085544,0.00932629,-0.04858148,0.00360577,-0.02092125,0.03235083,-0.03356137,-0.02242709,0.01708413,-0.01723214,-0.1015193,-0.01375561,-0.00675507,0.01890154,-0.07853459,0.12114616,0.03721648],"last_embed":{"hash":"1l89gco","tokens":460}}},"last_read":{"hash":"1l89gco","at":1774951889146},"class_name":"SmartSource","last_import":{"mtime":1774951819951,"size":2790,"at":1774951884796,"hash":"1l89gco"},"blocks":{"#---frontmatter---":[1,53],"#Recent Progress in Research on the Pharmacological Potential of Mushrooms and Prospects for Their Clinical Application":[55,59],"#Recent Progress in Research on the Pharmacological Potential of Mushrooms and Prospects for Their Clinical Application#{1}":[57,59]},"outlinks":[{"title":"Author/Susanna M. Badalyan","target":"Author/Susanna M. Badalyan","line":42},{"title":"Author/Susanna M. Badalyan","target":"Author/Susanna M. Badalyan","line":43},{"title":"Author/Anush Barkhudaryan","target":"Author/Anush Barkhudaryan","line":44},{"title":"Author/Anush Barkhudaryan","target":"Author/Anush Barkhudaryan","line":45},{"title":"Author/Anush Barkhudaryan","target":"Author/Anush Barkhudaryan","line":46},{"title":"Author/Sylvie Rapior","target":"Author/Sylvie Rapior","line":47},{"title":"Author/Sylvie Rapior","target":"Author/Sylvie Rapior","line":48},{"title":"PDF","target":"biblib/badalyan_recent_2019/badalyan_recent_2019.pdf","line":50}],"metadata":{"id":"badalyan_recent_2019","type":"article-journal","title":"Recent Progress in Research on the Pharmacological Potential of Mushrooms and Prospects for Their Clinical Application","issued":{"date-parts":[[2019]]},"DOI":"10.1007/978-981-13-6382-5_1","container-title":"null","abstract":"Fungi are considered one of the most diverse, ecologically significant, and economically important organisms on Earth. The edible and medicinal mushrooms have long been known by humans and were used by ancient civilizations not only as valuable food but also as medicines. Mushrooms are producers of high- and low-molecular-weight bioactive compounds (alkaloids, lectins, lipids, peptidoglycans, phenolics, polyketides, polysaccharides, proteins, polysaccharide-protein/peptides, ribosomal and non-ribosomal peptides, steroids, terpenoids, etc.) possessing more than 130 different therapeutic effects (analgesic, antibacterial, antifungal, anti-inflammatory, antioxidant, antiplatelet, antiviral, cytotoxic, hepatoprotective, hypocholesterolemic, hypoglycemic, hypotensive, immunomodulatory, immunosuppressive, mitogenic/regenerative, etc.). The early record of Materia Medica shows evidence of using mushrooms for treatment of different diseases. Mushrooms were widely used in the traditional medicine of many countries around the world and became great resources for modern clinical and pharmacological research. However, the medicinal and biotechnological potential of mushrooms has not been fully investigated. This review discusses recent advances in research on the pharmacological potential of mushrooms and perspectives for their clinical application.","tags":["#literature_note"],"author":[{"family":"Badalyan","given":"Susanna M.","literal":""},{"family":"Badalyan","given":"Susanna M.","literal":""},{"family":"Barkhudaryan","given":"Anush","literal":""},{"family":"Barkhudaryan","given":"Anush","literal":""},{"family":"Barkhudaryan","given":"Anush","literal":""},{"family":"Rapior","given":"Sylvie","literal":""},{"family":"Rapior","given":"Sylvie","literal":""}],"citation-key":"badalyan_recent_2019","year":"2019","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Recent Progress in Research on the Pharmacological Potential of Mushrooms and Prospects for Their Clinical Application"],"author-links":["[[Author/Susanna M. Badalyan]]","[[Author/Susanna M. Badalyan]]","[[Author/Anush Barkhudaryan]]","[[Author/Anush Barkhudaryan]]","[[Author/Anush Barkhudaryan]]","[[Author/Sylvie Rapior]]","[[Author/Sylvie Rapior]]"],"attachment":["[[biblib/badalyan_recent_2019/badalyan_recent_2019.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"1l89gco","at":1774951889137}},"smart_blocks:Research/@badalyan_recent_2019.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[0.00956336,-0.02867895,0.0254075,-0.04214785,0.03226946,-0.02264678,0.00382094,0.02591311,-0.03752949,-0.02048125,-0.00212122,-0.05836963,0.0070646,0.00989448,0.00555538,0.00058031,0.02136616,-0.00027017,-0.05929372,0.02523644,0.03473505,0.0225061,0.00777392,0.00746523,0.03549017,0.00916221,-0.03683074,-0.01994899,-0.05364372,-0.194414,-0.01364265,0.00910824,0.05517535,-0.03130644,-0.02892054,-0.02597405,-0.01274645,0.04734177,0.00593103,0.04768123,0.05057642,0.03340954,0.0086614,0.05008485,-0.03754516,-0.02394651,-0.05446239,-0.04480995,0.00619061,-0.04554548,-0.00285608,-0.08063582,-0.01150457,0.02255843,0.01968936,-0.06208221,-0.00211919,0.0450606,0.0065836,0.08900749,0.09339007,0.01992554,-0.18157397,0.05523621,0.03717927,-0.01018151,-0.09778728,0.00093602,0.08071266,0.00732008,-0.03137021,-0.00540769,0.08255551,0.07487185,0.05480307,0.00978781,-0.01814499,-0.06485692,-0.05904233,-0.01399211,0.03933028,0.07901578,0.01374052,-0.00050735,-0.06975717,-0.04037304,-0.03281822,-0.02512553,0.05767244,0.01043097,0.02918466,-0.00750423,0.01680815,0.02382324,-0.08988382,0.00882378,-0.00405986,-0.03785124,-0.0370637,0.12730925,-0.0783966,0.00514301,0.04753413,0.00400036,0.02321072,-0.01923167,-0.05840639,-0.09011904,0.03965575,0.08516634,0.03267738,-0.00517907,-0.02196967,0.03684209,-0.00069042,0.00657456,0.11946504,0.04718344,-0.01404519,-0.01472352,-0.06389689,0.04134532,0.07306652,0.00763284,0.05587469,-0.00977985,-0.009