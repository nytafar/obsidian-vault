42174,0.00001765,0.16669461,0.00827525,-0.02488139,0.00327292,-0.01590584,-0.00457224,-0.01198155,0.00159546,-0.02513301,0.05934433,0.05263438,-0.05733366,0.03455939,0.07406278,-0.03930267,-0.03356937,-0.02051525,-0.03955363,0.00324992,-0.01847767,-0.07065213,-0.04511415,0.10000056,-0.08812123,-0.04751883,-0.08415223,0.0250491,-0.00282031,-0.01350585,-0.00823474,0.00826929,0.03009939,-0.02721506,0.02875881,0.06500771,-0.00460469,-0.04180609,-0.01908346,-0.007884,-0.00838571,-0.03232801,0.1052395,0.05700558],"last_embed":{"hash":"h4vjty","tokens":468}}},"last_read":{"hash":"h4vjty","at":1774951890720},"class_name":"SmartSource","last_import":{"mtime":1774951821569,"size":2500,"at":1774951884802,"hash":"h4vjty"},"blocks":{"#---frontmatter---":[1,57],"#Distribution and accumulation of dietary ergothioneine and its metabolites in mouse tissues":[59,63],"#Distribution and accumulation of dietary ergothioneine and its metabolites in mouse tissues#{1}":[61,63]},"outlinks":[{"title":"Author/Richard Ming Yi Tang","target":"Author/Richard Ming Yi Tang","line":45},{"title":"Author/Richard M. Y. Tang","target":"Author/Richard M. Y. Tang","line":46},{"title":"Author/Irwin K. Cheah","target":"Author/Irwin K. Cheah","line":47},{"title":"Author/Irwin K. Cheah","target":"Author/Irwin K. Cheah","line":48},{"title":"Author/Terry Shze Keong Yew","target":"Author/Terry Shze Keong Yew","line":49},{"title":"Author/Terry Shze Keong Yew","target":"Author/Terry Shze Keong Yew","line":50},{"title":"Author/Barry Halliwell","target":"Author/Barry Halliwell","line":51},{"title":"Author/Barry Halliwell","target":"Author/Barry Halliwell","line":52},{"title":"PDF","target":"biblib/tang_distribution_2018/tang_distribution_2018.pdf","line":54}],"metadata":{"id":"tang_distribution_2018","type":"article-journal","title":"Distribution and accumulation of dietary ergothioneine and its metabolites in mouse tissues","issued":{"date-parts":[[2018]]},"DOI":"10.1038/s41598-018-20021-z","container-title":"Scientific Reports","abstract":"L-ergothioneine (ET) is a diet-derived amino acid that accumulates at high concentrations in animals and humans. Numerous studies have highlighted its antioxidant abilities in vitro, and possible cytoprotective capabilities in vivo. We investigated the uptake and distribution of ET in various organs by a highly sensitive and specific liquid chromatography coupled tandem mass spectrometry (LC-MS/MS) technique, both before and after oral administration of pure ET (35 and 70mg/kg/day for 1, 7, and 28 days) to male C57BL6J mice. ET primarily concentrates in the liver and whole blood, and also in spleen, kidney, lung, heart, intestines, eye, and brain tissues. Strong correlations were found between ET and its putative metabolites - hercynine, ET-sulfonate (ET-SO3H), and S-methyl ET. Hercynine accumulates in the brain after prolonged ET administration. This study demonstrates the uptake and distribution of ET and provides a foundation for future studies with ET to target oxidative damage in a range of tissues in human diseases.","tags":["#literature_note"],"author":[{"family":"Tang","given":"Richard Ming Yi","literal":""},{"family":"Tang","given":"Richard M. Y.","literal":""},{"family":"Cheah","given":"Irwin K.","literal":""},{"family":"Cheah","given":"Irwin K.","literal":""},{"family":"Yew","given":"Terry Shze Keong","literal":""},{"family":"Yew","given":"Terry Shze Keong","literal":""},{"family":"Halliwell","given":"Barry","literal":""},{"family":"Halliwell","given":"Barry","literal":""}],"citation-key":"tang_distribution_2018","year":"2018","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Distribution and accumulation of dietary ergothioneine and its metabolites in mouse tissues"],"author-links":["[[Author/Richard Ming Yi Tang]]","[[Author/Richard M. Y. Tang]]","[[Author/Irwin K. Cheah]]","[[Author/Irwin K. Cheah]]","[[Author/Terry Shze Keong Yew]]","[[Author/Terry Shze Keong Yew]]","[[Author/Barry Halliwell]]","[[Author/Bar