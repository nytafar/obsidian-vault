82,-0.01554587,0.18688564,0.05155001,-0.02171719,0.03293597,-0.03662275,0.04810577,-0.0263463,0.02311854,0.02618762,0.00448398,0.09205586,-0.01212844,0.06572891,0.08503607,-0.05088916,-0.04681033,-0.00688925,-0.01221241,0.01979005,-0.0510078,-0.09887453,-0.01094895,0.12867412,-0.08411573,0.00765584,-0.02286918,-0.01192726,0.00425186,-0.0389002,-0.03139019,0.03222849,0.06431103,-0.05716311,0.02592363,0.04303428,-0.06788998,-0.06276008,-0.05476013,0.01124189,-0.01570144,-0.06538744,0.10816946,0.04974832],"last_embed":{"hash":"acfbb7","tokens":470}}},"last_read":{"hash":"acfbb7","at":1774951885762},"class_name":"SmartSource","last_import":{"mtime":1774951814239,"size":3450,"at":1774951884765,"hash":"acfbb7"},"blocks":{"#---frontmatter---":[1,81],"#A Status Review of the Bioactive Activities of Tiger Milk Mushroom Lignosus rhinocerotis (Cooke) Ryvarden.":[83,87],"#A Status Review of the Bioactive Activities of Tiger Milk Mushroom Lignosus rhinocerotis (Cooke) Ryvarden.#{1}":[85,87]},"outlinks":[{"title":"Author/Neeranjini Nallathamby","target":"Author/Neeranjini Nallathamby","line":63},{"title":"Author/Neeranjini Nallathamby","target":"Author/Neeranjini Nallathamby","line":64},{"title":"Author/Chia Wei Phan","target":"Author/Chia Wei Phan","line":65},{"title":"Author/Chia-Wei Phan","target":"Author/Chia-Wei Phan","line":66},{"title":"Author/Syntyche Ling-Sing Seow","target":"Author/Syntyche Ling-Sing Seow","line":67},{"title":"Author/Syntyche Ling-Sing Seow","target":"Author/Syntyche Ling-Sing Seow","line":68},{"title":"Author/Asweni Baskaran","target":"Author/Asweni Baskaran","line":69},{"title":"Author/Asweni Baskaran","target":"Author/Asweni Baskaran","line":70},{"title":"Author/Hariprasath Lakshmanan","target":"Author/Hariprasath Lakshmanan","line":71},{"title":"Author/Hariprasath Lakshmanan","target":"Author/Hariprasath Lakshmanan","line":72},{"title":"Author/Sri Nurestri Abd Malek","target":"Author/Sri Nurestri Abd Malek","line":73},{"title":"Author/Sri Nurestri Abd Malek","target":"Author/Sri Nurestri Abd Malek","line":74},{"title":"Author/Vikineswary Sabaratnam","target":"Author/Vikineswary Sabaratnam","line":75},{"title":"Author/Vikineswary Sabaratnam","target":"Author/Vikineswary Sabaratnam","line":76},{"title":"PDF","target":"biblib/nallathamby_status_2018/nallathamby_status_2018.pdf","line":78}],"metadata":{"id":"nallathamby_status_2018","type":"article-journal","title":"A Status Review of the Bioactive Activities of Tiger Milk Mushroom Lignosus rhinocerotis (Cooke) Ryvarden.","issued":{"date-parts":[[2018]]},"DOI":"10.3389/fphar.2017.00998","container-title":"Frontiers in Pharmacology","abstract":"Edible and medicinal mushrooms are regularly used in natural medicines and home remedies since antiquity for ailments like fever, inflammation, and respiratory disorders. Lignosus rhinocerotis (Cooke) Ryvarden is a polypore found in Malaysia and other regions in South East Asia. It can be located on a spot where a tigress drips milk while feeding, hence the name “tiger’s milk mushroom”. The sclerotium of L. rhinocerotis is highly sought after by the native communities in Malaysia to stave off hunger, relieve cough and asthma, and provide stamina. The genomic features of L. rhinocerotis have been described. The pharmacological and toxicity effects, if any, of L. rhinocerotis sclerotium have been scientifically verified in recent years. In this review, the validated investigations including the cognitive function, neuroprotection, immune modulation, anti-asthmatic, anti-coagulation, anti-inflammatory, anti-microbial/ anti-viral, anti-obesity, anti-cancer/ anti-tumor, and antioxidant properties are highlighted. These findings suggest that L. rhinocerotis can be considered as an alternative and natural medicine in the management of non-communicable diseases. However, there is a paucity of validation studies including human clinical trials of the mycochemicals of L. rhinocerotis.","tags":["#literature_note"],"author":[{"family":"Nallathamby","given":"Neeranjini","literal":""},{"family":"Nallathamby","given":"Neeranjini","literal":""},{"family":"Phan","given":"Chia Wei","literal":""},{"family":"Phan","given":"Chia-Wei","literal":""},{"family":"Seow","given":"Syntyche Ling-Sing","literal":""},{"family":"Seow","given":"Syntyche Ling-Sing","literal":""},{"family":"Baskaran","given":"Asweni","literal":""},{"family":"Baskaran","given":"Asweni","literal":""},{"family":"Lakshmanan","given":"Hariprasath","literal":""},{"family":"Lakshmanan","given":"Hariprasath","literal":""},{"family":"Malek","given":"Sri Nurestri Abd","literal":""},{"family":"Malek","given":"Sri Nurestri Abd","literal":""},{"family":"Sabaratnam","given":"Vikineswary","literal":""},{"family":"Sabaratnam","given":"Vikineswary","literal":""}],"citation-key":"nallathamby_status_2018","year":"2018","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["A Status Review of the Bioactive Activities of Tiger Milk Mushroom Lignosus rhinocerotis (Cooke) Ryvarden."],"author-links":["[[Author/Neeranjini Nallathamby]]","[[Author/Neeranjini Nallathamby]]","[[Author/Chia Wei Phan]]","[[Author/Chia-Wei Phan]]","[[Author/Syntyche Ling-Sing Seow]]","[[Author/Syntyche Ling-Sing Seow]]","[[Author/Asweni Baskaran]]","[[Author/Asweni Baskaran]]","[[Author/Hariprasath Lakshmanan]]","[[Author/Hariprasath Lakshmanan]]","[[Author/Sri Nurestri Abd Malek]]","[[Author/Sri Nurestri Abd Malek]]","[[Author/Vikineswary Sabaratnam]]","[[Author/Vikineswary Sabaratnam]]"],"attachment":["[[biblib/nallathamby_status_2018/nallathamby_status_2018.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"acfbb7","at":1774951885753}},"smart_blocks:Research/@nallathamby_status_2018.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.0022733,-0.00496114,0.02838777,0.01709375,0.07640967,0.02427051,0.05238935,0.00100464,-0.07376718,-0.02012284,-0.03541624,-0.04134639,0.06133188,0.01672623,0.02