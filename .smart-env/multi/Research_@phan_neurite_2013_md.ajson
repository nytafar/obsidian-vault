,0.05941783,0.01938198,0.18523392,-0.01639305,0.00921798,-0.01173004,-0.08129025,0.01788902,-0.03011618,-0.00262992,0.00554176,0.0470227,0.07690135,-0.04921601,0.07107174,0.0511281,-0.05282124,-0.06558411,-0.03407687,-0.04166718,0.01471023,-0.04815098,-0.07182983,-0.00267151,0.12294245,-0.07479773,-0.00970071,-0.02440823,-0.00015039,0.02353675,-0.02504547,0.00710936,-0.02388389,0.07678206,-0.0425454,-0.00520207,-0.01444937,-0.06408148,-0.00505213,0.00884704,0.00517439,0.00901326,-0.03841162,0.08686973,0.00594787],"last_embed":{"hash":"1gkxyml","tokens":457}}},"last_read":{"hash":"1gkxyml","at":1774951886818},"class_name":"SmartSource","last_import":{"mtime":1774951815772,"size":3396,"at":1774951884775,"hash":"1gkxyml"},"blocks":{"#---frontmatter---":[1,65],"#Neurite outgrowth stimulatory effects of culinary-medicinal mushrooms and their toxicity assessment using differentiating Neuro-2a and embryonic fibroblast BALB/3T3":[67,71],"#Neurite outgrowth stimulatory effects of culinary-medicinal mushrooms and their toxicity assessment using differentiating Neuro-2a and embryonic fibroblast BALB/3T3#{1}":[69,71]},"outlinks":[{"title":"Author/Chia Wei Phan","target":"Author/Chia Wei Phan","line":51},{"title":"Author/Chia-Wei Phan","target":"Author/Chia-Wei Phan","line":52},{"title":"Author/Pamela David","target":"Author/Pamela David","line":53},{"title":"Author/Pamela David","target":"Author/Pamela David","line":54},{"title":"Author/Murali Naidu","target":"Author/Murali Naidu","line":55},{"title":"Author/Murali Naidu","target":"Author/Murali Naidu","line":56},{"title":"Author/Kah-Hui Wong","target":"Author/Kah-Hui Wong","line":57},{"title":"Author/Kah-Hui Wong","target":"Author/Kah-Hui Wong","line":58},{"title":"Author/Vikineswary Sabaratnam","target":"Author/Vikineswary Sabaratnam","line":59},{"title":"Author/Vikineswary Sabaratnam","target":"Author/Vikineswary Sabaratnam","line":60},{"title":"PDF","target":"biblib/phan_neurite_2013/phan_neurite_2013.pdf","line":62}],"metadata":{"id":"phan_neurite_2013","type":"article-journal","title":"Neurite outgrowth stimulatory effects of culinary-medicinal mushrooms and their toxicity assessment using differentiating Neuro-2a and embryonic fibroblast BALB/3T3","issued":{"date-parts":[[2013]]},"DOI":"10.1186/1472-6882-13-261","container-title":"BMC Complementary and Alternative Medicine","abstract":"Background: Mushrooms are not only regarded as gourmet cuisine but also as therapeutic agent to promote cognition health. However, little toxicological information is available regarding their safety. Therefore, the aim of this study was to screen selected ethno-pharmacologically important mushrooms for stimulatory effects on neurite outgrowth and to test for any cytotoxicity. Methods: The stimulatory effect of mushrooms on neurite outgrowth was assessed in differentiating mouse neuroblastoma (N2a) cells. Neurite length was measured using Image-Pro Insight processor system. Neuritogenesis activity was further validated by fluorescence immunocytochemical staining of neurofilaments. In vitro cytotoxicity was investigated by using mouse embryonic fibroblast (BALB/3T3) and N2a cells for any embryo- and neuro-toxic effects; respectively. Results: Aqueous extracts of Ganoderma lucidum, Lignosus rhinocerotis, Pleurotus giganteus and Grifola frondosa ;a s well as an ethanol extract of Cordyceps militaris significantly (p < 0.05) promoted the neurite outgrowth in N2a cells by 38.4 ± 4.2%, 38.1 ± 2.6%, 33.4 ± 4.6%, 33.7 ± 1.5%, and 35.8 ± 3.4%; respectively. The IC50 values obtained from tetrazolium (MTT), neutral red uptake (NRU) and lactate dehydrogenase (LDH) release assays showed no toxic effects following 24 h exposure of N2a and 3T3 cells to mushroom extracts. Conclusion: Our results indicate that G. lucidum, L. rhinocerotis, P. giganteus, G. frondosa and C. militaris may be developed as safe and healthy dietary supplements for brain and cognitive health.","tags":["#literature_note"],"author":[{"family":"Phan","given":"Chia Wei","literal":""},{"family":"Phan","given":"Chia-Wei","literal":""},{"family":"David","given":"Pamela","literal":""},{"family":"David","given":"Pamela","literal":""},{"family":"Naidu","given":"Murali","literal":""},{"family":"Naidu","given":"Murali","literal":""},{"family":"Wong","given":"Kah-Hui","literal":""},{"family":"Wong","given":"Kah-Hui","literal":""},{"family":"Sabaratnam","given":"Vikineswary","literal":""},{"family":"Sabaratnam","given":"Vikineswary","literal":""}],"citation-key":"phan_neurite_2013","year":"2013","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Neurite outgrowth stimulatory effects of culinary-medicinal mushrooms and their toxicity assessment using differentiating Neuro-2a and embryonic fibroblast BALB/3T3"],"author-links":["[[Author/Chia Wei Phan]]","[[Author/Chia-Wei Phan]]","[[Author/Pamela David]]","[[Author/Pamela David]]","[[Author/Murali Naidu]]","[[Author/Murali Naidu]]","[[Author/Kah-Hui Wong]]","[[Author/Kah-Hui Wong]]","[[Author/Vikineswary Sabaratnam]]","[[Author/Vikineswary Sabaratnam]]"],"attachment":["[[biblib/phan_neurite_2013/phan_neurite_2013.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"1gkxyml","at":1774951886807}},"smart_blocks:Research/@phan_neurite_2013.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[0.01481389,-0.03797884,0.0492598,-0.00011005,-0.01649026,0.0412427,0.04794443,0.03143441,-0.05554955,0.00304491,-0.00236032,-0.0207718,0.04107797,0.07052973,-0.02623017,-0.01690701,-0.01997684,0.02651769,-0.0830299,0.0141535,0.04808854,-0.0252267,0.04288454,-0.01668303,-0.0125132,0.02683744,-0.00509157,-0.00594874,-0.04113816,-0.21092467,0.01954193,0.01099428,-0.01433024,-0.07523529,-0.04811854,0.00000931,-0.01799062,-0.00630696,-0.01410854,0.01532147,0.01679284,0.04196137,-0.00126568,0.05711187,0.02185333,-0.04214115,-0.02263777,-0.06627194,0.04870639,-0.00294034,-0.02895409,-0.09240972,0.041572