.02875866,0.05443606,0.16571604,-0.02805411,-0.00630602,0.05059911,0.00991166,0.01207045,0.03814342,0.00763517,-0.0138861,0.05872608,0.08734527,-0.01761572,0.03801512,0.03718589,-0.1121556,-0.05191739,0.0058642,0.00679155,0.04336948,0.02243716,0.03030048,-0.03731651,0.11505183,-0.05316807,-0.00122837,-0.04906604,-0.04992939,-0.01252898,0.03734016,-0.02124535,0.01575396,0.0335,-0.01986246,0.01076328,0.00295858,0.01836832,0.04934306,-0.04082036,-0.06722714,-0.0005097,-0.01612361,0.11718652,0.01839513],"last_embed":{"hash":"1rv9oul","tokens":450}}},"last_read":{"hash":"1rv9oul","at":1774951895747},"class_name":"SmartSource","last_import":{"mtime":1774951828876,"size":3573,"at":1774951884830,"hash":"1rv9oul"},"blocks":{"#---frontmatter---":[1,85],"#Effects of L-Theanine Administration on Stress-Related Symptoms and Cognitive Functions in Healthy Adults: A Randomized Controlled Trial.":[87,91],"#Effects of L-Theanine Administration on Stress-Related Symptoms and Cognitive Functions in Healthy Adults: A Randomized Controlled Trial.#{1}":[89,91]},"outlinks":[{"title":"Author/Shinsuke Hidese","target":"Author/Shinsuke Hidese","line":66},{"title":"Author/Shinsuke Hidese","target":"Author/Shinsuke Hidese","line":67},{"title":"Author/Shintaro Ogawa","target":"Author/Shintaro Ogawa","line":68},{"title":"Author/Shintaro Ogawa","target":"Author/Shintaro Ogawa","line":69},{"title":"Author/Miho Ota","target":"Author/Miho Ota","line":70},{"title":"Author/Miho Ota","target":"Author/Miho Ota","line":71},{"title":"Author/Ikki Ishida","target":"Author/Ikki Ishida","line":72},{"title":"Author/Ikki Ishida","target":"Author/Ikki Ishida","line":73},{"title":"Author/Zenta Yasukawa","target":"Author/Zenta Yasukawa","line":74},{"title":"Author/Zenta Yasukawa","target":"Author/Zenta Yasukawa","line":75},{"title":"Author/Makoto Ozeki","target":"Author/Makoto Ozeki","line":76},{"title":"Author/Makoto Ozeki","target":"Author/Makoto Ozeki","line":77},{"title":"Author/Makoto Ozeki","target":"Author/Makoto Ozeki","line":78},{"title":"Author/Hiroshi Kunugi","target":"Author/Hiroshi Kunugi","line":79},{"title":"Author/Hiroshi Kunugi","target":"Author/Hiroshi Kunugi","line":80},{"title":"PDF","target":"biblib/hidese_effects_2019/hidese_effects_2019.pdf","line":82}],"metadata":{"id":"hidese_effects_2019","type":"article-journal","title":"Effects of L-Theanine Administration on Stress-Related Symptoms and Cognitive Functions in Healthy Adults: A Randomized Controlled Trial.","issued":{"date-parts":[[2019]]},"DOI":"10.3390/nu11102362","container-title":"Nutrients","abstract":"This randomized, placebo-controlled, crossover, and double-blind trial aimed to examine the possible effects of four weeks L-theanine administration on stress-related symptoms and cognitive functions in healthy adults. Participants were 30 individuals (nine men and 21 women; age: 48.3 ± 11.9 years) who had no major psychiatric illness. L-theanine (200 mg/day) or placebo tablets were randomly and blindly assigned for four-week administration. For stress-related symptoms, Self-rating Depression Scale, State-Trait Anxiety Inventory-trait, and Pittsburgh Sleep Quality Index (PSQI) scores decreased after L-theanine administration (p = 0.019, 0.006, and 0.013, respectively). The PSQI subscale scores for sleep latency, sleep disturbance, and use of sleep medication reduced after L-theanine administration, compared to the placebo administration (all p < 0.05). For cognitive functions, verbal fluency and executive function scores improved after L-theanine administration (p = 0.001 and 0.031, respectively). Stratified analyses revealed that scores for verbal fluency (p = 0.002), especially letter fluency (p = 0.002), increased after L-theanine administration, compared to the placebo administration, in individuals who were sub-grouped into the lower half by the median split based on the mean pretreatment scores. Our findings suggest that L-theanine has the potential to promote mental health in the general population with stress-related ailments and cognitive impairments.","tags":["#literature_note"],"author":[{"family":"Hidese","given":"Shinsuke","literal":""},{"family":"Hidese","given":"Shinsuke","literal":""},{"family":"Ogawa","given":"Shintaro","literal":""},{"family":"Ogawa","given":"Shintaro","literal":""},{"family":"Ota","given":"Miho","literal":""},{"family":"Ota","given":"Miho","literal":""},{"family":"Ishida","given":"Ikki","literal":""},{"family":"Ishida","given":"Ikki","literal":""},{"family":"Yasukawa","given":"Zenta","literal":""},{"family":"Yasukawa","given":"Zenta","literal":""},{"family":"Ozeki","given":"Makoto","literal":""},{"family":"Ozeki","given":"Makoto","literal":""},{"family":"Ozeki","given":"Makoto","literal":""},{"family":"Kunugi","given":"Hiroshi","literal":""},{"family":"Kunugi","given":"Hiroshi","literal":""}],"citation-key":"hidese_effects_2019","year":"2019","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Effects of L-Theanine Administration on Stress-Related Symptoms and Cognitive Functions in Healthy Adults: A Randomized Controlled Trial."],"author-links":["[[Author/Shinsuke Hidese]]","[[Author/Shinsuke Hidese]]","[[Author/Shintaro Ogawa]]","[[Author/Shintaro Ogawa]]","[[Author/Miho Ota]]","[[Author/Miho Ota]]","[[Author/Ikki Ishida]]","[[Author/Ikki Ishida]]","[[Author/Zenta Yasukawa]]","[[Author/Zenta Yasukawa]]","[[Author/Makoto Ozeki]]","[[Author/Makoto Ozeki]]","[[Author/Makoto Ozeki]]","[[Author/Hiroshi Kunugi]]","[[Author/Hiroshi Kunugi]]"],"attachment":["[[biblib/hidese_effects_2019/hidese_effects_2019.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"1rv9oul","at":1774951895738}},"smart_blocks:Research/@hidese_effects_2019.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[0.00296082,-0.00125572,0.03156164,0.00525171,0.01077107,0.05077907,0.06360433,0.02622683,0.01534906,-0.02927451,-0.02414208,0.02674206,0.09227677,0.05373865,0.