95,0.08948365,0.1845243,0.00228486,-0.04240675,0.01526371,-0.00486106,0.0025439,0.0153276,0.00850018,-0.00880605,0.07337633,0.08441343,-0.01814451,-0.00250833,0.03606531,-0.07502902,-0.02196346,0.01115037,0.01920803,0.03180641,0.04223816,0.0250028,0.02852867,0.13593653,-0.00996701,-0.01651314,-0.0624327,-0.03577754,0.00993868,-0.00587377,-0.01491399,0.00177212,0.05745445,-0.0056783,0.00333456,-0.03745802,-0.01834634,-0.0205496,0.00767231,0.08081438,0.00746053,-0.00285534,0.06655328,0.03137956],"last_embed":{"hash":"1ai7bg3","tokens":371}}},"last_read":{"hash":"1ai7bg3","at":1774951895637},"class_name":"SmartSource","last_import":{"mtime":1774951828589,"size":3671,"at":1774951884829,"hash":"1ai7bg3"},"blocks":{"#---frontmatter---":[1,89],"#Effects of L-theanine on the release of alpha-brain waves in human volunteers":[91,95],"#Effects of L-theanine on the release of alpha-brain waves in human volunteers#{1}":[93,95]},"outlinks":[{"title":"Author/Kanari Kobayashi","target":"Author/Kanari Kobayashi","line":69},{"title":"Author/Kanari Kobayashi","target":"Author/Kanari Kobayashi","line":70},{"title":"Author/Yukiko Nagato","target":"Author/Yukiko Nagato","line":71},{"title":"Author/Yukiko Nagato","target":"Author/Yukiko Nagato","line":72},{"title":"Author/Nobuyuki Aoi","target":"Author/Nobuyuki Aoi","line":73},{"title":"Author/Nobuyuki Aoi","target":"Author/Nobuyuki Aoi","line":74},{"title":"Author/Lekh Raj Juneja","target":"Author/Lekh Raj Juneja","line":75},{"title":"Author/Lekh Raj Juneja","target":"Author/Lekh Raj Juneja","line":76},{"title":"Author/Mujo Kim","target":"Author/Mujo Kim","line":77},{"title":"Author/Mujo Kim","target":"Author/Mujo Kim","line":78},{"title":"Author/Takehiko Yamamoto","target":"Author/Takehiko Yamamoto","line":79},{"title":"Author/Takehiko Yamamoto","target":"Author/Takehiko Yamamoto","line":80},{"title":"Author/Takehiko Yamamoto","target":"Author/Takehiko Yamamoto","line":81},{"title":"Author/Takehiko Yamamoto","target":"Author/Takehiko Yamamoto","line":82},{"title":"Author/Shin-ichiro Sugimoto","target":"Author/Shin-ichiro Sugimoto","line":83},{"title":"Author/Sukeo Sugimoto","target":"Author/Sukeo Sugimoto","line":84},{"title":"PDF","target":"biblib/kobayashi_effects_1998/kobayashi_effects_1998.pdf","line":86}],"metadata":{"id":"kobayashi_effects_1998","type":"article-journal","title":"Effects of L-theanine on the release of alpha-brain waves in human volunteers","issued":{"date-parts":[[1998]]},"DOI":"10.1271/nogeikagaku1924.72.153","container-title":"Bulletin of the Agricultural Chemical Society of Japan","abstract":"L-テアニンは緑茶の葉中および抽出液中に含まれているアミノ酸の一種で,カフェインによる興奮を抑制することが知られている.また,ラットへのL-テアニンの経口投与により,脳内のセロトニンが減少し,カテコールアミンの増加ずることが知られている. L-テアニンは動物実験で安全なことがすでに確認されている. 筆者らはL-テアニン服用による脳波への影響について検討した結果,リラックスをもたらすことを確認した. L-テアニンの影響を不安程度の異なる精神状態で調べるため, MAS法に従って段階I(高不安域群)の4名と段階V(低不安域群)の4名の計8名の女子学生を被験者に選定した. その結果, L-テアニン200mgを含む水100ml服用によって後頭部・頭頂部にα波の出現が認められた.α波出現は服用後40分後に観測され,少なくとも2時間は持続すると考えられる.α波の出現によるリラックス作用は,段階Vの低不安域群より段階Iの高不安域群の方が優れていた. L-テアニン服用後,被験者は眠気を感じず,十分なリラックスを感じた.また,指先が暖かくなったとの体感を感じた被験者もいた. 今回の研究により, L-テアニンは新しいタイプの添加物として食品や飲料に応用される可能性が示唆された.今後はさまざまなL-テアニン含有食品についての効果を検討するつもりである.","tags":["#literature_note"],"author":[{"family":"Kobayashi","given":"Kanari","literal":""},{"family":"Kobayashi","given":"Kanari","literal":""},{"family":"Nagato","given":"Yukiko","literal":""},{"family":"Nagato","given":"Yukiko","literal":""},{"family":"Aoi","given":"Nobuyuki","literal":""},{"family":"Aoi","given":"Nobuyuki","literal":""},{"family":"Juneja","given":"Lekh Raj","literal":""},{"family":"Juneja","given":"Lekh Raj","literal":""},{"family":"Kim","given":"Mujo","literal":""},{"family":"Kim","given":"Mujo","literal":""},{"family":"Yamamoto","given":"Takehiko","literal":""},{"family":"Yamamoto","given":"Takehiko","literal":""},{"family":"Yamamoto","given":"Takehiko","literal":""},{"family":"Yamamoto","given":"Takehiko","literal":""},{"family":"Sugimoto","given":"Shin-ichiro","literal":""},{"family":"Sugimoto",