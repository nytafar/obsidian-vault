127,0.00179263,-0.01932046,0.15514131,-0.02880817,0.00064424,0.01448836,-0.0808732,0.05450049,0.01123454,-0.04121544,0.00407415,0.01819464,0.06926411,-0.05484661,0.0335967,0.04437651,-0.05341807,0.00464714,-0.02433256,-0.05134783,-0.01830525,-0.00608504,-0.03242658,-0.01423853,0.10223684,-0.08633695,-0.04415976,-0.04482464,-0.0473491,-0.01273589,-0.02579594,0.04186227,0.05872026,0.10117038,0.00778852,-0.0055608,-0.02562679,-0.06223578,0.01219703,0.03024729,-0.05167288,0.01572061,-0.00176448,0.14566688,-0.03910752],"last_embed":{"hash":"1rjih9p","tokens":439}}},"last_read":{"hash":"1rjih9p","at":1774951886226},"class_name":"SmartSource","last_import":{"mtime":1774951814857,"size":1842,"at":1774951884769,"hash":"1rjih9p"},"blocks":{"#---frontmatter---":[1,33],"#Nitric oxide and nitroxidative stress in Alzheimer's disease.":[35,39],"#Nitric oxide and nitroxidative stress in Alzheimer's disease.#{1}":[37,39]},"outlinks":[{"title":"Author/Tadeusz Maliński","target":"Author/Tadeusz Maliński","line":27},{"title":"Author/Tadeusz Malinski","target":"Author/Tadeusz Malinski","line":28},{"title":"PDF","target":"biblib/malinski_nitric_2007/malinski_nitric_2007.pdf","line":30}],"metadata":{"id":"malinski_nitric_2007","type":"article-journal","title":"Nitric oxide and nitroxidative stress in Alzheimer's disease.","issued":{"date-parts":[[2007]]},"DOI":"10.3233/jad-2007-11208","container-title":"Journal of Alzheimer's Disease","abstract":"Nitric oxide is a signaling molecule produced by neurons and endothelial cells in the brain. NO is synthesized from L-arginine and oxygen by nitric oxide synthase: neuronal (nNOS), endothelial (eNOS), and inducible (iNOS). The endothelial NO acts as a vasorelaxant in the vasculature and as a neurotransmitter when produced by neurons (under the pathological conditions of Alzheimer's disease). NO can be scavenged in a rapid reaction with superoxide (O � ) to generate peroxynitrite (ONOO � ), with a half-life of 100 nM), ONOOcan undergo homolytic or heterolytic cleavage to produce NO + ,N O2, and OH · , highly reactive oxidative species and secondary components of nitroxidative stress. The high nitroxidative stress can initiate a cascade of redox reactions which can trigger apoptosis and evoke cytotoxic effects on neurons and endothelial cells. This article reviews the functions of NO and the potential role of NO/O � /ONOOinduced nitroxidative stress in neuronal and endothelial degeneration observed in","tags":["#literature_note"],"author":[{"family":"Maliński","given":"Tadeusz","literal":""},{"family":"Malinski","given":"Tadeusz","literal":""}],"citation-key":"malinski_nitric_2007","year":"2007","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Nitric oxide and nitroxidative stress in Alzheimer's disease."],"author-links":["[[Author/Tadeusz Maliński]]","[[Author/Tadeusz Malinski]]"],"attachment":["[[biblib/malinski_nitric_2007/malinski_nitric_2007.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"1rjih9p","at":1774951886217}},"smart_blocks:Research/@malinski_nitric_2007.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.06423625,0.02640047,0.03473929,-0.01429195,-0.000246,0.06829973,0.08574339,0.01955883,-0.00768999,-0.01145816,-0.02265897,-0.04000645,0.05945919,0.04943932,-0.00681497,-0.04198155,-0.03861411,0.00695494,-0.07321125,0.01544973,0.06052705,0.01466312,0.06715898,0.03919747,0.04644182,0.07070684,0.04103556,0.04581762,-0.04085412,-0.21228483,-0.02606323,-0.00374408,-0.03503014,-0.0290805,-0.02484483,0.00335244,0.02969658,0.02696604,-0.04335919,-0.02712881,0.0677689,-0.00128814,-0.03664942,-0.0008745,0.06607759,-0.05737918,-0.01601505,-0.07651284,0.02186286,-0.04778952,0.01168522,-0.03947809,0.01884693,0.02447321,0.04215055,-0.0077717,0.01554256,0.05929341,0.04653409,0.03287542,0.0743288,0.03232218,-0.19322966,0.03184042,0.07350505,-0.11525254,-0.06037746,-0.01675279,-0.00293188,-0.01131832,-0.03515404,