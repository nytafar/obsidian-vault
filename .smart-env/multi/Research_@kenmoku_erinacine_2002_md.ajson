4,0.00477641,-0.01433723,0.20860034,0.03269116,-0.01872612,0.01444326,-0.03903906,0.03622158,0.0387582,-0.02223224,-0.02144658,0.02596724,0.05642439,-0.07605003,0.051469,-0.00933076,-0.04635782,-0.04573726,-0.03364412,-0.02527963,-0.03288477,0.012558,-0.07342113,-0.03402779,0.12385477,-0.0509572,-0.06175594,-0.03196223,0.02373734,0.02274882,0.00163735,0.03329053,-0.01905563,-0.01837698,0.01795127,0.01718878,-0.02358386,-0.0266427,-0.0230248,0.03149789,-0.02897318,-0.01754055,-0.04185924,0.09214455,0.05377522],"last_embed":{"hash":"nz7qqh","tokens":469}}},"last_read":{"hash":"nz7qqh","at":1774951892290},"class_name":"SmartSource","last_import":{"mtime":1774951824079,"size":2658,"at":1774951884813,"hash":"nz7qqh"},"blocks":{"#---frontmatter---":[1,69],"#Erinacine Q, a new erinacine from Hericium erinaceum, and its biosynthetic route to erinacine C in the basidiomycete.":[71,75],"#Erinacine Q, a new erinacine from Hericium erinaceum, and its biosynthetic route to erinacine C in the basidiomycete.#{1}":[73,75]},"outlinks":[{"title":"Author/Hiromichi Kenmoku","target":"Author/Hiromichi Kenmoku","line":54},{"title":"Author/Hiromichi Kenmoku","target":"Author/Hiromichi Kenmoku","line":55},{"title":"Author/Takashi Shimai","target":"Author/Takashi Shimai","line":56},{"title":"Author/Takashi Shimai","target":"Author/Takashi Shimai","line":57},{"title":"Author/Tomonobu Toyomasu","target":"Author/Tomonobu Toyomasu","line":58},{"title":"Author/Tomonobu Toyomasu","target":"Author/Tomonobu Toyomasu","line":59},{"title":"Author/Nobuo Kato","target":"Author/Nobuo Kato","line":60},{"title":"Author/Nobuo Kato","target":"Author/Nobuo Kato","line":61},{"title":"Author/Nobuo Kato","target":"Author/Nobuo Kato","line":62},{"title":"Author/Takeshi Sassa","target":"Author/Takeshi Sassa","line":63},{"title":"Author/Takeshi Sassa","target":"Author/Takeshi Sassa","line":64},{"title":"PDF","target":"biblib/kenmoku_erinacine_2002/kenmoku_erinacine_2002.pdf","line":66}],"metadata":{"id":"kenmoku_erinacine_2002","type":"article-journal","title":"Erinacine Q, a new erinacine from Hericium erinaceum, and its biosynthetic route to erinacine C in the basidiomycete.","issued":{"date-parts":[[2002]]},"DOI":"10.1271/bbb.66.571","container-title":"Bioscience, Biotechnology, and Biochemistry","abstract":"Erinacines as cyathane-xylosides are known to have potent stimulating activity for nerve-growth-factor synthesis. Our search for new cyathane metabolites from a liquid culture of Hericium erinaceum YB4-6237 resulted in the isolation of a new erinacine named erinacine Q (1). NMR spectrometry and a chemical derivation from erinacine P (2) determined the compound to be a derivative in which the formyl group of erinacine P had been reduced to the hydroxymethyl group. To clarify the biosynthetic relationship between erinacine Q and the others, [1′-13C]erinacine Q ([1′-13C]-1) was chemically derived from [1′-13C]erinacine P ([1′-13C]-2) which had been prepared by feeding [1-13C]-D-glucose to the basidiomycete. The biotransformation of labeled erinacine Q into [1′-13C]erinacine C ([1′-13C]-5) via [1′-13C]erinacine P in this basidiomycete was demonstrated by NMR spectrometry.","tags":["#literature_note"],"author":[{"family":"Kenmoku","given":"Hiromichi","literal":""},{"family":"Kenmoku","given":"Hiromichi","literal":""},{"family":"Shimai","given":"Takashi","literal":""},{"family":"Shimai","given":"Takashi","literal":""},{"family":"Toyomasu","given":"Tomonobu","literal":""},{"family":"Toyomasu","given":"Tomonobu","literal":""},{"family":"Kato","given":"Nobuo","literal":""},{"family":"Kato","given":"Nobuo","literal":""},{"family":"Kato","given":"Nobuo","literal":""},{"family":"Sassa","given":"Takeshi","literal":""},{"family":"Sassa","given":"Takeshi","literal":""}],"citation-key":"kenmoku_erinacine_2002","year":"2002","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Erinacine Q, a new erinacine from Hericium erinaceum, and its biosynthetic route to erinacine C 