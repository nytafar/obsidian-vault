142,0.01906123,0.03429708,0.14848101,-0.03189036,0.0011438,-0.01795589,0.01385435,0.01527625,0.02280341,0.02324755,-0.03591471,0.00967429,0.0660314,-0.0070024,0.05730158,0.06354827,-0.05657222,0.02419288,0.01489331,-0.03042488,0.00485154,-0.02643997,-0.08666172,-0.03651335,0.08218245,-0.052583,0.00358728,-0.01993049,-0.05460096,-0.06468122,-0.00423147,-0.03545952,0.02331416,0.02249679,-0.00948373,-0.00721973,-0.01823527,-0.04416014,0.00183967,-0.00244671,0.01294679,-0.0066905,-0.03358738,0.08264757,-0.00096525],"last_embed":{"hash":"1thxtfx","tokens":481}}},"last_read":{"hash":"1thxtfx","at":1774951890432},"class_name":"SmartSource","last_import":{"mtime":1774951821010,"size":3884,"at":1774951884800,"hash":"1thxtfx"},"blocks":{"#---frontmatter---":[1,105],"#Curcumin Improves Amyloid β-Peptide (1-42) Induced Spatial Memory Deficits through BDNF-ERK Signaling Pathway":[107,111],"#Curcumin Improves Amyloid β-Peptide (1-42) Induced Spatial Memory Deficits through BDNF-ERK Signaling Pathway#{1}":[109,111]},"outlinks":[{"title":"Author/Lu Zhang","target":"Author/Lu Zhang","line":81},{"title":"Author/Lu Zhang","target":"Author/Lu Zhang","line":82},{"title":"Author/Yu Fang","target":"Author/Yu Fang","line":83},{"title":"Author/Yu Fang","target":"Author/Yu Fang","line":84},{"title":"Author/Yuming Xu","target":"Author/Yuming Xu","line":85},{"title":"Author/Yuming Xu","target":"Author/Yuming Xu","line":86},{"title":"Author/Yajun Lian","target":"Author/Yajun Lian","line":87},{"title":"Author/Yajun Lian","target":"Author/Yajun Lian","line":88},{"title":"Author/Ning Xie","target":"Author/Ning Xie","line":89},{"title":"Author/Nanchang Xie","target":"Author/Nanchang Xie","line":90},{"title":"Author/Tingfang Wu","target":"Author/Tingfang Wu","line":91},{"title":"Author/Tianwen Wu","target":"Author/Tianwen Wu","line":92},{"title":"Author/Haifeng Zhang","target":"Author/Haifeng Zhang","line":93},{"title":"Author/Haifeng Zhang","target":"Author/Haifeng Zhang","line":94},{"title":"Author/Limin Sun","target":"Author/Limin Sun","line":95},{"title":"Author/Limin Sun","target":"Author/Limin Sun","line":96},{"title":"Author/Ruifang Zhang","target":"Author/Ruifang Zhang","line":97},{"title":"Author/Ruifang Zhang","target":"Author/Ruifang Zhang","line":98},{"title":"Author/Zhenhua Wang","target":"Author/Zhenhua Wang","line":99},{"title":"Author/Zhenhua Wang","target":"Author/Zhenhua Wang","line":100},{"title":"PDF","target":"biblib/zhang_curcumin_2015/zhang_curcumin_2015.pdf","line":102}],"metadata":{"id":"zhang_curcumin_2015","type":"article-journal","title":"Curcumin Improves Amyloid β-Peptide (1-42) Induced Spatial Memory Deficits through BDNF-ERK Signaling Pathway","issued":{"date-parts":[[2015]]},"DOI":"10.1371/journal.pone.0131525","container-title":"PLOS ONE","abstract":"Curcumin, the most active component of turmeric, has various beneficial properties, such as antioxidant, anti-inflammatory, and antitumor effects. Previous studies have suggested that curcumin reduces the levels of amyloid and oxidized proteins and prevents memory deficits and thus is beneficial to patients with Alzheimer’s disease (AD). However, the molecular mechanisms underlying curcumin’s effect on cognitive functions are not well-understood. In the present study, we examined the working memory and spatial reference memory in rats that received a ventricular injection of amyloid-β1-42 (Aβ1-42), representing a rodent model of Alzheimer’s disease (AD). The rats treated with Aβ1-42 exhibited obvious cognitive deficits in behavioral tasks. Chronic (seven consecutive days, once per day) but not acute (once a day) curcumin treatments (50, 100, and 200 mg/kg) improved the cognitive functions in a dose-dependent manner. In addition, the beneficial effect of curcumin is accompanied by increased BDNF levels and elevated levels of phosphorylated ERK in the hippocampus. Furthermore, the cognition enhancement effect of curcumin could be mimicked by the overexpression of BDNF in the hippocampus and blocked by either bilateral hippocampal injections with lentiviruses that express BDNF shRNA or a microinjection of ERK inhibitor. These findings suggest that chronic curcumin ameliorates AD-related cognitive deficits and that upregulated BDNF-ERK signaling in the hippocampus may underlie the cognitive improvement produced by curcumin.","tags":["#literature_note"],"author":[{"family":"Zhang","given":"Lu","literal":""},{"family":"Zhang","given":"Lu","literal":""},{"family":"Fang","given":"Yu","literal":""},{"family":"Fang","given":"Yu","literal":""},{"family":"Xu","given":"Yuming","literal":""},{"family":"Xu","given":"Yuming","literal":""},{"family":"Lian","given":"Yajun","literal":""},{"family":"Lian","given":"Yajun","literal":""},{"family":"Xie","given":"Ning","literal":""},{"family":"Xie","given":"Nanchang","literal":""},{"family":"Wu","given":"Tingfang","literal":""},{"family":"Wu","given":"Tianwen","literal":""},{"family":"Zhang","given":"Haifeng","literal":""},{"family":"Zhang","given":"Haifeng","literal":""},{"family":"Sun","given":"Limin","literal":""},{"family":"Sun","given":"Limin","literal":""},{"family":"Zhang","given":"Ruifang","literal":""},{"family":"Zhang","given":"Ruifang","literal":""},{"family":"Wang","given":"Zhenhua","literal":""},{"family":"Wang","given":"Zhenhua","literal":""}],"citation-key":"zhang_curcumin_2015","year":"2015","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Curcumin Improves Amyloid β-Peptide (1-42) Induced Spatial Memory Deficits through BDNF-ERK Signaling Pathway"],"author-links":["[[Author/Lu Zhang]]","[[Author/Lu Zhang]]","[[Author/Yu Fang]]","[[Author/Yu Fang]]","[[Author/Yuming Xu]]","[[Author/Yuming Xu]]","[[Author/Yajun Lian]]","[[Author/Yajun Lian]]","[[Author/Ning Xie]]","[[Author/Nanchang Xie]]","[[Author/Tingfang Wu]]","[[Author/Tianwen Wu]]","[[Author/Haifeng Zhang]]","[[Author/Haifeng Zhang]]","[[Author/Limin Sun]]","[[Author/Limin Sun]]","[[Author/Ruifang Zhang]]","[[Author/Ruifang Zha