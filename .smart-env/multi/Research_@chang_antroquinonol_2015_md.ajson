84647,-0.00307993,0.01247357,0.16601826,-0.01457846,-0.03737181,0.00463693,-0.03702839,0.07238766,0.03522168,-0.0052802,-0.02205653,0.02837987,0.08155882,-0.03505429,0.08890644,0.093003,-0.07772674,-0.03737308,0.00883037,-0.02995388,0.01898864,0.01504408,-0.0981489,0.00409352,0.07486282,0.0016758,-0.04471225,0.02145439,-0.02894331,0.02488594,-0.01343996,-0.054022,0.02507173,0.03612749,-0.02162519,0.02865298,0.02946213,-0.00163591,0.02945304,-0.05071905,0.02331649,0.01537521,-0.04946261,0.13861895,0.02754412],"last_embed":{"hash":"jkcn3f","tokens":467}}},"last_read":{"hash":"jkcn3f","at":1774951890411},"class_name":"SmartSource","last_import":{"mtime":1774951820973,"size":2613,"at":1774951884800,"hash":"jkcn3f"},"blocks":{"#---frontmatter---":[1,49],"#Antroquinonol Lowers Brain Amyloid-β Levels and Improves Spatial Learning and Memory in a Transgenic Mouse Model of Alzheimer’s Disease":[51,55],"#Antroquinonol Lowers Brain Amyloid-β Levels and Improves Spatial Learning and Memory in a Transgenic Mouse Model of Alzheimer’s Disease#{1}":[53,55]},"outlinks":[{"title":"Author/Wen Han Chang","target":"Author/Wen Han Chang","line":39},{"title":"Author/Wen-Han Chang","target":"Author/Wen-Han Chang","line":40},{"title":"Author/Miles C. Chen","target":"Author/Miles C. Chen","line":41},{"title":"Author/Miles C. Chen","target":"Author/Miles C. Chen","line":42},{"title":"Author/Irene H. Cheng","target":"Author/Irene H. Cheng","line":43},{"title":"Author/Irene H. Cheng","target":"Author/Irene H. Cheng","line":44},{"title":"PDF","target":"biblib/chang_antroquinonol_2015/chang_antroquinonol_2015.pdf","line":46}],"metadata":{"id":"chang_antroquinonol_2015","type":"article-journal","title":"Antroquinonol Lowers Brain Amyloid-β Levels and Improves Spatial Learning and Memory in a Transgenic Mouse Model of Alzheimer’s Disease","issued":{"date-parts":[[2015]]},"DOI":"10.1038/srep15067","container-title":"Scientific Reports","abstract":"Alzheimer’s disease (AD) is the most common form of dementia. The deposition of brain amyloid-β peptides (Aβ), which are cleaved from amyloid precursor protein (APP), is one of the pathological hallmarks of AD. Aβ-induced oxidative stress and neuroinflammation play important roles in the pathogenesis of AD. Antroquinonol, a ubiquinone derivative isolated from Antrodia camphorata, has been shown to reduce oxidative stress and inflammatory cytokines via activating the nuclear transcription factor erythroid-2-related factor 2 (Nrf2) pathway, which is downregulated in AD. Therefore, we examined whether antroquinonol could improve AD-like pathological and behavioral deficits in the APP transgenic mouse model. We found that antroquinonol was able to cross the blood-brain barrier and had no adverse effects via oral intake. Two months of antroquinonol consumption improved learning and memory in the Morris water maze test, reduced hippocampal Aβ levels, and reduced the degree of astrogliosis. These effects may be mediated through the increase of Nrf2 and the decrease of histone deacetylase 2 (HDAC2) levels. These findings suggest that antroquinonol could have beneficial effects on AD-like deficits in APP transgenic mouse.","tags":["#literature_note"],"author":[{"family":"Chang","given":"Wen Han","literal":""},{"family":"Chang","given":"Wen-Han","literal":""},{"family":"Chen","given":"Miles C.","literal":""},{"family":"Chen","given":"Miles C.","literal":""},{"family":"Cheng","given":"Irene H.","literal":""},{"family":"Cheng","given":"Irene H.","literal":""}],"citation-key":"chang_antroquinonol_2015","year":"2015","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Antroquinonol Lowers Brain Amyloid-β Levels and Improves Spatial Learning and Memory in a Transgenic Mouse Model of Alzheimer’s Disease"],"author-links":["[[Author/Wen Han Chang]]","[[Author/Wen-Han Chang]]","[[Author/Miles C. Chen]]","[[Author/Miles C. Chen]]","[[Author/Irene H. Cheng]]","[[Author/Irene H. Cheng]]"],"attachment":["[[biblib/chang_antroquinonol_2015/chang_antroquinonol_2015.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"jkcn3f","at":1774951890402}},"smart_blocks:Research/@chang_antroquinonol_2015.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.04056487,0.01868054,0.0279657,0.00204189,-0.03047369,0.08142955,0.00375734,0.05116733,-0.00647708,-0.04436796,-0.03634283,-0.05750453,0.06006107,0.09290501,-0.00252708,0.0065221,-0.08469555,0.04953067,-0.06308044,0.03134018,0.03347196,-0.0321933,0.04725974,-0.02198349,0.02688134,0.07271508,-0.0498625,-0.04259119,-0.07942478,-0.21592493,-0.03109709,-0.02297795,0.01019977,-0.02527733,-0.0482216,0.02102818,-0.03576168,0.02876015,-0.0120357,0.01350937,0.04090484,0.04264617,-0.01609147,-0.00916454,-0.00717867,-0.06131321,-0.04396765,-0.0435622,0.00283531,-0.00816991,0.02179481,0.00537981,0.01984796,0.05779219,0.00940063,-0.00319396,-0.02637841,0.09524851,0.01476356,0.07740836,0.03170011,0.08176644,-0.17980386,0.09692502,0.07826561,0.00450346,-0.06784019,-0.03468748,0.01545235,-0.00757343,-0.09943229,0.03250257,0.03056683,0.00941411,0.02365138,0.01047559,-0.03466551,-0.04839911,0.06454019,-0.0298842,0.07220035,0.07134884,-0.00684361,-0.03458194,0.02836115,-0.0245743,0.00143858,-0.05472568,-0.01609651,-0.03465294,0.0140885,-0.01784629,0.02391916,0.04200009,-0.01777579,-0.02026965,-0.02193371,-0.02803897,-0.07796336,0.12483695,-0.03885787,0.02536498,-0.02930429,-0.03166988,-0.00426352,-0.07550134,0.00052592,-0.04942298,-0.02906336,0.0356444,0.0013289,-0.00193988,-0.00469853,0.02623667,0.01616169,0.0449246,0.08082244,-0.01117715,-0.08408251,0.02857861,-0.01682033,-0.00653165,0.03070688,-0.02533516,0.03028889,0.00036162,-0.04021283,0.10311148,0.06330951,-0.01188107,0.03932702,-0.00387006,0.01082071,0.066245,-0.00364513,-0.01352833,-0.02259897,-0.08381838,-0.01399928,0.01193386,-0.01557692,0.02970463,0.01878885,-0.03719632,-0.06020074,0.1062407,0.06887186,-0.00382665,-0.04599741,0.0