916,-0.00282943,0.18054178,0.04527435,-0.03087739,0.00941603,-0.03138036,0.00384184,0.01151244,-0.01326534,0.02600384,0.03133276,0.10142631,0.0037083,0.09336656,0.04610347,-0.04816755,-0.0223233,-0.01493617,-0.01967364,-0.01117215,-0.02589172,-0.09452285,-0.04495189,0.12100752,-0.0396001,-0.01971146,-0.03912444,0.00412481,0.00525078,-0.01960078,-0.014409,0.03460123,0.07819922,0.01994459,-0.00589849,-0.01148882,-0.00834487,-0.04010879,-0.00642549,0.05047659,-0.00624051,-0.01208876,0.06793322,0.03965161],"last_embed":{"hash":"16n9hte","tokens":469}}},"last_read":{"hash":"16n9hte","at":1774951893239},"class_name":"SmartSource","last_import":{"mtime":1774951825730,"size":2669,"at":1774951884818,"hash":"16n9hte"},"blocks":{"#---frontmatter---":[1,60],"#Activity of Aqueous Extracts of Lion's Mane Mushroom Hericium erinaceus (Bull.: Fr.) Pers. (Aphyllophoromycetideae) on the Neural Cell Line NG108-15":[62,66],"#Activity of Aqueous Extracts of Lion's Mane Mushroom Hericium erinaceus (Bull.: Fr.) Pers. (Aphyllophoromycetideae) on the Neural Cell Line NG108-15#{1}":[64,66]},"outlinks":[{"title":"Author/Kah-Hui Wong","target":"Author/Kah-Hui Wong","line":48},{"title":"Author/Kah-Hui Wong","target":"Author/Kah-Hui Wong","line":49},{"title":"Author/Vikineswary Sabaratnam","target":"Author/Vikineswary Sabaratnam","line":50},{"title":"Author/Vikineswary Sabaratnam","target":"Author/Vikineswary Sabaratnam","line":51},{"title":"Author/Sabaratnam Vikineswary","target":"Author/Sabaratnam Vikineswary","line":52},{"title":"Author/Murali Naidu","target":"Author/Murali Naidu","line":53},{"title":"Author/Murali Naidu","target":"Author/Murali Naidu","line":54},{"title":"Author/Roger J. Keynes","target":"Author/Roger J. Keynes","line":55},{"title":"Author/Roger J. Keynes","target":"Author/Roger J. Keynes","line":56}],"metadata":{"id":"wong_activity_2007","type":"article-journal","title":"Activity of Aqueous Extracts of Lion's Mane Mushroom Hericium erinaceus (Bull.: Fr.) Pers. (Aphyllophoromycetideae) on the Neural Cell Line NG108-15","issued":{"date-parts":[[2007]]},"DOI":"10.1615/intjmedmushr.v9.i1.70","container-title":"International Journal of Medicinal Mushrooms","abstract":"The pharmacology and clinical applications of medicinal mushrooms have been extensively documented. One such mushroom, Hericium erinaceus, has been reported to reduce gastric ulcers and the aftereffects of chemotherapy. H. erinaceus is a temperate mushroom but is now being cultivated in tropical Malaysia. In this study, we investigated the activity of aqueous extracts of fruit bodies and mycelium of H. erinaceus in stimulating neurite outgrowth from cultured cells of the neural hybrid clone NG108-15 with a long-term view toward the possible use of this mushroom in the treatment of neurological disorders. Our results showed that extracts of H. erinaceus grown in tropical conditions do induce neurite outgrowth from these cells. Maximum stimulation of neurite outgrowth was recorded with mycelial extracts, and the least stimulation was observed with oven-dried fruit body extract. Aqueous extracts of H. erinaceus therefore contain neuroactive compounds that stimulate neurite outgrowth in vitro.","tags":["#literature_note"],"author":[{"family":"Wong","given":"Kah-Hui","literal":""},{"family":"Wong","given":"Kah-Hui","literal":""},{"family":"Sabaratnam","given":"Vikineswary","literal":""},{"family":"Sabaratnam","given":"Vikineswary","literal":""},{"family":"Vikineswary","given":"Sabaratnam","literal":""},{"family":"Naidu","given":"Murali","literal":""},{"family":"Naidu","given":"Murali","literal":""},{"family":"Keynes","given":"Roger J.","literal":""},{"family":"Keynes","given":"Roger J.","literal":""}],"citation-key":"wong_activity_2007","year":"2007","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Activity of Aqueous Extracts of Lion's Mane Mushroom Hericium erinaceus (Bull.: Fr.) Pers. (Aphyllophoromycetideae) on the Neural Cell Line NG108-15"],"author-links":["[