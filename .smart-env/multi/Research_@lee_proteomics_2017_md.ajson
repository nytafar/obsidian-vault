-0.07701164,0.05830723,-0.00259194,0.19029517,-0.04619035,0.04187662,0.05568785,-0.00112426,0.02310092,0.03926735,-0.00270065,-0.02562677,0.01684447,0.03815297,-0.02237949,0.0369165,0.03988619,0.03002483,0.01812831,-0.06116819,-0.03768899,0.0361967,0.01347047,-0.040549,-0.01332118,0.09733441,-0.06444594,-0.09115175,-0.04689131,0.01043419,-0.03495633,-0.01528785,-0.00593993,0.00014771,0.01342084,-0.03243452,0.03323835,0.01668246,0.0327092,-0.03685492,0.01573322,0.05590329,-0.01522104,-0.04200312,0.12885858,0.06177663],"last_embed":{"hash":"23o683","tokens":450}}},"last_read":{"hash":"23o683","at":1774951893162},"class_name":"SmartSource","last_import":{"mtime":1774951825643,"size":4808,"at":1774951884818,"hash":"23o683"},"blocks":{"#---frontmatter---":[1,121],"#A proteomics approach to identifying novel protein targets involved in erinacine A-mediated inhibition of colorectal cancer cells' aggressiveness.":[123,127],"#A proteomics approach to identifying novel protein targets involved in erinacine A-mediated inhibition of colorectal cancer cells' aggressiveness.#{1}":[125,127]},"outlinks":[{"title":"Author/Ko-Chao Lee","target":"Author/Ko-Chao Lee","line":93},{"title":"Author/Ko-Chao Lee","target":"Author/Ko-Chao Lee","line":94},{"title":"Author/Hsing-Chun Kuo","target":"Author/Hsing-Chun Kuo","line":95},{"title":"Author/Hsing-Chun Kuo","target":"Author/Hsing-Chun Kuo","line":96},{"title":"Author/Chien-Heng Shen","target":"Author/Chien-Heng Shen","line":97},{"title":"Author/Chien-Heng Shen","target":"Author/Chien-Heng Shen","line":98},{"title":"Author/Chun-Wei Lu","target":"Author/Chun-Wei Lu","line":99},{"title":"Author/Chien-Chang Lu","target":"Author/Chien-Chang Lu","line":100},{"title":"Author/Wen-Shih Huang","target":"Author/Wen-Shih Huang","line":101},{"title":"Author/Wen-Shih Huang","target":"Author/Wen-Shih Huang","line":102},{"title":"Author/Meng-Che Hsieh","target":"Author/Meng-Che Hsieh","line":103},{"title":"Author/Meng-Chiao Hsieh","target":"Author/Meng-Chiao Hsieh","line":104},{"title":"Author/Cheng-Yi Huang","target":"Author/Cheng-Yi Huang","line":105},{"title":"Author/Cheng-Yi Huang","target":"Author/Cheng-Yi Huang","line":106},{"title":"Author/Yi-Hung Kuo","target":"Author/Yi-Hung Kuo","line":107},{"title":"Author/Yi-Hung Kuo","target":"Author/Yi-Hung Kuo","line":108},{"title":"Author/Yung-Yu Hsieh","target":"Author/Yung-Yu Hsieh","line":109},{"title":"Author/Yung-Yu Hsieh","target":"Author/Yung-Yu Hsieh","line":110},{"title":"Author/Chiao-Fang Teng","target":"Author/Chiao-Fang Teng","line":111},{"title":"Author/Chih-Chuan Teng","target":"Author/Chih-Chuan Teng","line":112},{"title":"Author/Li-Ya Lee","target":"Author/Li-Ya Lee","line":113},{"title":"Author/Li-Ya Lee","target":"Author/Li-Ya Lee","line":114},{"title":"Author/Shui-Yi Tung","target":"Author/Shui-Yi Tung","line":115},{"title":"Author/Shui-Yi Tung","target":"Author/Shui-Yi Tung","line":116},{"title":"PDF","target":"biblib/lee_proteomics_2017/lee_proteomics_2017.pdf","line":118}],"metadata":{"id":"lee_proteomics_2017","type":"article-journal","title":"A proteomics approach to identifying novel protein targets involved in erinacine A-mediated inhibition of colorectal cancer cells' aggressiveness.","issued":{"date-parts":[[2017]]},"DOI":"10.1111/jcmm.13004","container-title":"Journal of Cellular and Molecular Medicine","abstract":"Erinacine A, a major active component of a diterpenoid derivative isolated from Hericium erinaceus mycelium, has been demonstrated to exert anticancer effects. Herein, we present an investigation of the molecular mechanism of erinacine A induction associated with cancer cells’ aggressive status and death. A proteomic approach was used to purify and identify the differentially expressed proteins following erinacine A treatment and the mechanism of its action in apoptotic and the targets of erinacine A. Our results demonstrate that erinacine A treatment of HCT-116 and DLD-1 cells increased cell cytotoxicity and reactive oxygen species (ROS) production as well as decreased cell proliferation and invasiveness. Ten differentially displayed proteins were determined and validated in vitro and in vivo between the erinacine A-treated and untreated groups. In addition, erinacine A time-dependent induction of cell death and inhibitory invasiveness was associated with sustained phosphorylation of the PI3K/mTOR/p70S6K and ROCK1/LIMK2/Cofilin pathways. Furthermore, we demonstrated that erinacine A–induced HCT-116 and DLD-1 cells viability and anti-invasion properties by up-regulating the activation of PI3K/mTOR/p70S6K and production of ROS. Experiments involving specific inhibitors demonstrated that the differential expression of cofilin-1 (COFL1) and profilin-1 (PROF1) during erinacine A treatment could be involved in the mechanisms of HCT-116 and DLD-1 cells death and decreased aggressiveness, which occurred via ROCK1/LIMK2/Cofilin expression, with activation of the PI3K/mTOR/p70S6K signalling pathway. These findings elucidate the mechanism of erinacine A inhibiting the aggressive status of cells by activating PI3K/mTOR/p70S6K downstream signalling and the novel protein targets COF1 and PROF1; this could be a good molecular strategy to limit the aggressiveness of CRC cells.","tags":["#literature_note"],"author":[{"family":"Lee","given":"Ko-Chao","literal":""},{"family":"Lee","given":"Ko-Chao","literal":""},{"family":"Kuo","given":"Hsing-Chun","literal":""},{"family":"Kuo","given":"Hsing-Chun","literal":""},{"family":"Shen","given":"Chien-Heng","literal":""},{"family":"Shen","given":"Chien-Heng","literal":""},{"family":"Lu","given":"Chun-Wei","literal":""},{"family":"Lu","given":"Chien-Chang","literal":""},{"family":"Huang","given":"Wen-Shih","literal":""},{"family":"Huang","given":"Wen-Shih","literal":""},{"family":"Hsieh","given":"Meng-Che","literal":""},{"family":"Hsieh","given":"Meng-Chiao","literal":""},{"family":"Huang","given":"Cheng-Yi","literal":""},{"family":"Huang","given":"Cheng-Yi","literal":""},{"family":"Kuo","given":"Yi-Hung","literal":""},{"family":"Kuo","given":"Yi-Hung","literal":""},{"family":"Hsieh","given":"Yung-Yu","literal":""},{"family":"Hsieh","given":"Yung-Yu","literal":""},{"family":"Teng","given":"Chiao-Fang","literal":""},{"family":"Teng","given":"Chih-Chuan","literal":""},{"family":"Lee","given":"Li-Ya","literal":""},{"family":"Lee","given":"Li-Ya","literal":""},{"family":"Tung","given":"Shui-Yi","literal":""},{"family":"Tung","given":"Shui-Yi","literal":""}],"citation-key":"lee_proteomics_2017","year":"2017","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["A proteomics approach to identifying novel protein targets involved in erinacine A-mediated inhibition of colorectal cancer cells' aggressiveness."],"author-links":["[[Author/Ko-Chao Lee]]","[[Author/Ko-Chao Lee]]","[[Author/Hsing-Chun Kuo]]","[[Author/Hsing-Chun Kuo]]","[[Author/Chien-Heng Shen]]","[[Author/Chien-Heng Shen]]","[[Author/Chun-Wei Lu]]","[[Author/Chien-Chang Lu]]","[[Author/Wen-Shih Huang]]","[[Author/Wen-Shih Huang]]","[[Author/Meng-Che Hsieh]]","[[Author/Meng-Chiao Hsieh]]","[[Author/Cheng-Yi Huang]]","[[Author/Cheng-Yi Huang]]","[[Author/Yi-Hung Kuo]]","[[Author/Yi-Hung Kuo]]","[[Author/Yung-Yu Hsieh]]","[[Author/Yung-Yu Hsieh]]","[[Author/Chiao-Fang Teng]]","[[Author/Chih-Chuan Teng]]","[[Author/Li-Ya Lee]]","[[Author/Li-Ya Lee]]","[[Author/Shui-Yi Tung]]","[[Author/Shui-Yi Tung]]"],"attachment":["[[biblib/lee_proteomics_2017/lee_proteomics_2017.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"23o683","at":1774951893153}},"smart_blocks:Research/@lee_proteomics_2017.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.08031385,-0.01050116,-0.01617911,-0.03266999,0.00918737,0.02230549,0.05370824,0.02316621,-0.02610575,-0.03839366,0.08479903,-0.07283098,0.06703791,0.00730772,-0.03821525,0.0141436,-0.02552651,0.03923849,-0.08194394,-0.00405751,-0.03424716,-0.034328