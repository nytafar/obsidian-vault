03,-0.00376314,0.09406475,0.17245051,-0.02434702,0.0232869,0.01322602,0.00206521,-0.01444833,0.02371363,0.03522627,-0.00320525,0.07322925,0.11040887,-0.05122051,0.04353313,0.04115491,-0.11500183,-0.04093659,0.01110088,0.00586269,0.04775107,0.04242737,-0.01675731,-0.06890779,0.13921021,-0.02529563,0.00073584,-0.05800318,-0.06749264,-0.01844727,0.01866923,-0.02935109,0.01573842,0.00148374,0.00284935,-0.03391087,-0.01750916,-0.01194727,-0.01650826,-0.0419895,-0.04488392,-0.01321681,0.00915085,0.12194416,0.01337101],"last_embed":{"hash":"15cfzdl","tokens":451}}},"last_read":{"hash":"15cfzdl","at":1774951895767},"class_name":"SmartSource","last_import":{"mtime":1774951828910,"size":3028,"at":1774951884830,"hash":"15cfzdl"},"blocks":{"#---frontmatter---":[1,73],"#Effects of l-Theanine on Cognitive Function in Middle-Aged and Older Subjects: A Randomized Placebo-Controlled Study.":[75,79],"#Effects of l-Theanine on Cognitive Function in Middle-Aged and Older Subjects: A Randomized Placebo-Controlled Study.#{1}":[77,79]},"outlinks":[{"title":"Author/Yoshitake Baba","target":"Author/Yoshitake Baba","line":57},{"title":"Author/Yoshitake Baba","target":"Author/Yoshitake Baba","line":58},{"title":"Author/Shun Inagaki","target":"Author/Shun Inagaki","line":59},{"title":"Author/Shun Inagaki","target":"Author/Shun Inagaki","line":60},{"title":"Author/Sae Nakagawa","target":"Author/Sae Nakagawa","line":61},{"title":"Author/Sae Nakagawa","target":"Author/Sae Nakagawa","line":62},{"title":"Author/Toshiyuki Kobayashi","target":"Author/Toshiyuki Kobayashi","line":63},{"title":"Author/Toshiyuki Kaneko","target":"Author/Toshiyuki Kaneko","line":64},{"title":"Author/Makoto Kobayashi","target":"Author/Makoto Kobayashi","line":65},{"title":"Author/Makoto Kobayashi","target":"Author/Makoto Kobayashi","line":66},{"title":"Author/Takanobu Takihara","target":"Author/Takanobu Takihara","line":67},{"title":"Author/Takanobu Takihara","target":"Author/Takanobu Takihara","line":68},{"title":"PDF","target":"biblib/baba_effects_2021/baba_effects_2021.pdf","line":70}],"metadata":{"id":"baba_effects_2021","type":"article-journal","title":"Effects of l-Theanine on Cognitive Function in Middle-Aged and Older Subjects: A Randomized Placebo-Controlled Study.","issued":{"date-parts":[[2021]]},"DOI":"10.1089/jmf.2020.4803","container-title":"Journal of Medicinal Food","abstract":"l-theanine (γ-glutamylethylamide), an amino acid in green tea, has been shown to affect brain functions by relieving stress disorders, improving mood, and maintaining normal sleep. However, the cognitive functions for which theanine is effective are unclear. This study aimed to clarify which cognitive functions are positively affected by intake of l-theanine. A double-blind, randomized, placebo-controlled study was conducted. The subjects were Japanese men and women aged 50-69 years. Mini Mental State Examination-Japanese version score was 24 or higher. Cognitrax was used as a test battery for cognitive function. Evaluations were performed before the intervention, after a single dose of l-theanine, and after 12 weeks of regular intake. The single dose of l-theanine reduced the reaction time to attention tasks (Stroop test, Part 1), and it increased the number of correct answers and decreased the number of omission errors in working memory tasks (4-Part continuous performance test, Part 4). In conclusion, our study indicated that l-theanine may contribute to improving attention, thus enhancing working memory and executive functions. Clinical Trial No.: UMIN000033812.","tags":["#literature_note"],"author":[{"family":"Baba","given":"Yoshitake","literal":""},{"family":"Baba","given":"Yoshitake","literal":""},{"family":"Inagaki","given":"Shun","literal":""},{"family":"Inagaki","given":"Shun","literal":""},{"family":"Nakagawa","given":"Sae","literal":""},{"family":"Nakagawa","given":"Sae","literal":""},{"family":"Kobayashi","given":"Toshiyuki","literal":""},{"family":"Kaneko","given":"Toshiyuki","literal":""},{"family":"Kobayashi","given":"Makoto","literal":""},{"family":"Kobayashi","given":"Makoto","literal":""},{"family":"Takihara","given":"Takanobu","literal":""},{"family":"Takihara","given":"Takanobu","literal":""}],"citation-key":"baba_effects_2021","year":"2021","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Effects of l-Theanine on Cognitive Function in Middle-Aged and Older Subjects: A Randomized Placebo-Controlled Study."],"author-links":["[[Author/Yoshitake Baba]]","[[Author/Yoshitake Baba]]","[[Author/Shun Inagaki]]","[[Author/Shun Inagaki]]","[[Author/Sae Nakagawa]]","[[Author/Sae Nakagawa]]","[[Author/Toshiyuki Kobayashi]]","[[Author/Toshiyuki Kaneko]]","[[Author/Makoto Kobayashi]]","[[Author/Makoto Kobayashi]]","[[Author/Takanobu Takihara]]","[[Author/Takanobu Takihara]]"],"attachment":["[[biblib/baba_effects_2021/baba_effects_2021.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"15cfzdl","at":1774951895755}},"smart_blocks:Research/@baba_effects_2021.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[0.00213436,-0.00047902,0.04405773,0.0143979,-0.00897383,0.07898495,0.09017716,0.04165706,-0.00985062,-0.02917216,-0.01300474,-0.00319626,0.06008163,0.10334877,0.0217382,-0.02578028,0.01387111,-0.00941048,-0.09895657,-0.05330066,-0.00179586,-0.01917193,0.08302703,0.01459884,-0.00062241,-0.02902084,-0.03174043,0.03060295,-0.07414473,-0.22657464,0.02307275,0.02964867,0.05939548,-0.04054768,-0.06343374,0.02824324,0.0353919,0.03216832,-0.02034576,0.01152373,0.08850382,0.05995437,0.01551032,-0.05757783,-0.04131779,-0.0050568,-0.07065474,-0.02704501,-0.016991,-0.02496758,-0.05050766,-0.04985091,0.04834916,0.01464903,-0.00596313,0.03625727,0.03128904,0.02299153,-0.00450568,0.05506981,0.03088825,0.01598939,-0.19783047,0.06737597,-0.00132529,-0.02489894,-0.07532269,-0.01809931,0.04550602,0.05599668,-0.13653572,0.02123758,0.01356386,0.00253051,0.05101785,-0.015137