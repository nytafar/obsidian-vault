3336,-0.01070391,0.03038884,0.21744145,0.05298728,-0.0472301,0.05841927,-0.02265748,0.05777714,-0.03794647,-0.02061758,-0.02600165,0.01305726,0.05290928,-0.07001784,0.03818141,0.0624859,-0.02818823,0.01108955,-0.02884007,0.00486063,-0.05368143,0.06052325,-0.0253707,0.00372218,0.11879897,-0.07110055,-0.08677898,-0.05910986,0.01031756,0.02594369,-0.02301102,0.05049369,-0.00868973,0.01444825,-0.00347512,-0.00668843,-0.07629275,-0.03034037,-0.06708394,-0.00915353,-0.03279933,0.03076378,-0.01339894,0.07856452,0.03692494],"last_embed":{"hash":"1kshmwy","tokens":436}}},"last_read":{"hash":"1kshmwy","at":1774951891137},"class_name":"SmartSource","last_import":{"mtime":1774951821989,"size":1955,"at":1774951884805,"hash":"1kshmwy"},"blocks":{"#---frontmatter---":[1,33],"#Enantioselective Total Syntheses of Cyathane Diterpenoids":[35,39],"#Enantioselective Total Syntheses of Cyathane Diterpenoids#{1}":[37,39]},"outlinks":[{"title":"Author/Masahisa Nakada","target":"Author/Masahisa Nakada","line":27},{"title":"Author/Masahisa Nakada","target":"Author/Masahisa Nakada","line":28},{"title":"PDF","target":"biblib/nakada_enantioselective_2014/nakada_enantioselective_2014.pdf","line":30}],"metadata":{"id":"nakada_enantioselective_2014","type":"article-journal","title":"Enantioselective Total Syntheses of Cyathane Diterpenoids","issued":{"date-parts":[[2014]]},"DOI":"10.1002/tcr.201402019","container-title":"Chemical Record","abstract":"A Personal Account describing the enantioselective total syntheses of cyathane diterpenoids achieved in the Nakada group. A convergent approach to the cyathane scaffold, the [5-6-7] tricyclic carbon skeleton commonly found in cyathane diterpenoids, has been developed using the catalytic asymmetric intramolecular cyclopropanation (CAIMCP) and baker's yeast reduction. This approach has been successfully applied for the enantioselective total syntheses of (+)-allocyathin B2, (−)-erinacine B, and (−)-erinacine E. The total synthesis of (−)-erinacine E has been achieved via the acyl group migratory intramolecular aldol reaction, which prevents the retro-aldol reaction and allows the construction of the strained structure. The highly efficient and stereoselective total syntheses of (−)-scabronines G, A, D, and (−)-episcabronine A have been achieved via the oxidative dearomatization/inverse electron demand Diels–Alder reaction cascade. Cascade reactions comprising three and five consecutive reactions were employed for the highly efficient total syntheses of (−)-scabronine A and (−)-episcabronine A, respectively.","tags":["#literature_note"],"author":[{"family":"Nakada","given":"Masahisa","literal":""},{"family":"Nakada","given":"Masahisa","literal":""}],"citation-key":"nakada_enantioselective_2014","year":"2014","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Enantioselective Total Syntheses of Cyathane Diterpenoids"],"author-links":["[[Author/Masahisa Nakada]]","[[Author/Masahisa Nakada]]"],"attachment":["[[biblib/nakada_enantioselective_2014/nakada_enantioselective_2014.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"1kshmwy","at":1774951891129}},"smart_blocks:Research/@nakada_enantioselective_2014.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.10729764,-0.0238533,-0.01581602,-0.00456964,-0.00566106,0.02353995,-0.06494947,0.02634365,-0.04662351,0.00063662,0.06672101,-0.08650822,0.02779363,-0.01171559,0.02354955,-0.00368535,-0.0465272,0.02436572,-0.05059787,0.02782897,0.02636812,-0.05970424,0.0739547,-0.01471292,0.06744626,0.03185509,0.02733895,0.01296068,-0.0637268,-0.25015852,0.00625362,0.05865452,0.01355069,-0.01810906,-0.00994979,-0.0011551,-0.05056784,0.02318213,-0.03187039,0.04415517,0.05321972,0.05133226,0.01416162,0.00283715,-0.00141729,-0.00281454,-0.08528977,0.01028408,-0.00834893,-0.04658112,-0.00380041,-0.08933009,-0.00057215,-0.01734341,-0.00186171,0.06470343,0.02815564,0.07762524,0.02449259,0.0024029