
"smart_sources:Research/@li_chemical_2015.md": {"path":"Research/@li_chemical_2015.md","last_embed":{"hash":null},"embeddings":{},"last_read":{"hash":"4b29fy","at":1774951884835},"class_name":"SmartSource","last_import":{"mtime":1774951830156,"size":3772,"at":1774951884835,"hash":"4b29fy"},"blocks":{"#---frontmatter---":[1,113],"#Chemical Compositions and Macrophage Activation of Polysaccharides from Leon's Mane Culinary-Medicinal Mushroom Hericium erinaceus (Higher Basidiomycetes) in Different Maturation Stages.":[115,119],"#Chemical Compositions and Macrophage Activation of Polysaccharides from Leon's Mane Culinary-Medicinal Mushroom Hericium erinaceus (Higher Basidiomycetes) in Different Maturation Stages.#{1}":[117,119]},"outlinks":[{"title":"Author/Qiaozhen Li","target":"Author/Qiaozhen Li","line":87},{"title":"Author/Qiaozhen Li","target":"Author/Qiaozhen Li","line":88},{"title":"Author/Di Wu","target":"Author/Di Wu","line":89},{"title":"Author/Di Wu","target":"Author/Di Wu","line":90},{"title":"Author/Di Wu","target":"Author/Di Wu","line":91},{"title":"Author/Di Wu","target":"Author/Di Wu","line":92},{"title":"Author/Xia Chen","target":"Author/Xia Chen","line":93},{"title":"Author/Xia Chen","target":"Author/Xia Chen","line":94},{"title":"Author/Xia Chen","target":"Author/Xia Chen","line":95},{"title":"Author/Shuai Zhou","target":"Author/Shuai Zhou","line":96},{"title":"Author/Shuai Zhou","target":"Author/Shuai Zhou","line":97},{"title":"Author/Shuai Zhou","target":"Author/Shuai Zhou","line":98},{"title":"Author/Shuai Zhou","target":"Author/Shuai Zhou","line":99},{"title":"Author/Shuai Zhou","target":"Author/Shuai Zhou","line":100},{"title":"Author/Yanfang Liu","target":"Author/Yanfang Liu","line":101},{"title":"Author/Yanfang Liu","target":"Author/Yanfang Liu","line":102},{"title":"Author/Yanfang Liu","target":"Author/Yanfang Liu","line":103},{"title":"Author/Yan Yang","target":"Author/Yan Yang","line":104},{"title":"Author/Yan Yang","target":"Author/Yan Yang","line":105},{"title":"Author/Yan Yang","target":"Author/Yan Yang","line":106},{"title":"Author/Fengjie Cui","target":"Author/Fengjie Cui","line":107},{"title":"Author/Fengjie Cui","target":"Author/Fengjie Cui","line":108},{"title":"PDF","target":"biblib/li_chemical_2015/li_chemical_2015.pdf","line":110}],"metadata":{"id":"li_chemical_2015","type":"article-journal","title":"Chemical Compositions and Macrophage Activation of Polysaccharides from Leon's Mane Culinary-Medicinal Mushroom Hericium erinaceus (Higher Basidiomycetes) in Different Maturation Stages.","issued":{"date-parts":[[2015]]},"DOI":"10.1615/intjmedmushrooms.v17.i5.40","container-title":"International Journal of Medicinal Mushrooms","abstract":"We studied the effect of the maturation stage on the chemical compositions and macrophage activation activity of polysaccharides from the culinary-medicinal mushroom Hericium erinaceus. Results showed that total polysaccharides increased, whereas protein content decreased with the maturation stage development of fruiting body. Nine polysaccharide fractions, 3 from each of the maturity stages IV (small fungal spine stage), V (mid-fungal spine stage) and VI (mature), were prepared using the gradient ethanol precipitation method. The polysaccharide fraction HP4A isolated from the maturating-stage (stage IV) fruiting body had a significant difference from the fractions HP5A (stage V) and HP6A (stage VI) in the molecular weight distribution and monosaccharide compositions. Immunostimulating tests revealed that the polysaccharide fraction HP6 isolated from the mature stage (stage VI) fruiting body presented higher macrophage activation activity. Our findings provided important information for the harvest and use of H. erinaceus with higher qualities and functional benefits.","tags":["#literature_note"],"author":[{"family":"Li","given":"Qiaozhen","literal":""},{"family":"Li","given":"Qiaozhen","literal":""},{"family":"Wu","given":"Di","literal":""},{"family":"Wu","given":"Di","literal":""},{"family":"Wu","given":"Di","literal":""},{"family":"Wu","given":"Di","literal":""},{"family":"Chen","given":"Xia","literal":""},{"family":"Chen","given":"Xia","literal":""},{"family":"Chen","given":"Xia","literal":""},{"family":"Zhou","given":"Shuai","literal":""},{"family":"Zhou","given":"Shuai","literal":""},{"family":"Zhou","given":"Shuai","literal":""},{"family":"Zhou","given":"Shuai","literal":""},{"family":"Zhou","given":"Shuai","literal":""},{"family":"Liu","given":"Yanfang","literal":""},{"family":"Liu","given":"Yanfang","literal":""},{"family":"Liu","given":"Yanfang","literal":""},{"family":"Yang","given":"Yan","literal":""},{"family":"Yang","given":"Yan","literal":""},{"family":"Yang","given":"Yan","literal":""},{"family":"Cui","given":"Fengjie","literal":""},{"family":"Cui","given":"Fengjie","literal":""}],"citation-key":"li_chemical_2015","year":"2015","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Chemical Compositions and Macrophage Activation of Polysaccharides from Leon's Mane Culinary-Medicinal Mushroom Hericium erinaceus (Higher Basidiomycetes) in Different Maturation Stages."],"author-links":["[[Author/Qiaozhen Li]]","[[Author/Qiaozhen Li]]","[[Author/Di Wu]]","[[Author/Di Wu]]","[[Author/Di Wu]]","[[Author/Di Wu]]","[[Author/Xia Chen]]","[[Author/Xia Chen]]","[[Author/Xia Chen]]","[[Author/Shuai Zhou]]","[[Author/Shuai Zhou]]","[[Author/Shuai Zhou]]","[[Author/Shuai Zhou]]","[[Author/Shuai Zhou]]","[[Author/Yanfang Liu]]","[[Author/Yanfang Liu]]","[[Author/Yanfang Liu]]","[[Author/Yan Yang]]","[[Author/Yan Yang]]","[[Author/Yan Yang]]","[[Author/Fengjie Cui]]","[[Author/Fengjie Cui]]"],"attachment":["[[biblib/li_chemical_2015/li_chemical_2015.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[]},
