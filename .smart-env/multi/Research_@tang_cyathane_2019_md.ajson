0550576,0.02588386,0.19179465,0.08929917,-0.00808321,-0.02118623,-0.0113433,0.02716484,-0.03100422,0.01281213,0.01893349,-0.00292004,0.04179304,-0.05782812,0.07384585,0.06302215,-0.02406065,-0.05800569,-0.0255254,-0.02940989,-0.00089781,0.00586339,-0.09773594,0.03295412,0.09237287,-0.08115441,-0.03537491,-0.02975708,-0.01067586,0.01240896,-0.02066476,0.03413761,0.04469252,0.05280041,-0.02274246,0.05338039,0.01009521,-0.08234751,-0.01920335,0.02543855,-0.04279374,-0.02570285,-0.02161594,0.10387834,0.07427289],"last_embed":{"hash":"qnoxrn","tokens":465}}},"last_read":{"hash":"qnoxrn","at":1774951886663},"class_name":"SmartSource","last_import":{"mtime":1774951815521,"size":3157,"at":1774951884774,"hash":"qnoxrn"},"blocks":{"#---frontmatter---":[1,92],"#Cyathane Diterpenes from Cultures of the Bird's Nest Fungus Cyathus hookeri and Their Neurotrophic and Anti-neuroinflammatory Activities.":[94,98],"#Cyathane Diterpenes from Cultures of the Bird's Nest Fungus Cyathus hookeri and Their Neurotrophic and Anti-neuroinflammatory Activities.#{1}":[96,98]},"outlinks":[{"title":"Author/Dan Tang","target":"Author/Dan Tang","line":72},{"title":"Author/Dan Tang","target":"Author/Dan Tang","line":73},{"title":"Author/Yuanzhen Xu","target":"Author/Yuanzhen Xu","line":74},{"title":"Author/Yuanzhen Xu","target":"Author/Yuanzhen Xu","line":75},{"title":"Author/Weiwei Wang","target":"Author/Weiwei Wang","line":76},{"title":"Author/Weiwei Wang","target":"Author/Weiwei Wang","line":77},{"title":"Author/Zhi Yang","target":"Author/Zhi Yang","line":78},{"title":"Author/Zhi Yang","target":"Author/Zhi Yang","line":79},{"title":"Author/Bo Liu","target":"Author/Bo Liu","line":80},{"title":"Author/Bo Liu","target":"Author/Bo Liu","line":81},{"title":"Author/Marc Stadler","target":"Author/Marc Stadler","line":82},{"title":"Author/Marc Stadler","target":"Author/Marc Stadler","line":83},{"title":"Author/Lingli Liu","target":"Author/Lingli Liu","line":84},{"title":"Author/Ling-Li Liu","target":"Author/Ling-Li Liu","line":85},{"title":"Author/Jin-Ming Gao","target":"Author/Jin-Ming Gao","line":86},{"title":"Author/Gao Jinming","target":"Author/Gao Jinming","line":87},{"title":"Author/Jin-Ming Gao","target":"Author/Jin-Ming Gao","line":88}],"metadata":{"id":"tang_cyathane_2019","type":"article-journal","title":"Cyathane Diterpenes from Cultures of the Bird's Nest Fungus Cyathus hookeri and Their Neurotrophic and Anti-neuroinflammatory Activities.","issued":{"date-parts":[[2019]]},"DOI":"10.1021/acs.jnatprod.9b00091","container-title":"Journal of Natural Products","abstract":"Six new cyathane diterpenoids, cyahookerins A–F (1–6), as well as nine known analogues (7–15), were isolated from the liquid culture of the basidiomycete Cyathus hookeri. Their structures were elucidated on the basis of extensive spectroscopic analyses (1D and 2D NMR, HRESIMS, and ECD), and the absolute configurations of compounds 1 and 4 were determined by single-crystal X-ray crystallography. Compounds 1 and 2 represent the first unusual cyathane acetals featuring a dioxolane ring. Compounds 1–6 displayed differential nerve growth factor-induced neurite outgrowth-promoting activity in PC-12 cells at concentrations of 10 μM. In addition, cyahookerin B (2), cyathin E (9), cyathin B2 (12), and cyathin Q (13) showed significant nitric oxide production inhibition in Lipopolysaccharide (LPS)-activated BV-2 microglial cells with IC50 values of 12.0, 6.9, 10.9, and 9.1 μM, respectively. Similar binding modes of the four compounds were indicated by molecular-docking studies, and structure–activity relationships ...","tags":["#literature_note"],"author":[{"family":"Tang","given":"Dan","literal":""},{"family":"Tang","given":"Dan","literal":""},{"family":"Xu","given":"Yuanzhen","literal":""},{"family":"Xu","given":"Yuanzhen","literal":""},{"family":"Wang","given":"Weiwei","literal":""},{"family":"Wang","given":"Weiwei","literal":""},{"family":"Yang","given":"Zhi","literal":""},{"family":"Yang","given":"Zhi","literal":""},{"family":"Liu","given":"Bo","literal":""},{"family":"Liu","given":"Bo","literal":""},{"family":"Stadler","given":"Marc","literal":""},{"family":"Stadler","given":"Marc","literal":""},{"family":"Liu","given":"Lingli","literal":""},{"family":"Liu","given":"Ling-Li","literal":""},{"family":"Gao","given":"Jin-Ming","literal":""},{"family":"Jinming","given":"Gao","literal":""},{"family":"Gao","given":"Jin-Ming","literal":""}],"citation-key":"tang_cyathane_2019","year":"2019","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Cyathane Diterpenes from Cultures of the Bird's Nest Fungus Cyathus hookeri and Their Neurotrophic and Anti-neuroinflammatory Activities."],"author-links":["[[Author/Dan Tang]]","[[Author/Dan Tang]]","[[Author/Yuanzhen Xu]]","[[Author/Yuanzhen Xu]]","[[Author/Weiwei Wang]]","[[Author/Weiwei Wang]]","[[Author/Zhi Yang]]","[[Author/Zhi Yang]]","[[Author/Bo Liu]]","[[Author/Bo Liu]]","[[Author/Marc Stadler]]","[[Author/Marc Stadler]]","[[Author/Lingli Liu]]","[[Author/Ling-Li Liu]]","[[Author/Jin-Ming Gao]]","[[Author/Gao Jinming]]","[[Author/Jin-Ming Gao]]"],"attachment":[],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"qnoxrn","at":1774951886652}},"smart_blocks:Research/@tang_cyathane_2019.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.04836909,-0.02083704,0.0036572,-0.05495648,0.0495618,0.02358461,0.02715784,0.03835401,-0.03377951,0.01778878,0.01320487,-0.0418501,0.02301959,0.00140394,0.02225582,-0.09577826,-0.0271246,-0.01978084,-0.05975823,0.02121536,0.03168155,-0.06196257,0.06649904,-0.03015872,0.01907969,0.04232521,-0.00870357,0.02968883,-0.04341928,-0.23484407,-0.00106799,0.05957846,-0.00386859,-0.01448521,0.00107662,-0.02498356,-0.00730275,0.00491694,-0.02822693,0.04867766,0.09234024,0.03165467,-0.00262718,0.0074054,-0.01010719,-0.07146915,-0.0767357,-0.01379995,0.03970891,-0.04980104,-0.01184374,-0.09135085,-0.00815509,0.00483799,-