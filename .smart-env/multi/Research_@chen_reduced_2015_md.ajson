93,0.03938175,0.14087407,0.03540695,-0.01206937,0.01573359,0.0091915,-0.00386347,0.07214933,-0.020133,0.02419889,-0.03770826,0.12453429,-0.01248246,0.01879481,0.05995972,-0.10041864,0.02465302,0.00194005,0.00146174,0.06734334,0.04704849,-0.03866139,-0.05578312,0.11093061,0.00990736,-0.02084918,-0.04008346,0.00385023,-0.01543225,-0.01859582,0.00952501,-0.0273072,-0.02706384,0.02688565,0.00902811,0.0546958,-0.03573314,0.0405967,-0.05883591,-0.01843448,0.01442331,-0.06541252,0.10689648,-0.00350582],"last_embed":{"hash":"p8aie0","tokens":432}}},"last_read":{"hash":"p8aie0","at":1774951885861},"class_name":"SmartSource","last_import":{"mtime":1774951814374,"size":3781,"at":1774951884765,"hash":"p8aie0"},"blocks":{"#---frontmatter---":[1,89],"#Reduced cerebellar gray matter is a neural signature of physical frailty.":[91,95],"#Reduced cerebellar gray matter is a neural signature of physical frailty.#{1}":[93,95]},"outlinks":[{"title":"Author/Wei Ta Chen","target":"Author/Wei Ta Chen","line":69},{"title":"Author/Wei-Ta Chen","target":"Author/Wei-Ta Chen","line":70},{"title":"Author/Kun Hsien Chou","target":"Author/Kun Hsien Chou","line":71},{"title":"Author/Kun-Hsien Chou","target":"Author/Kun-Hsien Chou","line":72},{"title":"Author/Li Kuo Liu","target":"Author/Li Kuo Liu","line":73},{"title":"Author/Li-Kuo Liu","target":"Author/Li-Kuo Liu","line":74},{"title":"Author/Pei-Lin Lee","target":"Author/Pei-Lin Lee","line":75},{"title":"Author/Pei-Lin Lee","target":"Author/Pei-Lin Lee","line":76},{"title":"Author/Wei-Ju Lee","target":"Author/Wei-Ju Lee","line":77},{"title":"Author/Wei-Ju Lee","target":"Author/Wei-Ju Lee","line":78},{"title":"Author/Liang Kung Chen","target":"Author/Liang Kung Chen","line":79},{"title":"Author/Liang-Kung Chen","target":"Author/Liang-Kung Chen","line":80},{"title":"Author/Pei Ning Wang","target":"Author/Pei Ning Wang","line":81},{"title":"Author/Pei-Ning Wang","target":"Author/Pei-Ning Wang","line":82},{"title":"Author/Ching Po Lin","target":"Author/Ching Po Lin","line":83},{"title":"Author/Ching-Po Lin","target":"Author/Ching-Po Lin","line":84},{"title":"PDF","target":"biblib/chen_reduced_2015/chen_reduced_2015.pdf","line":86}],"metadata":{"id":"chen_reduced_2015","type":"article-journal","title":"Reduced cerebellar gray matter is a neural signature of physical frailty.","issued":{"date-parts":[[2015]]},"DOI":"10.1002/hbm.22870","container-title":"Human Brain Mapping","abstract":"Physical frailty has been recognized as a clinical syndrome resulting from declines in various physiological systems; however, the role of the central nervous system in the pathophysiology of frailty remains unclear. The I-Lan Longitudinal Aging Study randomly sampled community-dwelling people aged 50 or older for a brain magnetic resonance imaging study. All participants were assessed for frailty status (robust, prefrail, and frail) based on the presence of five frailty components: slow walking speed, muscle weakness, low physical activity, exhaustion and weight loss (Fried criteria). Gray matter volume (GMV) changes associated with frailty status and individual frailty components were examined. Overall, 456 participants (64.0±8.5 years, 47.6% women) were included in this study. The prefrail (n=178, 39.0%) and frail (n=19, 4.2%) subjects were grouped for analysis. The prefrail–frail group showed reduced GMV, compared to the robust group (n=259, 56.8%), in the cerebellum, hippocampi, middle frontal gyri, and several other cerebral regions (corrected P<0.05). Each frailty component was associated with GMV changes in functionally related brain areas. Hierarchical cluster analysis categorized these components into three subsets. Motor-related components, including weakness, low activity, and slowness, comprised one subset with a common cerebellar involvement. Exhaustion and weight loss were the other two subsets without cerebellar changes. To conclude, physical frailty is associated with a decreased reserve in specific brain regions, especially cerebellum. Further longitudinal studies are needed to explore if the cerebellum- and noncerebellum-based frailty components reflect a distinctive future risk for developing frailty. Hum Brain Mapp 36:3666–3676, 2015. © 2015 Wiley Periodicals, Inc.","tags":["#literature_note"],"author":[{"family":"Chen","given":"Wei Ta","literal":""},{"family":"Chen","given":"Wei-Ta","literal":""},{"family":"Chou","given":"Kun Hsien","literal":""},{"family":"Chou","given":"Kun-Hsien","literal":""},{"family":"Liu","given":"Li Kuo","literal":""},{"family":"Liu","given":"Li-Kuo","literal":""},{"family":"Lee","given":"Pei-Lin","literal":""},{"family":"Lee","given":"Pei-Lin","literal":""},{"family":"Lee","given":"Wei-Ju","literal":""},{"family":"Lee","given":"Wei-Ju","literal":""},{"family":"Chen","given":"Liang Kung","literal":""},{"family":"Chen","given":"Liang-Kung","literal":""},{"family":"Wang","given":"Pei Ning","literal":""},{"family":"Wang","given":"Pei-Ning","literal":""},{"family":"Lin","given":"Ching Po","literal":""},{"family":"Lin","given":"Ching-Po","literal":""}],"citation-key":"chen_reduced_2015","year":"2015","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Reduced cerebellar gray matter is a neural signature of physical frailty."],"author-links":["[[Author/Wei Ta Chen]]","[[Author/Wei-Ta Chen]]","[[Author/Kun Hsien Chou]]","[[Author/Kun-Hsien Chou]]","[[Author/Li Kuo Liu]]","[[Author/Li-Kuo Liu]]","[[Author/Pei-Lin Lee]]","[[Author/Pei-Lin Lee]]","[[Author/Wei-Ju Lee]]","[[Author/Wei-Ju Lee]]","[[Author/Liang Kung Chen]]","[[Author/Liang-Kung Chen]]","[[Author/Pei Ning Wang]]","[[Author/Pei-Ning Wang]]","[[Author/Ching Po Lin]]","[[Author/Ching-Po Lin]]"],"attachment":["[[biblib/chen_reduced_2015/chen_reduced_2015.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"p8aie0","at":1774951885853}},"smart_blocks:Research/@chen_reduced_2015.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bg