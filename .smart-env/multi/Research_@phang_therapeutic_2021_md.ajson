5,-0.01224316,0.01172783,0.17938089,0.00118352,0.01371044,-0.02871561,-0.06153991,0.01231749,-0.07527644,0.00016856,0.01930512,0.03535939,0.12197093,-0.01819449,0.03147321,0.05413733,-0.0651409,-0.03033649,-0.01467816,0.02911133,0.00364785,-0.01760162,-0.0430533,0.02067158,0.1100101,-0.02755859,-0.05788374,-0.02228369,0.0195178,0.01545542,-0.03993283,0.00405467,-0.02315308,0.07143746,-0.00723037,-0.03170056,0.03002543,-0.02402361,-0.03962191,-0.04086121,0.03395965,0.05038882,-0.06745615,0.12481562,0.02710682],"last_embed":{"hash":"178ae1c","tokens":426}}},"last_read":{"hash":"178ae1c","at":1774951891175},"class_name":"SmartSource","last_import":{"mtime":1774951822054,"size":3752,"at":1774951884805,"hash":"178ae1c"},"blocks":{"#---frontmatter---":[1,73],"#Therapeutic roles of natural remedies in combating hereditary ataxia: A systematic review.":[75,79],"#Therapeutic roles of natural remedies in combating hereditary ataxia: A systematic review.#{1}":[77,79]},"outlinks":[{"title":"Author/Michael Weng Lok Phang","target":"Author/Michael Weng Lok Phang","line":57},{"title":"Author/Michael Weng Lok Phang","target":"Author/Michael Weng Lok Phang","line":58},{"title":"Author/Sze Yuen Lew","target":"Author/Sze Yuen Lew","line":59},{"title":"Author/Sze Yuen Lew","target":"Author/Sze Yuen Lew","line":60},{"title":"Author/Ivy Chung","target":"Author/Ivy Chung","line":61},{"title":"Author/Ivy Chung","target":"Author/Ivy Chung","line":62},{"title":"Author/William Kiong-Seng Lim","target":"Author/William Kiong-Seng Lim","line":63},{"title":"Author/William K. Lim","target":"Author/William K. Lim","line":64},{"title":"Author/Lee Wei Lim","target":"Author/Lee Wei Lim","line":65},{"title":"Author/Lee Wei Lim","target":"Author/Lee Wei Lim","line":66},{"title":"Author/Kah-Hui Wong","target":"Author/Kah-Hui Wong","line":67},{"title":"Author/Kah-Hui Wong","target":"Author/Kah-Hui Wong","line":68},{"title":"PDF","target":"biblib/phang_therapeutic_2021/phang_therapeutic_2021.pdf","line":70}],"metadata":{"id":"phang_therapeutic_2021","type":"article-journal","title":"Therapeutic roles of natural remedies in combating hereditary ataxia: A systematic review.","issued":{"date-parts":[[2021]]},"DOI":"10.1186/s13020-020-00414-x","container-title":"Chinese Medicine","abstract":"BACKGROUND Hereditary ataxia (HA) represents a group of genetically heterogeneous neurodegenerative diseases caused by dysfunction of the cerebellum or disruption of the connection between the cerebellum and other areas of the central nervous system. Phenotypic manifestation of HA includes unsteadiness of stance and gait, dysarthria, nystagmus, dysmetria and complaints of clumsiness. There are no specific treatments for HA. Management strategies provide supportive treatment to reduce symptoms. OBJECTIVES This systematic review aimed to identify, evaluate and summarise the published literature on the therapeutic roles of natural remedies in the treatment of HA to provide evidence for clinical practice. METHODS A systematic literature search was conducted using the Preferred Reporting Items for Systematic Reviewsand Meta-Analyses (PRISMA). Web of Science, PubMed and Science Direct Scopus were thoroughly searched for relevant published articles from June 2007 to July 2020. RESULTS Ten pre-clinical and two clinical studies were eligible for inclusion in this systematic review. We identified the therapeutic roles of medicinal plants Brassica napus, Gardenia jasminoides, Gastrodia elata, Ginkgo biloba, Glycyrrhiza inflata, Paeonia lactiflora, Pueraria lobata and Rehmannia glutinosa; herbal formulations Shaoyao Gancao Tang and Zhengan Xifeng Tang; and medicinal mushroom Hericium erinaceus in the treatment of HA. In this review, we evaluated the mode of actions contributing to their therapeutic effects, including activation of the ubiquitin-proteasome system, activation of antioxidant pathways, maintenance of intracellular calcium homeostasis and regulation of chaperones. We also briefly highlighted the integral cellular signalling pathways responsible for orchestrating the mode of actions. CONCLUSION We reviewed the therapeutic roles of natural remedies in improving or halting the progression of HA, which warrant further study for applications into clinical practice.","tags":["#literature_note"],"author":[{"family":"Phang","given":"Michael Weng Lok","literal":""},{"family":"Phang","given":"Michael Weng Lok","literal":""},{"family":"Lew","given":"Sze Yuen","literal":""},{"family":"Lew","given":"Sze Yuen","literal":""},{"family":"Chung","given":"Ivy","literal":""},{"family":"Chung","given":"Ivy","literal":""},{"family":"Lim","given":"William Kiong-Seng","literal":""},{"family":"Lim","given":"William K.","literal":""},{"family":"Lim","given":"Lee Wei","literal":""},{"family":"Lim","given":"Lee Wei","literal":""},{"family":"Wong","given":"Kah-Hui","literal":""},{"family":"Wong","given":"Kah-Hui","literal":""}],"citation-key":"phang_therapeutic_2021","year":"2021","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Therapeutic roles of natural remedies in combating hereditary ataxia: A systematic review."],"author-links":["[[Author/Michael Weng Lok Phang]]","[[Author/Michael Weng Lok Phang]]","[[Author/Sze Yuen Lew]]","[[Author/Sze Yuen Lew]]","[[Author/Ivy Chung]]","[[Author/Ivy Chung]]","[[Author/William Kiong-Seng Lim]]","[[Author/William K. Lim]]","[[Author/Lee Wei Lim]]","[[Author/Lee Wei Lim]]","[[Author/Kah-Hui Wong]]","[[Author/Kah-Hui Wong]]"],"attachment":["[[biblib/phang_therapeutic_2021/phang_therapeutic_2021.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"178ae1c","at":1774951891166}},"smart_blocks:Research/@phang_therapeutic_2021.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[0.00167025,0.00190198,0.04868418,-0.0062311,-0.0037494,0.02408358,0.04369537,0.05057557,-0.02732327,-0.02104602,0.03151297,-0.09784573,0.0217556,0.04885397,0.01911235,0.03