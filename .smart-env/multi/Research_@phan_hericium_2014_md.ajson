9464,0.00605464,0.17553067,0.04692321,-0.05694429,0.03749682,-0.03699203,0.02336775,0.02492549,0.01404919,0.0011682,0.05310944,0.08266969,-0.04245018,0.07932499,0.06417876,-0.04430671,0.0007171,-0.03381634,-0.03211434,-0.00805205,-0.03884415,-0.0932173,-0.02806208,0.10387061,-0.06212522,-0.01545435,-0.01808125,0.00443319,0.03020031,-0.00701727,0.01237481,0.00788764,0.04956913,-0.02842649,-0.00771327,0.00735471,-0.03766213,-0.02856792,-0.00779103,0.01735367,-0.00170038,-0.0227455,0.11621287,0.03510401],"last_embed":{"hash":"lozmc5","tokens":508}}},"last_read":{"hash":"lozmc5","at":1774951887482},"class_name":"SmartSource","last_import":{"mtime":1774951817069,"size":4233,"at":1774951884781,"hash":"lozmc5"},"blocks":{"#---frontmatter---":[1,93],"#Hericium erinaceus (Bull.: Fr) Pers. cultivated under tropical conditions: isolation of hericenones and demonstration of NGF-mediated neurite outgrowth in PC12 cells via MEK/ERK and PI3K-Akt signaling pathways":[95,99],"#Hericium erinaceus (Bull.: Fr) Pers. cultivated under tropical conditions: isolation of hericenones and demonstration of NGF-mediated neurite outgrowth in PC12 cells via MEK/ERK and PI3K-Akt signaling pathways#{1}":[97,99]},"outlinks":[{"title":"Author/Chia Wei Phan","target":"Author/Chia Wei Phan","line":72},{"title":"Author/Chia-Wei Phan","target":"Author/Chia-Wei Phan","line":73},{"title":"Author/Guan-Serm Lee","target":"Author/Guan-Serm Lee","line":74},{"title":"Author/Guan-Serm Lee","target":"Author/Guan-Serm Lee","line":75},{"title":"Author/ZhongXiang Zhang","target":"Author/ZhongXiang Zhang","line":76},{"title":"Author/Sok Lai Hong","target":"Author/Sok Lai Hong","line":77},{"title":"Author/Sok Lai Hong","target":"Author/Sok Lai Hong","line":78},{"title":"Author/Yuin-Teng Wong","target":"Author/Yuin-Teng Wong","line":79},{"title":"Author/Yuin-Teng Wong","target":"Author/Yuin-Teng Wong","line":80},{"title":"Author/Robert Brkljača","target":"Author/Robert Brkljača","line":81},{"title":"Author/Robert Brkljača","target":"Author/Robert Brkljača","line":82},{"title":"Author/Sylvia Urban","target":"Author/Sylvia Urban","line":83},{"title":"Author/Sylvia Urban","target":"Author/Sylvia Urban","line":84},{"title":"Author/Sri Nurestri Abd Malek","target":"Author/Sri Nurestri Abd Malek","line":85},{"title":"Author/Sri Nurestri Abd Malek","target":"Author/Sri Nurestri Abd Malek","line":86},{"title":"Author/Vikineswary Sabaratnam","target":"Author/Vikineswary Sabaratnam","line":87},{"title":"Author/Vikineswary Sabaratnam","target":"Author/Vikineswary Sabaratnam","line":88},{"title":"PDF","target":"biblib/phan_hericium_2014/phan_hericium_2014.pdf","line":90}],"metadata":{"id":"phan_hericium_2014","type":"article-journal","title":"Hericium erinaceus (Bull.: Fr) Pers. cultivated under tropical conditions: isolation of hericenones and demonstration of NGF-mediated neurite outgrowth in PC12 cells via MEK/ERK and PI3K-Akt signaling pathways","issued":{"date-parts":[[2014]]},"DOI":"10.1039/c4fo00452c","container-title":"Food & Function","abstract":"Hericium erinaceus (Bull.: Fr.) Pers. is an edible and medicinal mushroom used traditionally to improve memory. In this study, we investigated the neuritogenic effects of hericenones isolated from H. erinaceus and the mechanisms of action involved. H. erinaceus was cultivated and the secondary metabolites were elucidated by high performance liquid chromatography (HPLC), liquid chromatography-mass spectrometry (LC-MS), and nuclear magnetic resonance (NMR). The secondary metabolites were tested for neurite outgrowth activity (if any). Rat pheochromocytoma (PC12) cells were employed and the nerve growth factor (NGF) level was also determined. The signaling pathways involved in the mushroom-induced neuritogenesis were investigated using several pharmacological inhibitors. Hericenones B–E (1–4), erinacerin A (5) and isohericerin (6) were isolated from the basidiocarps of H. erinaceus. The hericenones did not promote neurite outgrowth but when induced with a low concentration of NGF (5 ng mL−1), the neuritogenic activity was comparable to that of the positive control (50 ng mL−1 of NGF). Hericenone E was able to stimulate NGF secretion which was two-fold higher than that of the positive control. The neuritogenesis process was partially blocked by the tyrosine kinase receptor (Trk) inhibitor, K252a, suggesting that the neuritogenic effect was not solely due to NGF. Hericenone E also increased the phosphorylation of extracellular-signal regulated kinases (ERKs) and protein kinase B (Akt). Taken together, this study suggests that hericenone E potentiated NGF-induced neuritogenesis in PC12 cells via the MEK/ERK and PI3K/Akt pathways.","tags":["#literature_note"],"author":[{"family":"Phan","given":"Chia Wei","literal":""},{"family":"Phan","given":"Chia-Wei","literal":""},{"family":"Lee","given":"Guan-Serm","literal":""},{"family":"Lee","given":"Guan-Serm","literal":""},{"family":"Zhang","given":"ZhongXiang","literal":""},{"family":"Hong","given":"Sok Lai","literal":""},{"family":"Hong","given":"Sok Lai","literal":""},{"family":"Wong","given":"Yuin-Teng","literal":""},{"family":"Wong","given":"Yuin-Teng","literal":""},{"family":"Brkljača","given":"Robert","literal":""},{"family":"Brkljača","given":"Robert","literal":""},{"family":"Urban","given":"Sylvia","literal":""},{"family":"Urban","given":"Sylvia","literal":""},{"family":"Malek","given":"Sri Nurestri Abd","literal":""},{"family":"Malek","given":"Sri Nurestri Abd","literal":""},{"family":"Sabaratnam","given":"Vikineswary","literal":""},{"family":"Sabaratnam","given":"Vikineswary","literal":""}],"citation-key":"phan_hericium_2014","year":"2014","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Hericium erinaceus (Bull.: Fr) Pers. cultivated under tropical conditions: isolation of hericenones and demonstration of NGF-mediated neurite outgrowth in PC12 cells via MEK/ERK and PI3K-Akt signaling pathways"],"author-links":["[[Author/Chia Wei Phan]]",