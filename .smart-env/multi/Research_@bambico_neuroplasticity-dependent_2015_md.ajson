54,-0.0099373,0.0623096,-0.0701778,0.00388451,0.00770859,0.14048357,0.05874249,0.03054326,0.02135535,-0.0035709,0.05308416,0.01918424,0.00345567,0.03330798,0.07073226,0.08085038,-0.06830433,0.03932804,0.05930988,-0.09084037,0.03477036,0.0190129,-0.04395952,-0.01799056,0.01950072,0.03433323,0.00449836,0.10827537,-0.04932842,0.01218577,-0.03674635,-0.00414665,0.03182914,0.00194159,0.00059838,0.05760117,0.02139232,0.01263307,-0.02374545,0.03767943,-0.0080658,0.06038067,-0.04518063,-0.010841,-0.02690044,-0.02850463,0.15171237,-0.06334496],"last_embed":{"hash":"1n54hst","tokens":444}}},"last_read":{"hash":"1n54hst","at":1774951890660},"class_name":"SmartSource","last_import":{"mtime":1774951821452,"size":3856,"at":1774951884801,"hash":"1n54hst"},"blocks":{"#---frontmatter---":[1,113],"#Neuroplasticity-dependent and -independent mechanisms of chronic deep brain stimulation in stressed rats.":[115,119],"#Neuroplasticity-dependent and -independent mechanisms of chronic deep brain stimulation in stressed rats.#{1}":[117,119]},"outlinks":[{"title":"Author/Francis Rodriguez Bambico","target":"Author/Francis Rodriguez Bambico","line":87},{"title":"Author/Francis Rodriguez Bambico","target":"Author/Francis Rodriguez Bambico","line":88},{"title":"Author/Tatiana Bregman","target":"Author/Tatiana Bregman","line":89},{"title":"Author/Tatiana Bregman","target":"Author/Tatiana Bregman","line":90},{"title":"Author/Mustansir Diwan","target":"Author/Mustansir Diwan","line":91},{"title":"Author/Mustansir Diwan","target":"Author/Mustansir Diwan","line":92},{"title":"Author/J. Li","target":"Author/J. Li","line":93},{"title":"Author/J. Li","target":"Author/J. Li","line":94},{"title":"Author/Soroush Darvish-Ghane","target":"Author/Soroush Darvish-Ghane","line":95},{"title":"Author/S. Darvish-Ghane","target":"Author/S. Darvish-Ghane","line":96},{"title":"Author/Z. Li","target":"Author/Z. Li","line":97},{"title":"Author/Zhuoliang Li","target":"Author/Zhuoliang Li","line":98},{"title":"Author/Bryce Laver","target":"Author/Bryce Laver","line":99},{"title":"Author/B. Laver","target":"Author/B. Laver","line":100},{"title":"Author/Beatriz Oliveira Amorim","target":"Author/Beatriz Oliveira Amorim","line":101},{"title":"Author/Beatriz Amorim","target":"Author/Beatriz Amorim","line":102},{"title":"Author/Luciene Covolan","target":"Author/Luciene Covolan","line":103},{"title":"Author/Luciene Covolan","target":"Author/Luciene Covolan","line":104},{"title":"Author/José N. Nóbrega","target":"Author/José N. Nóbrega","line":105},{"title":"Author/José N. Nobrega","target":"Author/José N. Nobrega","line":106},{"title":"Author/Clement Hamani","target":"Author/Clement Hamani","line":107},{"title":"Author/Clement Hamani","target":"Author/Clement Hamani","line":108},{"title":"PDF","target":"biblib/bambico_neuroplasticity-dependent_2015/bambico_neuroplasticity-dependent_2015.pdf","line":110}],"metadata":{"id":"bambico_neuroplasticity-dependent_2015","type":"article-journal","title":"Neuroplasticity-dependent and -independent mechanisms of chronic deep brain stimulation in stressed rats.","issued":{"date-parts":[[2015]]},"DOI":"10.1038/tp.2015.166","container-title":"Translational Psychiatry","abstract":"Chronic ventromedial prefrontal cortex (vmPFC) deep brain stimulation (DBS) improves depressive-like behaviour in rats via serotonergic and neurotrophic-related mechanisms. We hypothesise that, in addition to these substrates, DBS-induced increases in hippocampal neurogenesis may also be involved. Our results show that stress-induced behavioural deficits in the sucrose preference test, forced swim test, novelty-suppressed feeding test (NSFT) and elevated plus maze were countered by chronic vmPFC DBS. In addition, stressed rats receiving stimulation had significant increases in hippocampal neurogenesis, PFC and hippocampal brain-derived neurotrophic factor levels. To block neurogenesis, stressed animals given DBS were injected with temozolomide. Such treatment reversed the anxiolytic-like effect of stimulation in the NSFT without significantly affecting performance in other behavioural tests. Taken together, our findings suggest that neuroplastic changes, including neurogenesis, may be involved in specific anxiolytic effects of DBS without affecting its general antidepressant-like response.","tags":["#literature_note"],"author":[{"family":"Bambico","given":"Francis Rodriguez","literal":""},{"family":"Bambico","given":"Francis Rodriguez","literal":""},{"family":"Bregman","given":"Tatiana","literal":""},{"family":"Bregman","given":"Tatiana","literal":""},{"family":"Diwan","given":"Mustansir","literal":""},{"family":"Diwan","given":"Mustansir","literal":""},{"family":"Li","given":"J.","literal":""},{"family":"Li","given":"J.","literal":""},{"family":"Darvish-Ghane","given":"Soroush","literal":""},{"family":"Darvish-Ghane","given":"S.","literal":""},{"family":"Li","given":"Z.","literal":""},{"family":"Li","given":"Zhuoliang","literal":""},{"family":"Laver","given":"Bryce","literal":""},{"family":"Laver","given":"B.","literal":""},{"family":"Amorim","given":"Beatriz Oliveira","literal":""},{"family":"Amorim","given":"Beatriz","literal":""},{"family":"Covolan","given":"Luciene","literal":""},{"family":"Covolan","given":"Luciene","literal":""},{"family":"Nóbrega","given":"José N.","literal":""},{"family":"Nobrega","given":"José N.","literal":""},{"family":"Hamani","given":"Clement","literal":""},{"family":"Hamani","given":"Clement","literal":""}],"citation-key":"bambico_neuroplasticity-dependent_2015","year":"2015","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Neuroplasticity-dependent and -independent mechanisms of chronic deep brain stimulation in stressed rats."],"author-links":["[[Author/Francis Rodriguez Bambico]]","[[Author/Francis Rodriguez Bambico]]","[[Author/Tatiana Bregman]]","[[Author/Tatiana Bregman]]","[[Author/Mustansir Diwan]]","[[Author/Mustansir Diwan]]","[[Author/J. Li]]","[[Author/J. Li]]","[[Author/Soroush Darvish-Ghane]]","[[Author/S. Darvish-Ghane]]","[[Author/Z. Li]]","[[Author/Zhuoliang Li]]","[[Author/Bryce Laver]]","[[Author/B. Laver]]","[[Author/Beatriz Oliveira Amorim]]","[[Author/Beatriz Amorim]]","[[Author/Luciene Covolan]]","[[Author/Luciene Covolan]]","[[Author/José N. Nóbrega]]","[[Author/José N. Nobrega]]","[[Author/Clement Hamani]]","[[Author/Clement Hamani]]"],"attachment":["[[biblib/bambico_neuroplasticity-dependent_2015/bambico_neuroplasticity-dependent_2015.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"1n54hst","at":1774951890652}},"smart_blocks:Research/@bambico_neuroplasticity-dependent_2015.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.05185328,0.01501332,0.03912875,-0.00003838,-0.03253976,0.06248241,-0.00057573,0.01811976,0.02797061,-0.03076748,-0.0309877,-0.02719643,0.03086767,0.0790668,0.04625687,0.01852459,0.00161964,-0.01420922,-0.00658325,-0.00940039,0.02490262,-0.11508401,0.04887248,-0.01754887,-0.03092999,-0.00368783,-0.01232953,0.00032393,-0.03898053,-0.23490588,0.07450738,0.00288766,0.02008565,-0.07142782,-0.03820197,-0.00054819,-0.01589018,0.07288668,-0.02262411,0.04829661,-0.00832239,0.04231398,0.00313702,-0.01966631,-0.00277591,-0.05950335,0.00530305,-0.08076015,0.02843446,-0.02916895,0.02560779,-0.05230326,0.0595957,0.04130398,0.01340885,0.01757706,0.05061087,0.04357011,0.03149512,0.05743664,0.0352703,0.08640689,-0.20010729,0.02362298,0.12514669,0.0027423,-0.09122606,-0.02526538,0.05940716,0.05641959,-0.08483545,0.05857918,0.05832638,0.01895731,0.02953162,-0.01882043,-0.02718592,-0.08709583,0.03507387,-0.04407279,0.06343859,0.02801071,-0.01606133,-0.0721892,-0.02368588,-0.02393411,0.02087708,-0.10185842,-0.04584302,0.01695505,-0.037591,-0.00370867,0.03865576,-0.0197689,-0.02880803,-0.00579523,-0.02246891,-0.03245351,-0.04035952,0.12041093,-0.04175547,0.06573077,-0.05435171,0.05864874,-0.0051724,0.00258866,0.01244636,-0.03008977,-0.0374039,0