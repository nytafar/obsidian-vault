223,0.05155932,0.17552747,0.02576183,-0.03846833,-0.02080103,0.0024085,0.01035559,0.04944893,0.03800016,-0.01555986,0.0328652,0.10897376,0.00319181,0.0950907,-0.00059335,-0.10182545,-0.06020426,0.00999167,0.0254684,0.0147278,-0.01271209,-0.07736127,-0.0297853,0.1176415,-0.03102628,0.0019548,-0.05168073,-0.02667472,0.01435934,-0.02180595,-0.02290583,0.02384605,0.00308501,0.01376965,-0.03186109,-0.00015335,0.01818214,-0.04929744,-0.03134636,0.00347965,0.0255047,-0.01375197,0.08726913,0.04139355],"last_embed":{"hash":"1ehm28m","tokens":438}}},"last_read":{"hash":"1ehm28m","at":1774951893354},"class_name":"SmartSource","last_import":{"mtime":1774951825961,"size":3035,"at":1774951884819,"hash":"1ehm28m"},"blocks":{"#---frontmatter---":[1,65],"#Improving effects of the mushroom Yamabushitake (Hericium erinaceus) on mild cognitive impairment: a double‐blind placebo‐controlled clinical trial":[67,71],"#Improving effects of the mushroom Yamabushitake (Hericium erinaceus) on mild cognitive impairment: a double‐blind placebo‐controlled clinical trial#{1}":[69,71]},"outlinks":[{"title":"Author/Koichiro Mori","target":"Author/Koichiro Mori","line":51},{"title":"Author/Koichiro Mori","target":"Author/Koichiro Mori","line":52},{"title":"Author/Satoshi Inatomi","target":"Author/Satoshi Inatomi","line":53},{"title":"Author/Satoshi Inatomi","target":"Author/Satoshi Inatomi","line":54},{"title":"Author/Kenzi Ouchi","target":"Author/Kenzi Ouchi","line":55},{"title":"Author/Kenzi Ouchi","target":"Author/Kenzi Ouchi","line":56},{"title":"Author/Yoshihito Azumi","target":"Author/Yoshihito Azumi","line":57},{"title":"Author/Yoshihito Azumi","target":"Author/Yoshihito Azumi","line":58},{"title":"Author/Takashi Tuchida","target":"Author/Takashi Tuchida","line":59},{"title":"Author/Takashi Tuchida","target":"Author/Takashi Tuchida","line":60},{"title":"PDF","target":"biblib/mori_improving_2009/mori_improving_2009.pdf","line":62}],"metadata":{"id":"mori_improving_2009","type":"article-journal","title":"Improving effects of the mushroom Yamabushitake (Hericium erinaceus) on mild cognitive impairment: a double‐blind placebo‐controlled clinical trial","issued":{"date-parts":[[2009]]},"DOI":"10.1002/ptr.2634","container-title":"Phytotherapy Research","abstract":"A double-blind, parallel-group, placebo-controlled trial was performed on 50- to 80-year-old Japanese men and women diagnosed with mild cognitive impairment in order to examine the efficacy of oral administration of Yamabushitake (Hericium erinaceus), an edible mushroom, for improving cognitive impairment, using a cognitive function scale based on the Revised Hasegawa Dementia Scale (HDS-R). After 2 weeks of preliminary examination, 30 subjects were randomized into two 15-person groups, one of which was given Yamabushitake and the other given a placebo. The subjects of the Yamabushitake group took four 250 mg tablets containing 96% of Yamabushitake dry powder three times a day for 16 weeks. After termination of the intake, the subjects were observed for the next 4 weeks. At weeks 8, 12 and 16 of the trial, the Yamabushitake group showed significantly increased scores on the cognitive function scale compared with the placebo group. The Yamabushitake group's scores increased with the duration of intake, but at week 4 after the termination of the 16 weeks intake, the scores decreased significantly. Laboratory tests showed no adverse effect of Yamabushitake. The results obtained in this study suggest that Yamabushitake is effective in improving mild cognitive impairment.","tags":["#literature_note"],"author":[{"family":"Mori","given":"Koichiro","literal":""},{"family":"Mori","given":"Koichiro","literal":""},{"family":"Inatomi","given":"Satoshi","literal":""},{"family":"Inatomi","given":"Satoshi","literal":""},{"family":"Ouchi","given":"Kenzi","literal":""},{"family":"Ouchi","given":"Kenzi","literal":""},{"family":"Azumi","given":"Yoshihito","literal":""},{"family":"Azumi","given":"Yoshihito","literal":""},{"family":"Tuchida","given":"Takashi","literal":""},{"family":"Tuchida","given":"Takashi","literal":""}],"citation-key":"mori_improving_2009","year":"2009","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Improving effects of the mushroom Yamabushitake (Hericium erinaceus) on mild cognitive impairment: a double‐blind placebo‐controlled clinical trial"],"author-links":["[[Author/Koichiro Mori]]","[[Author/Koichiro Mori]]","[[Author/Satoshi Inatomi]]","[[Author/Satoshi Inatomi]]","[[Author/Kenzi Ouchi]]","[[Author/Kenzi Ouchi]]","[[Author/Yoshihito Azumi]]","[[Author/Yoshihito Azumi]]","[[Author/Takashi Tuchida]]","[[Author/Takashi Tuchida]]"],"attachment":["[[biblib/mori_improving_2009/mori_improving_2009.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"1ehm28m","at":1774951893345}},"smart_blocks:Research/@mori_improving_2009.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.02222276,-0.04438851,0.06580888,-0.02978067,-0.02310263,0.03384219,0.00017872,0.03179345,-0.03245579,0.01687894,-0.00012071,-0.05269917,0.07028642,0.06460311,0.05152367,-0.01738378,0.03183453,-0.00315412,-0.04818463,-0.00030919,-0.01355096,0.01151694,0.0182458,0.03183938,0.05335753,0.00606786,-0.05156976,0.00119423,-0.05851116,-0.22489329,-0.00838298,-0.04327304,0.02636698,-0.02695823,-0.0568703,-0.00757733,-0.00516112,0.03744878,-0.00415102,-0.01071004,0.05000153,0.0686555,-0.00446782,0.0261505,-0.04782095,-0.05346163,-0.03353605,-0.02708939,0.01239658,-0.03477341,-0.03482666,-0.09734458,0.01464656,0.05135523,0.05981755,0.02812194,-0.02996426,0.01881287,0.02837144,0.03427498,-0.00507625,0.07970493,-0.19482967,0.05473752,0.03973871,-0.02258285,-0.08669553,-0.0401538,0.05235662,0.0383845,-0.03836708,0.06353163,0.06545164,0.03551815,0.05956202,-0.04826285,-0.00517018,-0.05802603,-0.01001671,-0.0192836,0.02964863,0.08635147,0.02339976,-0.02400801,0.03148411,-0.09926663,-0.05981943,-0.04477604,-0.0