,-0.00643476,0.0230004,0.03490862,0.18237618,-0.00283191,0.01490549,0.0470479,-0.05380014,0.01807487,0.01838507,-0.02415789,-0.04650762,0.05569707,0.09974871,-0.06972862,0.05790103,0.08043661,-0.07293282,-0.05307481,-0.00429372,-0.02057016,0.01522437,0.04018504,-0.0136261,-0.00998975,0.12563322,-0.05960715,-0.02914021,-0.04868415,-0.04123432,0.01612813,-0.00832275,-0.00484307,-0.01388708,0.01507978,0.0230145,-0.06197492,0.00242169,-0.01777752,-0.02121964,-0.06388192,-0.07873906,0.00162306,0.03042885,0.12714346,0.04138959],"last_embed":{"hash":"fcsc6j","tokens":512}}},"last_read":{"hash":"fcsc6j","at":1774951895672},"class_name":"SmartSource","last_import":{"mtime":1774951828738,"size":2311,"at":1774951884829,"hash":"fcsc6j"},"blocks":{"#---frontmatter---":[1,57],"#The neuropharmacology of L-theanine(N-ethyl-L-glutamine): a possible neuroprotective and cognitive enhancing agent.":[59,63],"#The neuropharmacology of L-theanine(N-ethyl-L-glutamine): a possible neuroprotective and cognitive enhancing agent.#{1}":[61,63]},"outlinks":[{"title":"Author/Pradeep J. Nathan","target":"Author/Pradeep J. Nathan","line":45},{"title":"Author/Pradeep J. Nathan","target":"Author/Pradeep J. Nathan","line":46},{"title":"Author/Kristy Lu","target":"Author/Kristy Lu","line":47},{"title":"Author/Kristy Lu","target":"Author/Kristy Lu","line":48},{"title":"Author/Marcus A. Gray","target":"Author/Marcus A. Gray","line":49},{"title":"Author/Marcus A. Gray","target":"Author/Marcus A. Gray","line":50},{"title":"Author/Chris Oliver","target":"Author/Chris Oliver","line":51},{"title":"Author/Chris Oliver","target":"Author/Chris Oliver","line":52},{"title":"PDF","target":"biblib/nathan_neuropharmacology_2006/nathan_neuropharmacology_2006.pdf","line":54}],"metadata":{"id":"nathan_neuropharmacology_2006","type":"article-journal","title":"The neuropharmacology of L-theanine(N-ethyl-L-glutamine): a possible neuroprotective and cognitive enhancing agent.","issued":{"date-parts":[[2006]]},"DOI":"10.1080/j157v06n02_02","container-title":"Journal of Herbal Pharmacotherapy","abstract":"L-theanine (N-ethyl-L-glutamine) or theanine is a major amino acid uniquely found in green tea. L-theanine has been historically reported as a relaxing agent, prompting scientific research on its pharmacology. Animal neurochemistry studies suggest that L-theanine increases brain serotonin, dopamine, GABA levels and has micromolar affinities for AMPA, Kainate and NMDA receptors. In addition has been shown to exert neuroprotective effects in animal models possibly through its antagonistic effects on group 1 metabotrophic glutamate receptors. Behavioural studies in animals suggest improvement in learning and memory. Overall, L-theanine displays a neuropharmacology suggestive of a possible neuroprotective and cognitive enhancing agent and warrants further investigation in animals and humans.","tags":["#literature_note"],"author":[{"family":"Nathan","given":"Pradeep J.","literal":""},{"family":"Nathan","given":"Pradeep J.","literal":""},{"family":"Lu","given":"Kristy","literal":""},{"family":"Lu","given":"Kristy","literal":""},{"family":"Gray","given":"Marcus A.","literal":""},{"family":"Gray","given":"Marcus A.","literal":""},{"family":"Oliver","given":"Chris","literal":""},{"family":"Oliver","given":"Chris","literal":""}],"citation-key":"nathan_neuropharmacology_2006","year":"2006","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["The neuropharmacology of L-theanine(N-ethyl-L-glutamine): a possible neuroprotective and cognitive enhancing agent."],"author-links":["[[Author/Pradeep J. Nathan]]","[[Author/Pradeep J. Nathan]]","[[Author/Kristy Lu]]","[[Author/Kristy Lu]]","[[Author/Marcus A. Gray]]","[[Author/Marcus A. Gray]]","[[Author/Chris Oliver]]","[[Author/Chris Oliver]]"],"attachment":["[[biblib/nathan_neuropharmacology_2006/nathan_neuropharmacology_2006.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"fcsc6j","at":17749