07036,0.01110303,0.01588809,0.1774033,-0.00266784,-0.03221846,0.02270249,-0.01598031,-0.00056724,-0.08191001,0.00815386,-0.01110072,0.04342609,0.12546474,-0.01498763,0.04620201,0.07359879,0.00127593,-0.056659,-0.02504484,-0.0371999,-0.00782603,-0.01704903,-0.11087571,-0.01547411,0.10372452,-0.11535177,-0.02408418,-0.040086,-0.0116123,-0.01949605,-0.02986124,0.02032957,-0.01554248,0.04507619,-0.01291686,-0.02549179,0.05349887,-0.04104242,-0.04845048,0.0188735,-0.03273521,0.05533313,-0.09571452,0.09008666,0.01041417],"last_embed":{"hash":"1w63419","tokens":406}}},"last_read":{"hash":"1w63419","at":1774951886080},"class_name":"SmartSource","last_import":{"mtime":1774951814668,"size":3172,"at":1774951884767,"hash":"1w63419"},"blocks":{"#---frontmatter---":[1,81],"#Bioactive metabolites from macrofungi: ethnopharmacology, biological activities and chemistry":[83,87],"#Bioactive metabolites from macrofungi: ethnopharmacology, biological activities and chemistry#{1}":[85,87]},"outlinks":[{"title":"Author/Dilani D. De Silva","target":"Author/Dilani D. De Silva","line":63},{"title":"Author/Dilani D. De Silva","target":"Author/Dilani D. De Silva","line":64},{"title":"Author/Sylvie Rapior","target":"Author/Sylvie Rapior","line":65},{"title":"Author/Sylvie Rapior","target":"Author/Sylvie Rapior","line":66},{"title":"Author/Enge Sudarman","target":"Author/Enge Sudarman","line":67},{"title":"Author/Enge Sudarman","target":"Author/Enge Sudarman","line":68},{"title":"Author/Marc Stadler","target":"Author/Marc Stadler","line":69},{"title":"Author/Marc Stadler","target":"Author/Marc Stadler","line":70},{"title":"Author/Jianchu Xu","target":"Author/Jianchu Xu","line":71},{"title":"Author/Jianchu Xu","target":"Author/Jianchu Xu","line":72},{"title":"Author/Siti Aisyah Alias","target":"Author/Siti Aisyah Alias","line":73},{"title":"Author/S. Aisyah Alias","target":"Author/S. Aisyah Alias","line":74},{"title":"Author/Kevin D. Hyde","target":"Author/Kevin D. Hyde","line":75},{"title":"Author/Kevin D. Hyde","target":"Author/Kevin D. Hyde","line":76},{"title":"PDF","target":"biblib/silva_bioactive_2013/silva_bioactive_2013.pdf","line":78}],"metadata":{"id":"silva_bioactive_2013","type":"article-journal","title":"Bioactive metabolites from macrofungi: ethnopharmacology, biological activities and chemistry","issued":{"date-parts":[[2013]]},"DOI":"10.1007/s13225-013-0265-2","container-title":"Fungal Diversity","abstract":"Exploration of natural sources for novel bioactive compounds has been an emerging field of medicine over the past decades, providing drugs or lead compounds of considerable therapeutic potential. This research has provided exciting evidence on the isolation of microbe-derived metabolites having prospective biological activities. Mushrooms have been valued as traditional sources of natural bioactive compounds for many centuries and have been targeted as promising therapeutic agents. Many novel biologically active compounds have been reported as a result of research on medicinal mushrooms. In this review, we compile the information on bioactive structure-elucidated metabolites from macrofungi discovered over the last decade and highlight their unique chemical diversity and potential benefits to novel drug discovery. The main emphasis is on their anti-Alzheimer, anti-diabetic, anti-malarial, anti-microbial, anti-oxidant, anti-tumor, anti-viral and hypocholesterolemic activities which are important medicinal targets in terms of drug discovery today. Moreover, the reader’s attention is brought to focus on mushroom products and food supplements available in the market with claimed biological activities and potential human health benefits.","tags":["#literature_note"],"author":[{"family":"Silva","given":"Dilani D. De","literal":""},{"family":"Silva","given":"Dilani D. De","literal":""},{"family":"Rapior","given":"Sylvie","literal":""},{"family":"Rapior","given":"Sylvie","literal":""},{"family":"Sudarman","given":"Enge","literal":""},{"family":"Sudarman","given":"Enge","literal":""},{"family":"Stadler","given":"Marc","literal":""},{"family":"Stadler","given":"Marc","literal":""},{"family":"Xu","given":"Jianchu","literal":""},{"family":"Xu","given":"Jianchu","literal":""},{"family":"Alias","given":"Siti Aisyah","literal":""},{"family":"Alias","given":"S. Aisyah","literal":""},{"family":"Hyde","given":"Kevin D.","literal":""},{"family":"Hyde","given":"Kevin D.","literal":""}],"citation-key":"silva_bioactive_2013","year":"2013","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Bioactive metabolites from macrofungi: ethnopharmacology, biological activities and chemistry"],"author-links":["[[Author/Dilani D. De Silva]]","[[Author/Dilani D. De Silva]]","[[Author/Sylvie Rapior]]","[[Author/Sylvie Rapior]]","[[Author/Enge Sudarman]]","[[Author/Enge Sudarman]]","[[Author/Marc Stadler]]","[[Author/Marc Stadler]]","[[Author/Jianchu Xu]]","[[Author/Jianchu Xu]]","[[Author/Siti Aisyah Alias]]","[[Author/S. Aisyah Alias]]","[[Author/Kevin D. Hyde]]","[[Author/Kevin D. Hyde]]"],"attachment":["[[biblib/silva_bioactive_2013/silva_bioactive_2013.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"1w63419","at":1774951886071}},"smart_blocks:Research/@silva_bioactive_2013.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.02680968,-0.02719282,0.05417593,-0.01886382,0.05054058,0.00709173,-0.00167124,0.03370932,-0.01855787,0.00012048,0.00455911,-0.04646083,-0.00056163,-0.02721417,0.00735605,0.00440835,0.00934539,-0.00578757,-0.06298186,0.0158897,0.04549615,-0.03198165,0.03535092,0.00401231,0.04083422,0.05704882,0.01896395,-0.02665384,-0.07127189,-0.20058723,-0.01533357,0.06343653,0.05874055,-0.04169097,-0.04149395,-0.01566338,-0.01206133,0.04654285,-0.02805546,0.02413442,0.07729045,0.03012794,0.02259518,0.01798901,-0.0277948,-0.01250807,-0.0801561,-0.00022392,0.00683097,-0.03500949,-0.02648024,-0.03930856,-0.01771096,0.01462485,0.0