.09840067,0.00310726,0.02987169,0.15197369,0.00538283,-0.02020941,0.00075848,-0.00939945,-0.04014564,-0.07355328,0.01727425,0.01655934,0.06216026,0.10742644,-0.01844069,0.04922257,0.04691168,-0.00029727,-0.00867682,-0.03539119,-0.03011189,-0.01566025,-0.05040161,-0.14272451,-0.06537423,0.09285363,-0.02990813,-0.02707127,-0.01190865,-0.01535744,-0.01591762,0.01453719,-0.01850135,0.01516782,0.01946356,-0.03787921,-0.02531703,-0.01310384,0.01018802,-0.068101,0.0103863,0.0038875,0.06724153,-0.06429832,0.09398898,0.02129799],"last_embed":{"hash":"1bbgkf2","tokens":441}}},"last_read":{"hash":"1bbgkf2","at":1774951886097},"class_name":"SmartSource","last_import":{"mtime":1774951814687,"size":3941,"at":1774951884768,"hash":"1bbgkf2"},"blocks":{"#---frontmatter---":[1,113],"#Antioxidant and Anti-Inflammatory Potential of Shiitake Culinary-Medicinal Mushroom, Lentinus edodes (Agaricomycetes), Sporophores from Various Culture Conditions.":[115,119],"#Antioxidant and Anti-Inflammatory Potential of Shiitake Culinary-Medicinal Mushroom, Lentinus edodes (Agaricomycetes), Sporophores from Various Culture Conditions.#{1}":[117,119]},"outlinks":[{"title":"Author/Ibrahima Diallo","target":"Author/Ibrahima Diallo","line":87},{"title":"Author/Ibrahima Diallo","target":"Author/Ibrahima Diallo","line":88},{"title":"Author/F. Boudard","target":"Author/F. Boudard","line":89},{"title":"Author/Frédéric Boudard","target":"Author/Frédéric Boudard","line":90},{"title":"Author/Sylvie Morel","target":"Author/Sylvie Morel","line":91},{"title":"Author/Sylvie Morel","target":"Author/Sylvie Morel","line":92},{"title":"Author/Vitou Manon","target":"Author/Vitou Manon","line":93},{"title":"Author/Manon Vitou","target":"Author/Manon Vitou","line":94},{"title":"Author/Caroline Guzman","target":"Author/Caroline Guzman","line":95},{"title":"Author/Caroline Guzman","target":"Author/Caroline Guzman","line":96},{"title":"Author/Nathalie Saint","target":"Author/Nathalie Saint","line":97},{"title":"Author/Nathalie Saint","target":"Author/Nathalie Saint","line":98},{"title":"Author/Alain Michel","target":"Author/Alain Michel","line":99},{"title":"Author/Alain Michel","target":"Author/Alain Michel","line":100},{"title":"Author/Sylvie Rapior","target":"Author/Sylvie Rapior","line":101},{"title":"Author/Sylvie Rapior","target":"Author/Sylvie Rapior","line":102},{"title":"Author/Lonsény Traoré","target":"Author/Lonsény Traoré","line":103},{"title":"Author/Lonseny Traoré","target":"Author/Lonseny Traoré","line":104},{"title":"Author/Patrick Poucheret","target":"Author/Patrick Poucheret","line":105},{"title":"Author/Patrick Poucheret","target":"Author/Patrick Poucheret","line":106},{"title":"Author/Françoise Fons","target":"Author/Françoise Fons","line":107},{"title":"Author/Françoise Fons","target":"Author/Françoise Fons","line":108},{"title":"PDF","target":"biblib/diallo_antioxidant_2020/diallo_antioxidant_2020.pdf","line":110}],"metadata":{"id":"diallo_antioxidant_2020","type":"article-journal","title":"Antioxidant and Anti-Inflammatory Potential of Shiitake Culinary-Medicinal Mushroom, Lentinus edodes (Agaricomycetes), Sporophores from Various Culture Conditions.","issued":{"date-parts":[[2020]]},"DOI":"10.1615/intjmedmushrooms.2020034864","container-title":"International Journal of Medicinal Mushrooms","abstract":"Lentinus edodes (=Lentinula edodes) is an edible mushroom grown and marketed for centuries due to its nutritional and medicinal properties. L. edodes has multiple pharmacological activities as antioxidant and anti-inflammatory. Few studies were performed taking into account the influence of culture conditions to optimize the biological properties of L. edodes on human health. Our work focused on the comparison of antioxidant capacity and anti-inflammatory activity of L. edodes fruit bodies cultivated by three mushroom producers in the French Occitanie region using the same strain in various growing conditions (orga nic and nonorganic). Sequential extraction was performed on freeze dried fungal materials. All extracts have a quantifiable but moderate antioxidant activity using the DPPH and ORAC tests. The antiinflammatory activity of the ethanol and aqueous extracts was evaluated on a model of inflammatory macrophages. The ethanol extracts inhibit NO production in a dose-dependent manner when the cells are pre-treated for 4 h with a 24 h stimulation time","tags":["#literature_note"],"author":[{"family":"Diallo","given":"Ibrahima","literal":""},{"family":"Diallo","given":"Ibrahima","literal":""},{"family":"Boudard","given":"F.","literal":""},{"family":"Boudard","given":"Frédéric","literal":""},{"family":"Morel","given":"Sylvie","literal":""},{"family":"Morel","given":"Sylvie","literal":""},{"family":"Manon","given":"Vitou","literal":""},{"family":"Vitou","given":"Manon","literal":""},{"family":"Guzman","given":"Caroline","literal":""},{"family":"Guzman","given":"Caroline","literal":""},{"family":"Saint","given":"Nathalie","literal":""},{"family":"Saint","given":"Nathalie","literal":""},{"family":"Michel","given":"Alain","literal":""},{"family":"Michel","given":"Alain","literal":""},{"family":"Rapior","given":"Sylvie","literal":""},{"family":"Rapior","given":"Sylvie","literal":""},{"family":"Traoré","given":"Lonsény","literal":""},{"family":"Traoré","given":"Lonseny","literal":""},{"family":"Poucheret","given":"Patrick","literal":""},{"family":"Poucheret","given":"Patrick","literal":""},{"family":"Fons","given":"Françoise","literal":""},{"family":"Fons","given":"Françoise","literal":""}],"citation-key":"diallo_antioxidant_2020","year":"2020","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Antioxidant and Anti-Inflammatory Potential of Shiitake Culinary-Medicinal Mushroom, Lentinus edodes (Agaricomycetes), Sporophores from Various Culture Conditions."],"author-links":["[[Author/Ibrahima Diallo]]","[[Author/Ibrahima Diallo]]","[[Author/F. Boudard]]","[[Author/Frédéric Boudard]]","[[Author/Sylvie Morel]]","[[Autho