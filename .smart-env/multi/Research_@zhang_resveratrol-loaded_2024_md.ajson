73,0.05025461,-0.12857094,0.00988895,0.0095736,0.17139399,0.0330893,-0.01956006,0.04169932,-0.06606658,0.06112126,-0.02410723,0.05671453,-0.05247145,0.04587545,0.0604497,-0.01820267,-0.01371427,0.0579529,-0.04622722,-0.00483171,0.04208371,0.02790025,0.05552173,-0.03331305,-0.03658194,-0.02414868,0.05388075,-0.08382995,-0.02695088,-0.00516148,0.02683736,0.00705918,-0.05249256,0.00600399,-0.04023095,-0.00227846,0.01502291,-0.03693133,-0.02704783,-0.04890393,-0.04668997,-0.01428202,0.00062266,0.01095429,-0.12988068,0.11593492,0.06588097],"last_embed":{"hash":"52y5h7","tokens":475}}},"last_read":{"hash":"52y5h7","at":1774951888103},"class_name":"SmartSource","last_import":{"mtime":1774951818253,"size":2927,"at":1774951884787,"hash":"52y5h7"},"blocks":{"#---frontmatter---":[1,56],"#Resveratrol-loaded sulfated Hericium erinaceus β-glucan-chitosan nanoparticles: Preparation, characterization and synergistic anti-inflammatory effects.":[58,62],"#Resveratrol-loaded sulfated Hericium erinaceus β-glucan-chitosan nanoparticles: Preparation, characterization and synergistic anti-inflammatory effects.#{1}":[60,62]},"outlinks":[{"title":"Author/Z. Zhang","target":"Author/Z. Zhang","line":45},{"title":"Author/M. Ge","target":"Author/M. Ge","line":46},{"title":"Author/D. Wu","target":"Author/D. Wu","line":47},{"title":"Author/W. Li","target":"Author/W. Li","line":48},{"title":"Author/W. Chen","target":"Author/W. Chen","line":49},{"title":"Author/P. Liu","target":"Author/P. Liu","line":50},{"title":"Author/H. Zhang","target":"Author/H. Zhang","line":51},{"title":"Author/Y. Yang","target":"Author/Y. Yang","line":52}],"metadata":{"id":"zhang_resveratrol-loaded_2024","type":"article-journal","title":"Resveratrol-loaded sulfated Hericium erinaceus β-glucan-chitosan nanoparticles: Preparation, characterization and synergistic anti-inflammatory effects.","issued":{"date-parts":[[2024]]},"DOI":"10.1016/j.carbpol.2024.121916","container-title":"Carbohydrate polymers","abstract":"Resveratrol (RES) is a natural polyphenol with excellent biological activity. But the poor stability and bioavailability of RES severely limit its application. Thus, the resveratrol-loaded sulfated Hericium erinaceus β-glucan-chitosan nanoparticles (DS-CS-RES NPs) were prepared using electrostatic self-assembly to solve these problems in this study. The structure of DS-CS-RES NPs was spherical or sub spherical shape with small average particle size (191.07 nm), which was characterized by FT-IR, FS, XRD and TEM. DS-CS-RES NPs exhibited good stability and RES had a sustainable release from the nanoparticles in gastrointestinal digestion. Meanwhile, DS-CS-RES NPs could improve the inflammatory injury of LPS stimulated RAW264.7 macrophages by inhibiting the production of NO, IL-1β, IL-6 and TNF-α. Furthermore, DS-CS-RES NPs had strong anti-inflammatory activity by regulating protein levels of NF-κB p65, STAT1 and TLR4 through NF-κB and JAK-STAT1 signaling pathway in vitro, and sulfated H. erinaceus β-glucan-chitosan nanoparticle (DS-CS NPs) and RES had synergistic anti-inflammatory effect. Overall, DS-CS NPs can serve as a potential green and safe functional carrier for encapsulating resveratrol, which can improve its anti-inflammatory activity. This work may be conducive to the development of functional carrier for encapsulating RES and applications of hydrophobic active molecules in functional foods or medicines.Copyright © 2024 Elsevier Ltd. All rights reserved.","tags":["#literature_note"],"author":[{"family":"Zhang","given":"Z.","literal":""},{"family":"Ge","given":"M.","literal":""},{"family":"Wu","given":"D.","literal":""},{"family":"Li","given":"W.","literal":""},{"family":"Chen","given":"W.","literal":""},{"family":"Liu","given":"P.","literal":""},{"family":"Zhang","given":"H.","literal":""},{"family":"Yang","given":"Y.","literal":""}],"citation-key":"zhang_resveratrol-loaded_2024","year":"2024","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Resveratrol-loaded sulfated Hericium erinaceus β-glucan-chitosan nanoparticles: Preparation, characterization and synergistic anti-inflammatory effects."],"author-links":["[[Author/Z. Zhang]]","[[Author/M. Ge]]","[[Author/D. Wu]]","[[Author/W. Li]]","[[Author/W. Chen]]","[[Author/P. Liu]]","[[Author/H. Zhang]]","[[Author/Y. Yang]]"],"attachment":[],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"52y5h7","at":1774951888089}},"smart_blocks:Research/@zhang_resveratrol-loaded_2024.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.01386406,-0.05664039,0.01978646,-0.06392857,0.01769721,0.04243889,-0.01060791,0.05707355,-0.06315261,-0.03306575,0.00095927,-0.04317738,0.0113689,0.04153607,0.00352993,-0.01504673,0.06072522,0.03041643,-0.10410149,0.04757854,0.02878532,-0.06821997,0.00254534,-0.03055937,-0.02869109,-0.023318,0.00589531,0.02094405,-0.05777144,-0.25201234,-0.01830675,-0.03899248,-0.01568407,0.02710081,-0.02191651,0.04717755,-0.02736865,0.03658461,-0.00614114,-0.0245625,0.03604042,-0.00805457,0.0125353,0.00884159,-0.02351114,-0.02683786,-0.03716468,-0.00334743,0.00749362,-0.0238635,0.04371431,-0.00737178,0.00741227,0.03220652,0.00607587,0.07046247,0.0080587,-0.02698442,0.09792446,0.08260661,0.08877552,0.02095377,-0.1875568,0.10403522,0.04542517,0.01038349,-0.08587108,0.03126622,0.08302542,0.09277003,-0.01556235,0.04610522,0.02505464,0.08518121,0.00729065,0.02338619,0.00462388,-0.06553602,-0.02141857,0.05680097,0.07334229,0.0141839,-0.00185114,-0.00703119,0.00503311,-0.01625581,-0.02177828,-0.1052567,0.03810051,0.00558507,-0.03492383,-0.02399059,0.02809068,0.01429091,-0.11933814,-0.0227515,0.04845274,0.00545361,-0.00151707,0.09922881,-0.01847863,-0.00292915,-0.02067934,-0.0784079,0.00613262,-0.0258457,0.01247631,-0.01811644,-0.03237983,0.01612876,0.1059258,-0.04746293,0.0101652,-0.07163591,-0.00277002,0.02343282,0.06891808,-0.00691421,-0.0388677,-0.0282984,-0.0171543,0.05215521,0.05085525,-0.06493309,0.0