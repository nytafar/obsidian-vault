784,-0.03210087,0.01645775,0.19674976,0.01479162,-0.09139844,0.08862277,0.02003564,0.02340049,0.00376922,0.04185364,-0.04819615,0.03767246,0.08865328,-0.04485115,0.0570884,0.054773,-0.00693972,0.03105586,0.03557936,-0.00049185,0.00145085,-0.03179612,-0.07635078,-0.00084341,0.14962611,-0.03016852,-0.08865806,-0.0429946,0.01293998,0.02194888,-0.01105146,0.03145731,0.01237241,0.01128636,-0.02937367,-0.01730075,-0.02258172,-0.0257502,-0.05683074,-0.00417524,0.03971839,-0.00914785,-0.03810305,0.14564431,0.04395796],"last_embed":{"hash":"gyd8ct","tokens":488}}},"last_read":{"hash":"gyd8ct","at":1774951892173},"class_name":"SmartSource","last_import":{"mtime":1774951823835,"size":2853,"at":1774951884812,"hash":"gyd8ct"},"blocks":{"#---frontmatter---":[1,65],"#Divergent Synthesis of Bioactive Resorcinols Isolated from the Fruiting Bodies of Hericium erinaceum: Total Syntheses of Hericenones A, B, and I, Hericenols B–D, and Erinacerins A and B":[67,71],"#Divergent Synthesis of Bioactive Resorcinols Isolated from the Fruiting Bodies of Hericium erinaceum: Total Syntheses of Hericenones A, B, and I, Hericenols B–D, and Erinacerins A and B#{1}":[69,71]},"outlinks":[{"title":"Author/Shōji Kobayashi","target":"Author/Shōji Kobayashi","line":51},{"title":"Author/Shoji Kobayashi","target":"Author/Shoji Kobayashi","line":52},{"title":"Author/Hidetsugu Tamanoi","target":"Author/Hidetsugu Tamanoi","line":53},{"title":"Author/Hidetsugu Tamanoi","target":"Author/Hidetsugu Tamanoi","line":54},{"title":"Author/Yuichi Hasegawa","target":"Author/Yuichi Hasegawa","line":55},{"title":"Author/Yuichi Hasegawa","target":"Author/Yuichi Hasegawa","line":56},{"title":"Author/Yusuke Segawa","target":"Author/Yusuke Segawa","line":57},{"title":"Author/Yusuke Segawa","target":"Author/Yusuke Segawa","line":58},{"title":"Author/Araki Masuyama","target":"Author/Araki Masuyama","line":59},{"title":"Author/Araki Masuyama","target":"Author/Araki Masuyama","line":60},{"title":"PDF","target":"biblib/kobayashi_divergent_2014/kobayashi_divergent_2014.pdf","line":62}],"metadata":{"id":"kobayashi_divergent_2014","type":"article-journal","title":"Divergent Synthesis of Bioactive Resorcinols Isolated from the Fruiting Bodies of Hericium erinaceum: Total Syntheses of Hericenones A, B, and I, Hericenols B–D, and Erinacerins A and B","issued":{"date-parts":[[2014]]},"DOI":"10.1021/jo500795z","container-title":"Journal of Organic Chemistry","abstract":"Total syntheses of 5′- and 7′-oxidized geranyl resorcylates isolated from the fruiting bodies of Hericium erinaceum and the submerged cultures of a Stereum species were achieved. Our synthesis features derivatization of a suitably functionalized 5′-oxidized geranyl phthalide as a common intermediate, which was obtained by Stille coupling between the phthalide core and the side chain, into a series of natural products by divergent functional group manipulations. The crucial C5′-oxygen functionality was installed at the initial stage by alkylation by an α-cyano ethoxyethyl ether. From a common synthetic intermediate, eight total syntheses including hericenones A, B, and I, hericenols B–D, and erinacerins A and B were achieved (hericenol B and erinacerin B were synthesized as racemates). The structure of hericenone B established in the isolation paper was unambiguously revised as the carbonyl regioisomer at the lactam moiety.","tags":["#literature_note"],"author":[{"family":"Kobayashi","given":"Shōji","literal":""},{"family":"Kobayashi","given":"Shoji","literal":""},{"family":"Tamanoi","given":"Hidetsugu","literal":""},{"family":"Tamanoi","given":"Hidetsugu","literal":""},{"family":"Hasegawa","given":"Yuichi","literal":""},{"family":"Hasegawa","given":"Yuichi","literal":""},{"family":"Segawa","given":"Yusuke","literal":""},{"family":"Segawa","given":"Yusuke","literal":""},{"family":"Masuyama","given":"Araki","literal":""},{"family":"Masuyama","given":"Araki","literal":""}],"citation-key":"kobayashi_divergent_2014","year":"2014","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Divergent Synthesis of Bioactive Resorcinols Isolated from the Fruiting Bodies of Hericium erinaceum: Total Syntheses of Hericenones A, B, and I, Hericenols B–D, and Erinacerins A and B"],"author-links":["[[Author/Shōji Kobayashi]]","[[Author/Shoji Kobayashi]]","[[Author/Hidetsugu Tamanoi]]","[[Author/Hidetsugu Tamanoi]]","[[Author/Yuichi Hasegawa]]","[[Author/Yuichi Hasegawa]]","[[Author/Yusuke Segawa]]","[[Author/Yusuke Segawa]]","[[Author/Araki Masuyama]]","[[Author/Araki Masuyama]]"],"attachment":["[[biblib/kobayashi_divergent_2014/kobayashi_divergent_2014.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"gyd8ct","at":1774951892154}},"smart_blocks:Research/@kobayashi_divergent_2014.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.07328454,-0.02826693,-0.01101203,-0.04334282,0.00765294,-0.02305035,-0.03067304,0.02107265,-0.05660825,0.01136016,0.02179979,-0.0830211,0.07231414,-0.00950895,0.01355784,0.00950289,-0.01514472,0.04869131,-0.0460619,-0.01024025,0.00155037,-0.08884124,0.0202771,-0.02024967,0.07067002,0.03798312,0.02221696,-0.00802538,-0.05960841,-0.23274972,-0.03283741,0.02977962,0.01470569,-0.03069768,0.00487257,0.02607894,-0.04058759,-0.00342355,-0.00609673,0.03669488,-0.01644671,-0.01194511,0.03421641,-0.0081771,0.01276581,-0.01943716,-0.04849103,0.02691222,-0.00065789,-0.06380338,-0.02000079,-0.00749635,-0.03024627,0.01097127,0.05730874,0.03081706,0.07120318,0.04285233,0.03055559,-0.04240508,0.04262411,0.10242444,-0.17786832,0.05999586,0.0111438,-0.01041984,-0.05365476,-0.11662623,0.07616942,0.0295218,-0.04127484,0.02890148,-0.01197079,0.04184229,0.03482748,-0.01953494,0.02875595,-0.04935645,0.02143905,-0.01776665,0.01148719,0.03106473,0.00959913,0.00578575,0.00926424,0.01349209,-0.00797656,-0.04827793,0.01129849,0.03755469,-0.03920494,-0.09217672,0.02893458,0.01131453,-0.07408851,0.04926653,0.00600848,-0.0338