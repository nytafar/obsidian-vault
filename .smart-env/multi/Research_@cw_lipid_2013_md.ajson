11159,0.02814055,-0.06655464,-0.00134433,-0.02170048,0.02152157,-0.01285223,0.0258037,0.01192448,0.02236954,0.09689946,-0.00674806,0.02605567,0.12433692,0.00619581,-0.04599949,-0.0372612,0.00556468,-0.01578951,-0.05637323,-0.05850545,-0.03242955,0.10007581,-0.0821674,-0.01130403,-0.03566298,-0.0043937,0.01383601,0.00651139,-0.06726994,-0.02881411,0.01771672,-0.00871367,-0.02958722,0.00680966,-0.02523774,-0.06482199,0.02548968,-0.02067212,-0.01089475,-0.02621302,0.10540506,0.05724861],"last_embed":{"hash":"su5v92","tokens":479}}},"last_read":{"hash":"su5v92","at":1774951888981},"class_name":"SmartSource","last_import":{"mtime":1774951819708,"size":2440,"at":1774951884795,"hash":"su5v92"},"blocks":{"#---frontmatter---":[1,73],"#Lipid Constituents of the Edible Mushroom, Pleurotus giganteus Demonstrate Anti-Candida Activity":[75,79],"#Lipid Constituents of the Edible Mushroom, Pleurotus giganteus Demonstrate Anti-Candida Activity#{1}":[77,79]},"outlinks":[{"title":"Author/Phan Cw","target":"Author/Phan Cw","line":57},{"title":"Author/Chia-Wei Phan","target":"Author/Chia-Wei Phan","line":58},{"title":"Author/Lee Gs","target":"Author/Lee Gs","line":59},{"title":"Author/Lee Gs","target":"Author/Lee Gs","line":60},{"title":"Author/Ian Macreadie","target":"Author/Ian Macreadie","line":61},{"title":"Author/Ian G. Macreadie","target":"Author/Ian G. Macreadie","line":62},{"title":"Author/Malek Sn","target":"Author/Malek Sn","line":63},{"title":"Author/Sri Nurestri Abd Malek","target":"Author/Sri Nurestri Abd Malek","line":64},{"title":"Author/Diana Pamela","target":"Author/Diana Pamela","line":65},{"title":"Author/Pamela D","target":"Author/Pamela D","line":66},{"title":"Author/Sabaratnam","target":"Author/Sabaratnam","line":67},{"title":"Author/Sabaratnam","target":"Author/Sabaratnam","line":68},{"title":"PDF","target":"biblib/cw_lipid_2013/cw_lipid_2013.pdf","line":70}],"metadata":{"id":"cw_lipid_2013","type":"article-journal","title":"Lipid Constituents of the Edible Mushroom, Pleurotus giganteus Demonstrate Anti-Candida Activity","issued":{"date-parts":[[2013]]},"DOI":"10.1177/1934578x1300801228","container-title":"Natural Product Communications","abstract":"Different solvent extracts of Pleurotus giganteus fruiting bodies were tested for antifungal activities against Candida species responsible for human infections. The lipids extracted from the ethyl acetate fraction significantly inhibited the growth of all the Candida species tested. Analysis by GC/MS revealed lipid components such as fatty acids, fatty acid methyl esters, ergosterol, and ergosterol derivatives. The sample with high amounts of fatty acid methyl esters was the most effective antifungal agent. The samples were not cytotoxic to a mammalian cell line, mouse embryonic fibroblasts BALB/c 3T3 clone A31. To our knowledge, this is the first report of antifungal activity of the lipid components of Pleurotus giganteus against Candida species.","tags":["#literature_note"],"author":[{"family":"Cw","given":"Phan","literal":""},{"family":"Phan","given":"Chia-Wei","literal":""},{"family":"Gs","given":"Lee","literal":""},{"family":"Gs","given":"Lee","literal":""},{"family":"Macreadie","given":"Ian","literal":""},{"family":"Macreadie","given":"Ian G.","literal":""},{"family":"Sn","given":"Malek","literal":""},{"family":"Malek","given":"Sri Nurestri Abd","literal":""},{"family":"Pamela","given":"Diana","literal":""},{"family":"D","given":"Pamela","literal":""},{"family":"Sabaratnam","given":"","literal":""},{"family":"Sabaratnam","given":"","literal":""}],"citation-key":"cw_lipid_2013","year":"2013","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Lipid Constituents of the Edible Mushroom, Pleurotus giganteus Demonstrate Anti-Candida Activity"],"author-links":["[[Author/Phan Cw]]","[[Author/Chia-Wei Phan]]","[[Author/Lee Gs]]","[[Author/Lee Gs]]","[[Author/Ian Macreadie]]","[[Author/Ian G. Macreadie]]","[[Author/Malek Sn]]","[[Author/Sri Nurestri Abd Malek]]","[[Au