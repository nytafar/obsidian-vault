,-0.00210595,0.01941009,0.16484791,-0.00327227,-0.03789345,0.00925797,0.00993755,0.01666931,0.02424234,0.04249417,0.03717452,0.06602112,0.12633826,-0.01953812,0.0818745,0.04410452,-0.0808889,0.00205138,0.01917843,-0.02471196,-0.00695664,-0.05007861,-0.06742805,-0.0257345,0.07857768,-0.07522796,-0.03815934,0.04636648,-0.0050445,0.01925241,0.01221135,0.02767011,0.02140994,0.06834519,-0.00531386,-0.00834765,-0.00253675,0.0263341,-0.06255367,-0.03076548,0.00595141,0.04418805,-0.07741643,0.10825439,0.05006077],"last_embed":{"hash":"17bawmu","tokens":496}}},"last_read":{"hash":"17bawmu","at":1774951888445},"class_name":"SmartSource","last_import":{"mtime":1774951818818,"size":4869,"at":1774951884789,"hash":"17bawmu"},"blocks":{"#---frontmatter---":[1,144],"#Ameliorating Effect of the Edible Mushroom &lt;i&gt;Hericium erinaceus&lt;/i&gt; on Depressive-Like Behavior in Ovariectomized Rats":[146,150],"#Ameliorating Effect of the Edible Mushroom &lt;i&gt;Hericium erinaceus&lt;/i&gt; on Depressive-Like Behavior in Ovariectomized Rats#{1}":[148,150]},"outlinks":[{"title":"Author/Azliza Mad Anuar","target":"Author/Azliza Mad Anuar","line":111},{"title":"Author/Azliza Mad Anuar","target":"Author/Azliza Mad Anuar","line":112},{"title":"Author/Akira Minami","target":"Author/Akira Minami","line":113},{"title":"Author/Akira Minami","target":"Author/Akira Minami","line":114},{"title":"Author/Hiroshi Matsushita","target":"Author/Hiroshi Matsushita","line":115},{"title":"Author/Hiroshi Matsushita","target":"Author/Hiroshi Matsushita","line":116},{"title":"Author/Kanako Ogino","target":"Author/Kanako Ogino","line":117},{"title":"Author/Kanako Ogino","target":"Author/Kanako Ogino","line":118},{"title":"Author/Kosei Fujita","target":"Author/Kosei Fujita","line":119},{"title":"Author/Kosei Fujita","target":"Author/Kosei Fujita","line":120},{"title":"Author/Hatsune Nakao","target":"Author/Hatsune Nakao","line":121},{"title":"Author/Hatsune Nakao","target":"Author/Hatsune Nakao","line":122},{"title":"Author/Shota Kimura","target":"Author/Shota Kimura","line":123},{"title":"Author/Shota Kimura","target":"Author/Shota Kimura","line":124},{"title":"Author/Vikineswary Sabaratnam","target":"Author/Vikineswary Sabaratnam","line":125},{"title":"Author/Vikineswary Sabaratnam","target":"Author/Vikineswary Sabaratnam","line":126},{"title":"Author/Kaoru Umehara","target":"Author/Kaoru Umehara","line":127},{"title":"Author/Kaoru Umehara","target":"Author/Kaoru Umehara","line":128},{"title":"Author/Yuuki Kurebayashi","target":"Author/Yuuki Kurebayashi","line":129},{"title":"Author/Yuuki Kurebayashi","target":"Author/Yuuki Kurebayashi","line":130},{"title":"Author/Tadanobu Takahashi","target":"Author/Tadanobu Takahashi","line":131},{"title":"Author/Toshifumi Takahashi","target":"Author/Toshifumi Takahashi","line":132},{"title":"Author/Hiroaki Kanazawa","target":"Author/Hiroaki Kanazawa","line":133},{"title":"Author/Hiroaki Kanazawa","target":"Author/Hiroaki Kanazawa","line":134},{"title":"Author/Akihiko Wakatsuki","target":"Author/Akihiko Wakatsuki","line":135},{"title":"Author/Akihiko Wakatsuki","target":"Author/Akihiko Wakatsuki","line":136},{"title":"Author/Takashi Suzuki","target":"Author/Takashi Suzuki","line":137},{"title":"Author/Takashi Suzuki","target":"Author/Takashi Suzuki","line":138},{"title":"Author/Hideyuki Takeuchi","target":"Author/Hideyuki Takeuchi","line":139},{"title":"Author/Hideyuki Takeuchi","target":"Author/Hideyuki Takeuchi","line":140}],"metadata":{"id":"anuar_ameliorating_2022","type":"article-journal","title":"Ameliorating Effect of the Edible Mushroom &lt;i&gt;Hericium erinaceus&lt;/i&gt; on Depressive-Like Behavior in Ovariectomized Rats","issued":{"date-parts":[[2022]]},"DOI":"10.1248/bpb.b22-00151","container-title":"Biological & Pharmaceutical Bulletin","abstract":"Estrogen deficiency during menopause causes a variety of neurological symptoms, including depression. The edible Lion's Mane mushroom, Hericium erinaceus (Bull.: Fr.) Pers. (HE), is a medicinal mushroom that has the potential for a neuroprotective effect and ameliorating neurological diseases, such as depression, anxiety, and neurodegenerative diseases. HE contains phytoestrogens, including daidzein and genistein. However, the ameliorating effect of HE on menopausal symptoms is not well understood. Here we investigated the impact of methanol extract of the HE fruiting body on depressive-like behavior in postmenopausal model rats. The activation of estrogen receptor alpha (ERα) causes body weight loss and uterine weight gain. Body weight gain and uterine weight loss by estrogen deficiency in ovariectomized (OVX) rats were reversed with 17β-estradiol (E2) but not with HE. Thus, the phytoestrogens in HE may hardly activate ERα. Estrogen receptor beta (ERβ) is expressed in the brain, and activation of ERβ ameliorates menopausal depressive symptoms. Notably, depressive-like behavior in OVX rats evaluated in forced swim test was reduced by administration of not only E2 but also HE for 92 d. Long-term activation of ERα increases the risk of breast and uterine cancers. HE, therefore, may be effective in treating menopausal depression without the risk of carcinogenesis caused by ERα activation.","tags":["#literature_note"],"author":[{"family":"Anuar","given":"Azliza Mad","literal":""},{"family":"Anuar","given":"Azliza Mad","literal":""},{"family":"Minami","given":"Akira","literal":""},{"family":"Minami","given":"Akira","literal":""},{"family":"Matsushita","given":"Hiroshi","literal":""},{"family":"Matsushita","given":"Hiroshi","literal":""},{"family":"Ogino","given":"Kanako","literal":""},{"family":"Ogino","given":"Kanako","literal":""},{"family":"Fujita","given":"Kosei","literal":""},{"family":"Fujita","given":"Kosei","literal":""},{"family":"Nakao","given":"Hatsune","literal":""},{"family":"Nakao","given":"Hatsune","literal":""},{"family":"Kimura","given":"Shota","literal":""},{"family":"Kimura","given":"Shota","literal":""},{"family":"Sabaratnam","given":"Vikineswary","literal":""},{"family":"Sabaratnam","given":"Vikineswary","literal":""},{"family":"Umehara","given":"Kaoru","literal":""},{"family":"Umehara","given":"Kaoru","literal":""},{"family":"Kurebayashi","given":"Yuuki","literal":""},{"family":"Kurebayashi","given":"Yuuki","literal":""},{"family":"Takahashi","given":"Tadanobu","literal":""},{"family":"Takahashi","given":"Toshifumi","literal":""},{"family":"Kanazawa","given":"Hiroaki","literal":""},{"family":"Kanazawa","given":"Hiroaki","literal":""},{"family":"Wakatsuki","given":"Akihiko","literal":""},{"family":"Wakatsuki","given":"Akihiko","literal":""},{"family":"Suzuki","given":"Takashi","literal":""},{"family":"Suzuki","given":"Takashi","literal":""},{"family":"Takeuchi","given":"Hideyuki","literal":""},{"family":"Takeuchi","given":"Hideyuki","literal":""}],"citation-key":"anuar_ameliorating_2022","year":"2022","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Ameliorating Effect of the Edible Mushroom &lt;i&gt;Hericium erinaceus&lt;/i&gt; on Depressive-Like Behavior in Ovariectomized Rats"],"author-links":["[[Author/Azliza Mad Anuar]]","[[Author/Azliza Mad Anuar]]","[[Author/Akira Minami]]","[[Author/Akira Minami]]","[[Author/Hiroshi Matsushita]]","[[Author/Hiroshi Matsushita]]","[[Author/Kanako Ogino]]","[[Author/Kanako Ogino]]","[[Author/Kosei Fujita]]","[[Author/Kosei Fujita]]","[[Author/Hatsune Nakao]]","[[Author/Hatsune Nakao]]","[[Author/Shota Kimura]]","[[Author/Shota Kimura]]","[[Author/Vikineswary Sabaratnam]]","[[Author/Vikineswary Sabaratnam]]","[[Author/Kaoru Umehara]]","[[Author/Kaoru Umehara]]","[[Author/Yuuki Kurebayashi]]","[[Author/Yuuki Kurebayashi]]","[[Author/Tadanobu Takahashi]]","[[Author/Toshifumi Takahashi]]","[[Author/Hiroaki Kanazawa]]","[[Author/Hiroaki Kanazawa]]","[[Author/Akihiko Wakatsuki]]","[[Author/Akihiko Wakatsuki]]","[[Author/Takashi Suzuki]]","[[Author/Takashi Suzuki]]","[[Author/Hideyuki Takeuchi]]","[[Author/Hideyuki Takeuchi]]"],"at