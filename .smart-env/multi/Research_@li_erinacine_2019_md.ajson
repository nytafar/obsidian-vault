
"smart_sources:Research/@li_erinacine_2019.md": {"path":"Research/@li_erinacine_2019.md","last_embed":{"hash":null},"embeddings":{},"last_read":{"hash":"aou3xf","at":1774951884831},"class_name":"SmartSource","last_import":{"mtime":1774951829225,"size":3927,"at":1774951884831,"hash":"aou3xf"},"blocks":{"#---frontmatter---":[1,113],"#Erinacine A-enriched Hericium erinaceus mycelia promotes longevity in Drosophila melanogaster and aged mice.":[115,119],"#Erinacine A-enriched Hericium erinaceus mycelia promotes longevity in Drosophila melanogaster and aged mice.#{1}":[117,119]},"outlinks":[{"title":"Author/I.-Chen Li","target":"Author/I.-Chen Li","line":87},{"title":"Author/I.-Chen Li","target":"Author/I.-Chen Li","line":88},{"title":"Author/Li-Ya Lee","target":"Author/Li-Ya Lee","line":89},{"title":"Author/Lee Li-Ya","target":"Author/Lee Li-Ya","line":90},{"title":"Author/Li-Ya Lee","target":"Author/Li-Ya Lee","line":91},{"title":"Author/Ying-Ju Chen","target":"Author/Ying-Ju Chen","line":92},{"title":"Author/Ying-Ju Chen","target":"Author/Ying-Ju Chen","line":93},{"title":"Author/Ying-Ju Chen","target":"Author/Ying-Ju Chen","line":94},{"title":"Author/Ying-Ju Chen","target":"Author/Ying-Ju Chen","line":95},{"title":"Author/Ying-Ju Chen","target":"Author/Ying-Ju Chen","line":96},{"title":"Author/Ming-Yu Chou","target":"Author/Ming-Yu Chou","line":97},{"title":"Author/Ming-Yu Chou","target":"Author/Ming-Yu Chou","line":98},{"title":"Author/Mingfu Wang","target":"Author/Mingfu Wang","line":99},{"title":"Author/Ming-Fu Wang","target":"Author/Ming-Fu Wang","line":100},{"title":"Author/Wanping Chen","target":"Author/Wanping Chen","line":101},{"title":"Author/Wan-Ping Chen","target":"Author/Wan-Ping Chen","line":102},{"title":"Author/Wan-Ping Chen","target":"Author/Wan-Ping Chen","line":103},{"title":"Author/Yen-Po Chen","target":"Author/Yen-Po Chen","line":104},{"title":"Author/Yen-Po Chen","target":"Author/Yen-Po Chen","line":105},{"title":"Author/Chen Chin-Chu","target":"Author/Chen Chin-Chu","line":106},{"title":"Author/Chin-Chu Chen","target":"Author/Chin-Chu Chen","line":107},{"title":"Author/Chin-Chu Chen","target":"Author/Chin-Chu Chen","line":108},{"title":"PDF","target":"biblib/li_erinacine_2019/li_erinacine_2019.pdf","line":110}],"metadata":{"id":"li_erinacine_2019","type":"article-journal","title":"Erinacine A-enriched Hericium erinaceus mycelia promotes longevity in Drosophila melanogaster and aged mice.","issued":{"date-parts":[[2019]]},"DOI":"10.1371/journal.pone.0217226","container-title":"PLOS ONE","abstract":"Erinacine A-enriched Hericium erinaceus mycelia is a well-established potential therapeutic agent for neurodegenerative disorders. However, the effect of erinacine A-enriched H. erinaceus mycelia on promoting longevity remains unclear. This is the first study to investigate the effect of erinacine A-enriched H. erinaceus mycelia on lifespan-prolonging activity in Drosophila melanogaster and senescence-accelerated P8 (SAMP8) mice. Two hundred D. melanogaster and 80 SAMP8 mice of both sexes were randomly divided into four groups and were administered with either the standard, low-dose, mid-dose, or high-dose erinacine A-enriched H. erinaceus mycelia. After treatment, the lifespan was measured in D. melanogaster, and the lifespan, food intake and oxidative damage were evaluated in SAMP8 mice. Results showed that supplementation with erinacine A-enriched H. erinaceus mycelia extended the lifespan in both D. melanogaster and SAMP8 by a maximum of 32% and 23%, respectively, compared to the untreated controls. Moreover, erinacine A-enriched H. erinaceus mycelia decreased TBARS levels and induced the anti-oxidative enzyme activities of superoxide dismutase, catalase, and glutathione peroxidase. Together, these findings suggest that erinacine A-enriched H. erinaceus mycelia supplement could promote longevity, mediated partly through the induction of endogenous antioxidants enzymes.","tags":["#literature_note"],"author":[{"family":"Li","given":"I.-Chen","literal":""},{"family":"Li","given":"I.-Chen","literal":""},{"family":"Lee","given":"Li-Ya","literal":""},{"family":"Li-Ya","given":"Lee","literal":""},{"family":"Lee","given":"Li-Ya","literal":""},{"family":"Chen","given":"Ying-Ju","literal":""},{"family":"Chen","given":"Ying-Ju","literal":""},{"family":"Chen","given":"Ying-Ju","literal":""},{"family":"Chen","given":"Ying-Ju","literal":""},{"family":"Chen","given":"Ying-Ju","literal":""},{"family":"Chou","given":"Ming-Yu","literal":""},{"family":"Chou","given":"Ming-Yu","literal":""},{"family":"Wang","given":"Mingfu","literal":""},{"family":"Wang","given":"Ming-Fu","literal":""},{"family":"Chen","given":"Wanping","literal":""},{"family":"Chen","given":"Wan-Ping","literal":""},{"family":"Chen","given":"Wan-Ping","literal":""},{"family":"Chen","given":"Yen-Po","literal":""},{"family":"Chen","given":"Yen-Po","literal":""},{"family":"Chin-Chu","given":"Chen","literal":""},{"family":"Chen","given":"Chin-Chu","literal":""},{"family":"Chen","given":"Chin-Chu","literal":""}],"citation-key":"li_erinacine_2019","year":"2019","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Erinacine A-enriched Hericium erinaceus mycelia promotes longevity in Drosophila melanogaster and aged mice."],"author-links":["[[Author/I.-Chen Li]]","[[Author/I.-Chen Li]]","[[Author/Li-Ya Lee]]","[[Author/Lee Li-Ya]]","[[Author/Li-Ya Lee]]","[[Author/Ying-Ju Chen]]","[[Author/Ying-Ju Chen]]","[[Author/Ying-Ju Chen]]","[[Author/Ying-Ju Chen]]","[[Author/Ying-Ju Chen]]","[[Author/Ming-Yu Chou]]","[[Author/Ming-Yu Chou]]","[[Author/Mingfu Wang]]","[[Author/Ming-Fu Wang]]","[[Author/Wanping Chen]]","[[Author/Wan-Ping Chen]]","[[Author/Wan-Ping Chen]]","[[Author/Yen-Po Chen]]","[[Author/Yen-Po Chen]]","[[Author/Chen Chin-Chu]]","[[Author/Chin-Chu Chen]]","[[Author/Chin-Chu Chen]]"],"attachment":["[[biblib/li_erinacine_2019/li_erinacine_2019.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[]},
