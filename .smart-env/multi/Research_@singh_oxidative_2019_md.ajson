157,0.02491344,0.15068458,-0.02647862,0.06633841,0.0352134,-0.02005725,0.03806857,-0.02562541,0.00927798,0.00871007,0.03111396,0.09712332,-0.0265198,0.0093396,0.07236093,-0.07461029,0.00246814,-0.01078806,-0.04785856,0.01932277,-0.01278049,-0.06530061,-0.03351025,0.10300543,-0.05518334,-0.08627021,-0.05690035,0.00064231,0.01369655,-0.04651945,-0.00927572,0.01527114,0.05032443,0.00450346,-0.03103888,-0.02190273,-0.01200039,0.04431883,-0.01968955,-0.00876562,0.00242841,-0.03542361,0.17092961,-0.03616224],"last_embed":{"hash":"1m1vcje","tokens":435}}},"last_read":{"hash":"1m1vcje","at":1774951888608},"class_name":"SmartSource","last_import":{"mtime":1774951819106,"size":3365,"at":1774951884791,"hash":"1m1vcje"},"blocks":{"#---frontmatter---":[1,53],"#Oxidative Stress: A Key Modulator in Neurodegenerative Diseases.":[55,59],"#Oxidative Stress: A Key Modulator in Neurodegenerative Diseases.#{1}":[57,59]},"outlinks":[{"title":"Author/Anju Singh","target":"Author/Anju Singh","line":42},{"title":"Author/Anju Singh","target":"Author/Anju Singh","line":43},{"title":"Author/Ritushree Kukreti","target":"Author/Ritushree Kukreti","line":44},{"title":"Author/Ritushree Kukreti","target":"Author/Ritushree Kukreti","line":45},{"title":"Author/Luciano Saso","target":"Author/Luciano Saso","line":46},{"title":"Author/Luciano Saso","target":"Author/Luciano Saso","line":47},{"title":"Author/Shrikant Kukreti","target":"Author/Shrikant Kukreti","line":48},{"title":"PDF","target":"biblib/singh_oxidative_2019/singh_oxidative_2019.pdf","line":50}],"metadata":{"id":"singh_oxidative_2019","type":"article-journal","title":"Oxidative Stress: A Key Modulator in Neurodegenerative Diseases.","issued":{"date-parts":[[2019]]},"DOI":"10.3390/molecules24081583","container-title":"Molecules","abstract":"Oxidative stress is proposed as a regulatory element in ageing and various neurological disorders. The excess of oxidants causes a reduction of antioxidants, which in turn produce an oxidation–reduction imbalance in organisms. Paucity of the antioxidant system generates oxidative-stress, characterized by elevated levels of reactive species (oxygen, hydroxyl free radical, and so on). Mitochondria play a key role in ATP supply to cells via oxidative phosphorylation, as well as synthesis of essential biological molecules. Various redox reactions catalyzed by enzymes take place in the oxidative phosphorylation process. An inefficient oxidative phosphorylation may generate reactive oxygen species (ROS), leading to mitochondrial dysfunction. Mitochondrial redox metabolism, phospholipid metabolism, and proteolytic pathways are found to be the major and potential source of free radicals. A lower concentration of ROS is essential for normal cellular signaling, whereas the higher concentration and long-time exposure of ROS cause damage to cellular macromolecules such as DNA, lipids and proteins, ultimately resulting in necrosis and apoptotic cell death. Normal and proper functioning of the central nervous system (CNS) is entirely dependent on the chemical integrity of brain. It is well established that the brain consumes a large amount of oxygen and is highly rich in lipid content, becoming prone to oxidative stress. A high consumption of oxygen leads to excessive production of ROS. Apart from this, the neuronal membranes are found to be rich in polyunsaturated fatty acids, which are highly susceptible to ROS. Various neurodegenerative diseases such as Parkinson’s disease (PD), Alzheimer’s disease (AD), Huntington’s disease (HD), and amyotrophic lateral sclerosis (ALS), among others, can be the result of biochemical alteration (due to oxidative stress) in bimolecular components. There is a need to understand the processes and role of oxidative stress in neurodegenerative diseases. This review is an effort towards improving our understanding of the pivotal role played by OS in neurodegenerative disorders.","tags":["#literature_note"],"author":[{"family":"Singh","given":"Anju","literal":""},{"family":"Singh","given":"Anju","literal":""},{"family":"Kukreti","given":"Ritushree","literal":""},{"family":"Kukreti","given":"Ritushree","literal":""},{"family":"Saso","given":"Luciano","literal":""},{"family":"Saso","given":"Luciano","literal":""},{"family":"Kukreti","given":"Shrikant","literal":""}],"citation-key":"singh_oxidative_2019","year":"2019","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Oxidative Stress: A Key Modulator in Neurodegenerative Diseases."],"author-links":["[[Author/Anju Singh]]","[[Author/Anju Singh]]","[[Author/Ritushree Kukreti]]","[[Author/Ritushree Kukreti]]","[[Author/Luciano Saso]]","[[Author/Luciano Saso]]","[[Author/Shrikant Kukreti]]"],"attachment":["[[biblib/singh_oxidative_2019/singh_oxidative_2019.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"1m1vcje","at":1774951888599}},"smart_blocks:Research/@singh_oxidative_2019.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.04773198,0.02098182,-0.00814178,0.00613898,0.01222936,0.00848486,0.03715753,0.03759278,0.00520244,-0.02044179,-0.02795845,-0.04643182,0.04295685,0.06727475,0.01071947,-0.03097718,-0.01292051,0.05826477,-0.1025906,0.01828154,0.06490162,-0.01570804,0.0039,-0.05136815,0.00910861,0.04213651,-0.02125499,-0.01385412,-0.05731819,-0.1773005,-0.0082386,0.00747813,0.05220028,-0.02431356,-0.02675773,0.00994236,-0.03765346,0.01293847,-0.02840628,0.02513476,0.07155241,0.01761311,0.02990994,0.03286228,-0.02821685,-0.02843038,-0.03940593,-0.02379331,0.03672455,-0.05754342,0.0465461,0.0273323,0.02823301,-0.02654853,0.07233644,-0.01037227,0.02479688,0.11039449,0.03032892,0.01206605,0.00517128,0.03972418,-0.19279295,0.03752705,0.10393921,-0.0588356,-0.00561414,0.01808274,0.06733891,-0.01279635,-0.12880862,0.00621991,0.00436646,-0.02980537,0.02170594,0.01305403,-0.03505826,-0.07702882,0.02820925,-0.00608359,0.06184988,0.04479313,-0.023351,-0.01233886,0.0035056,-0.0