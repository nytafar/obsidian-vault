,0.04409088,-0.04301869,0.17456646,0.00821646,-0.0597055,0.02003592,-0.03771568,0.01982701,-0.01233514,0.01984682,-0.0257149,0.01658485,0.11066784,-0.06715013,0.08398306,0.0292147,-0.06392449,-0.04130398,-0.03193983,0.00933311,-0.00099573,-0.02708088,-0.09429991,-0.04311298,0.084944,-0.0590149,-0.05176306,-0.05057544,-0.02765857,-0.04082165,-0.0074528,-0.02918434,-0.060185,0.02912644,0.00081512,-0.00085074,-0.01065804,0.04060913,-0.05360565,-0.01752673,-0.03447307,0.02307258,-0.03555596,0.10962113,0.02694601],"last_embed":{"hash":"1c4y0r7","tokens":446}}},"last_read":{"hash":"1c4y0r7","at":1774951888353},"class_name":"SmartSource","last_import":{"mtime":1774951818672,"size":3518,"at":1774951884788,"hash":"1c4y0r7"},"blocks":{"#---frontmatter---":[1,73],"#Identification of Common Liver Metabolites of the Natural Bioactive Compound Erinacine A, Purified from Hericium erinaceus Mycelium":[75,79],"#Identification of Common Liver Metabolites of the Natural Bioactive Compound Erinacine A, Purified from Hericium erinaceus Mycelium#{1}":[77,79]},"outlinks":[{"title":"Author/Yu-Hsuan Kuo","target":"Author/Yu-Hsuan Kuo","line":57},{"title":"Author/Yu-Hsuan Kuo","target":"Author/Yu-Hsuan Kuo","line":58},{"title":"Author/Ting-Wei Lin","target":"Author/Ting-Wei Lin","line":59},{"title":"Author/Te-Hsien Lin","target":"Author/Te-Hsien Lin","line":60},{"title":"Author/Jing-Yi Lin","target":"Author/Jing-Yi Lin","line":61},{"title":"Author/Jingyi Lin","target":"Author/Jingyi Lin","line":62},{"title":"Author/Yu-Wen Chen","target":"Author/Yu-Wen Chen","line":63},{"title":"Author/Yu-Wen Chen","target":"Author/Yu-Wen Chen","line":64},{"title":"Author/Tsung-Ju Li","target":"Author/Tsung-Ju Li","line":65},{"title":"Author/Tsung-Ju Li","target":"Author/Tsung-Ju Li","line":66},{"title":"Author/Chin-Chu Chen","target":"Author/Chin-Chu Chen","line":67},{"title":"Author/Chin-Chu Chen","target":"Author/Chin-Chu Chen","line":68},{"title":"PDF","target":"biblib/kuo_identification_2022/kuo_identification_2022.pdf","line":70}],"metadata":{"id":"kuo_identification_2022","type":"article-journal","title":"Identification of Common Liver Metabolites of the Natural Bioactive Compound Erinacine A, Purified from Hericium erinaceus Mycelium","issued":{"date-parts":[[2022]]},"DOI":"10.3390/app12031201","container-title":"Applied sciences","abstract":"Metabolite identification, in the early stage, for compound discovery is necessary to assess the knowledge for the pharmaceutical improvement of drug safety and efficacy. Even if the drug has been released into the market, identification and continuous evaluation of the metabolites are required to avoid the risk of post-marketing withdrawal. Hericium erinaceus (HE), a medicinal mushroom, has broadly documented nutraceutical benefits, including anti-oxidant, anti-tumor, anti-aging, hypolipidemic, and gastric mucosal protection effects. Recently, erinacine A has been reported as the main natural bioactive compound in the mycelium of HE for functional food development. In neurological studies, the consumption of enrinacine A enriched HE mycelium demonstrates its significant nutraceutical effects in Alzheimer’s disease, Parkinson’s disease, and ischemic stroke. For the first time, we explored the metabolic process of erinacine A molecule and identified its metabolites from the rat and human liver S9 fraction. Using a liquid chromatography/triple quadrupole mass spectrometer for quantitative analysis, we observed that 75.44% of erinacine A was metabolized within 60 min in rat, and 32.34% of erinacine A was metabolized within 120 min in human S9. Using an ultra-performance liquid chromatography/quadrupole time-of-flight mass spectrometry (UPLC-QTOF/MS) to identify the metabolites of erinacine A, five common metabolites were identified, and their possible structures were evaluated. Understanding the metabolic process of erinacine A and establishing its metabolite profile database will help promote the nutraceutical application and discovery of related biomarkers in the future.","tags":["#literature_note"],"author":[{"family":"Kuo","given":"Yu-Hsuan","literal":""},{"family":"Kuo","given":"Yu-Hsuan","literal":""},{"family":"Lin","given":"Ting-Wei","literal":""},{"family":"Lin","given":"Te-Hsien","literal":""},{"family":"Lin","given":"Jing-Yi","literal":""},{"family":"Lin","given":"Jingyi","literal":""},{"family":"Chen","given":"Yu-Wen","literal":""},{"family":"Chen","given":"Yu-Wen","literal":""},{"family":"Li","given":"Tsung-Ju","literal":""},{"family":"Li","given":"Tsung-Ju","literal":""},{"family":"Chen","given":"Chin-Chu","literal":""},{"family":"Chen","given":"Chin-Chu","literal":""}],"citation-key":"kuo_identification_2022","year":"2022","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Identification of Common Liver Metabolites of the Natural Bioactive Compound Erinacine A, Purified from Hericium erinaceus Mycelium"],"author-links":["[[Author/Yu-Hsuan Kuo]]","[[Author/Yu-Hsuan Kuo]]","[[Author/Ting-Wei Lin]]","[[Author/Te-Hsien Lin]]","[[Author/Jing-Yi Lin]]","[[Author/Jingyi Lin]]","[[Author/Yu-Wen Chen]]","[[Author/Yu-Wen Chen]]","[[Author/Tsung-Ju Li]]","[[Author/Tsung-Ju Li]]","[[Author/Chin-Chu Chen]]","[[Author/Chin-Chu Chen]]"],"attachment":["[[biblib/kuo_identification_2022/kuo_identification_2022.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"1c4y0r7","at":1774951888341}},"smart_blocks:Research/@kuo_identification_2022.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.00781422,-0.02399869,0.00949177,-0.0182713,0.01944214,0.04679374,0.03424874,0.0229096,-0.02273287,0.00828342,0.02355531,-0.06995704,0.02640758,-0.02992709,-0.01160343,0.00687962,0.01686504,0.01948807,-0.07596572,-0.00899166,-0.00327221,-0.01067912,-0.0096214,0.00567019,0.03587055,0.03062689,-0.0175425,-0.02403798,-0.08205327,-0.21652132,0.01767476,-0.02003902,0.02411094,-0.03837438,0.00671141,0.01066743,0.0008427