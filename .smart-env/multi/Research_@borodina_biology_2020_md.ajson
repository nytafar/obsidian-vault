,0.01794448,0.00220927,0.15183659,0.02076063,0.01562348,-0.00089453,0.01296907,0.02229365,-0.03526014,0.00641341,-0.01455237,0.06758779,0.09246464,-0.04865643,0.07795149,0.04673426,0.01628972,-0.063122,-0.05502563,-0.03785086,-0.00305194,-0.00970338,-0.10287757,-0.04111335,0.14026295,-0.10050294,-0.08619277,-0.07379252,0.04873072,-0.03361652,-0.02126,0.01083002,-0.01095413,0.0215619,-0.02731473,-0.0197148,0.02279942,0.02645945,-0.0223019,-0.01475044,-0.01523064,-0.00630121,-0.06565066,0.10492455,0.05250656],"last_embed":{"hash":"1d9k2ga","tokens":465}}},"last_read":{"hash":"1d9k2ga","at":1774951889221},"class_name":"SmartSource","last_import":{"mtime":1774951820094,"size":3469,"at":1774951884797,"hash":"1d9k2ga"},"blocks":{"#---frontmatter---":[1,101],"#The biology of ergothioneine, an antioxidant nutraceutical.":[103,107],"#The biology of ergothioneine, an antioxidant nutraceutical.#{1}":[105,107]},"outlinks":[{"title":"Author/Irina Borodina","target":"Author/Irina Borodina","line":78},{"title":"Author/Irina Borodina","target":"Author/Irina Borodina","line":79},{"title":"Author/Louise C. Kenny","target":"Author/Louise C. Kenny","line":80},{"title":"Author/Cathal McCarthy","target":"Author/Cathal McCarthy","line":81},{"title":"Author/Louise C. Kenny","target":"Author/Louise C. Kenny","line":82},{"title":"Author/Ali S. Khashan","target":"Author/Ali S. Khashan","line":83},{"title":"Author/Cathal McCarthy","target":"Author/Cathal McCarthy","line":84},{"title":"Author/Kalaivani Paramasivan","target":"Author/Kalaivani Paramasivan","line":85},{"title":"Author/Kalaivani Paramasivan","target":"Author/Kalaivani Paramasivan","line":86},{"title":"Author/Kalaivani Paramasivan","target":"Author/Kalaivani Paramasivan","line":87},{"title":"Author/Etheresia Pretorius","target":"Author/Etheresia Pretorius","line":88},{"title":"Author/Etheresia Pretorius","target":"Author/Etheresia Pretorius","line":89},{"title":"Author/Timothy J. Roberts","target":"Author/Timothy J. Roberts","line":90},{"title":"Author/Timothy J. Roberts","target":"Author/Timothy J. Roberts","line":91},{"title":"Author/Timothy Roberts","target":"Author/Timothy Roberts","line":92},{"title":"Author/Steven Axel van der Hoek","target":"Author/Steven Axel van der Hoek","line":93},{"title":"Author/Steven A. van der Hoek","target":"Author/Steven A. van der Hoek","line":94},{"title":"Author/Douglas B. Kell","target":"Author/Douglas B. Kell","line":95},{"title":"Author/Douglas B. Kell","target":"Author/Douglas B. Kell","line":96},{"title":"PDF","target":"biblib/borodina_biology_2020/borodina_biology_2020.pdf","line":98}],"metadata":{"id":"borodina_biology_2020","type":"article-journal","title":"The biology of ergothioneine, an antioxidant nutraceutical.","issued":{"date-parts":[[2020]]},"DOI":"10.1017/s0954422419000301","container-title":"Nutrition Research Reviews","abstract":"Ergothioneine (ERG) is an unusual thio-histidine betaine amino acid that has potent antioxidant activities. It is synthesised by a variety of microbes, especially fungi (including in mushroom fruiting bodies) and actinobacteria, but is not synthesised by plants and animals who acquire it via the soil and their diet, respectively. Animals have evolved a highly selective transporter for it, known as solute carrier family 22, member 4 (SLC22A4) in humans, signifying its importance, and ERG may even have the status of a vitamin. ERG accumulates differentially in various tissues, according to their expression of SLC22A4, favouring those such as erythrocytes that may be subject to oxidative stress. Mushroom or ERG consumption seems to provide significant prevention against oxidative stress in a large variety of systems. ERG seems to have strong cytoprotective status, and its concentration is lowered in a number of chronic inflammatory diseases. It has been passed as safe by regulatory agencies, and may have value as a nutraceutical and antioxidant more generally.","tags":["#literature_note"],"author":[{"family":"Borodina","given":"Irina","literal":""},{"family":"Borodina","given":"Irina","literal":""},{"family":"Kenny","given":"Louise C.","literal":""},{"family":"McCarthy","given":"Cathal","literal":""},{"family":"Kenny","given":"Louise C.","literal":""},{"family":"Khashan","given":"Ali S.","literal":""},{"family":"McCarthy","given":"Cathal","literal":""},{"family":"Paramasivan","given":"Kalaivani","literal":""},{"family":"Paramasivan","given":"Kalaivani","literal":""},{"family":"Paramasivan","given":"Kalaivani","literal":""},{"family":"Pretorius","given":"Etheresia","literal":""},{"family":"Pretorius","given":"Etheresia","literal":""},{"family":"Roberts","given":"Timothy J.","literal":""},{"family":"Roberts","given":"Timothy J.","literal":""},{"family":"Roberts","given":"Timothy","literal":""},{"family":"Hoek","given":"Steven Axel van der","literal":""},{"family":"Hoek","given":"Steven A. van der","literal":""},{"family":"Kell","given":"Douglas B.","literal":""},{"family":"Kell","given":"Douglas B.","literal":""}],"citation-key":"borodina_biology_2020","year":"2020","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["The biology of ergothioneine, an antioxidant nutraceutical."],"author-links":["[[Author/Irina Borodina]]","[[Author/Irina Borodina]]","[[Author/Louise C. Kenny]]","[[Author/Cathal McCarthy]]","[[Author/Louise C. Kenny]]","[[Author/Ali S. Khashan]]","[[Author/Cathal McCarthy]]","[[Author/Kalaivani Paramasivan]]","[[Author/Kalaivani Paramasivan]]","[[Author/Kalaivani Paramasivan]]","[[Author/Etheresia Pretorius]]","[[Author/Etheresia Pretorius]]","[[Author/Timothy J. Roberts]]","[[Author/Timothy J. Roberts]]","[[Author/Timothy Roberts]]","[[Author/Steven Axel van der Hoek]]","[[Author/Steven A. van der Hoek]]","[[Author/Douglas B. Kell]]","[[Author/Douglas B. Kell]]"],"attachment":["[[biblib/borodina_biology_2020/borodina_biology_2020.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"1d9k2ga","at":1774951