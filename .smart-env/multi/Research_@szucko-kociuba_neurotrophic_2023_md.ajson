7014,0.05213867,-0.09750596,0.0165427,0.0377021,0.19803756,0.03779527,-0.03759542,0.0065588,-0.02468075,0.04558367,0.0147196,0.01111304,-0.0026988,0.03317143,0.06835551,-0.01910487,0.06367403,0.02516845,-0.07414766,-0.03980839,-0.03228535,-0.04083954,0.0076907,-0.0091248,-0.04018141,-0.05246297,0.10418463,-0.06446813,-0.04897925,-0.00472515,-0.03068041,0.0180658,-0.00643605,0.00152811,0.02312055,0.00826938,0.01119359,-0.01875826,0.01398723,-0.0098605,-0.04759744,-0.00044226,0.00289961,-0.0176049,-0.06634614,0.10590244,0.05477957],"last_embed":{"hash":"1d5b0a1","tokens":479}}},"last_read":{"hash":"1d5b0a1","at":1774951887977},"class_name":"SmartSource","last_import":{"mtime":1774951818114,"size":2149,"at":1774951884785,"hash":"1d5b0a1"},"blocks":{"#---frontmatter---":[1,41],"#Neurotrophic and Neuroprotective Effects of Hericium erinaceus":[43,47],"#Neurotrophic and Neuroprotective Effects of Hericium erinaceus#{1}":[45,47]},"outlinks":[{"title":"Author/Izabela Szućko-Kociuba","target":"Author/Izabela Szućko-Kociuba","line":33},{"title":"Author/Alicja Trzeciak-Ryczek","target":"Author/Alicja Trzeciak-Ryczek","line":34},{"title":"Author/Patrycja Kupnicka","target":"Author/Patrycja Kupnicka","line":35},{"title":"Author/Dariusz Chlubek","target":"Author/Dariusz Chlubek","line":36},{"title":"PDF","target":"biblib/szucko-kociuba_neurotrophic_2023/szucko-kociuba_neurotrophic_2023.pdf","line":38}],"metadata":{"id":"szucko-kociuba_neurotrophic_2023","type":"article-journal","title":"Neurotrophic and Neuroprotective Effects of Hericium erinaceus","issued":{"date-parts":[[2023]]},"DOI":"10.3390/ijms242115960","container-title":"International journal of molecular sciences","abstract":"Hericium erinaceus is a valuable mushroom known for its strong bioactive properties. It shows promising potential as an excellent neuroprotective agent, capable of stimulating nerve growth factor release, regulating inflammatory processes, reducing oxidative stress, and safeguarding nerve cells from apoptosis. The active compounds in the mushroom, such as erinacines and hericenones, have been the subject of research, providing evidence of their neuroprotective effects. Further research and standardization processes for dietary supplements focused on H. erinaceus are essential to ensuring effectiveness and safety in protecting the nervous system. Advancements in isolation and characterization techniques, along with improved access to pure analytical standards, will play a critical role in achieving standardized, high-quality dietary supplements based on H. erinaceus. The aim of this study is to analyze the protective and nourishing effects of H. erinaceus on the nervous system and present the most up-to-date research findings related to this topic.","tags":["#literature_note"],"author":[{"family":"Szućko-Kociuba","given":"Izabela","literal":""},{"family":"Trzeciak-Ryczek","given":"Alicja","literal":""},{"family":"Kupnicka","given":"Patrycja","literal":""},{"family":"Chlubek","given":"Dariusz","literal":""}],"citation-key":"szucko-kociuba_neurotrophic_2023","year":"2023","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Neurotrophic and Neuroprotective Effects of Hericium erinaceus"],"author-links":["[[Author/Izabela Szućko-Kociuba]]","[[Author/Alicja Trzeciak-Ryczek]]","[[Author/Patrycja Kupnicka]]","[[Author/Dariusz Chlubek]]"],"attachment":["[[biblib/szucko-kociuba_neurotrophic_2023/szucko-kociuba_neurotrophic_2023.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"1d5b0a1","at":1774951887966}},"smart_blocks:Research/@szucko-kociuba_neurotrophic_2023.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.00509929,-0.00846249,0.00660015,-0.0249111,-0.00328468,0.02809274,0.04742435,0.04288689,-0.04695029,-0.0031669,-0.02168907,-0.04140129,0.0409821,0.01596905,-0.02664893,0.0147236,0.01090714,-0.00301529,-0.09109146,0.00591677,0.02914383,-0.03650423,0.02584863,0.034606