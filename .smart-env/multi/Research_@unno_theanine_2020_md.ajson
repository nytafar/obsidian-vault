292101,0.16409658,-0.02949166,0.03057888,0.06500228,-0.03492059,0.02241845,0.02015264,0.01616848,-0.02461717,0.05869072,0.07452236,-0.0477711,0.05363763,0.06046502,-0.09156571,-0.00464412,-0.00912828,-0.02056897,-0.00715288,0.03060973,-0.0564942,-0.07465092,0.0979747,-0.07409138,-0.04653301,-0.02894606,-0.05285589,-0.00609253,0.01899443,-0.00119923,0.04966154,-0.01289951,-0.00451842,-0.02727432,0.0044012,-0.00270075,0.01663903,-0.03422144,-0.03628566,-0.04024485,-0.00242443,0.15640712,0.05036258],"last_embed":{"hash":"bdj3id","tokens":458}}},"last_read":{"hash":"bdj3id","at":1774951895654},"class_name":"SmartSource","last_import":{"mtime":1774951828634,"size":4346,"at":1774951884829,"hash":"bdj3id"},"blocks":{"#---frontmatter---":[1,129],"#Theanine, the Main Amino Acid in Tea, Prevents Stress-Induced Brain Atrophy by Modifying Early Stress Responses":[131,135],"#Theanine, the Main Amino Acid in Tea, Prevents Stress-Induced Brain Atrophy by Modifying Early Stress Responses#{1}":[133,135]},"outlinks":[{"title":"Author/Keiko Unno","target":"Author/Keiko Unno","line":99},{"title":"Author/Keiko Unno","target":"Author/Keiko Unno","line":100},{"title":"Author/Akira Sumiyoshi","target":"Author/Akira Sumiyoshi","line":101},{"title":"Author/Akira Sumiyoshi","target":"Author/Akira Sumiyoshi","line":102},{"title":"Author/Tomokazu Konishi","target":"Author/Tomokazu Konishi","line":103},{"title":"Author/Tomokazu Konishi","target":"Author/Tomokazu Konishi","line":104},{"title":"Author/Michiko Hayashi","target":"Author/Michiko Hayashi","line":105},{"title":"Author/Michiko Hayashi","target":"Author/Michiko Hayashi","line":106},{"title":"Author/Kyoko Taguchi","target":"Author/Kyoko Taguchi","line":107},{"title":"Author/Kyoko Taguchi","target":"Author/Kyoko Taguchi","line":108},{"title":"Author/Yoshio Muguruma","target":"Author/Yoshio Muguruma","line":109},{"title":"Author/Yoshio Muguruma","target":"Author/Yoshio Muguruma","line":110},{"title":"Author/Kōichi Inoue","target":"Author/Kōichi Inoue","line":111},{"title":"Author/Koichi Inoue","target":"Author/Koichi Inoue","line":112},{"title":"Author/Kazuaki Iguchi","target":"Author/Kazuaki Iguchi","line":113},{"title":"Author/Kazuaki Iguchi","target":"Author/Kazuaki Iguchi","line":114},{"title":"Author/Hiroi Nonaka","target":"Author/Hiroi Nonaka","line":115},{"title":"Author/Hiroi Nonaka","target":"Author/Hiroi Nonaka","line":116},{"title":"Author/Ryuta Kawashima","target":"Author/Ryuta Kawashima","line":117},{"title":"Author/Ryuta Kawashima","target":"Author/Ryuta Kawashima","line":118},{"title":"Author/Sanae Hasegawa-Ishii","target":"Author/Sanae Hasegawa-Ishii","line":119},{"title":"Author/Sanae Hasegawa-Ishii","target":"Author/Sanae Hasegawa-Ishii","line":120},{"title":"Author/Atsuyoshi Shimada","target":"Author/Atsuyoshi Shimada","line":121},{"title":"Author/Atsuyoshi Shimada","target":"Author/Atsuyoshi Shimada","line":122},{"title":"Author/Yoriyuki Nakamura","target":"Author/Yoriyuki Nakamura","line":123},{"title":"Author/Yoriyuki Nakamura","target":"Author/Yoriyuki Nakamura","line":124},{"title":"PDF","target":"biblib/unno_theanine_2020/unno_theanine_2020.pdf","line":126}],"metadata":{"id":"unno_theanine_2020","type":"article-journal","title":"Theanine, the Main Amino Acid in Tea, Prevents Stress-Induced Brain Atrophy by Modifying Early Stress Responses","issued":{"date-parts":[[2020]]},"DOI":"10.3390/nu12010174","container-title":"Nutrients","abstract":"Chronic stress can impair the health of human brains. An important strategy that may prevent the accumulation of stress may be the consumption of functional foods. When senescence-accelerated mice prone 10 (SAMP10), a stress-sensitive strain, were loaded with stress using imposed male mouse territoriality, brain volume decreased. However, in mice that ingested theanine (6 mg/kg), the main amino acid in tea leaves, brain atrophy was suppressed, even under stress. On the other hand, brain atrophy was not clearly observed in a mouse strain that aged normally (Slc:ddY). The expression level of the transcription factor Npas4 (neuronal PAS domain protein 4), which regulates the formation and maintenance of inhibitory synapses in response to excitatory synaptic activity, decreased in the hippocampus and prefrontal cortex of stressed SAMP10 mice, but increased in mice that ingested theanine. Lipocalin 2 (Lcn2), the expression of which increased in response to stress, was significantly high in the hippocampus and prefrontal cortex of stressed SAMP10 mice, but not in mice that ingested theanine. These data suggest that Npas4 and Lcn2 are involved in the brain atrophy and stress vulnerability of SAMP10 mice, which are prevented by the consumption of theanine, causing changes in the expression of these genes.","tags":["#literature_note"],"author":[{"family":"Unno","given":"Keiko","literal":""},{"family":"Unno","given":"Keiko","literal":""},{"family":"Sumiyoshi","given":"Akira","literal":""},{"family":"Sumiyoshi","given":"Akira","literal":""},{"family":"Konishi","given":"Tomokazu","literal":""},{"family":"Konishi","given":"Tomokazu","literal":""},{"family":"Hayashi","given":"Michiko","literal":""},{"family":"Hayashi","given":"Michiko","literal":""},{"family":"Taguchi","given":"Kyoko","literal":""},{"family":"Taguchi","given":"Kyoko","literal":""},{"family":"Muguruma","given":"Yoshio","literal":""},{"family":"Muguruma","given":"Yoshio","literal":""},{"family":"Inoue","given":"Kōichi","literal":""},{"family":"Inoue","given":"Koichi","literal":""},{"family":"Iguchi","given":"Kazuaki","literal":""},{"family":"Iguchi","given":"Kazuaki","literal":""},{"family":"Nonaka","given":"Hiroi","literal":""},{"family":"Nonaka","given":"Hiroi","literal":""},{"family":"Kawashima","given":"Ryuta","literal":""},{"family":"Kawashima","given":"Ryuta","literal":""},{"family":"Hasegawa-Ishii","given":"Sanae","literal":""},{"family":"Hasegawa-Ishii","given":"Sanae","literal":""},{"family":"Shimada","given":"Atsuyoshi","literal":""},{"family":"Shimada","given":"Atsuyoshi","literal":""},{"family":"Nakamura","given":"Yoriyuki","literal":""},{"family":"Nakamura","given":"Yoriyuki","literal":""}],"citation-key":"unno_theanine_2020","year":"2020","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Theanine, the Main Amino Acid in Tea, Prevents Stress-Induced Brain Atrophy by Modifying Early Stress Responses"],"author-links":["[[Author/Keiko Unno]]","[[Author/Keiko Unno]]","[[Author/Akira Sumiyoshi]]","[[Author/Akira Sumiyoshi]]","[[Author/Tomokazu Konishi]]","[[Author/Tomokazu Konishi]]","[[Author/Michiko Hayashi]]","[[Author/Michiko Hayashi]]","[[Author/Kyoko Taguchi]]","[[Author/Kyoko Taguchi]]","[[Author/Yoshio Muguruma]]","[[Author/Yoshio Muguruma]]","[[Author/Kōichi Inoue]]","[[Author/Koichi Inoue]]","[[Author/Kazuaki Iguchi]]","[[Author/Kazuaki Iguchi]]","[[Author/Hiroi Nonaka]]","[[Author/Hiroi Nonaka]]","[[Author/Ryuta Kawashima]]","[[Author/Ryuta Kawashima]]","[[Author/Sanae Hasegawa-Ishii]]","[[Author/Sanae Hasegawa-Ishii]]","[[Author/Atsuyoshi Shimada]]","[[Author/Atsuyoshi Shimada]]","[[Author/Yoriyuki Nakamura]]","[[Author/Yoriyuki Nakamura]]"],"attachment":["[[biblib/unno_theanine_2020/unno_theanine_2020.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"bdj3id","at":1774951895645}},"smart_blocks:Research/@unno_theanine_2020.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.01194099,0.01068213,-0.00209858,0.02123553,0.00188108,0.07133384,0.0941938,0.02285616,-0.03221687,-0.02884531,-0.00513905,-0.03556385,0.08179997,0.08183345,0.06105508,0.01576452,-0.02254515,0.01424407,-0.0924576,0.01249173,0.0008545,-0.0003358,0.0874251,-0.04810783,0.02947561,0.00408381,-0.04334283,0.00009385,-0.06868373,-0.23356926,0.02584123,-0.04291276,0.02643031,-0.07705538,-0.03068511,0.02157563,0.02000744,0.00786853,0.00931809,0.06913564,0.07355918,0.04141579,-0.03970033,-0.05518487,-0.01127557,0.00711375,0.00579467,-0.05