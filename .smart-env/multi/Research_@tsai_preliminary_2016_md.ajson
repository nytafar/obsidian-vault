4,-0.00603155,-0.0170781,0.15431637,-0.01448955,-0.04743426,0.00671425,-0.04953329,0.04347341,0.01788363,0.026861,0.0132209,0.04384144,0.07173518,-0.05265567,0.10348863,0.07333273,-0.02226104,0.02917076,-0.00405424,0.02508443,-0.0000471,0.01096763,-0.05716607,-0.00642541,0.06429821,-0.08292906,-0.02268708,-0.03896892,0.00999099,0.00014173,-0.01547704,-0.03137799,0.0107906,0.02584625,0.03812408,0.00711857,0.01876026,-0.0000367,-0.03386421,-0.05201373,0.02441983,0.01575725,-0.0467265,0.10636987,0.05389426],"last_embed":{"hash":"11qmlhw","tokens":453}}},"last_read":{"hash":"11qmlhw","at":1774951894182},"class_name":"SmartSource","last_import":{"mtime":1774951827067,"size":4798,"at":1774951884824,"hash":"11qmlhw"},"blocks":{"#---frontmatter---":[1,109],"#A preliminary randomised controlled study of short-term Antrodia cinnamomea treatment combined with chemotherapy for patients with advanced cancer":[111,115],"#A preliminary randomised controlled study of short-term Antrodia cinnamomea treatment combined with chemotherapy for patients with advanced cancer#{1}":[113,115]},"outlinks":[{"title":"Author/Ming-Yen Tsai","target":"Author/Ming-Yen Tsai","line":84},{"title":"Author/Ming-Yen Tsai","target":"Author/Ming-Yen Tsai","line":85},{"title":"Author/Yu-Chiang Hung","target":"Author/Yu-Chiang Hung","line":86},{"title":"Author/Yu-Chiang Hung","target":"Author/Yu-Chiang Hung","line":87},{"title":"Author/Yen-Hao Chen","target":"Author/Yen-Hao Chen","line":88},{"title":"Author/Yen-Hao Chen","target":"Author/Yen-Hao Chen","line":89},{"title":"Author/Yung-Hsiang Chen","target":"Author/Yung-Hsiang Chen","line":90},{"title":"Author/Yung-Hsiang Chen","target":"Author/Yung-Hsiang Chen","line":91},{"title":"Author/Yu-Chuen Huang","target":"Author/Yu-Chuen Huang","line":92},{"title":"Author/Yu Chuen Huang","target":"Author/Yu Chuen Huang","line":93},{"title":"Author/Yu-Chuen Huang","target":"Author/Yu-Chuen Huang","line":94},{"title":"Author/Yu-Chuen Huang","target":"Author/Yu-Chuen Huang","line":95},{"title":"Author/Chao-Wei Kao","target":"Author/Chao-Wei Kao","line":96},{"title":"Author/Chao-Wei Kao","target":"Author/Chao-Wei Kao","line":97},{"title":"Author/Yu-Li Su","target":"Author/Yu-Li Su","line":98},{"title":"Author/Yu-Li Su","target":"Author/Yu-Li Su","line":99},{"title":"Author/Hsienhsueh Elley Chiu","target":"Author/Hsienhsueh Elley Chiu","line":100},{"title":"Author/Hsien-Hsueh Elley Chiu","target":"Author/Hsien-Hsueh Elley Chiu","line":101},{"title":"Author/Kun-Ming Rau","target":"Author/Kun-Ming Rau","line":102},{"title":"Author/Kun-Ming Rau","target":"Author/Kun-Ming Rau","line":103},{"title":"Author/Kun-Ming Rau","target":"Author/Kun-Ming Rau","line":104},{"title":"PDF","target":"biblib/tsai_preliminary_2016/tsai_preliminary_2016.pdf","line":106}],"metadata":{"id":"tsai_preliminary_2016","type":"article-journal","title":"A preliminary randomised controlled study of short-term Antrodia cinnamomea treatment combined with chemotherapy for patients with advanced cancer","issued":{"date-parts":[[2016]]},"DOI":"10.1186/s12906-016-1312-9","container-title":"BMC Complementary and Alternative Medicine","abstract":"Antrodia cinnamomea (AC) is a popular medicinal mushroom in Taiwan that has been widely used for treatment of various cancers. Few clinical studies have reported its application and efficiency in therapeutic chemotherapy strategies. We performed a double-blind, randomized clinical study to investigate whether AC given for 30days had acceptable safety and efficacy in advanced cancer patients receiving chemotherapy. Patients with advanced and/or metastatic adenocarcinoma, performance status (PS) 0–2, and adequate organ function who had previously been treated with standard chemotherapy were randomly assigned to receive routine chemotherapy regimens with AC (20ml twice daily) orally for 30days or placebo. The primary endpoint was 6-month overall survival (OS); the secondary endpoints were disease control rate (DCR), quality of life (QoL), adverse event (AE), and biochemical features within 30days of treatment. From August 2010 to July 2012, 37 subjects with gastric, lung, liver, breast, and colorectal cancer (17 in the AC group, 20 in the placebo group) were enrolled in the study. Disease progression was the primary cause of death in 4 (33.3%) AC and 8 (66.7%) placebo recipients. Mean OSs were 5.4months for the AC group and 5.0months for the placebo group (p=0.340), and the DCRs were 41.2 and 55%, respectively (p=0.33). Most hematologic, liver, or kidney functions did not differ significantly between the two groups, but platelet counts were lower in the AC group than in the placebo group (p=0.02). QoL assessments were similar in the two groups, except that the AC group showed significant improvements in quality of sleep (p=0.04). Although we found a lower mortality rate and longer mean OS in the AC group than in the control group, A. cinnamomea combined with chemotherapy was not shown to improve the outcome of advanced cancer patients, possibly due to the small sample size. In fact, the combination may present a potential risk of lowered platelet counts. Adequately powered clinical trials will be necessary to address this question. ClinicalTrials.gov NCT01287286 .","tags":["#literature_note"],"author":[{"family":"Tsai","given":"Ming-Yen","literal":""},{"family":"Tsai","given":"Ming-Yen","literal":""},{"family":"Hung","given":"Yu-Chiang","literal":""},{"family":"Hung","given":"Yu-Chiang","literal":""},{"family":"Chen","given":"Yen-Hao","literal":""},{"family":"Chen","given":"Yen-Hao","literal":""},{"family":"Chen","given":"Yung-Hsiang","literal":""},{"family":"Chen","given":"Yung-Hsiang","literal":""},{"family":"Huang","given":"Yu-Chuen","literal":""},{"family":"Huang","given":"Yu Chuen","literal":""},{"family":"Huang","given":"Yu-Chuen","literal":""},{"family":"Huang","given":"Yu-Chuen","literal":""},{"family":"Kao","given":"Chao-Wei","literal":""},{"family":"Kao","given":"Chao-Wei","literal":""},{"family":"Su","given":"Yu-Li","literal":""},{"family":"Su","given":"Yu-Li","literal":""},{"family":"Chiu","given":"Hsienhsueh Elley","literal":""},{"family":"Chiu","given":"Hsien-Hsueh Elley","literal":""},{"family":"Rau","given":"Kun-Ming","literal":""},{"family":"Rau","given":"Kun-Ming","literal":""},{"family":"Rau","given":"Kun-Ming","literal":""}],"citation-key":"tsai_preliminary_2016","year":"2016","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["A preliminary randomised controlled study of short-term Antrodia cinnamomea treatment combined with chemotherapy for patients with advanced cancer"],"author-links":["[[Author/Ming-Yen Tsai]]","[[Author/Ming-Yen Tsai]]","[[Author/Yu-Chiang Hung]]","[[Author/Yu-Chiang Hung]]","[[Author/Yen-Hao Chen]]","[[Author/Yen-Hao Chen]]","[[Author/Yung-Hsiang Chen]]","[[Author/Yung-Hsiang Chen]]","[[Author/Yu-Chuen Huang]]","[[Author/Yu Chuen Huang]]","[[Author/Yu-Chuen Huang]]","[[Author/Yu-Chuen Huang]]","[[Author/Chao-Wei Kao]]","[[Author/Chao-Wei Kao]]","[[Author/Yu-Li Su]]","[[Author/Yu-Li Su]]","[[Author/Hsienhsueh Elley Chiu]]","[[Author/Hsien-Hsueh Elley Chiu]]","[[Author/Kun-Ming Rau]]","[[Author/Kun-Ming Rau]]","[[Author/Kun-Ming Rau]]"],"attachment":["[[biblib/tsai_preliminary_2016/tsai_preliminary_2016.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"11qmlhw","at":1774951894171}},"smart_blocks:Research/@tsai_preliminary_2016.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.03463393,0.01675852,0.01403435,-0.02338937,-0.01273286,0.00225463,0.02167379,-0.00623265,-0.02064686,-0.02337362,0.0341537,-0.04535692,0.02092464,0.06198721,0.01121287,0.01534149,0.02830379,-0.03083849,-0.020095,0.05080962,-0.05538033,-0.01122801,0.0218691,-0.01915537,0.02944986,0.02448719,-0.01692933,-0.05850299,-0.05791468,-0.22059442,-0.03404724,-0.01244269,0.00289138,-0.03240306,-0.05315524,-0.02217742,-0.0248494,0.03247491,0.02183272,0.0161