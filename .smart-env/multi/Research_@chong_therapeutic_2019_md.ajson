51,0.04154239,-0.09305988,0.01722574,-0.00299333,0.17185636,-0.01335245,-0.00834246,-0.00074085,0.02154697,0.01519116,-0.02339461,-0.01274269,-0.01373778,0.05568941,0.13199797,0.00289567,0.06913023,0.02751376,-0.1141993,-0.02317,0.03286065,-0.00127121,0.03677417,0.01418205,-0.03135164,-0.02196066,0.09451339,-0.02638931,-0.02387671,0.00678462,-0.01400179,0.00728268,0.03001481,0.05435694,0.03835038,0.030306,0.01900945,-0.01718099,-0.01833409,-0.01924491,-0.03889682,-0.00704739,-0.010633,-0.02916664,-0.09221794,0.11769099,0.09547614],"last_embed":{"hash":"1uz57fq","tokens":434}}},"last_read":{"hash":"1uz57fq","at":1774951894046},"class_name":"SmartSource","last_import":{"mtime":1774951826841,"size":2710,"at":1774951884823,"hash":"1uz57fq"},"blocks":{"#---frontmatter---":[1,61],"#Therapeutic Potential of Hericium erinaceus for Depressive Disorder":[63,67],"#Therapeutic Potential of Hericium erinaceus for Depressive Disorder#{1}":[65,67]},"outlinks":[{"title":"Author/Pit Shan Chong","target":"Author/Pit Shan Chong","line":48},{"title":"Author/Pit Shan Chong","target":"Author/Pit Shan Chong","line":49},{"title":"Author/Man-Lung Fung","target":"Author/Man-Lung Fung","line":50},{"title":"Author/Man-Lung Fung","target":"Author/Man-Lung Fung","line":51},{"title":"Author/Kah-Hui Wong","target":"Author/Kah-Hui Wong","line":52},{"title":"Author/Kah-Hui Wong","target":"Author/Kah-Hui Wong","line":53},{"title":"Author/Lee Yong Lim","target":"Author/Lee Yong Lim","line":54},{"title":"Author/Lee Wei Lim","target":"Author/Lee Wei Lim","line":55},{"title":"Author/Lee Wei Lim","target":"Author/Lee Wei Lim","line":56},{"title":"PDF","target":"biblib/chong_therapeutic_2019/chong_therapeutic_2019.pdf","line":58}],"metadata":{"id":"chong_therapeutic_2019","type":"article-journal","title":"Therapeutic Potential of Hericium erinaceus for Depressive Disorder","issued":{"date-parts":[[2019]]},"DOI":"10.3390/ijms21010163","container-title":"International Journal of Molecular Sciences","abstract":"Depression is a common and severe neuropsychiatric disorder that is one of the leading causes of global disease burden. Although various anti-depressants are currently available, their efficacies are barely adequate and many have side effects. Hericium erinaceus, also known as Lion’s mane mushroom, has been shown to have various health benefits, including antioxidative, antidiabetic, anticancer, anti-inflammatory, antimicrobial, antihyperglycemic, and hypolipidemic effects. It has been used to treat cognitive impairment, Parkinson’s disease, and Alzheimer’s disease. Bioactive compounds extracted from the mycelia and fruiting bodies of H. erinaceus have been found to promote the expression of neurotrophic factors that are associated with cell proliferation such as nerve growth factors. Although antidepressant effects of H. erinaceus have not been validated and compared to the conventional antidepressants, based on the neurotrophic and neurogenic pathophysiology of depression, H. erinaceus may be a potential alternative medicine for the treatment of depression. This article critically reviews the current literature on the potential benefits of H. erinaceus as a treatment for depressive disorder as well as its mechanisms underlying the antidepressant-like activities.","tags":["#literature_note"],"author":[{"family":"Chong","given":"Pit Shan","literal":""},{"family":"Chong","given":"Pit Shan","literal":""},{"family":"Fung","given":"Man-Lung","literal":""},{"family":"Fung","given":"Man-Lung","literal":""},{"family":"Wong","given":"Kah-Hui","literal":""},{"family":"Wong","given":"Kah-Hui","literal":""},{"family":"Lim","given":"Lee Yong","literal":""},{"family":"Lim","given":"Lee Wei","literal":""},{"family":"Lim","given":"Lee Wei","literal":""}],"citation-key":"chong_therapeutic_2019","year":"2019","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Therapeutic Potential of Hericium erinaceus for Depressive Disorder"],"author-links":["[[Author/Pit Shan Chong]]","[[Author/Pit Shan Chong]]","[[Author/Man-Lung Fung]]","[[Author/Man-Lung Fung]]","[[Author/Kah-Hui Wong]]","[[Author/Kah-Hui Wong]]","[[Author/Lee Yong Lim]]","[[Author/Lee Wei Lim]]","[[Author/Lee Wei Lim]]"],"attachment":["[[biblib/chong_therapeutic_2019/chong_therapeutic_2019.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"1uz57fq","at":1774951894037}},"smart_blocks:Research/@chong_therapeutic_2019.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.00840606,-0.01164294,0.06242362,-0.00599973,-0.00643933,0.03136309,0.03683756,0.06779589,-0.05627969,-0.01045776,0.03245322,-0.05710389,0.06829152,0.02384098,-0.01226142,0.01073533,-0.00613052,0.00854434,-0.09451748,-0.04461085,0.0127585,-0.02559156,0.01041957,-0.00253435,-0.00399331,0.02277428,-0.0357064,-0.00707233,-0.07164435,-0.17679086,-0.00155213,0.03524594,0.020162,-0.00796442,-0.00411732,0.00321517,-0.04649835,0.04368501,-0.02032195,0.04231649,0.0679896,0.04780049,0.05093605,0.0171763,0.00513243,-0.08290976,-0.01580637,-0.05567668,0.03301848,-0.00881353,0.03180385,-0.01850324,0.06256866,0.02595527,0.04882274,-0.00416262,0.01984547,0.06670965,0.02481679,0.08979284,0.10413913,0.07102648,-0.20487554,0.05376866,0.09799094,-0.02110515,-0.10540351,-0.03060315,0.09529392,0.037651,-0.02488899,0.00194375,0.07564317,0.07284129,-0.01550664,-0.00317129,-0.00293694,-0.04670302,-0.0062373,-0.03279398,0.05470359,0.08726176,0.05720487,0.00060063,-0.03492197,-0.05219249,0.00550095,-0.07823797,-0.00030383,0.00936078,-0.04934752,-0.05895378,0.01802391,-0.0019215,-0.03965569,-0.01889496,0.00475588,-0.00659902,-0.09522595,0.14252049,-0.08075529,-0.02289719,-0.03694679,-0.06395919,0.01865938,-0.02096762,-0.01646526,-0.06422377,0.02346742,0.02018859,0.05246346,-0.02610711,0.02455623,-0.02661779,-0.028461,0.03037909,0.08027579,0.04032739,0.00320418,-0.00346657,-0.03570137,0.01984254,0.03979133,0.00184246,0.01816515,-0.06316006,-0.04962712,0.03