-0.05339667,-0.01062611,0.0108612,0.19732586,-0.01143084,-0.02052662,0.01996823,-0.04096726,0.03877291,-0.03431282,0.05415973,0.01108064,0.06208016,0.08797882,-0.05706301,0.03472611,0.06997839,0.00689062,-0.07878691,-0.01831209,0.00680646,-0.0108765,-0.06742748,-0.07885621,0.01330412,0.0873153,-0.06704571,-0.0586796,-0.01261842,0.0200894,0.003692,-0.05468164,-0.03964253,0.0150913,0.02572789,-0.06085681,-0.04861772,-0.02866176,-0.02066943,-0.09405169,0.00812038,0.01110247,0.02682958,-0.08699977,0.11610954,0.05735363],"last_embed":{"hash":"1erm187","tokens":476}}},"last_read":{"hash":"1erm187","at":1774951894753},"class_name":"SmartSource","last_import":{"mtime":1774951827395,"size":2381,"at":1774951884824,"hash":"1erm187"},"blocks":{"#---frontmatter---":[1,49],"#Entomotoxic and nematotoxic lectins and protease inhibitors from fungal fruiting bodies":[51,55],"#Entomotoxic and nematotoxic lectins and protease inhibitors from fungal fruiting bodies#{1}":[53,55]},"outlinks":[{"title":"Author/Jerica Sabotič","target":"Author/Jerica Sabotič","line":39},{"title":"Author/Jerica Sabotič","target":"Author/Jerica Sabotič","line":40},{"title":"Author/Robin A. Ohm","target":"Author/Robin A. Ohm","line":41},{"title":"Author/Robin A. Ohm","target":"Author/Robin A. Ohm","line":42},{"title":"Author/Markus Künzler","target":"Author/Markus Künzler","line":43},{"title":"Author/Markus Künzler","target":"Author/Markus Künzler","line":44},{"title":"PDF","target":"biblib/sabotic_entomotoxic_2016/sabotic_entomotoxic_2016.pdf","line":46}],"metadata":{"id":"sabotic_entomotoxic_2016","type":"article-journal","title":"Entomotoxic and nematotoxic lectins and protease inhibitors from fungal fruiting bodies","issued":{"date-parts":[[2016]]},"DOI":"10.1007/s00253-015-7075-2","container-title":"Applied Microbiology and Biotechnology","abstract":"Fruiting bodies or sporocarps of dikaryotic (ascomycetous and basidiomycetous) fungi, commonly referred to as mushrooms, are often rich in entomotoxic and nematotoxic proteins that include lectins and protease inhibitors. These protein toxins are thought to act as effectors of an innate defense system of mushrooms against animal predators including fungivorous insects and nematodes. In this review, we summarize current knowledge about the structures, target molecules, and regulation of the biosynthesis of the best characterized representatives of these fungal defense proteins, including galectins, beta-trefoil-type lectins, actinoporin-type lectins, beta-propeller-type lectins and beta-trefoil-type chimerolectins, as well as mycospin and mycocypin families of protease inhibitors. We also present an overview of the phylogenetic distribution of these proteins among a selection of fungal genomes and draw some conclusions about their evolution and physiological function. Finally, we present an outlook for future research directions in this field and their potential applications in medicine and crop protection.","tags":["#literature_note"],"author":[{"family":"Sabotič","given":"Jerica","literal":""},{"family":"Sabotič","given":"Jerica","literal":""},{"family":"Ohm","given":"Robin A.","literal":""},{"family":"Ohm","given":"Robin A.","literal":""},{"family":"Künzler","given":"Markus","literal":""},{"family":"Künzler","given":"Markus","literal":""}],"citation-key":"sabotic_entomotoxic_2016","year":"2016","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Entomotoxic and nematotoxic lectins and protease inhibitors from fungal fruiting bodies"],"author-links":["[[Author/Jerica Sabotič]]","[[Author/Jerica Sabotič]]","[[Author/Robin A. Ohm]]","[[Author/Robin A. Ohm]]","[[Author/Markus Künzler]]","[[Author/Markus Künzler]]"],"attachment":["[[biblib/sabotic_entomotoxic_2016/sabotic_entomotoxic_2016.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"1erm187","at":1774951894745}},"smart_blocks:Research/@sabotic_entomotoxic_2016.md#---frontmatter---": {"path":null,"embedding