239657,-0.09543982,0.05839045,0.07276882,0.17010951,0.03194863,0.02539923,-0.02128363,-0.07341175,0.05805789,0.03212807,-0.02961445,0.03778474,0.03149912,0.04514662,-0.02506463,0.01895942,0.08334573,-0.05587732,0.02320539,-0.02482064,-0.03370326,0.05776658,-0.02018675,-0.04787683,0.03317684,0.12077214,-0.03659651,-0.05825765,-0.01231847,0.0374428,-0.04397571,-0.04574914,0.03322607,-0.00656653,0.0129775,-0.00797132,0.00230117,0.00564384,-0.01107703,-0.00625721,-0.03320644,0.02614472,-0.01194839,-0.00770541,0.14757411,0.0145035],"last_embed":{"hash":"1nm6dg1","tokens":427}}},"last_read":{"hash":"1nm6dg1","at":1774951890820},"class_name":"SmartSource","last_import":{"mtime":1774951821767,"size":3510,"at":1774951884804,"hash":"1nm6dg1"},"blocks":{"#---frontmatter---":[1,93],"#Modulated DISP3/PTCHD2 expression influences neural stem cell fate decisions.":[95,99],"#Modulated DISP3/PTCHD2 expression influences neural stem cell fate decisions.#{1}":[97,99]},"outlinks":[{"title":"Author/Jana Konířová","target":"Author/Jana Konířová","line":72},{"title":"Author/Jana Konířová","target":"Author/Jana Konířová","line":73},{"title":"Author/Jana Konířová","target":"Author/Jana Konířová","line":74},{"title":"Author/Jana Oltová","target":"Author/Jana Oltová","line":75},{"title":"Author/Jana Oltová","target":"Author/Jana Oltová","line":76},{"title":"Author/Alicia Corlett","target":"Author/Alicia Corlett","line":77},{"title":"Author/Alicia Corlett","target":"Author/Alicia Corlett","line":78},{"title":"Author/Justyna Kopycińska","target":"Author/Justyna Kopycińska","line":79},{"title":"Author/Justyna Kopycińska","target":"Author/Justyna Kopycińska","line":80},{"title":"Author/Michal Kolář","target":"Author/Michal Kolář","line":81},{"title":"Author/Michal Kolář","target":"Author/Michal Kolář","line":82},{"title":"Author/Michal Kolář","target":"Author/Michal Kolář","line":83},{"title":"Author/Petr Bartunek","target":"Author/Petr Bartunek","line":84},{"title":"Author/Petr Bartůněk","target":"Author/Petr Bartůněk","line":85},{"title":"Author/Petr Bartůněk","target":"Author/Petr Bartůněk","line":86},{"title":"Author/Martina Zı́ková","target":"Author/Martina Zı́ková","line":87},{"title":"Author/Martina Zikova","target":"Author/Martina Zikova","line":88},{"title":"PDF","target":"biblib/konirova_modulated_2017/konirova_modulated_2017.pdf","line":90}],"metadata":{"id":"konirova_modulated_2017","type":"article-journal","title":"Modulated DISP3/PTCHD2 expression influences neural stem cell fate decisions.","issued":{"date-parts":[[2017]]},"DOI":"10.1038/srep41597","container-title":"Scientific Reports","abstract":"Neural stem cells (NSCs) are defined by their dual ability to self-renew through mitotic cell division or differentiate into the varied neural cell types of the CNS. DISP3/PTCHD2 is a sterol-sensing domain-containing protein, highly expressed in neural tissues, whose expression is regulated by thyroid hormone. In the present study, we used a mouse NSC line to investigate what effect DISP3 may have on the self-renewal and/or differentiation potential of the cells. We demonstrated that NSC differentiation triggered significant reduction in DISP3 expression in the resulting astrocytes, neurons and oligodendrocytes. Moreover, when DISP3 expression was disrupted, the NSC “stemness” was suppressed, leading to a larger population of cells undergoing spontaneous neuronal differentiation. Conversely, overexpression of DISP3 resulted in increased NSC proliferation. When NSCs were cultured under differentiation conditions, we observed that the lack of DISP3 augmented the number of NSCs differentiating into each of the neural cell lineages and that neuronal morphology was altered. In contrast, DISP3 overexpression resulted in impaired cell differentiation. Taken together, our findings imply that DISP3 may help dictate the NSC cell fate to either undergo self-renewal or switch to the terminal differentiation cell program.","tags":["#literature_note"],"author":[{"family":"Konířová","given":"Jana","literal":""},{"family":"Konířová","given":"Jana","literal":""},{"family":"Konířová","given":"Jana","literal":""},{"family":"Oltová","given":"Jana","literal":""},{"family":"Oltová","given":"Jana","literal":""},{"family":"Corlett","given":"Alicia","literal":""},{"family":"Corlett","given":"Alicia","literal":""},{"family":"Kopycińska","given":"Justyna","literal":""},{"family":"Kopycińska","given":"Justyna","literal":""},{"family":"Kolář","given":"Michal","literal":""},{"family":"Kolář","given":"Michal","literal":""},{"family":"Kolář","given":"Michal","literal":""},{"family":"Bartunek","given":"Petr","literal":""},{"family":"Bartůněk","given":"Petr","literal":""},{"family":"Bartůněk","given":"Petr","literal":""},{"family":"Zı́ková","given":"Martina","literal":""},{"family":"Zikova","given":"Martina","literal":""}],"citation-key":"konirova_modulated_2017","year":"2017","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Modulated DISP3/PTCHD2 expression influences neural stem cell fate decisions."],"author-links":["[[Author/Jana Konířová]]","[[Author/Jana Konířová]]","[[Author/Jana Konířová]]","[[Author/Jana Oltová]]","[[Author/Jana Oltová]]","[[Author/Alicia Corlett]]","[[Author/Alicia Corlett]]","[[Author/Justyna Kopycińska]]","[[Author/Justyna Kopycińska]]","[[Author/Michal Kolář]]","[[Author/Michal Kolář]]","[[Author/Michal Kolář]]","[[Author/Petr Bartunek]]","[[Author/Petr Bartůněk]]","[[Author/Petr Bartůněk]]","[[Author/Martina Zı́ková]]","[[Author/Martina Zikova]]"],"attachment":["[[biblib/konirova_modulated_2017/konirova_modulated_2017.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"1nm6dg1","at":1774951890810}},"smart_blocks:Research/@konirova_modulated_2017.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.02481646,0.022026,-0.01752522,-0.00931242,-0.05255817,0.08368032,0.03125885,0.05726762,-0.01846441,0.00440303,0.03439599,-