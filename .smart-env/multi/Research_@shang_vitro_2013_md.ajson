0.18903969,0.02777388,-0.04308121,-0.01044311,-0.01740995,0.04398872,-0.02155344,0.0286447,0.03365212,0.01283377,0.14640073,-0.02011193,0.100118,0.04454901,-0.03926456,-0.06026745,-0.01910015,-0.01461134,0.00289983,-0.02575979,-0.12338482,-0.03425894,0.08048801,-0.06730116,-0.02080121,-0.01895564,-0.01967267,0.02008256,0.0212314,-0.00900944,0.0493927,0.03253436,0.04090185,-0.01790487,0.00117431,-0.00505326,-0.04437664,0.02729159,0.0210842,-0.00263901,-0.05901341,0.05090022,0.06221799],"last_embed":{"hash":"158z29n","tokens":499}}},"last_read":{"hash":"158z29n","at":1774951891849},"class_name":"SmartSource","last_import":{"mtime":1774951823257,"size":3577,"at":1774951884810,"hash":"158z29n"},"blocks":{"#---frontmatter---":[1,76],"#In vitro anti-Helicobacter pylori effects of medicinal mushroom extracts, with special emphasis on the Lion's Mane mushroom, Hericium erinaceus (higher Basidiomycetes).":[78,82],"#In vitro anti-Helicobacter pylori effects of medicinal mushroom extracts, with special emphasis on the Lion's Mane mushroom, Hericium erinaceus (higher Basidiomycetes).#{1}":[80,82]},"outlinks":[{"title":"Author/Xiaodong Shang","target":"Author/Xiaodong Shang","line":60},{"title":"Author/Xiaodong Shang","target":"Author/Xiaodong Shang","line":61},{"title":"Author/Qian Tan","target":"Author/Qian Tan","line":62},{"title":"Author/Qi Tan","target":"Author/Qi Tan","line":63},{"title":"Author/Qi Tan","target":"Author/Qi Tan","line":64},{"title":"Author/Liu Ruina","target":"Author/Liu Ruina","line":65},{"title":"Author/Ruina Liu","target":"Author/Ruina Liu","line":66},{"title":"Author/Kangying Yu","target":"Author/Kangying Yu","line":67},{"title":"Author/Kangying Yu","target":"Author/Kangying Yu","line":68},{"title":"Author/Pingzuo Li","target":"Author/Pingzuo Li","line":69},{"title":"Author/Pingzuo Li","target":"Author/Pingzuo Li","line":70},{"title":"Author/Guoping Zhao","target":"Author/Guoping Zhao","line":71},{"title":"Author/Guo-Ping Zhao","target":"Author/Guo-Ping Zhao","line":72}],"metadata":{"id":"shang_vitro_2013","type":"article-journal","title":"In vitro anti-Helicobacter pylori effects of medicinal mushroom extracts, with special emphasis on the Lion's Mane mushroom, Hericium erinaceus (higher Basidiomycetes).","issued":{"date-parts":[[2013]]},"DOI":"10.1615/intjmedmushr.v15.i2.50","container-title":"International Journal of Medicinal Mushrooms","abstract":"Although the medicinal mushroom Hericium erinaceus is used extensively in traditional Chinese medicine to treat chronic superficial gastritis, the underlining pharmaceutical mechanism is yet to be fully understood. In this study, minimum inhibitory concentration (MIC) values of extracts prepared from the fruiting bodies of 14 mushroom species (H. erinaceus, Ganoderma lucidum, Cordyceps militaris, Pleurotus eryngii, P. ostreatus, Agrocybe aegerita, Lentinus edodes, Agaricus brasiliensis, A. bisporus, Coprinus comatus, Grifola frondosa, Phellinus igniarius, Flammulina velutipes, and Hypsizygus marmoreus) were determined against Helicobacter pylori using laboratory strains of ATCC 43504 and SS1 as well as 9 clinical isolates via an in vitro microplate agar diffusion assay. Ethanol extracts (EEs) of 12 mushrooms inhibited the growth of H. pylori in vitro, with MIC values 10 mg/mL). MIC values of ethyl acetate fractions (EAFs) of H. erinaceus against 9 clinical isolates of H. pylori ranged between 62.5 and 250 µg/mL. The bacteriostatic activity of EAFs was found to be concentration-dependant, and the half maximal inhibitory concentration and minimum bactericidal concentration values for H. pylori ATCC 43504 were 73.0 and 200 µg/mL, respectively. The direct inhibitory effect of EEs and EAFs of H. erinaceus against H. pylori could be another pharmaceutical mechanism of medicinal mushrooms-besides the immunomodulating effect of polysaccharides, suggested previously-in the treatment of H. pylori-associated gastrointestinal disorders. Further research to identify the active component(s) is currently undertaking in our laboratory.","tags":["#literature_note"],"author":[{"family":"Shang","given":"Xiaodong","literal":""},{"family":"Shang","given":"Xiaodong","literal":""},{"family":"Tan","given":"Qian","literal":""},{"family":"Tan","given":"Qi","literal":""},{"family":"Tan","given":"Qi","literal":""},{"family":"Ruina","given":"Liu","literal":""},{"family":"Liu","given":"Ruina","literal":""},{"family":"Yu","given":"Kangying","literal":""},{"family":"Yu","given":"Kangying","literal":""},{"family":"Li","given":"Pingzuo","literal":""},{"family":"Li","given":"Pingzuo","literal":""},{"family":"Zhao","given":"Guoping","literal":""},{"family":"Zhao","given":"Guo-Ping","literal":""}],"citation-key":"shang_vitro_2013","year":"2013","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["In vitro anti-Helicobacter pylori effects of medicinal mushroom extracts, with special emphasis on the Lion's Mane mushroom, Hericium erinaceus (higher Basidiomycetes)."],"author-links":["[[Author/Xiaodong Shang]]","[[Author/Xiaodong Shang]]","[[Author/Qian Tan]]","[[Author/Qi Tan]]","[[Author/Qi Tan]]","[[Author/Liu Ruina]]","[[Author/Ruina Liu]]","[[Author/Kangying Yu]]","[[Author/Kangying Yu]]","[[Author/Pingzuo Li]]","[[Author/Pingzuo Li]]","[[Author/Guoping Zhao]]","[[Author/Guo-Ping Zhao]]"],"attachment":[],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"158z29n","at":1774951891838}},"smart_blocks:Research/@shang_vitro_2013.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[0.00617284,-0.04576902,0.01046457,-0.06139747,0.04569243,0.00278284,0.00638036,0.02743584,-0.05748409,0.00529447,0.03687607,-0.09617149,0.03512624,-0.0187333,0.00763419,0.04605924,0.01925066,-0.00841135,-0.12529914,0.01356519,0.02854104,-0.02272129,-0.00453397,0.01267182,0.03888772,0.0777076,0.00779842,-0.02914765,-0.03430817,-0.21006836,-0.00953409,-0.04640059,0.03679297,-0.00235857,-0.03944666,-0.02935603,-0.005