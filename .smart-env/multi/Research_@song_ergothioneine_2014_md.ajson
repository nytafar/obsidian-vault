8,0.02378275,0.05204871,0.1851383,0.00322865,-0.01920441,-0.00159187,-0.01503581,0.05240742,0.07739728,0.02877466,-0.00955761,0.07006174,0.10131277,-0.03607638,0.10026354,0.02008682,-0.04145398,-0.00105712,0.00952874,-0.00247381,0.05131543,0.01919146,-0.02130244,-0.04227524,0.12415662,-0.04565176,0.0437803,-0.07860786,-0.0587059,-0.01229014,0.02711539,-0.02478721,0.00033066,0.02986208,-0.01298304,0.02045241,0.03616639,0.01993072,-0.02386412,-0.02959266,-0.02346597,0.03756728,-0.01020658,0.09019608,0.03696785],"last_embed":{"hash":"mm6we0","tokens":510}}},"last_read":{"hash":"mm6we0","at":1774951885723},"class_name":"SmartSource","last_import":{"mtime":1774951814201,"size":3159,"at":1774951884764,"hash":"mm6we0"},"blocks":{"#---frontmatter---":[1,85],"#Ergothioneine and melatonin attenuate oxidative stress and protect against learning and memory deficits in C57BL/6J mice treated with D-galactose":[87,91],"#Ergothioneine and melatonin attenuate oxidative stress and protect against learning and memory deficits in C57BL/6J mice treated with D-galactose#{1}":[89,91]},"outlinks":[{"title":"Author/Tuzz-Ying Song","target":"Author/Tuzz-Ying Song","line":66},{"title":"Author/Tuzz-Ying Song","target":"Author/Tuzz-Ying Song","line":67},{"title":"Author/Herng Ching Lin","target":"Author/Herng Ching Lin","line":68},{"title":"Author/H.-C. Lin","target":"Author/H.-C. Lin","line":69},{"title":"Author/Chien-Lin Chen","target":"Author/Chien-Lin Chen","line":70},{"title":"Author/C.-L. Chen","target":"Author/C.-L. Chen","line":71},{"title":"Author/June H. Wu","target":"Author/June H. Wu","line":72},{"title":"Author/Jhoa-Huei Wu","target":"Author/Jhoa-Huei Wu","line":73},{"title":"Author/Jyh-Horng Wu","target":"Author/Jyh-Horng Wu","line":74},{"title":"Author/Jiunn-Wang Liao","target":"Author/Jiunn-Wang Liao","line":75},{"title":"Author/Jiunn-Wang Liao","target":"Author/Jiunn-Wang Liao","line":76},{"title":"Author/Miao-Lin Hu","target":"Author/Miao-Lin Hu","line":77},{"title":"Author/Miao-Lin Hu","target":"Author/Miao-Lin Hu","line":78},{"title":"Author/Miao-Lin Hu","target":"Author/Miao-Lin Hu","line":79},{"title":"Author/Miao-Lin Hu","target":"Author/Miao-Lin Hu","line":80},{"title":"PDF","target":"biblib/song_ergothioneine_2014/song_ergothioneine_2014.pdf","line":82}],"metadata":{"id":"song_ergothioneine_2014","type":"article-journal","title":"Ergothioneine and melatonin attenuate oxidative stress and protect against learning and memory deficits in C57BL/6J mice treated with D-galactose","issued":{"date-parts":[[2014]]},"DOI":"10.3109/10715762.2014.920954","container-title":"Free Radical Research","abstract":"AbstractMale C57BL/6J mice treated with D-galactose (DG) were used to examine the effects of ergothioneine (EGT), melatonin (MEL), or their combination (EGT+MEL) on learning and memory abilities. The mice were divided into five groups and injected subcutaneously with DG (0.3 mL of 1% DG/mouse) except for group 1 (normal controls). Group 3 was orally supplemented with EGT [0.5 mg/kg body weight (bw)], group 4 with MEL (10 mg/kg bw, p.o.), and group 5 with EGT+MEL. EGT and MEL were provided daily for 88 days, while DG was provided between days 7 to 56. Active avoidance task and Morris water-maze task were used to evaluate learning and memory abilities. DG treatment markedly increased escape latency and decreased the number of avoidance in the active avoidance test, whereas EGT and MEL alone significantly improved the performance. DG also impaired the learning and memory abilities in the water-maze task, and EGT and MEL alone also significantly improved the performance. EGT+MEL produced the strongest effects...","tags":["#literature_note"],"author":[{"family":"Song","given":"Tuzz-Ying","literal":""},{"family":"Song","given":"Tuzz-Ying","literal":""},{"family":"Lin","given":"Herng Ching","literal":""},{"family":"Lin","given":"H.-C.","literal":""},{"family":"Chen","given":"Chien-Lin","literal":""},{"family":"Chen","given":"C.-L.","literal":""},{"family":"Wu","given":"June H.","literal":""},{"family":"Wu","given":"Jhoa-Huei","literal":""},{"family":"Wu","given":"Jyh-Horng","literal":""},{"family":"Liao","given":"Jiunn-Wang","literal":""},{"family":"Liao","given":"Jiunn-Wang","literal":""},{"family":"Hu","given":"Miao-Lin","literal":""},{"family":"Hu","given":"Miao-Lin","literal":""},{"family":"Hu","given":"Miao-Lin","literal":""},{"family":"Hu","given":"Miao-Lin","literal":""}],"citation-key":"song_ergothioneine_2014","year":"2014","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Ergothioneine and melatonin attenuate oxidative stress and protect against learning and memory deficits in C57BL/6J mice treated with D-galactose"],"author-links":["[[Author/Tuzz-Ying Song]]","[[Author/Tuzz-Ying Song]]","[[Author/Herng Ching Lin]]","[[Author/H.-C. Lin]]","[[Author/Chien-Lin Chen]]","[[Author/C.-L. Chen]]","[[Author/June H. Wu]]","[[Author/Jhoa-Huei Wu]]","[[Author/Jyh-Horng Wu]]","[[Author/Jiunn-Wang Liao]]","[[Author/Jiunn-Wang Liao]]","[[Author/Miao-Lin Hu]]","[[Author/Miao-Lin Hu]]","[[Author/Miao-Lin Hu]]","[[Author/Miao-Lin Hu]]"],"attachment":["[[biblib/song_ergothioneine_2014/song_ergothioneine_2014.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"mm6we0","at":1774951885713}},"smart_blocks:Research/@song_ergothioneine_2014.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.01819152,0.01405795,0.05997979,0.01100119,-0.00005209,0.04404077,-0.0062353,0.04141394,-0.02564888,-0.0228602,0.00103203,-0.00810761,0.02442224,0.07196402,0.01121264,0.03193015,-0.03970706,0.00159671,-0.09309834,0.01077639,0.00278278,-0.01936075,-0.00130418,-0.02720038,0.01996019,-0.00260193,-0.07124797,-0.03278942,-0.09708554,-0.22449751,0.00075268,-0.0357731,0.04696015,-0.01583761,-0.10196725,0.0523027,-0.01726891,0.04735295,-0.02319249,-0.00108201,0.09036573,0.05519498,-0.01282047,0.00634721,-0.02218429,0.04697153,-0.06046743,-0.0841661