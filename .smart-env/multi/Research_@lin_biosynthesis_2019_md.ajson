-0.01119791,0.01367256,0.18296629,0.03750634,0.02103957,0.02553662,-0.0150352,0.03281921,-0.03445651,0.03876724,0.02478841,0.05421231,0.12509036,-0.03679921,0.03469737,0.04477364,-0.02305231,-0.02519072,-0.03017318,0.00186263,-0.04167747,-0.05928611,-0.13617715,-0.03700845,0.11255936,-0.06955354,-0.05316858,-0.06267657,0.00936759,0.02607429,-0.05604755,0.00651837,0.04051083,0.02841694,-0.07083065,-0.01696376,0.01559322,-0.05060442,-0.05791059,-0.00411007,-0.0646608,0.02506524,-0.0653799,0.07802684,0.00209075],"last_embed":{"hash":"1pfl72e","tokens":428}}},"last_read":{"hash":"1pfl72e","at":1774951889256},"class_name":"SmartSource","last_import":{"mtime":1774951820160,"size":2143,"at":1774951884797,"hash":"1pfl72e"},"blocks":{"#---frontmatter---":[1,61],"#Biosynthesis of bioactive natural products from Basidiomycota":[63,67],"#Biosynthesis of bioactive natural products from Basidiomycota#{1}":[65,67]},"outlinks":[{"title":"Author/Hsiao-Ching Lin","target":"Author/Hsiao-Ching Lin","line":48},{"title":"Author/Hsiao-Ching Lin","target":"Author/Hsiao-Ching Lin","line":49},{"title":"Author/Ranuka T. Hewage","target":"Author/Ranuka T. Hewage","line":50},{"title":"Author/Ranuka T. Hewage","target":"Author/Ranuka T. Hewage","line":51},{"title":"Author/Ranuka T. Hewage","target":"Author/Ranuka T. Hewage","line":52},{"title":"Author/Yuan-Chun Lu","target":"Author/Yuan-Chun Lu","line":53},{"title":"Author/Yuan-Chun Lu","target":"Author/Yuan-Chun Lu","line":54},{"title":"Author/Yit-Heng Chooi","target":"Author/Yit-Heng Chooi","line":55},{"title":"Author/Yit-Heng Chooi","target":"Author/Yit-Heng Chooi","line":56},{"title":"PDF","target":"biblib/lin_biosynthesis_2019/lin_biosynthesis_2019.pdf","line":58}],"metadata":{"id":"lin_biosynthesis_2019","type":"article-journal","title":"Biosynthesis of bioactive natural products from Basidiomycota","issued":{"date-parts":[[2019]]},"DOI":"10.1039/c8ob02774a","container-title":"Organic and Biomolecular Chemistry","abstract":"The Basidiomycota, also called club fungi, comprise a diverse group of fungi. Basidiomycota are strongly related to ecosystem functioning along with human life. These fungi display a wide range of bioactivities, and some are known to produce of deadly toxins or hallucinogens. Some Basidiomycota have be used as medicinal mushrooms for thousands of years. Recently, the biosyntheses of several classes of natural products from Basidiomycota have been reported. Here, we review recent studies on the biosynthetic pathways and enzymes of bioactive natural products from Basidiomycota fungi, with a focus on terpenoids, alkaloids, ribosomally synthesized and post-translationally modified peptides (RiPPs), and polyketides.","tags":["#literature_note"],"author":[{"family":"Lin","given":"Hsiao-Ching","literal":""},{"family":"Lin","given":"Hsiao-Ching","literal":""},{"family":"Hewage","given":"Ranuka T.","literal":""},{"family":"Hewage","given":"Ranuka T.","literal":""},{"family":"Hewage","given":"Ranuka T.","literal":""},{"family":"Lu","given":"Yuan-Chun","literal":""},{"family":"Lu","given":"Yuan-Chun","literal":""},{"family":"Chooi","given":"Yit-Heng","literal":""},{"family":"Chooi","given":"Yit-Heng","literal":""}],"citation-key":"lin_biosynthesis_2019","year":"2019","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Biosynthesis of bioactive natural products from Basidiomycota"],"author-links":["[[Author/Hsiao-Ching Lin]]","[[Author/Hsiao-Ching Lin]]","[[Author/Ranuka T. Hewage]]","[[Author/Ranuka T. Hewage]]","[[Author/Ranuka T. Hewage]]","[[Author/Yuan-Chun Lu]]","[[Author/Yuan-Chun Lu]]","[[Author/Yit-Heng Chooi]]","[[Author/Yit-Heng Chooi]]"],"attachment":["[[biblib/lin_biosynthesis_2019/lin_biosynthesis_2019.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"1pfl72e","at":1774951889248}},"smart_blocks:Research/@lin_biosynthesis_2019.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.0301573