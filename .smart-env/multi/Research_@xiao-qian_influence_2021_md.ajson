1,-0.01487523,0.17021921,0.00121834,-0.01735153,-0.00345124,0.01217208,0.02642103,-0.00984402,0.01196671,0.01836954,0.03500996,0.10406093,-0.0028527,0.04424511,0.04324858,-0.02638745,-0.05546026,-0.0059497,-0.00139683,0.02738812,-0.0059839,-0.09929717,-0.03989255,0.10838925,-0.08104346,-0.03584791,-0.03555951,-0.01374509,0.01030441,-0.0193812,0.01164371,-0.00001708,0.00475278,-0.00536155,-0.03134295,-0.05324833,-0.00915499,-0.0331715,-0.0131197,0.0354648,-0.0001905,-0.12527408,0.09660812,0.0322693],"last_embed":{"hash":"15xw41c","tokens":473}}},"last_read":{"hash":"15xw41c","at":1774951892804},"class_name":"SmartSource","last_import":{"mtime":1774951824897,"size":3757,"at":1774951884816,"hash":"15xw41c"},"blocks":{"#---frontmatter---":[1,97],"#Influence of Short-Term Consumption of Hericium erinaceus on Serum Biochemical Markers and the Changes of the Gut Microbiota: A Pilot Study.":[99,103],"#Influence of Short-Term Consumption of Hericium erinaceus on Serum Biochemical Markers and the Changes of the Gut Microbiota: A Pilot Study.#{1}":[101,103]},"outlinks":[{"title":"Author/Xie Xiao-qian","target":"Author/Xie Xiao-qian","line":75},{"title":"Author/Xiao-Qian Xie","target":"Author/Xiao-Qian Xie","line":76},{"title":"Author/Yan Geng","target":"Author/Yan Geng","line":77},{"title":"Author/Yan Geng","target":"Author/Yan Geng","line":78},{"title":"Author/Qijie Guan","target":"Author/Qijie Guan","line":79},{"title":"Author/Qijie Guan","target":"Author/Qijie Guan","line":80},{"title":"Author/Yilin Ren","target":"Author/Yilin Ren","line":81},{"title":"Author/Yilin Ren","target":"Author/Yilin Ren","line":82},{"title":"Author/Lin Guo","target":"Author/Lin Guo","line":83},{"title":"Author/Guo Lin","target":"Author/Guo Lin","line":84},{"title":"Author/Qiqi Lv","target":"Author/Qiqi Lv","line":85},{"title":"Author/Qiqi Lv","target":"Author/Qiqi Lv","line":86},{"title":"Author/Zhen-Ming Lü","target":"Author/Zhen-Ming Lü","line":87},{"title":"Author/Zhen-Ming Lu","target":"Author/Zhen-Ming Lu","line":88},{"title":"Author/Jin-Song Shi","target":"Author/Jin-Song Shi","line":89},{"title":"Author/Jinsong Shi","target":"Author/Jinsong Shi","line":90},{"title":"Author/Zhenghong Xu","target":"Author/Zhenghong Xu","line":91},{"title":"Author/Zhenghong Xu","target":"Author/Zhenghong Xu","line":92},{"title":"PDF","target":"biblib/xiao-qian_influence_2021/xiao-qian_influence_2021.pdf","line":94}],"metadata":{"id":"xiao-qian_influence_2021","type":"article-journal","title":"Influence of Short-Term Consumption of Hericium erinaceus on Serum Biochemical Markers and the Changes of the Gut Microbiota: A Pilot Study.","issued":{"date-parts":[[2021]]},"DOI":"10.3390/nu13031008","container-title":"Nutrients","abstract":"Hericium erinaceus (H. erinaceus) is widely studied as a medicinal and edible fungus. Recent studies have shown that H. erinaceus has protective effects for diseases, such as inflammatory bowel disease and cancer, which are related to gut microbiota. To investigate the benefits of H. erinaceus intake on gut microbiota and blood indices in adulthood, we recruited 13 healthy adults to consume H. erinaceus powder as a dietary supplement. Blood changes due to H. erinaceus consumption were determined by routine hematological examination and characterized by serum biochemical markers. Microbiota composition was profiled by 16S ribosomal RNA gene sequencing. Results showed that daily H. erinaceus supplementation increased the alpha diversity within the gut microbiota community, upregulated the relative abundance of some short-chain fatty acid (SCFA) producing bacteria (Kineothrix alysoides, Gemmiger formicilis, Fusicatenibacter saccharivorans, Eubacterium rectale, Faecalibacterium prausnitzii), and downregulated some pathobionts (Streptococcus thermophilus, Bacteroides caccae, Romboutsia timonensis). Changes within the gut microbiota were correlated with blood chemical indices including alkaline phosphatase (ALP), low-density lipoprotein (LDL), uric acid (UA), and creatinine (CREA). Thus, we found that the gut microbiota alterations may be part of physiological adaptations to a seven-day H. erinaceus supplementation, potentially influencing beneficial health effects.","tags":["#literature_note"],"author":[{"family":"Xiao-qian","given":"Xie","literal":""},{"family":"Xie","given":"Xiao-Qian","literal":""},{"family":"Geng","given":"Yan","literal":""},{"family":"Geng","given":"Yan","literal":""},{"family":"Guan","given":"Qijie","literal":""},{"family":"Guan","given":"Qijie","literal":""},{"family":"Ren","given":"Yilin","literal":""},{"family":"Ren","given":"Yilin","literal":""},{"family":"Guo","given":"Lin","literal":""},{"family":"Lin","given":"Guo","literal":""},{"family":"Lv","given":"Qiqi","literal":""},{"family":"Lv","given":"Qiqi","literal":""},{"family":"Lü","given":"Zhen-Ming","literal":""},{"family":"Lu","given":"Zhen-Ming","literal":""},{"family":"Shi","given":"Jin-Song","literal":""},{"family":"Shi","given":"Jinsong","literal":""},{"family":"Xu","given":"Zhenghong","literal":""},{"family":"Xu","given":"Zhenghong","literal":""}],"citation-key":"xiao-qian_influence_2021","year":"2021","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Influence of Short-Term Consumption of Hericium erinaceus on Serum Biochemical Markers and the Changes of the Gut Microbiota: A Pilot Study."],"author-links":["[[Author/Xie Xiao-qian]]","[[Author/Xiao-Qian Xie]]","[[Author/Yan Geng]]","[[Author/Yan Geng]]","[[Author/Qijie Guan]]","[[Author/Qijie Guan]]","[[Author/Yilin Ren]]","[[Author/Yilin Ren]]","[[Author/Lin Guo]]","[[Author/Guo Lin]]","[[Author/Qiqi Lv]]","[[Author/Qiqi Lv]]","[[Author/Zhen-Ming Lü]]","[[Author/Zhen-Ming Lu]]","[[Author/Jin-Song Shi]]","[[Author/Jinsong Shi]]","[[Author/Zhenghong Xu]]","[[Author/Zhenghong Xu]]"],"attachment":["[[biblib/xiao-qian_influence_2021/xiao-qian_influence_2021.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"15xw41c