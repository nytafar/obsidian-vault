0.01809267,0.20156838,0.02767597,-0.07854994,0.00925256,-0.04864454,0.01091054,0.01513278,0.01785951,0.0038448,0.06790402,0.10914828,0.01993567,0.04779236,0.04198023,-0.01200525,-0.03034715,-0.06661507,-0.03812002,-0.02902281,-0.0124777,-0.14266816,-0.0733688,0.1085394,-0.04434205,-0.01714763,-0.07085792,-0.02147956,-0.01215809,-0.08073159,-0.02631182,-0.00229044,0.02192445,-0.02910414,-0.04687912,-0.01254695,0.02191036,-0.0061233,-0.05176905,0.02726198,-0.01263088,-0.06160935,0.06918753,0.03478812],"last_embed":{"hash":"5trv11","tokens":462}}},"last_read":{"hash":"5trv11","at":1774951889303},"class_name":"SmartSource","last_import":{"mtime":1774951820241,"size":3452,"at":1774951884797,"hash":"5trv11"},"blocks":{"#---frontmatter---":[1,85],"#First successful domestication and determination of nutritional and antioxidant properties of the red ear mushroom Auricularia thailandica ( Auriculariales, Basidiomycota )":[87,91],"#First successful domestication and determination of nutritional and antioxidant properties of the red ear mushroom Auricularia thailandica ( Auriculariales, Basidiomycota )#{1}":[89,91]},"outlinks":[{"title":"Author/Asanka R. Bandara","target":"Author/Asanka R. Bandara","line":66},{"title":"Author/Asanka R. Bandara","target":"Author/Asanka R. Bandara","line":67},{"title":"Author/Asanka R. Bandara","target":"Author/Asanka R. Bandara","line":68},{"title":"Author/Samantha C. Karunarathna","target":"Author/Samantha C. Karunarathna","line":69},{"title":"Author/Samantha C. Karunarathna","target":"Author/Samantha C. Karunarathna","line":70},{"title":"Author/Peter E. Mortimer","target":"Author/Peter E. Mortimer","line":71},{"title":"Author/Peter E. Mortimer","target":"Author/Peter E. Mortimer","line":72},{"title":"Author/Kevin D. Hyde","target":"Author/Kevin D. Hyde","line":73},{"title":"Author/Kevin D. Hyde","target":"Author/Kevin D. Hyde","line":74},{"title":"Author/Sehroon Khan","target":"Author/Sehroon Khan","line":75},{"title":"Author/Sehroon Khan","target":"Author/Sehroon Khan","line":76},{"title":"Author/Pattana Kakumyan","target":"Author/Pattana Kakumyan","line":77},{"title":"Author/Pattana Kakumyan","target":"Author/Pattana Kakumyan","line":78},{"title":"Author/Jianchu Xu","target":"Author/Jianchu Xu","line":79},{"title":"Author/Jianchu Xu","target":"Author/Jianchu Xu","line":80},{"title":"PDF","target":"biblib/bandara_first_2017/bandara_first_2017.pdf","line":82}],"metadata":{"id":"bandara_first_2017","type":"article-journal","title":"First successful domestication and determination of nutritional and antioxidant properties of the red ear mushroom Auricularia thailandica ( Auriculariales, Basidiomycota )","issued":{"date-parts":[[2017]]},"DOI":"10.1007/s11557-017-1344-7","container-title":"Mycological Progress","abstract":"In order to fulfill the increasing demand for edible mushrooms and maintain a steady supply throughout the year, it is necessary to domesticate new wild edible mushroom species. In this study, we domesticated Auricularia thailandica, a newly identified edible species that was collected from the wild in Thailand. We compared the growth of A. thailandica in three different growth media: sawdust, wheat husk and sugarcane bagasse. The use of sawdust resulted in the fastest rate of mycelial colonisation at 56.4 +/- 1.2 days, pinheads were formed in 14.2 +/- 0.4 days and the biological efficiency was 17.1 +/- 2.8%. Nutritional analysis showed that A. thailandica contained a higher proportion of protein (12.99 +/- 0.05%) and fat (2.93 +/- 0.66%) by dry weight than other commercial Auricularia spp. available on the market. The antioxidant potential of A. thailandica varied with the extraction solvent used, and the effective concentration was found to be significantly lower in methanol extract than aqueous extract. Additionally, this species has an attractive reddish orange colour and larger basidiocarps than other commercially available species.","tags":["#literature_note"],"author":[{"family":"Bandara","given":"Asanka R.","literal":""},{"family":"Bandara","given":"Asanka R.","literal":""},{"family":"Bandara","given":"Asanka R.","literal":""},{"family":"Karunarathna","given":"Samantha C.","literal":""},{"family":"Karunarathna","given":"Samantha C.","literal":""},{"family":"Mortimer","given":"Peter E.","literal":""},{"family":"Mortimer","given":"Peter E.","literal":""},{"family":"Hyde","given":"Kevin D.","literal":""},{"family":"Hyde","given":"Kevin D.","literal":""},{"family":"Khan","given":"Sehroon","literal":""},{"family":"Khan","given":"Sehroon","literal":""},{"family":"Kakumyan","given":"Pattana","literal":""},{"family":"Kakumyan","given":"Pattana","literal":""},{"family":"Xu","given":"Jianchu","literal":""},{"family":"Xu","given":"Jianchu","literal":""}],"citation-key":"bandara_first_2017","year":"2017","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["First successful domestication and determination of nutritional and antioxidant properties of the red ear mushroom Auricularia thailandica ( Auriculariales, Basidiomycota )"],"author-links":["[[Author/Asanka R. Bandara]]","[[Author/Asanka R. Bandara]]","[[Author/Asanka R. Bandara]]","[[Author/Samantha C. Karunarathna]]","[[Author/Samantha C. Karunarathna]]","[[Author/Peter E. Mortimer]]","[[Author/Peter E. Mortimer]]","[[Author/Kevin D. Hyde]]","[[Author/Kevin D. Hyde]]","[[Author/Sehroon Khan]]","[[Author/Sehroon Khan]]","[[Author/Pattana Kakumyan]]","[[Author/Pattana Kakumyan]]","[[Author/Jianchu Xu]]","[[Author/Jianchu Xu]]"],"attachment":["[[biblib/bandara_first_2017/bandara_first_2017.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"5trv11","at":1774951889294}},"smart_blocks:Research/@bandara_first_2017.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.0357793,-0.04420884,0.02016099,-0.0268795,0.03013223,-0.00357447,0.01555141,0.03878087,-0.04385939,-0.00518939,0.0226088,-0.08739767,-0.01742678,0.044