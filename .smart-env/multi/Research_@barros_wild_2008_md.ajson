78,-0.01840563,-0.04235602,0.02903789,-0.0311895,0.00338163,-0.03177808,0.0404503,0.06144781,0.04845401,0.10663524,-0.00264487,0.01107493,0.09885772,-0.01303618,-0.02466771,-0.02085183,-0.02162072,0.05032878,-0.05574654,-0.12843452,-0.06739624,0.1034675,-0.11430715,-0.04897804,-0.07897635,-0.00561778,-0.00230367,-0.00976493,-0.00196942,-0.04002283,0.05496309,-0.01683707,-0.05966262,-0.04832941,0.03192251,-0.04200514,-0.00911604,0.03631516,-0.01653969,-0.08458079,0.11616188,0.02181903],"last_embed":{"hash":"ivdeo4","tokens":432}}},"last_read":{"hash":"ivdeo4","at":1774951885810},"class_name":"SmartSource","last_import":{"mtime":1774951814294,"size":2967,"at":1774951884765,"hash":"ivdeo4"},"blocks":{"#---frontmatter---":[1,65],"#Wild and commercial mushrooms as source of nutrients and nutraceuticals":[67,71],"#Wild and commercial mushrooms as source of nutrients and nutraceuticals#{1}":[69,71]},"outlinks":[{"title":"Author/Lillian Barros","target":"Author/Lillian Barros","line":51},{"title":"Author/Lillian Barros","target":"Author/Lillian Barros","line":52},{"title":"Author/Telma Cruz","target":"Author/Telma Cruz","line":53},{"title":"Author/Telma Cruz","target":"Author/Telma Cruz","line":54},{"title":"Author/Paula Baptista","target":"Author/Paula Baptista","line":55},{"title":"Author/Paula Baptista","target":"Author/Paula Baptista","line":56},{"title":"Author/Letí-cia M. Estevinho","target":"Author/Letí-cia M. Estevinho","line":57},{"title":"Author/Leticia M. Estevinho","target":"Author/Leticia M. Estevinho","line":58},{"title":"Author/Isabel C. F. R. Ferreira","target":"Author/Isabel C. F. R. Ferreira","line":59},{"title":"Author/Isabel C. F. R. Ferreira","target":"Author/Isabel C. F. R. Ferreira","line":60},{"title":"PDF","target":"biblib/barros_wild_2008/barros_wild_2008.pdf","line":62}],"metadata":{"id":"barros_wild_2008","type":"article-journal","title":"Wild and commercial mushrooms as source of nutrients and nutraceuticals","issued":{"date-parts":[[2008]]},"DOI":"10.1016/j.fct.2008.04.030","container-title":"Food and Chemical Toxicology","abstract":"Abstract In order to promote the use of mushrooms as source of nutrients and nutraceuticals, several experiments were performed in wild and commercial species. The analysis of nutrients included determination of proteins, fats, ash, and carbohydrates, particularly sugars by HPLC-RI. The analysis of nutraceuticals included determination of fatty acids by GC-FID, and other phytochemicals such as tocopherols, by HPLC-fluorescence, and phenolics, flavonoids, carotenoids and ascorbic acid, by spectrophotometer techniques. The antimicrobial properties of the mushrooms were also screened against fungi, Gram positive and Gram negative bacteria. The wild mushroom species proved to be less energetic than the commercial sp., containing higher contents of protein and lower fat concentrations. In general, commercial species seem to have higher concentrations of sugars, while wild sp. contained lower values of MUFA but also higher contents of PUFA. α-Tocopherol was detected in higher amounts in the wild species, while γ-tocopherol was not found in these species. Wild mushrooms revealed a higher content of phenols but a lower content of ascorbic acid, than commercial mushrooms. There were no differences between the antimicrobial properties of wild and commercial species. The ongoing research will lead to a new generation of foods, and will certainly promote their nutritional and medicinal use.","tags":["#literature_note"],"author":[{"family":"Barros","given":"Lillian","literal":""},{"family":"Barros","given":"Lillian","literal":""},{"family":"Cruz","given":"Telma","literal":""},{"family":"Cruz","given":"Telma","literal":""},{"family":"Baptista","given":"Paula","literal":""},{"family":"Baptista","given":"Paula","literal":""},{"family":"Estevinho","given":"Letí-cia M.","literal":""},{"family":"Estevinho","given":"Leticia M.","literal":""},{"family":"Ferreira","given":"Isabel C. F. R.","literal":""},{"family":"Ferreira","given":"Isabel C. F. R.","literal":""}],"citation-key":"barros_wild_2008","year":"2008","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Wild and commercial mushrooms as source of nutrients and nutraceuticals"],"author-links":["[[Author/Lillian Barros]]","[[Author/Lillian Barros]]","[[Author/Telma Cruz]]","[[Author/Telma Cruz]]","[[Author/Paula Baptista]]","[[Author/Paula Baptista]]","[[Author/Letí-cia M. Estevinho]]","[[Author/Leticia M. Estevinho]]","[[Author/Isabel C. F. R. Ferreira]]","[[Author/Isabel C. F. R. Ferreira]]"],"attachment":["[[biblib/barros_wild_2008/barros_wild_2008.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"ivdeo4","at":1774951885803}},"smart_blocks:Research/@barros_wild_2008.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.00578597,0.003887,0.02162029,-0.01528475,0.04852742,-0.00567847,0.02333999,0.02448643,-0.04047392,-0.01372394,-0.01713422,-0.08842103,0.05672763,-0.0082306,0.00489311,-0.01826671,0.05054607,-0.00551086,-0.07153104,0.04990453,0.09911177,0.01683337,0.00864985,-0.00006069,0.04823392,0.04205449,-0.02877597,0.01580619,-0.06186463,-0.21845382,-0.01900133,-0.02923785,0.0425042,-0.04610076,0.01984102,-0.03036738,0.02385234,0.03189236,-0.01723366,0.08265871,0.12002632,-0.00317075,0.01462042,0.05726923,-0.01707221,-0.02007977,-0.02207086,-0.03048134,0.05118904,-0.0271501,-0.06833537,-0.04187112,0.0142137,0.03100194,-0.03299164,-0.02641674,0.06084623,0.02646412,0.04012402,0.04480398,0.03277944,-0.00132508,-0.19679829,0.05333911,0.0786697,0.02222782,-0.08908466,0.05559403,0.05649012,-0.0327022,-0.04033213,0.05380145,0.06067751,0.0267706,0.00818362,0.01497019,-0.03749615,-0.01249002,-0.05234853,0.01768995,0.00060776,0.01921974,-0.00537716,0.02781661,-0.03728642,-0.04721405,0.01313128,-0.01258955,0.07484611,0.03206854,0.0234887,-0.04417529,0.04952688,0.04234299,-0.07220635,-0.04702206,-0.0347863,-0.0350011