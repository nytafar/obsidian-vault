.02523068,-0.05450432,0.04238176,0.03459791,0.16284482,-0.01064504,-0.02634617,0.01906686,-0.04161225,0.0142203,-0.02606163,0.07327132,0.02134742,0.05816058,0.10756309,-0.0166656,0.06731156,0.11558529,-0.02098481,-0.0597111,-0.03517756,-0.02164488,0.00762108,-0.07218643,-0.12374208,-0.00487239,0.07593588,-0.08288352,-0.06885123,-0.02108778,0.01659341,-0.01344476,0.0032467,-0.01736974,0.0132398,-0.01271968,-0.0547987,-0.03514853,0.00866163,-0.03124958,-0.04265211,0.01086262,0.01147861,0.02635483,-0.04355784,0.13617916,0.00822737],"last_embed":{"hash":"1f7nx0c","tokens":469}}},"last_read":{"hash":"1f7nx0c","at":1774951886027},"class_name":"SmartSource","last_import":{"mtime":1774951814590,"size":2149,"at":1774951884767,"hash":"1f7nx0c"},"blocks":{"#---frontmatter---":[1,48],"#The Cardioprotective Properties of Agaricomycetes Mushrooms Growing in the Territory of Armenia: Review.":[50,54],"#The Cardioprotective Properties of Agaricomycetes Mushrooms Growing in the Territory of Armenia: Review.#{1}":[52,54]},"outlinks":[{"title":"Author/Susanna M. Badalyan","target":"Author/Susanna M. Badalyan","line":39},{"title":"Author/Susanna M. Badalyan","target":"Author/Susanna M. Badalyan","line":40},{"title":"Author/Anush Barkhudaryan","target":"Author/Anush Barkhudaryan","line":41},{"title":"Author/Anush Barkhudaryan","target":"Author/Anush Barkhudaryan","line":42},{"title":"Author/Sylvie Rapior","target":"Author/Sylvie Rapior","line":43},{"title":"Author/Sylvie Rapior","target":"Author/Sylvie Rapior","line":44}],"metadata":{"id":"badalyan_cardioprotective_2021","type":"article-journal","title":"The Cardioprotective Properties of Agaricomycetes Mushrooms Growing in the Territory of Armenia: Review.","issued":{"date-parts":[[2021]]},"DOI":"10.1615/intjmedmushrooms.2021038280","container-title":"International Journal of Medicinal Mushrooms","abstract":"Several edible and medicinal Agaricomycetes mushrooms possess biologically active compounds with different therapeutic effects, such as antioxidant, anti-inflammatory, hypocholesterolemic, hypoglycemic, anti-hypertensive, fibrinolytic, and thrombolytic, and have potential use as cardioprotective remedies. Previous studies have shown that mushrooms possessing cardioprotective effects (CPEs) contain a high amount of vitamins and minerals and low fat content, which make them applicable as a supplementary dietary and functional food for the prevention and treatment of cardiovascular diseases. The current review evaluates the resource value of 31 edible and nonedible medicinal Agaricomycetes mushrooms with potential CPEs growing in the territory of Armenia and discusses the future perspectives of their usage in biotechnology and biomedicine.","tags":["#literature_note"],"author":[{"family":"Badalyan","given":"Susanna M.","literal":""},{"family":"Badalyan","given":"Susanna M.","literal":""},{"family":"Barkhudaryan","given":"Anush","literal":""},{"family":"Barkhudaryan","given":"Anush","literal":""},{"family":"Rapior","given":"Sylvie","literal":""},{"family":"Rapior","given":"Sylvie","literal":""}],"citation-key":"badalyan_cardioprotective_2021","year":"2021","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["The Cardioprotective Properties of Agaricomycetes Mushrooms Growing in the Territory of Armenia: Review."],"author-links":["[[Author/Susanna M. Badalyan]]","[[Author/Susanna M. Badalyan]]","[[Author/Anush Barkhudaryan]]","[[Author/Anush Barkhudaryan]]","[[Author/Sylvie Rapior]]","[[Author/Sylvie Rapior]]"],"attachment":[],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"1f7nx0c","at":1774951886018}},"smart_blocks:Research/@badalyan_cardioprotective_2021.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[0.00474094,-0.00420579,0.02588267,-0.01840257,0.00796535,-0.02449688,-0.01192786,0.07223364,-0.05506614,-0.00744176,-0.02960693,-0.07789142,0.01340606,0.01546978,-0.01354546,-0.00628862,0.04640433,0.00850971,-0.0