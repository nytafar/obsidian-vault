.00200838,-0.00149893,0.17185459,0.0074452,-0.00549115,0.05428272,-0.03380481,0.0387519,0.03395887,-0.02307412,-0.00369353,0.03049184,0.07317225,-0.02355386,0.04913189,-0.00841762,-0.07373425,-0.00202564,-0.01157632,-0.00955078,0.00200963,0.01217184,-0.04440646,-0.05375706,0.07905282,-0.02280656,-0.11588331,0.00662482,-0.02977075,0.0222931,-0.0053812,0.01266564,-0.0041403,-0.00682043,0.0110784,0.0032694,-0.01931846,0.00428348,-0.00709302,0.01032746,-0.03861733,-0.00255801,-0.08956853,0.10032286,0.05637603],"last_embed":{"hash":"z49dab","tokens":499}}},"last_read":{"hash":"z49dab","at":1774951887730},"class_name":"SmartSource","last_import":{"mtime":1774951817579,"size":4114,"at":1774951884783,"hash":"z49dab"},"blocks":{"#---frontmatter---":[1,109],"#Erinacine A-Enriched Hericium erinaceus Mycelium Produces Antidepressant-Like Effects through Modulating BDNF/PI3K/Akt/GSK-3β Signaling in Mice.":[111,115],"#Erinacine A-Enriched Hericium erinaceus Mycelium Produces Antidepressant-Like Effects through Modulating BDNF/PI3K/Akt/GSK-3β Signaling in Mice.#{1}":[113,115]},"outlinks":[{"title":"Author/Chun-Hung Chiu","target":"Author/Chun-Hung Chiu","line":84},{"title":"Author/Chun-Hung Chiu","target":"Author/Chun-Hung Chiu","line":85},{"title":"Author/Charng-Cherng Chyau","target":"Author/Charng-Cherng Chyau","line":86},{"title":"Author/Charng-Cherng Chyau","target":"Author/Charng-Cherng Chyau","line":87},{"title":"Author/Chen Chin-Chu","target":"Author/Chen Chin-Chu","line":88},{"title":"Author/Chin-Chu Chen","target":"Author/Chin-Chu Chen","line":89},{"title":"Author/Chen Chin-Chu","target":"Author/Chen Chin-Chu","line":90},{"title":"Author/Li-Ya Lee","target":"Author/Li-Ya Lee","line":91},{"title":"Author/Li-Ya Lee","target":"Author/Li-Ya Lee","line":92},{"title":"Author/Wanping Chen","target":"Author/Wanping Chen","line":93},{"title":"Author/Wan-Ping Chen","target":"Author/Wan-Ping Chen","line":94},{"title":"Author/Wan-Ping Chen","target":"Author/Wan-Ping Chen","line":95},{"title":"Author/Liu Jialing","target":"Author/Liu Jialing","line":96},{"title":"Author/Jia-Ling Liu","target":"Author/Jia-Ling Liu","line":97},{"title":"Author/Wen-Hsin Lin","target":"Author/Wen-Hsin Lin","line":98},{"title":"Author/Wen-Hsin Lin","target":"Author/Wen-Hsin Lin","line":99},{"title":"Author/Wen-Hsin Lin","target":"Author/Wen-Hsin Lin","line":100},{"title":"Author/Wen-Hsin Lin","target":"Author/Wen-Hsin Lin","line":101},{"title":"Author/Mei-Chin Mong","target":"Author/Mei-Chin Mong","line":102},{"title":"Author/Mei-Chin Mong","target":"Author/Mei-Chin Mong","line":103},{"title":"Author/Mei-Chin Mong","target":"Author/Mei-Chin Mong","line":104},{"title":"PDF","target":"biblib/chiu_erinacine_2018/chiu_erinacine_2018.pdf","line":106}],"metadata":{"id":"chiu_erinacine_2018","type":"article-journal","title":"Erinacine A-Enriched Hericium erinaceus Mycelium Produces Antidepressant-Like Effects through Modulating BDNF/PI3K/Akt/GSK-3β Signaling in Mice.","issued":{"date-parts":[[2018]]},"DOI":"10.3390/ijms19020341","container-title":"International Journal of Molecular Sciences","abstract":"Antidepressant-like effects of ethanolic extract of Hericium erinaceus (HE) mycelium enriched in erinacine A on depressive mice challenged by repeated restraint stress (RS) were examined. HE at 100, 200 or 400 mg/kg body weight/day was orally given to mice for four weeks. After two weeks of HE administration, all mice except the control group went through with 14 days of RS protocol. Stressed mice exhibited various behavioral alterations, such as extending immobility time in the tail suspension test (TST) and forced swimming test (FST), and increasing the number of entries in open arm (POAE) and the time spent in the open arm (PTOA). Moreover, the levels of norepinephrine (NE), dopamine (DA) and serotonin (5-HT) were decreased in the stressed mice, while the levels of interleukin (IL)-6 and tumor necrosis factor (TNF)-α were increased. These changes were significantly inverted by the administration of HE, especially at the dose of 200 or 400 mg/kg body weight/day. Additionally, HE was shown to activate the BDNF/TrkB/PI3K/Akt/GSK-3β pathways and block the NF-κB signals in mice. Taken together, erinacine A-enriched HE mycelium could reverse the depressive-like behavior caused by RS and was accompanied by the modulation of monoamine neurotransmitters as well as pro-inflammatory cytokines, and regulation of BDNF pathways. Therefore, erinacine A-enriched HE mycelium could be an attractive agent for the treatment of depressive disorders.","tags":["#literature_note"],"author":[{"family":"Chiu","given":"Chun-Hung","literal":""},{"family":"Chiu","given":"Chun-Hung","literal":""},{"family":"Chyau","given":"Charng-Cherng","literal":""},{"family":"Chyau","given":"Charng-Cherng","literal":""},{"family":"Chin-Chu","given":"Chen","literal":""},{"family":"Chen","given":"Chin-Chu","literal":""},{"family":"Chin-Chu","given":"Chen","literal":""},{"family":"Lee","given":"Li-Ya","literal":""},{"family":"Lee","given":"Li-Ya","literal":""},{"family":"Chen","given":"Wanping","literal":""},{"family":"Chen","given":"Wan-Ping","literal":""},{"family":"Chen","given":"Wan-Ping","literal":""},{"family":"Jialing","given":"Liu","literal":""},{"family":"Liu","given":"Jia-Ling","literal":""},{"family":"Lin","given":"Wen-Hsin","literal":""},{"family":"Lin","given":"Wen-Hsin","literal":""},{"family":"Lin","given":"Wen-Hsin","literal":""},{"family":"Lin","given":"Wen-Hsin","literal":""},{"family":"Mong","given":"Mei-Chin","literal":""},{"family":"Mong","given":"Mei-Chin","literal":""},{"family":"Mong","given":"Mei-Chin","literal":""}],"citation-key":"chiu_erinacine_2018","year":"2018","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Erinacine A-Enriched Hericium erinaceus Mycelium Produces Antidepressant-Like Effects through Modulating BDNF/PI3K/Akt/GSK-3β Signaling in Mice."],"author-links":["[[Author/Chun-Hung Chiu]]","[[Author/Chun-Hung Chiu]]","[[Aut