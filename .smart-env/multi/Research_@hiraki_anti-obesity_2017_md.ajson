00039695,-0.03021775,0.16478503,0.00116186,-0.04842995,0.00725143,-0.01636691,0.01635935,0.02422292,0.01395468,-0.02737216,0.03910291,0.1032887,0.03355195,0.03371941,0.06180316,-0.02649953,-0.02206865,-0.00236167,-0.01525505,0.03734156,0.02514093,-0.04937604,-0.04348861,0.0856375,-0.08595086,-0.02142042,0.01027539,-0.00468998,0.00069523,0.01796186,-0.01427434,0.01670805,0.02704508,0.00317294,-0.07412582,-0.01715017,-0.00886802,-0.05753497,0.02422435,0.00775894,0.02945832,-0.08505552,0.08592609,0.07916278],"last_embed":{"hash":"jhp5rv","tokens":484}}},"last_read":{"hash":"jhp5rv","at":1774951891938},"class_name":"SmartSource","last_import":{"mtime":1774951823404,"size":3576,"at":1774951884810,"hash":"jhp5rv"},"blocks":{"#---frontmatter---":[1,105],"#Anti-obesity activity of Yamabushitake (Hericium erinaceus) powder in ovariectomized mice, and its potentially active compounds":[107,111],"#Anti-obesity activity of Yamabushitake (Hericium erinaceus) powder in ovariectomized mice, and its potentially active compounds#{1}":[109,111]},"outlinks":[{"title":"Author/Eri Hiraki","target":"Author/Eri Hiraki","line":81},{"title":"Author/Eri Hiraki","target":"Author/Eri Hiraki","line":82},{"title":"Author/Shu Furuta","target":"Author/Shu Furuta","line":83},{"title":"Author/Shoko Furuta","target":"Author/Shoko Furuta","line":84},{"title":"Author/Rika Kuwahara","target":"Author/Rika Kuwahara","line":85},{"title":"Author/Rika Kuwahara","target":"Author/Rika Kuwahara","line":86},{"title":"Author/Naomichi Takemoto","target":"Author/Naomichi Takemoto","line":87},{"title":"Author/Naomichi Takemoto","target":"Author/Naomichi Takemoto","line":88},{"title":"Author/Takeaki Nagata","target":"Author/Takeaki Nagata","line":89},{"title":"Author/Toshiro Nagata","target":"Author/Toshiro Nagata","line":90},{"title":"Author/Taiki Akasaka","target":"Author/Taiki Akasaka","line":91},{"title":"Author/Taiki Akasaka","target":"Author/Taiki Akasaka","line":92},{"title":"Author/Bungo Shirouchi","target":"Author/Bungo Shirouchi","line":93},{"title":"Author/Bungo Shirouchi","target":"Author/Bungo Shirouchi","line":94},{"title":"Author/Koichiro Ohnuki","target":"Author/Koichiro Ohnuki","line":95},{"title":"Author/Masao Sato","target":"Author/Masao Sato","line":96},{"title":"Author/Kuniyoshi Shimizu","target":"Author/Kuniyoshi Shimizu","line":97},{"title":"Author/Koichiro Ohnuki","target":"Author/Koichiro Ohnuki","line":98},{"title":"Author/Koichiro Ohnuki","target":"Author/Koichiro Ohnuki","line":99},{"title":"Author/Kuniyoshi Shimizu","target":"Author/Kuniyoshi Shimizu","line":100},{"title":"PDF","target":"biblib/hiraki_anti-obesity_2017/hiraki_anti-obesity_2017.pdf","line":102}],"metadata":{"id":"hiraki_anti-obesity_2017","type":"article-journal","title":"Anti-obesity activity of Yamabushitake (Hericium erinaceus) powder in ovariectomized mice, and its potentially active compounds","issued":{"date-parts":[[2017]]},"DOI":"10.1007/s11418-017-1075-8","container-title":"Journal of Natural Medicines","abstract":"Hericium erinaceus (H. erinaceus) improves the symptoms of menopause. In this study, using ovariectomized mice as a model of menopause, we investigated the anti-obesity effect of this mushroom in menopause. Mice fed diets containing H. erinaceus powder showed significant decreases in the amounts of fat tissue, plasma levels of total cholesterol, and leptin. To determine the mechanism, groups of mice were respectively fed a diet containing H. erinaceus powder, a diet containing ethanol extract of H. erinaceus, and a diet containing a residue of the extract. As a result, H. erinaceus powder was found to increase fecal lipid levels in excreted matter. Further in vitro investigation showed that ethanol extract inhibited the activity of lipase, and four lipase-inhibitory compounds were isolated from the extract: hericenone C, hericenone D, hericenone F, and hericenone G. In short, we suggest that H. erinaceus has an anti-obesity effect during menopause because it decreases the ability to absorb lipids.","tags":["#literature_note"],"author":[{"family":"Hiraki","given":"Eri","literal":""},{"family":"Hiraki","given":"Eri","literal":""},{"family":"Furuta","given":"Shu","literal":""},{"family":"Furuta","given":"Shoko","literal":""},{"family":"Kuwahara","given":"Rika","literal":""},{"family":"Kuwahara","given":"Rika","literal":""},{"family":"Takemoto","given":"Naomichi","literal":""},{"family":"Takemoto","given":"Naomichi","literal":""},{"family":"Nagata","given":"Takeaki","literal":""},{"family":"Nagata","given":"Toshiro","literal":""},{"family":"Akasaka","given":"Taiki","literal":""},{"family":"Akasaka","given":"Taiki","literal":""},{"family":"Shirouchi","given":"Bungo","literal":""},{"family":"Shirouchi","given":"Bungo","literal":""},{"family":"Ohnuki","given":"Koichiro","literal":""},{"family":"Sato","given":"Masao","literal":""},{"family":"Shimizu","given":"Kuniyoshi","literal":""},{"family":"Ohnuki","given":"Koichiro","literal":""},{"family":"Ohnuki","given":"Koichiro","literal":""},{"family":"Shimizu","given":"Kuniyoshi","literal":""}],"citation-key":"hiraki_anti-obesity_2017","year":"2017","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Anti-obesity activity of Yamabushitake (Hericium erinaceus) powder in ovariectomized mice, and its potentially active compounds"],"author-links":["[[Author/Eri Hiraki]]","[[Author/Eri Hiraki]]","[[Author/Shu Furuta]]","[[Author/Shoko Furuta]]","[[Author/Rika Kuwahara]]","[[Author/Rika Kuwahara]]","[[Author/Naomichi Takemoto]]","[[Author/Naomichi Takemoto]]","[[Author/Takeaki Nagata]]","[[Author/Toshiro Nagata]]","[[Author/Taiki Akasaka]]","[[Author/Taiki Akasaka]]","[[Author/Bungo Shirouchi]]","[[Author/Bungo Shirouchi]]","[[Author/Koichiro Ohnuki]]","[[Author/Masao Sato]]","[[Author/Kuniyoshi Shimizu]]","[[Author/Koichiro Ohnuki]]","[[Author/Koichiro Ohnuki]]","[[Author/Kuniyoshi Shimizu]]"],"attachment":["[[biblib/hiraki_anti-obesity_2017/hiraki_anti-obesity_2017.pdf|PDF]]"],