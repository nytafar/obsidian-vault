04382747,0.04086049,0.03465874,0.16506492,-0.01806485,0.01955982,0.02652146,0.02926527,0.00679077,0.00470755,0.01981953,0.00171126,-0.00378805,0.08607633,-0.01824702,0.01367194,0.08562789,-0.06831957,-0.07174848,0.01033795,-0.00971441,0.02605925,0.00687388,-0.10661978,-0.03791881,0.12209219,-0.0344261,-0.01394882,-0.05767895,-0.07850761,-0.0366551,-0.02159038,-0.04099979,0.02675778,0.0153237,-0.00845139,-0.04051571,-0.00010757,-0.01873746,0.0019979,-0.01028575,-0.00973201,-0.00891244,-0.02934388,0.16089123,0.0174071],"last_embed":{"hash":"mo7l2f","tokens":433}}},"last_read":{"hash":"mo7l2f","at":1774951886337},"class_name":"SmartSource","last_import":{"mtime":1774951815020,"size":3634,"at":1774951884771,"hash":"mo7l2f"},"blocks":{"#---frontmatter---":[1,93],"#Combination of antioxidant supplements improved cognitive function in the elderly.":[95,99],"#Combination of antioxidant supplements improved cognitive function in the elderly.#{1}":[97,99]},"outlinks":[{"title":"Author/Fumihiko Yasuno","target":"Author/Fumihiko Yasuno","line":72},{"title":"Author/Fumihiko Yasuno","target":"Author/Fumihiko Yasuno","line":73},{"title":"Author/Satoshi Tanimukai","target":"Author/Satoshi Tanimukai","line":74},{"title":"Author/Satoshi Tanimukai","target":"Author/Satoshi Tanimukai","line":75},{"title":"Author/Megumi Sasaki","target":"Author/Megumi Sasaki","line":76},{"title":"Author/Megumi Sasaki","target":"Author/Megumi Sasaki","line":77},{"title":"Author/Chiaki Ikejima","target":"Author/Chiaki Ikejima","line":78},{"title":"Author/Chiaki Ikejima","target":"Author/Chiaki Ikejima","line":79},{"title":"Author/Fumio Yamashita","target":"Author/Fumio Yamashita","line":80},{"title":"Author/Fumio Yamashita","target":"Author/Fumio Yamashita","line":81},{"title":"Author/Fumio Yamashita","target":"Author/Fumio Yamashita","line":82},{"title":"Author/Chiine Kodama","target":"Author/Chiine Kodama","line":83},{"title":"Author/Chiine Kodama","target":"Author/Chiine Kodama","line":84},{"title":"Author/Katsuyoshi Mizukami","target":"Author/Katsuyoshi Mizukami","line":85},{"title":"Author/Katsuyoshi Mizukami","target":"Author/Katsuyoshi Mizukami","line":86},{"title":"Author/Takashi Asada","target":"Author/Takashi Asada","line":87},{"title":"Author/Takashi Asada","target":"Author/Takashi Asada","line":88},{"title":"PDF","target":"biblib/yasuno_combination_2012/yasuno_combination_2012.pdf","line":90}],"metadata":{"id":"yasuno_combination_2012","type":"article-journal","title":"Combination of antioxidant supplements improved cognitive function in the elderly.","issued":{"date-parts":[[2012]]},"DOI":"10.3233/jad-2012-121225","container-title":"Journal of Alzheimer's Disease","abstract":"Although nutrients or agents with antioxidant properties were reported to show a preventive effect on cognitive decline in animal studies, epidemiologic data on select antioxidants have shown conflicting results. We investigated whether a combination of antioxidants from supplements is effective for the improvement of cognitive function of elderly. Forty-one subjects from a community dwelling aged 65 years and older took supplements containing n-3 polyunsaturated fatty acids (n-3 PUFA), lycopene, and Ginkgo biloba extracts (GE) daily for 3 years. The data of 622 subjects without supplement intake were used as control. We investigated the changes in cognitive function during a 3-year follow-up. We also investigated the influence of apolipoprotein E (APOE) genotype on the effect of antioxidants. We found that a combination of antioxidants improved cognitive function of aged persons after 3 years. Our present study also indicated this improvement in cognitive function with supplement intake in both APOE4 non-carrier (E4-) and APOE4 carrier (E4+) groups. Especially, in E4+, we found a large effect size of the improvement of cognition. When multiple antioxidants are used in combination, they protect against vulnerability to other agents and synergistically potentiate their antioxidant properties. These synergistically potentiated antioxidant effects of agents contribute to the improvement of cognitive function.","tags":["#literature_note"],"author":[{"family":"Yasuno","given":"Fumihiko","literal":""},{"family":"Yasuno","given":"Fumihiko","literal":""},{"family":"Tanimukai","given":"Satoshi","literal":""},{"family":"Tanimukai","given":"Satoshi","literal":""},{"family":"Sasaki","given":"Megumi","literal":""},{"family":"Sasaki","given":"Megumi","literal":""},{"family":"Ikejima","given":"Chiaki","literal":""},{"family":"Ikejima","given":"Chiaki","literal":""},{"family":"Yamashita","given":"Fumio","literal":""},{"family":"Yamashita","given":"Fumio","literal":""},{"family":"Yamashita","given":"Fumio","literal":""},{"family":"Kodama","given":"Chiine","literal":""},{"family":"Kodama","given":"Chiine","literal":""},{"family":"Mizukami","given":"Katsuyoshi","literal":""},{"family":"Mizukami","given":"Katsuyoshi","literal":""},{"family":"Asada","given":"Takashi","literal":""},{"family":"Asada","given":"Takashi","literal":""}],"citation-key":"yasuno_combination_2012","year":"2012","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Combination of antioxidant supplements improved cognitive function in the elderly."],"author-links":["[[Author/Fumihiko Yasuno]]","[[Author/Fumihiko Yasuno]]","[[Author/Satoshi Tanimukai]]","[[Author/Satoshi Tanimukai]]","[[Author/Megumi Sasaki]]","[[Author/Megumi Sasaki]]","[[Author/Chiaki Ikejima]]","[[Author/Chiaki Ikejima]]","[[Author/Fumio Yamashita]]","[[Author/Fumio Yamashita]]","[[Author/Fumio Yamashita]]","[[Author/Chiine Kodama]]","[[Author/Chiine Kodama]]","[[Author/Katsuyoshi Mizukami]]","[[Author/Katsuyoshi Mizukami]]","[[Author/Takashi Asada]]","[[Author/Takashi Asada]]"],"attachment":["[[biblib/yasuno_combination_2012/yasuno_combination_2012.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"mo7l2f","at":1774951886329}},"smart_blocks:Research/@yasuno_combi