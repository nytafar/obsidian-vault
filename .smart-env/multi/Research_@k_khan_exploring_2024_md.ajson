01,0.01007003,-0.01507493,0.18222895,-0.01198029,-0.04067236,0.04954199,-0.01858311,0.03394569,-0.00341749,0.00448257,0.08276211,0.05593266,0.14550214,-0.02425331,-0.01103835,0.07312504,0.01629695,-0.06496461,-0.00740101,-0.00230265,0.03146689,-0.04113808,-0.08180835,-0.05101583,0.08589981,-0.14446634,-0.02578273,-0.05906381,-0.01094498,0.05403797,0.02326341,-0.01642995,-0.0305452,0.0086166,-0.03048341,-0.01128287,-0.00449855,-0.00255031,-0.0139186,-0.01533172,0.00145521,-0.00272075,-0.09207857,0.11257083,-0.01601407],"last_embed":{"hash":"zfarzi","tokens":501}}},"last_read":{"hash":"zfarzi","at":1774951884958},"class_name":"SmartSource","last_import":{"mtime":1774951813688,"size":2849,"at":1774951884751,"hash":"zfarzi"},"blocks":{"#---frontmatter---":[1,60],"#Exploring the nutritional composition and quality parameters of natural honey from diverse melliferous flora.":[62,66],"#Exploring the nutritional composition and quality parameters of natural honey from diverse melliferous flora.#{1}":[64,66]},"outlinks":[{"title":"Author/K Khan","target":"Author/K Khan","line":48},{"title":"Author/K Malik","target":"Author/K Malik","line":49},{"title":"Author/M Ahmad","target":"Author/M Ahmad","line":50},{"title":"Author/MNI Raja","target":"Author/MNI Raja","line":51},{"title":"Author/M Nazish","target":"Author/M Nazish","line":52},{"title":"Author/A Kamal","target":"Author/A Kamal","line":53},{"title":"Author/G Albasher","target":"Author/G Albasher","line":54},{"title":"Author/S Ahmad","target":"Author/S Ahmad","line":55},{"title":"Author/MT Naseem","target":"Author/MT Naseem","line":56}],"metadata":{"id":"k_khan_exploring_2024","type":"article-journal","title":"Exploring the nutritional composition and quality parameters of natural honey from diverse melliferous flora.","issued":{"date-parts":[[2024]]},"DOI":"10.1038/s41598-024-79672-w","container-title":"Scientific reports","abstract":"Natural honey is enriched with essential and beneficial nutrients. This study aimed to investigate the melliferous flora microscopic techniques and assess the biochemical properties of honey. Flavonoid and phenolic contents in honey samples were analyzed via colorimetric and Folin-Ciocalteu methods and the alpha-amylase, reducing power, and minerals using Pull's and spectroscopy methods. HPLC determined the Sucrose, fructose, and glucose content in the honey samples. Four different classes of moisture content were used to assist the honey quality, including A + < 17, A = 17-18, B = 18-19, and C > 19. This study identified the Eucalyptus globulus, Trifolium pratense, Neltuma juliflora, Ziziphus mauritiana, Asphodelus tenuifolius, Cynodon dactylon, Saccharum spontaneum, and Vachellia nilotica as the predominant plant species honey samples. The total range of moisture was observed from 16.5 to 21.1% in the samples studied. The honey class within the range of 16.5-17.5% was identified as the optimal class. Four classes of sucrose level were used to evaluate the honey quality, including: (2.50-2.60 = A +); (2.61-2.75 = A); (2.76-3.00 = B); (3.00 + = C). The total variation of sucrose levels in the analyzed ranged from 2.50 to 3.89%. Overall, the findings of these studies implemented various aspects of honey production, quality, and potential health benefits, benefiting consumers, beekeepers, and researchers.© 2024. The Author(s).","tags":["#literature_note"],"author":[{"family":"K Khan","given":"","literal":""},{"family":"K Malik","given":"","literal":""},{"family":"M Ahmad","given":"","literal":""},{"family":"MNI Raja","given":"","literal":""},{"family":"M Nazish","given":"","literal":""},{"family":"A Kamal","given":"","literal":""},{"family":"G Albasher","given":"","literal":""},{"family":"S Ahmad","given":"","literal":""},{"family":"MT Naseem","given":"","literal":""}],"citation-key":"k_khan_exploring_2024","year":"2024","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Exploring the nutritional composition and quality parameters of natural honey from diverse melliferous flora."],"author-links":["[[Author/K Khan]]","[[Author/K Malik]]","[[Author/M Ahmad]]","[[Author/MNI Raja]]","[[Author/M Nazish]]","[[Author/A Kamal]]","[[Author/G Albasher]]","[[Author/S Ahmad]]","[[Author/MT Naseem]]"],"attachment":[],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"zfarzi","at":1774951884946}},"smart_blocks:Research/@k_khan_exploring_2024.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.01399303,-0.03614209,0.0131363,-0.04512836,0.07406805,0.03761766,0.02219015,0.03026184,-0.05197948,0.00271462,0.01916475,-0.0995801,0.03934742,0.00254463,0.05929079,-0.0255059,0.0519431,-0.00635968,-0.12045591,0.00434663,0.10882037,-0.0318683,0.02234798,-0.00355077,0.09384904,0.00819374,0.01333265,-0.02943936,-0.05868771,-0.23898883,-0.04266407,-0.02014675,0.0632873,-0.02083942,-0.05019181,0.02523102,-0.01839674,0.04006939,-0.02759198,0.01666054,0.0907328,-0.01515445,-0.01662788,0.0073803,-0.0287041,-0.02960002,-0.0319671,0.00864051,0.03213901,-0.047285,-0.03726671,-0.00227953,-0.05889058,0.04398295,0.00728293,0.03047181,0.04820776,0.01195661,0.01672283,0.06734782,0.0178408,0.0120843,-0.17631,0.03270834,0.04460374,0.00936755,-0.09096274,-0.02947193,0.02286159,-0.04159702,-0.12200034,0.05216535,0.03959364,0.05040726,0.06361089,-0.00924999,0.01839776,-0.03026895,-0.04091007,0.03232039,-0.02151465,0.02081091,0.01046769,-0.04399187,-0.01301462,-0.02349305,0.01838148,-0.04597796,0.06999609,-0.0404878,0.04040052,-0.07138699,-0.03079135,0.04391225,-0.04547373,0.01494966,-0.02333303,-0.01627772,0.04909408,0.11994091,-0.05459279,0.05133101,-0.01715972,-0.047425,0.00674555,-0.07324949,-0.0323361,-0.02133709,0.02109946,0.05169997,0.07824498,-0.00229698,-0.01949875,-0.01219301,-0.06119161,0.05477701,0.08930575,-0.0409738,0.0002048,-0.02990095,-0.00539605,0.01114945,0.08860552,-0.06627838,0.08392067,-0.00114923,-0.02500754,0.04177263,0.02006861,-0.01780371,0.06135191,0.