37649,0.03105873,0.02093724,0.16886277,0.03083753,-0.00814102,0.01597132,-0.06302778,0.02417051,-0.00357303,-0.0209189,0.03366779,0.00667711,0.10230146,0.01172778,0.09636918,0.08714194,-0.06851469,-0.05510384,-0.00880794,-0.01548771,0.02055768,-0.03318677,-0.06795297,0.00914407,0.09946618,-0.05349633,-0.02473359,0.00975777,-0.02231822,0.00324171,-0.04555106,-0.00189265,0.03395949,0.07595059,-0.00087743,-0.00709838,0.02736553,-0.04148912,-0.02340648,-0.04379036,0.00767075,-0.00154265,-0.05366776,0.11330679,0.03883208],"last_embed":{"hash":"za8374","tokens":447}}},"last_read":{"hash":"za8374","at":1774951886803},"class_name":"SmartSource","last_import":{"mtime":1774951815739,"size":3922,"at":1774951884775,"hash":"za8374"},"blocks":{"#---frontmatter---":[1,72],"#Lion's Mane, Hericium erinaceus and Tiger Milk, Lignosus rhinocerotis (Higher Basidiomycetes) Medicinal Mushrooms Stimulate Neurite Outgrowth in Dissociated Cells of Brain, Spinal Cord, and Retina: An In Vitro Study.":[74,78],"#Lion's Mane, Hericium erinaceus and Tiger Milk, Lignosus rhinocerotis (Higher Basidiomycetes) Medicinal Mushrooms Stimulate Neurite Outgrowth in Dissociated Cells of Brain, Spinal Cord, and Retina: An In Vitro Study.#{1}":[76,78]},"outlinks":[{"title":"Author/Snehlata P. Samberkar","target":"Author/Snehlata P. Samberkar","line":57},{"title":"Author/Snehlata P. Samberkar","target":"Author/Snehlata P. Samberkar","line":58},{"title":"Author/S. R. Gandhi","target":"Author/S. R. Gandhi","line":59},{"title":"Author/Sivasangkary Gandhi","target":"Author/Sivasangkary Gandhi","line":60},{"title":"Author/Murali Naidu","target":"Author/Murali Naidu","line":61},{"title":"Author/Murali Naidu","target":"Author/Murali Naidu","line":62},{"title":"Author/Kah-Hui Wong","target":"Author/Kah-Hui Wong","line":63},{"title":"Author/Kah-Hui Wong","target":"Author/Kah-Hui Wong","line":64},{"title":"Author/Jegadeesh Raman","target":"Author/Jegadeesh Raman","line":65},{"title":"Author/Jegadeesh Raman","target":"Author/Jegadeesh Raman","line":66},{"title":"Author/Vikineswary Sabaratnam","target":"Author/Vikineswary Sabaratnam","line":67},{"title":"Author/Vikineswary Sabaratnam","target":"Author/Vikineswary Sabaratnam","line":68}],"metadata":{"id":"samberkar_lions_2015","type":"article-journal","title":"Lion's Mane, Hericium erinaceus and Tiger Milk, Lignosus rhinocerotis (Higher Basidiomycetes) Medicinal Mushrooms Stimulate Neurite Outgrowth in Dissociated Cells of Brain, Spinal Cord, and Retina: An In Vitro Study.","issued":{"date-parts":[[2015]]},"DOI":"10.1615/intjmedmushrooms.v17.i11.40","container-title":"International Journal of Medicinal Mushrooms","abstract":"Neurodegenerative disease is defined as a deterioration of the nervous system in the intellectual and cognitive capabilities. Statistics show that more than 80-90 million individuals age 65 and above in 2050 may be affected by neurodegenerative conditions like Alzheimer's and Parkinson's disease. Studies have shown that out of 2000 different types of edible and/or medicinal mushrooms, only a few countable mushrooms have been selected until now for neurohealth activity. Hericium erinaceus is one of the well-established medicinal mushrooms for neu- ronal health. It has been documented for its regenerative capability in peripheral nerve. Another mushroom used as traditional medicine is Lignosus rhinocerotis, which has been used for various illnesses. It has been documented for its neurite outgrowth potential in PC12 cells. Based on the regenerative capabilities of both the mushrooms, prior- ity was given to select them for our study. The aim of this study was to investigate the potential of H. erinaceus and L. rhinocerotis to stimulate neurite outgrowth in dissociated cells of brain, spinal cord, and retina from chick embryo when compared to brain derived neurotrophic factor (BDNF). Neurite outgrowth activity was confirmed by the immu- nofluorescence method in all tissue samples. Treatment with different concentrations of extracts resulted in neuronal differentiation and neuronal elongation. H. erinaceus extract at 50 µg/mL triggered neurite outgrowth at 20.47%, 22.47%, and 21.70% in brain, spinal cord, and retinal cells. L. rhinocerotis sclerotium extract at 50 µg/mL induced maximum neurite outgrowth of 20.77% and 24.73% in brain and spinal cord, whereas 20.77% of neurite outgrowth was observed in retinal cells at 25µg/mL, respectively.","tags":["#literature_note"],"author":[{"family":"Samberkar","given":"Snehlata P.","literal":""},{"family":"Samberkar","given":"Snehlata P.","literal":""},{"family":"Gandhi","given":"S. R.","literal":""},{"family":"Gandhi","given":"Sivasangkary","literal":""},{"family":"Naidu","given":"Murali","literal":""},{"family":"Naidu","given":"Murali","literal":""},{"family":"Wong","given":"Kah-Hui","literal":""},{"family":"Wong","given":"Kah-Hui","literal":""},{"family":"Raman","given":"Jegadeesh","literal":""},{"family":"Raman","given":"Jegadeesh","literal":""},{"family":"Sabaratnam","given":"Vikineswary","literal":""},{"family":"Sabaratnam","given":"Vikineswary","literal":""}],"citation-key":"samberkar_lions_2015","year":"2015","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Lion's Mane, Hericium erinaceus and Tiger Milk, Lignosus rhinocerotis (Higher Basidiomycetes) Medicinal Mushrooms Stimulate Neurite Outgrowth in Dissociated Cells of Brain, Spinal Cord, and Retina: An In Vitro Study."],"author-links":["[[Author/Snehlata P. Samberkar]]","[[Author/Snehlata P. Samberkar]]","[[Author/S. R. Gandhi]]","[[Author/Sivasangkary Gandhi]]","[[Author/Murali Naidu]]","[[Author/Murali Naidu]]","[[Author/Kah-Hui Wong]]","[[Author/Kah-Hui Wong]]","[[Author/Jegadeesh Raman]]","[[Author/Jegadeesh Raman]]","[[Author/Vikineswary Sabaratnam]]","[[Author/Vikineswary Sabaratnam]]"],"attachment":[],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"za8374","at":1774951886786}},"smart_blocks:Research/@samberkar_lions_2