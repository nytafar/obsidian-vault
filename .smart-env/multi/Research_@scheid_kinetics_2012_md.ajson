82,0.16847883,-0.05323053,-0.00586379,0.04929338,-0.01815287,0.02469606,-0.05573998,-0.01811233,-0.05009702,0.07852951,0.07757608,-0.04731471,0.0095973,0.05086705,-0.0503267,-0.02408925,-0.03278073,0.01427489,0.0072123,-0.00648529,-0.01984428,-0.03601035,0.07630935,-0.06639209,-0.08222997,-0.09432123,0.00767024,0.00061182,-0.00668111,-0.00881339,-0.01411671,0.02296311,-0.00117684,-0.01051824,-0.010807,-0.01981841,-0.03704196,-0.08083647,-0.0450548,0.01484952,-0.02767303,0.11384237,0.03177515],"last_embed":{"hash":"16aqz7p","tokens":510}}},"last_read":{"hash":"16aqz7p","at":1774951895953},"class_name":"SmartSource","last_import":{"mtime":1774951828947,"size":3970,"at":1774951884830,"hash":"16aqz7p"},"blocks":{"#---frontmatter---":[1,89],"#Kinetics of l-Theanine Uptake and Metabolism in Healthy Participants Are Comparable After Ingestion of l-Theanine via Capsules and Green Tea":[91,95],"#Kinetics of l-Theanine Uptake and Metabolism in Healthy Participants Are Comparable After Ingestion of l-Theanine via Capsules and Green Tea#{1}":[93,95]},"outlinks":[{"title":"Author/Lisa Scheid","target":"Author/Lisa Scheid","line":69},{"title":"Author/Lisa Scheid","target":"Author/Lisa Scheid","line":70},{"title":"Author/Sabine Ellinger","target":"Author/Sabine Ellinger","line":71},{"title":"Author/Sabine Ellinger","target":"Author/Sabine Ellinger","line":72},{"title":"Author/Birgit Alteheld","target":"Author/Birgit Alteheld","line":73},{"title":"Author/Birgit Alteheld","target":"Author/Birgit Alteheld","line":74},{"title":"Author/Hannes Herholz","target":"Author/Hannes Herholz","line":75},{"title":"Author/Hannes Herholz","target":"Author/Hannes Herholz","line":76},{"title":"Author/Jörg Ellinger","target":"Author/Jörg Ellinger","line":77},{"title":"Author/Jörg Ellinger","target":"Author/Jörg Ellinger","line":78},{"title":"Author/Thomas Henn","target":"Author/Thomas Henn","line":79},{"title":"Author/Thomas Henn","target":"Author/Thomas Henn","line":80},{"title":"Author/Hans-Peter Helfrich","target":"Author/Hans-Peter Helfrich","line":81},{"title":"Author/Hans-Peter Helfrich","target":"Author/Hans-Peter Helfrich","line":82},{"title":"Author/Peter Stehle","target":"Author/Peter Stehle","line":83},{"title":"Author/Peter Stehle","target":"Author/Peter Stehle","line":84},{"title":"PDF","target":"biblib/scheid_kinetics_2012/scheid_kinetics_2012.pdf","line":86}],"metadata":{"id":"scheid_kinetics_2012","type":"article-journal","title":"Kinetics of l-Theanine Uptake and Metabolism in Healthy Participants Are Comparable After Ingestion of l-Theanine via Capsules and Green Tea","issued":{"date-parts":[[2012]]},"DOI":"10.3945/jn.112.166371","container-title":"Journal of Nutrition","abstract":"L-Theanine, an amino acid in green tea, is suggested to improve cognition and mood. Therefore, L-theanine is available as a supplement and is now used as an ingredient in functional drinks. Because data on the metabolic fate of L-theanine from human studies are lacking, we investigated the kinetics of L-theanine uptake and its metabolites, ethylamine and glutamic acid, in healthy participants. Within a randomized crossover study, 12 participants ingested a bolus of 100 mg L-theanine via capsules or green tea. On further occasions, 3 participants received 50 and 200 mg L-theanine via capsules. Blood and urine were collected before and up to 24 h postconsumption to determine the concentrations of L-theanine, proteinogenic amino acids, and ethylamine in plasma, erythrocytes, and urine by HPLC. L-Theanine increased in plasma, erythrocytes, and urine with comparable results after both treatments. The maximum plasma concentration of L-theanine occurred 0.8 h after intake of 100 mg L-theanine via capsules (24.3 6 5.7 mmol/L) and tea (26.5 6 5.2 mmol/L), respectively. The AUC of L-theanine in plasma increased dose dependently after intake of 50, 100, and 200 mg L-theanine via capsules. Moreover, ethylamine and glutamic acid increased in plasma and were excreted by urine after intake of capsules and tea. In conclusion, L-theanine is rapidly absorbed and seems to be hydrolyzed to ethylamine and glutamic acid. A minor part of L-theanine is retained in erythrocytes. Kinetics and urinary excretion of L-theanine, ethylamine, and glutamic acid are comparable after both treatments. Thus, functional effects of L-theanine intake may result from L-theanine, ethylamine, or glutamic acid. J. Nutr. doi: 10.3945/jn.112.166371.","tags":["#literature_note"],"author":[{"family":"Scheid","given":"Lisa","literal":""},{"family":"Scheid","given":"Lisa","literal":""},{"family":"Ellinger","given":"Sabine","literal":""},{"family":"Ellinger","given":"Sabine","literal":""},{"family":"Alteheld","given":"Birgit","literal":""},{"family":"Alteheld","given":"Birgit","literal":""},{"family":"Herholz","given":"Hannes","literal":""},{"family":"Herholz","given":"Hannes","literal":""},{"family":"Ellinger","given":"Jörg","literal":""},{"family":"Ellinger","given":"Jörg","literal":""},{"family":"Henn","given":"Thomas","literal":""},{"family":"Henn","given":"Thomas","literal":""},{"family":"Helfrich","given":"Hans-Peter","literal":""},{"family":"Helfrich","given":"Hans-Peter","literal":""},{"family":"Stehle","given":"Peter","literal":""},{"family":"Stehle","given":"Peter","literal":""}],"citation-key":"scheid_kinetics_2012","year":"2012","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Kinetics of l-Theanine Uptake and Metabolism in Healthy Participants Are Comparable After Ingestion of l-Theanine via Capsules and Green Tea"],"author-links":["[[Author/Lisa Scheid]]","[[Author/Lisa Scheid]]","[[Author/Sabine Ellinger]]","[[Author/Sabine Ellinger]]","[[Author/Birgit Alteheld]]","[[Author/Birgit Alteheld]]","[[Author/Hannes Herholz]]","[[Author/Hannes Herholz]]","[[Author/Jörg Ellinger]]","[[Author/Jörg Ellinger]]","[[Author/Thomas Henn]]","[[Author/Thomas Henn]]","[[Author/Hans-Peter Helfrich]]","[[Author/Hans-Peter Helfrich]]","[[Author/Peter Stehle]]","[[Au