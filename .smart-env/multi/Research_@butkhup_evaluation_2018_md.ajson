0707131,0.02971402,0.00206797,0.19823106,0.02112708,-0.0660891,0.0038574,-0.05684584,-0.02167475,-0.03016214,0.01797609,-0.00410684,0.05776818,0.17798966,-0.04267827,0.04789053,0.1002601,-0.02103045,-0.04106275,-0.03747502,0.00831755,0.01547806,-0.01771851,-0.11487912,-0.00125818,0.10788958,-0.08320007,-0.00944618,-0.03517149,0.04272059,-0.00454433,-0.023553,0.00844728,-0.03177975,0.01535313,-0.03836097,-0.0533365,0.0268259,-0.01136539,-0.04335156,-0.02956869,-0.01236175,0.05359462,-0.03707292,0.07648077,0.03058094],"last_embed":{"hash":"mi85ot","tokens":458}}},"last_read":{"hash":"mi85ot","at":1774951885572},"class_name":"SmartSource","last_import":{"mtime":1774951814026,"size":2246,"at":1774951884760,"hash":"mi85ot"},"blocks":{"#---frontmatter---":[1,49],"#Evaluation of bioactivities and phenolic contents of wild edible mushrooms from northeastern Thailand.":[51,55],"#Evaluation of bioactivities and phenolic contents of wild edible mushrooms from northeastern Thailand.#{1}":[53,55]},"outlinks":[{"title":"Author/Luchai Butkhup","target":"Author/Luchai Butkhup","line":39},{"title":"Author/Luchai Butkhup","target":"Author/Luchai Butkhup","line":40},{"title":"Author/Wannee Samappito","target":"Author/Wannee Samappito","line":41},{"title":"Author/Wannee Samappito","target":"Author/Wannee Samappito","line":42},{"title":"Author/Sujitar Jorjong","target":"Author/Sujitar Jorjong","line":43},{"title":"Author/Sujitar Jorjong","target":"Author/Sujitar Jorjong","line":44},{"title":"PDF","target":"biblib/butkhup_evaluation_2018/butkhup_evaluation_2018.pdf","line":46}],"metadata":{"id":"butkhup_evaluation_2018","type":"article-journal","title":"Evaluation of bioactivities and phenolic contents of wild edible mushrooms from northeastern Thailand.","issued":{"date-parts":[[2018]]},"DOI":"10.1007/s10068-017-0237-5","container-title":"Food Science and Biotechnology","abstract":"Twenty-five wild edible mushrooms from Northeastern Thailand were analyzed for their antioxidant activities, proteins, sugars, β-glucan, and phenolic profiles. Results showed that T. clypeatus and V. volvacea exhibited the greatest scavenging activity (83.07 and 86.60%) and reductive power (9.79 and 8.42g Fe(II)/kg, respectively). T. clypeatus recorded the highest content of (+)-catechin and naringenin (13.40 and 0.74g/kg dw), with V. volvacea the highest amount of quercetin and quercetin-3-O-rutinoside (1.82 and 1.16g/kg dw, respectively). Both T. clypeatus and V. volvacea also exhibited the greatest amounts of β-glucan (125.23 and 344.43g/kg dw) and protein (343.30 and 452.20g/kg dw, respectively) among the mushroom species evaluated. Results suggested that both T. clypeatus and V. volvacea were a good source of healthy compounds, namely β-glucan and flavonoids, and could be used to mitigate diseases involving free radicals.","tags":["#literature_note"],"author":[{"family":"Butkhup","given":"Luchai","literal":""},{"family":"Butkhup","given":"Luchai","literal":""},{"family":"Samappito","given":"Wannee","literal":""},{"family":"Samappito","given":"Wannee","literal":""},{"family":"Jorjong","given":"Sujitar","literal":""},{"family":"Jorjong","given":"Sujitar","literal":""}],"citation-key":"butkhup_evaluation_2018","year":"2018","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Evaluation of bioactivities and phenolic contents of wild edible mushrooms from northeastern Thailand."],"author-links":["[[Author/Luchai Butkhup]]","[[Author/Luchai Butkhup]]","[[Author/Wannee Samappito]]","[[Author/Wannee Samappito]]","[[Author/Sujitar Jorjong]]","[[Author/Sujitar Jorjong]]"],"attachment":["[[biblib/butkhup_evaluation_2018/butkhup_evaluation_2018.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"mi85ot","at":1774951885562}},"smart_blocks:Research/@butkhup_evaluation_2018.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.03007246,-0.03600822,0.02223387,-0.00300903,0.02593132,-0.01459