,-0.01069154,0.0673588,0.15216412,-0.0257811,-0.01684098,-0.01839808,-0.0001833,0.02438191,-0.06931467,0.04925427,0.03051749,0.01917071,0.07999939,-0.04636115,-0.00998611,0.06859764,-0.03479461,-0.02145836,-0.01652502,-0.00040471,0.01444741,0.03837197,-0.01872478,-0.01802774,0.08857638,-0.10109847,-0.01867444,-0.06743198,0.03279622,-0.03521452,-0.01254041,-0.0257308,0.03138284,0.05323381,-0.01058304,-0.01998669,-0.02767593,-0.07996642,-0.01717007,-0.0258666,0.02501116,-0.03421808,-0.06265305,0.13581859,0.0532844],"last_embed":{"hash":"1kn9ii9","tokens":471}}},"last_read":{"hash":"1kn9ii9","at":1774951894771},"class_name":"SmartSource","last_import":{"mtime":1774951827430,"size":3205,"at":1774951884824,"hash":"1kn9ii9"},"blocks":{"#---frontmatter---":[1,65],"#The effects of Crocus sativus (saffron) and its constituents on nervous system: A review":[67,71],"#The effects of Crocus sativus (saffron) and its constituents on nervous system: A review#{1}":[69,71]},"outlinks":[{"title":"Author/Mohammad Reza Khazdair","target":"Author/Mohammad Reza Khazdair","line":51},{"title":"Author/Mohammad Reza Khazdair","target":"Author/Mohammad Reza Khazdair","line":52},{"title":"Author/Mohammad Hossein Boskabady","target":"Author/Mohammad Hossein Boskabady","line":53},{"title":"Author/Mohammad Hossein Boskabady","target":"Author/Mohammad Hossein Boskabady","line":54},{"title":"Author/Mahmoud Hosseini","target":"Author/Mahmoud Hosseini","line":55},{"title":"Author/Mahmoud Hosseini","target":"Author/Mahmoud Hosseini","line":56},{"title":"Author/Ramin Rezaee","target":"Author/Ramin Rezaee","line":57},{"title":"Author/Ramin Rezaee","target":"Author/Ramin Rezaee","line":58},{"title":"Author/A. Tsatsakis","target":"Author/A. Tsatsakis","line":59},{"title":"Author/Aristeidis M. Tsatsakis","target":"Author/Aristeidis M. Tsatsakis","line":60},{"title":"PDF","target":"biblib/khazdair_effects_2015/khazdair_effects_2015.pdf","line":62}],"metadata":{"id":"khazdair_effects_2015","type":"article-journal","title":"The effects of Crocus sativus (saffron) and its constituents on nervous system: A review","issued":{"date-parts":[[2015]]},"DOI":"10.22038/ajp.2015.4503","container-title":"avicenna journal of phytomedicine","abstract":"Saffron or Crocus sativus L. (C. sativus) has been widely used as a medicinal plant to promote human health, especially in Asia. The main components of saffron are crocin, picrocrocin and safranal. The median lethal doses (LD50) of C. sativus are 200 mg/ml and 20.7 g/kg in vitro and in animal studies, respectively. Saffron has been suggested to be effective in the treatment of a wide range of disorders including coronary artery diseases, hypertension, stomach disorders, dysmenorrhea and learning and memory impairments. In addition, different studies have indicated that saffron has anti-inflammatory, anti-atherosclerotic, antigenotoxic and cytotoxic activities. Antitussive effects of stigmas and petals of C. sativus and its components, safranal and crocin have also been demonstrated. The anticonvulsant and anti-Alzheimer properties of saffron extract were shown in human and animal studies. The efﬁcacy of C. sativus in the treatment of mild to moderate depression was also reported in clinical trial. Administration of C. sativus and its constituents increased glutamate and dopamine levels in the brain in a dose-dependent manner. It also interacts with the opioid system to reduce withdrawal syndrome. Therefore, in the present article, the effects of C. sativus and its constituents on the nervous system and the possible underlying mechanisms are reviewed. Our literature review showed that C. sativus and its components can be considered as promising agents in the treatment of nervous system disorders.","tags":["#literature_note"],"author":[{"family":"Khazdair","given":"Mohammad Reza","literal":""},{"family":"Khazdair","given":"Mohammad Reza","literal":""},{"family":"Boskabady","given":"Mohammad Hossein","literal":""},{"family":"Boskabady","given":"Mohammad Hossein","literal":""},{"family":"Hosseini","given":"Mahmoud","literal":""},{"family":"Hosseini","given":"Mahmoud","literal":""},{"family":"Rezaee","given":"Ramin","literal":""},{"family":"Rezaee","given":"Ramin","literal":""},{"family":"Tsatsakis","given":"A.","literal":""},{"family":"Tsatsakis","given":"Aristeidis M.","literal":""}],"citation-key":"khazdair_effects_2015","year":"2015","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["The effects of Crocus sativus (saffron) and its constituents on nervous system: A review"],"author-links":["[[Author/Mohammad Reza Khazdair]]","[[Author/Mohammad Reza Khazdair]]","[[Author/Mohammad Hossein Boskabady]]","[[Author/Mohammad Hossein Boskabady]]","[[Author/Mahmoud Hosseini]]","[[Author/Mahmoud Hosseini]]","[[Author/Ramin Rezaee]]","[[Author/Ramin Rezaee]]","[[Author/A. Tsatsakis]]","[[Author/Aristeidis M. Tsatsakis]]"],"attachment":["[[biblib/khazdair_effects_2015/khazdair_effects_2015.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"1kn9ii9","at":1774951894762}},"smart_blocks:Research/@khazdair_effects_2015.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.0203669,-0.04495352,0.02188743,0.06808391,0.0517398,0.00940992,0.04204822,0.03851447,-0.07286819,0.00654905,0.01225038,-0.03414837,0.07488911,0.07764455,-0.00606275,-0.04034689,0.01294553,-0.00181822,-0.03902287,0.02226046,-0.00940845,0.01515243,0.08659542,-0.02611793,-0.02845451,0.04104049,0.00250005,-0.04382654,-0.05539247,-0.18978029,0.03909095,0.03448175,0.01332933,-0.00548772,-0.06123409,-0.01983679,-0.05026181,0.06300361,-0.04220692,0.03245591,0.05850033,0.04389288,0.01551745,-0.0048527,-0.02772185,0.01997074,-0.06919326,-0.05146359,0.07754163,0.03542663,-0.02854547,-0.02886528,0.03286971,0.07075939,-0.00082862,-0.01374373,0.01047262,0.02853035,-0.02695394,0.0329775,-0.01108148,0.09651138,-0.23878653,0.05619118,0.04706693,-0.03742772,-0.05527243,-0