03652793,-0.02832568,0.18687986,0.01277857,-0.05611542,0.04097444,-0.01829118,0.0174823,-0.00271415,0.04476158,0.01658242,0.02316165,0.09445669,-0.03712866,0.08625442,0.00463045,-0.07227775,-0.0297019,-0.03824455,-0.01848131,0.00280413,0.0040852,-0.07918914,-0.06581025,0.11603809,-0.08344623,-0.04960649,-0.09111621,-0.01301408,-0.01886475,-0.0308915,-0.00617143,-0.03336622,0.03531919,-0.03750741,-0.00074941,-0.00746123,0.00022898,-0.08237267,-0.02080753,-0.00693615,0.00533206,-0.05450676,0.07778607,0.09006929],"last_embed":{"hash":"1g70sld","tokens":479}}},"last_read":{"hash":"1g70sld","at":1774951893388},"class_name":"SmartSource","last_import":{"mtime":1774951826012,"size":2131,"at":1774951884820,"hash":"1g70sld"},"blocks":{"#---frontmatter---":[1,48],"#The use of Hericium erinaceus and Trametes versicolor extracts in supportive treatment in oncology.":[50,54],"#The use of Hericium erinaceus and Trametes versicolor extracts in supportive treatment in oncology.#{1}":[52,54]},"outlinks":[{"title":"Author/Mateusz Winder","target":"Author/Mateusz Winder","line":39},{"title":"Author/Mateusz Winder","target":"Author/Mateusz Winder","line":40},{"title":"Author/Weronika Bulska-Będkowska","target":"Author/Weronika Bulska-Będkowska","line":41},{"title":"Author/Weronika Bulska-Bedkowska","target":"Author/Weronika Bulska-Bedkowska","line":42},{"title":"Author/Jerzy Chudek","target":"Author/Jerzy Chudek","line":43},{"title":"Author/Jerzy Chudek","target":"Author/Jerzy Chudek","line":44}],"metadata":{"id":"winder_use_2021","type":"article-journal","title":"The use of Hericium erinaceus and Trametes versicolor extracts in supportive treatment in oncology.","issued":{"date-parts":[[2021]]},"DOI":"10.2478/acph-2021-0007","container-title":"Acta pharmaceutica (Zagreb, Croatia)","abstract":"Substances available in nature with potential therapeutic effects are the subject of research that raises tremendous hopes for new challenges in medicine. Fungi are the most common organisms in the ecosystem and the most interesting in this respect. This review discusses two species of edible fungi, used for centuries in Eastern natural medicine, with the best-documented effect - Hericium erinaceus (He) and Trametes versicolor (Tv). The results of in vivo and in vitro studies conducted on mice and human cell lines demonstrate immunomodulatory, potentially, anticancer, anti-inflammatory and neuroregenerative effects of substances isolated from these fungi. The substances contained in the extracts of He and Tv seem to have immunomodulatory effects that may support chemotherapy. The use of these extracts is justified stronger than the other supportive treat ments based on supplements.","tags":["#literature_note"],"author":[{"family":"Winder","given":"Mateusz","literal":""},{"family":"Winder","given":"Mateusz","literal":""},{"family":"Bulska-Będkowska","given":"Weronika","literal":""},{"family":"Bulska-Bedkowska","given":"Weronika","literal":""},{"family":"Chudek","given":"Jerzy","literal":""},{"family":"Chudek","given":"Jerzy","literal":""}],"citation-key":"winder_use_2021","year":"2021","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["The use of Hericium erinaceus and Trametes versicolor extracts in supportive treatment in oncology."],"author-links":["[[Author/Mateusz Winder]]","[[Author/Mateusz Winder]]","[[Author/Weronika Bulska-Będkowska]]","[[Author/Weronika Bulska-Bedkowska]]","[[Author/Jerzy Chudek]]","[[Author/Jerzy Chudek]]"],"attachment":[],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"1g70sld","at":1774951893379}},"smart_blocks:Research/@winder_use_2021.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.00649123,0.00591004,0.03837344,-0.01819788,0.04201828,-0.01055675,0.01986522,0.06385753,-0.06789151,-0.02006679,0.00307802,-0.10208812,-0.02261215,-0.00595091,0.00946616,-0.01532304,0.00130862,0.03018849,-0.08416963,0.02248719,0.02609477,-0.05519124,0.01164853