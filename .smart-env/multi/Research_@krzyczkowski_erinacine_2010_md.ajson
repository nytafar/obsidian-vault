3598,-0.11081227,0.03689754,-0.01526384,0.18703219,-0.01014559,-0.0746671,0.01612034,-0.03460642,0.03046829,0.01384208,-0.01611517,-0.00451985,0.05859745,0.10484964,-0.01527159,0.03977635,0.02415437,-0.0322319,-0.03772382,-0.06515446,0.02681661,-0.01322556,-0.04827072,-0.08606424,-0.03592149,0.11162958,-0.02867518,-0.04507671,-0.08540914,0.02987771,-0.00727258,-0.06252907,0.03030242,-0.00113936,0.00431407,-0.06434703,0.03729396,-0.01261873,0.01024192,-0.0369108,0.01918566,-0.01554165,0.02594745,-0.03368318,0.09558508,0.02644992],"last_embed":{"hash":"a2uqsl","tokens":500}}},"last_read":{"hash":"a2uqsl","at":1774951892203},"class_name":"SmartSource","last_import":{"mtime":1774951823902,"size":2355,"at":1774951884812,"hash":"a2uqsl"},"blocks":{"#---frontmatter---":[1,49],"#Erinacine A biosynthesis in submerged cultivation of Hericium erinaceum: Quantification and improved cultivation":[51,55],"#Erinacine A biosynthesis in submerged cultivation of Hericium erinaceum: Quantification and improved cultivation#{1}":[53,55]},"outlinks":[{"title":"Author/Wojciech Krzyczkowski","target":"Author/Wojciech Krzyczkowski","line":39},{"title":"Author/W. Krzyczkowski","target":"Author/W. Krzyczkowski","line":40},{"title":"Author/Eliza Malinowska","target":"Author/Eliza Malinowska","line":41},{"title":"Author/Eliza Malinowska","target":"Author/Eliza Malinowska","line":42},{"title":"Author/Franciszek Herold","target":"Author/Franciszek Herold","line":43},{"title":"Author/Franciszek Herold","target":"Author/Franciszek Herold","line":44},{"title":"PDF","target":"biblib/krzyczkowski_erinacine_2010/krzyczkowski_erinacine_2010.pdf","line":46}],"metadata":{"id":"krzyczkowski_erinacine_2010","type":"article-journal","title":"Erinacine A biosynthesis in submerged cultivation of Hericium erinaceum: Quantification and improved cultivation","issued":{"date-parts":[[2010]]},"DOI":"10.1002/elsc.201000084","container-title":"Engineering in Life Sciences","abstract":"This paper describes the validation of an HPLC method for quantitative determination of erinacine A as well as optimization of the culture medium composition for its effective production in submerged culture of the edible and medicinal mushroom Hericium erinaceum. The effects of different medium components were examined by the one-factor-at-a-time method and then by the central composite rotatable design. The most favorable combination of nutrient medium constituents ensuring the highest erinacine A production was found to be: glucose 69.87g/L, casein peptone 11.17g/L, NaCl 1.45g/L, ZnSO4 55.24mg/L, KH2PO4 1.0g/L, and pH 4.5. The kinetics of metabolite biosynthesis was examined during the cultivation in a 10-L bioreactor. Under the optimal conditions the biomass yield was 13.3±2.6g/L, while the production of erinacine A was 192±42mg/L. The optimal time to obtain the highest production of erinacine A during cultivation of H. erinaceum in a bioreactor was eight days.","tags":["#literature_note"],"author":[{"family":"Krzyczkowski","given":"Wojciech","literal":""},{"family":"Krzyczkowski","given":"W.","literal":""},{"family":"Malinowska","given":"Eliza","literal":""},{"family":"Malinowska","given":"Eliza","literal":""},{"family":"Herold","given":"Franciszek","literal":""},{"family":"Herold","given":"Franciszek","literal":""}],"citation-key":"krzyczkowski_erinacine_2010","year":"2010","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Erinacine A biosynthesis in submerged cultivation of Hericium erinaceum: Quantification and improved cultivation"],"author-links":["[[Author/Wojciech Krzyczkowski]]","[[Author/W. Krzyczkowski]]","[[Author/Eliza Malinowska]]","[[Author/Eliza Malinowska]]","[[Author/Franciszek Herold]]","[[Author/Franciszek Herold]]"],"attachment":["[[biblib/krzyczkowski_erinacine_2010/krzyczkowski_erinacine_2010.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"a2uqsl","at":1774951892194}},"smart_blocks:Research/@krzyczkowski_