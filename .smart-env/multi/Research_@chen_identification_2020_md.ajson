,0.04080974,-0.05109844,0.186313,0.02855011,-0.05610814,0.06161295,0.00956104,0.01540354,-0.01506455,0.0242289,0.00347231,0.01934927,0.13094215,-0.03977199,0.07201651,0.02831652,-0.04060083,-0.03108744,-0.03957669,0.00575188,0.01975683,-0.02331686,-0.10348774,-0.02240883,0.11217494,-0.08732932,-0.02957821,-0.00703434,-0.02501211,0.00985893,0.02960204,-0.03090486,-0.01363866,0.01675047,-0.00754333,-0.04438255,-0.03775389,-0.01317702,-0.06562619,-0.00988173,0.03307726,0.03867204,-0.03027995,0.09163521,0.04075088],"last_embed":{"hash":"hddouv","tokens":499}}},"last_read":{"hash":"hddouv","at":1774951891461},"class_name":"SmartSource","last_import":{"mtime":1774951822543,"size":2417,"at":1774951884807,"hash":"hddouv"},"blocks":{"#---frontmatter---":[1,73],"#Identification and α-Glucosidase Inhibitory Activity of Meroterpenoids from Hericium erinaceus.":[75,79],"#Identification and α-Glucosidase Inhibitory Activity of Meroterpenoids from Hericium erinaceus.#{1}":[77,79]},"outlinks":[{"title":"Author/Baosong Chen","target":"Author/Baosong Chen","line":57},{"title":"Author/Baosong Chen","target":"Author/Baosong Chen","line":58},{"title":"Author/Junjie Han","target":"Author/Junjie Han","line":59},{"title":"Author/Junjie Han","target":"Author/Junjie Han","line":60},{"title":"Author/Bao Li","target":"Author/Bao Li","line":61},{"title":"Author/Li Bao","target":"Author/Li Bao","line":62},{"title":"Author/Wenzhao Wang","target":"Author/Wenzhao Wang","line":63},{"title":"Author/Wenzhao Wang","target":"Author/Wenzhao Wang","line":64},{"title":"Author/Ke Ma","target":"Author/Ke Ma","line":65},{"title":"Author/Ke Ma","target":"Author/Ke Ma","line":66},{"title":"Author/Hongwei Liu","target":"Author/Hongwei Liu","line":67},{"title":"Author/Hongwei Liu","target":"Author/Hongwei Liu","line":68},{"title":"PDF","target":"biblib/chen_identification_2020/chen_identification_2020.pdf","line":70}],"metadata":{"id":"chen_identification_2020","type":"article-journal","title":"Identification and α-Glucosidase Inhibitory Activity of Meroterpenoids from Hericium erinaceus.","issued":{"date-parts":[[2020]]},"DOI":"10.1055/a-1146-8369","container-title":"Planta Medica","abstract":"Hericium erinaceus is a very popular edible and medicinal mushroom used for the treatment of enervation and gastrointestinal diseases in Eastern Asia. Chemical investigation on the fruiting body of Hericium erinaceus led to the isolation of 4 new (1: - 4: ) and 10 known meroterpenoids (5: - 14: ). The structures of new compounds were determined via analysis of NMR and MS data in combination with chemical derivatization. The inhibitory activities of 1: - 14: against alpha-glucosidase were evaluated using p-nitrophenyl-alpha-D-glucopyranoside, sucrose, or maltose as substrate. Compounds 6, 9, 11: - 13: were demonstrated to show the alpha-glucosidase inhibitory activities. This work confirms the potential of H. erinaceus in the treatment of diabetes.","tags":["#literature_note"],"author":[{"family":"Chen","given":"Baosong","literal":""},{"family":"Chen","given":"Baosong","literal":""},{"family":"Han","given":"Junjie","literal":""},{"family":"Han","given":"Junjie","literal":""},{"family":"Li","given":"Bao","literal":""},{"family":"Bao","given":"Li","literal":""},{"family":"Wang","given":"Wenzhao","literal":""},{"family":"Wang","given":"Wenzhao","literal":""},{"family":"Ma","given":"Ke","literal":""},{"family":"Ma","given":"Ke","literal":""},{"family":"Liu","given":"Hongwei","literal":""},{"family":"Liu","given":"Hongwei","literal":""}],"citation-key":"chen_identification_2020","year":"2020","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Identification and α-Glucosidase Inhibitory Activity of Meroterpenoids from Hericium erinaceus."],"author-links":["[[Author/Baosong Chen]]","[[Author/Baosong Chen]]","[[Author/Junjie Han]]","[[Author/Junjie Han]]","[[Author/Bao Li]]","[[Author/Li Bao]]","[[Author/Wenzhao Wang]]","[[Author/Wenzhao Wang]]","[[Author/Ke Ma]]","[[Author/Ke 