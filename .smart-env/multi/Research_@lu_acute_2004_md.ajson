7,0.16538087,0.00745138,-0.00556336,0.07564979,-0.00312162,0.02013355,-0.01320275,0.00318191,-0.01667803,0.03212074,0.08595721,-0.0571124,0.05078626,0.05526507,-0.11710384,-0.01378479,0.01589913,0.01578751,0.03109234,0.03915791,0.01693439,-0.04339617,0.09802645,-0.04633212,-0.01980671,-0.03511705,-0.0537956,-0.00079468,-0.00485474,-0.00364596,-0.00938195,0.04763753,0.00303995,-0.0164248,-0.0690425,-0.03987047,0.00424026,-0.03281544,-0.04254034,-0.01245505,0.0051522,0.09759817,0.04402813],"last_embed":{"hash":"1ei0ww7","tokens":459}}},"last_read":{"hash":"1ei0ww7","at":1774951895604},"class_name":"SmartSource","last_import":{"mtime":1774951828517,"size":3749,"at":1774951884829,"hash":"1ei0ww7"},"blocks":{"#---frontmatter---":[1,97],"#The Acute Effects of L-theanine in Comparison With Alprazolam on Anticipatory Anxiety in Humans":[99,103],"#The Acute Effects of L-theanine in Comparison With Alprazolam on Anticipatory Anxiety in Humans#{1}":[101,103]},"outlinks":[{"title":"Author/Kristy Lu","target":"Author/Kristy Lu","line":75},{"title":"Author/Kristy Lu","target":"Author/Kristy Lu","line":76},{"title":"Author/Marcus A. Gray","target":"Author/Marcus A. Gray","line":77},{"title":"Author/Marcus A. Gray","target":"Author/Marcus A. Gray","line":78},{"title":"Author/Chris Oliver","target":"Author/Chris Oliver","line":79},{"title":"Author/Chris Oliver","target":"Author/Chris Oliver","line":80},{"title":"Author/David T. J. Liley","target":"Author/David T. J. Liley","line":81},{"title":"Author/David T. J. Liley","target":"Author/David T. J. Liley","line":82},{"title":"Author/Ben J. Harrison","target":"Author/Ben J. Harrison","line":83},{"title":"Author/Ben J. Harrison","target":"Author/Ben J. Harrison","line":84},{"title":"Author/Cali F. Bartholomeusz","target":"Author/Cali F. Bartholomeusz","line":85},{"title":"Author/Cali F. Bartholomeusz","target":"Author/Cali F. Bartholomeusz","line":86},{"title":"Author/K. Luan Phan","target":"Author/K. Luan Phan","line":87},{"title":"Author/K. Luan Phan","target":"Author/K. Luan Phan","line":88},{"title":"Author/Kinh Luan Phan","target":"Author/Kinh Luan Phan","line":89},{"title":"Author/Kinh Luan Phan","target":"Author/Kinh Luan Phan","line":90},{"title":"Author/Pradeep J. Nathan","target":"Author/Pradeep J. Nathan","line":91},{"title":"Author/Pradeep J. Nathan","target":"Author/Pradeep J. Nathan","line":92},{"title":"PDF","target":"biblib/lu_acute_2004/lu_acute_2004.pdf","line":94}],"metadata":{"id":"lu_acute_2004","type":"article-journal","title":"The Acute Effects of L-theanine in Comparison With Alprazolam on Anticipatory Anxiety in Humans","issued":{"date-parts":[[2004]]},"DOI":"10.1002/hup.611","container-title":"Human Psychopharmacology-clinical and Experimental","abstract":"L-Theanine (δ-glutamylethylamide) is one of the predominant amino acids ordinarily found in green tea, and historically has been used as a relaxing agent. The current study examined the acute effects of L-theanine in comparison with a standard benzodiazepine anxiolytic, alprazolam and placebo on behavioural measures of anxiety in healthy human subjects using the model of anticipatory anxiety (AA). Sixteen healthy volunteers received alprazolam (1 mg), L-theanine (200 mg) or placebo in a double-blind placebo-controlled repeated measures design. The acute effects of alprazolam and L-theanine were assessed under a relaxed and experimentally induced anxiety condition. Subjective self-reports of anxiety including BAI, VAMS, STAI state anxiety, were obtained during both task conditions at pre- and post-drug administrations. The results showed some evidence for relaxing effects of L-theanine during the baseline condition on the tranquil–troubled subscale of the VAMS. Alprazolam did not exert any anxiolytic effects in comparison with the placebo on any of the measures during the relaxed state. Neither L-theanine nor alprazalam had any significant anxiolytic effects during the experimentally induced anxiety state. The findings suggest that while L-theanine may have some relaxing effects under resting conditions, neither L-theanine not alprazolam demonstrate any acute anxiolytic effects under conditions of increased anxiety in the AA model.","tags":["#literature_note"],"author":[{"family":"Lu","given":"Kristy","literal":""},{"family":"Lu","given":"Kristy","literal":""},{"family":"Gray","given":"Marcus A.","literal":""},{"family":"Gray","given":"Marcus A.","literal":""},{"family":"Oliver","given":"Chris","literal":""},{"family":"Oliver","given":"Chris","literal":""},{"family":"Liley","given":"David T. J.","literal":""},{"family":"Liley","given":"David T. J.","literal":""},{"family":"Harrison","given":"Ben J.","literal":""},{"family":"Harrison","given":"Ben J.","literal":""},{"family":"Bartholomeusz","given":"Cali F.","literal":""},{"family":"Bartholomeusz","given":"Cali F.","literal":""},{"family":"Phan","given":"K. Luan","literal":""},{"family":"Phan","given":"K. Luan","literal":""},{"family":"Phan","given":"Kinh Luan","literal":""},{"family":"Phan","given":"Kinh Luan","literal":""},{"family":"Nathan","given":"Pradeep J.","literal":""},{"family":"Nathan","given":"Pradeep J.","literal":""}],"citation-key":"lu_acute_2004","year":"2004","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["The Acute Effects of L-theanine in Comparison With Alprazolam on Anticipatory Anxiety in Humans"],"author-links":["[[Author/Kristy Lu]]","[[Author/Kristy Lu]]","[[Author/Marcus A. Gray]]","[[Author/Marcus A. Gray]]","[[Author/Chris Oliver]]","[[Author/Chris Oliver]]","[[Author/David T. J. Liley]]","[[Author/David T. J. Liley]]","[[Author/Ben J. Harrison]]","[[Author/Ben J. Harrison]]","[[Author/Cali F. Bartholomeusz]]","[[Author/Cali F. Bartholomeusz]]","[[Author/K. Luan Phan]]","[[Author/K. Luan Phan]]","[[Author/Kinh Luan Phan]]","[[Author/Kinh Luan Phan]]","[[Author/Pradeep J. Nathan]]","[[Author/Pradeep J. Nathan]]"],"attachment":["[[biblib/lu_acute_2004/lu_acute_2004.pdf|PDF]]"],"related":[