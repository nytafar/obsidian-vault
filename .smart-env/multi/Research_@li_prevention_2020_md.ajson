04684,-0.02633346,0.16103449,0.01603457,-0.0435946,0.03944403,-0.00839504,0.01406217,0.02078445,0.01354905,0.00105131,0.02466462,0.08178533,-0.00006362,0.08778016,0.07577389,-0.0787563,-0.0534536,0.01719006,-0.01280922,0.06358381,-0.00144516,-0.07745598,-0.01482552,0.05399822,0.00525707,-0.02432936,0.01064812,-0.04094649,0.00085094,-0.01014534,-0.07503784,0.01606355,-0.0343453,-0.00602508,0.00978354,0.02403523,-0.01884637,-0.0302473,0.00762933,0.00763354,0.02276694,-0.0530327,0.1252678,0.04041401],"last_embed":{"hash":"1ya1vio","tokens":421}}},"last_read":{"hash":"1ya1vio","at":1774951888536},"class_name":"SmartSource","last_import":{"mtime":1774951818970,"size":5219,"at":1774951884791,"hash":"1ya1vio"},"blocks":{"#---frontmatter---":[1,117],"#Prevention of Early Alzheimer's Disease by Erinacine A-Enriched Hericium erinaceus Mycelia Pilot Double-Blind Placebo-Controlled Study.":[119,123],"#Prevention of Early Alzheimer's Disease by Erinacine A-Enriched Hericium erinaceus Mycelia Pilot Double-Blind Placebo-Controlled Study.#{1}":[121,123]},"outlinks":[{"title":"Author/I.-Chen Li","target":"Author/I.-Chen Li","line":90},{"title":"Author/I.-Chen Li","target":"Author/I.-Chen Li","line":91},{"title":"Author/Han-Hsin Chang","target":"Author/Han-Hsin Chang","line":92},{"title":"Author/Han-Hsin Chang","target":"Author/Han-Hsin Chang","line":93},{"title":"Author/Chi-Huang Lin","target":"Author/Chi-Huang Lin","line":94},{"title":"Author/Chuan-Han Lin","target":"Author/Chuan-Han Lin","line":95},{"title":"Author/Wanping Chen","target":"Author/Wanping Chen","line":96},{"title":"Author/Wan-Ping Chen","target":"Author/Wan-Ping Chen","line":97},{"title":"Author/Wan-Ping Chen","target":"Author/Wan-Ping Chen","line":98},{"title":"Author/Tian-Huey Lu","target":"Author/Tian-Huey Lu","line":99},{"title":"Author/Tsung-Han Lu","target":"Author/Tsung-Han Lu","line":100},{"title":"Author/Li-Ya Lee","target":"Author/Li-Ya Lee","line":101},{"title":"Author/Lee Li-Ya","target":"Author/Lee Li-Ya","line":102},{"title":"Author/Yu-Wen Chen","target":"Author/Yu-Wen Chen","line":103},{"title":"Author/Yu-Wen Chen","target":"Author/Yu-Wen Chen","line":104},{"title":"Author/Yu-Wen Chen","target":"Author/Yu-Wen Chen","line":105},{"title":"Author/Yen-Po Chen","target":"Author/Yen-Po Chen","line":106},{"title":"Author/Yen-Po Chen","target":"Author/Yen-Po Chen","line":107},{"title":"Author/Chin-Chu Chen","target":"Author/Chin-Chu Chen","line":108},{"title":"Author/Chen Chin-Chu","target":"Author/Chen Chin-Chu","line":109},{"title":"Author/David Pei-Cheng Lin","target":"Author/David Pei-Cheng Lin","line":110},{"title":"Author/David Pei-Cheng Lin","target":"Author/David Pei-Cheng Lin","line":111},{"title":"Author/David Pei-Cheng Lin","target":"Author/David Pei-Cheng Lin","line":112},{"title":"PDF","target":"biblib/li_prevention_2020/li_prevention_2020.pdf","line":114}],"metadata":{"id":"li_prevention_2020","type":"article-journal","title":"Prevention of Early Alzheimer's Disease by Erinacine A-Enriched Hericium erinaceus Mycelia Pilot Double-Blind Placebo-Controlled Study.","issued":{"date-parts":[[2020]]},"DOI":"10.3389/fnagi.2020.00155","container-title":"Frontiers in Aging Neuroscience","abstract":"Objective: To investigate the efficacy and safety of three H. erinaceus mycelia (EAHE) capsules (350 mg/capsule; containing 5 mg/g erinacine A active ingredient) per day for the treatment of patients with mild Alzheimer’s Disease (AD). Methods: This study comprised a 3-week no-drug screening period, followed by a 49-week double-blind treatment period with 2-parallel groups in which eligible patients were randomized to either three 5 mg/g EAHE mycelia capsules per day or identical appearing placebo capsules. Cognitive assessments, ophthalmic examinations, biomarker collection, and neuroimaging were followed throughout the study period. Results: After 49 weeks of EAHE intervention, a significant decrease in Cognitive Abilities Screening Instrument score was noted in the placebo group, a significant improvement in Mini-Mental State Examination score was observed in the EAHE group and a significant Instrumental Activities of Daily Living score difference were found between the two groups. In addition, EAHE group achieved a significantly better contrast sensitivity when compared to the placebo group. Moreover, only the placebo group observed significantly lowered biomarkers such as calcium, albumin, apolipoprotein E4, hemoglobin, and brain-derived neurotrophic factor and significantly elevated alpha1-antichymotrypsin and amyloid-beta peptide 1-40 over the study period. Using diffusion tensor imaging, the mean apparent diffusion coefficient (ADC) values from the arcuate fasciculus region in the dominant hemisphere significantly increased in the placebo group while no significant difference was found in the EAHE group in comparison to their baselines. Moreover, ADC values from the parahippocampal cingulum region in the dominant hemisphere significantly decreased in the EAHE group whereas no significant difference was found in the placebo group when compared to their baselines. Lastly, except for four subjects who dropped out of the study due to abdominal discomfort, nausea, and skin rash, no other adverse events were reported. Conclusions: Three 350 mg/g EAHE capsules intervention for 49 weeks demonstrated higher CASI, MMSE, and IADL scores and achieved a better contrast sensitivity in patients with mild AD when compared to the placebo group, suggesting that EAHE is safe, well-tolerated, and may be important in achieving neurocognitive benefits. Trial registration: ClinicalTrials.gov identifier NCT04065061.","tags":["#literature_note"],"author":[{"family":"Li","given":"I.-Chen","literal":""},{"family":"Li","given":"I.-Chen","literal":""},{"family":"Chang","given":"Han-Hsin","literal":""},{"family":"Chang","given":"Han-Hsin","literal":""},{"family":"Lin","given":"Chi-Huang","literal":""},{"family":"Lin","given":"Chuan-Han","literal":""},{"family":"Chen","given":"Wanping","literal":""},{"family":"Chen","given":"Wan-Ping","literal":""},{"family":"Chen","given":"Wan-Ping","literal":""},{"family":"Lu","given":"Tian-Huey","literal":""},{"family":"Lu","given":"Tsung-Han","literal":""},{"family":"Lee","given":"Li-Ya","literal":""},{"family":"Li-Ya","given":"Lee","literal":""},{"family":"Chen","given":"Yu-Wen","literal":""},{"family":"Chen","given":"Yu-Wen","literal":""},{"family":"Chen","given":"Yu-Wen","literal":""},{"family":"Chen","given":"Yen-Po","literal":""},{"family":"Chen","given":"Yen-Po","literal":""},{"family":"Chen","given":"Chin-Chu","literal":""},{"family":"Chin-Chu","given":"Chen","literal":""},{"family":"Lin","given":"David Pei-Cheng","literal":""},{"family":"Lin","given":"David Pei-Cheng","literal":""},{"family":"Lin","given":"David Pei-Cheng","literal":""}],"citation-key":"li_prevention_2020","year":"2020","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Prevention of Early Alzheimer's Disease by Erinacine A-Enriched Hericium erinaceus Mycelia Pilot Double-Blind Placebo-Controlled Study."],"author-links":["[[Author/I.-Chen Li]]","[[Author/I.-Chen Li]]","[[Author/Han-Hsin Chang]]","[[Author/Han-Hsin Chang]]","[[Author/Chi-Huang Lin]]","[[Author/Chuan-Han Lin]]","[[Author/Wanping Chen]]","[[Author/Wan-Ping Chen]]","[[Author/Wan-Ping Chen]]","[[Author/Tian-Huey Lu]]","[[Author/Tsung-Han Lu]]","[[Author/Li-Ya Lee]]","[[Author/Lee Li-Ya]]","[[Author/Yu-Wen Chen]]","[[Author/Yu-Wen Chen]]","[[Author/Yu-Wen Chen]]","[[Author/Yen-Po Chen]]","[[Author/Yen-Po Chen]]","[[Author/Chin-Chu Chen]]","[[Author/Chen Chin-Chu]]","[[Author/David Pei-Cheng Lin]]","[[Author/David Pei-Cheng Lin]]","[[Author/David Pei-Cheng Lin]]"],"attachment":["[[biblib/li_prevention_2020/li_prevention_2020.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"1ya1vio","at":1774951888528}},"smart_blocks:Research/@li_prevention_2020.md#---frontmatter---": {"path":null,