,-0.01672379,-0.04157632,-0.01214569,-0.02098533,0.17459686,0.00405622,-0.00979756,0.0469611,0.02495646,0.00675557,-0.00980262,0.03663585,0.04350939,-0.04149717,0.08404402,-0.04914968,0.0647755,0.04367932,0.03128795,0.00270818,0.01901722,-0.02574609,-0.0118286,0.03926326,-0.02148111,-0.06470755,0.15344372,-0.03390054,-0.00263133,-0.05857835,-0.01479805,0.02680224,-0.02291842,-0.02026734,-0.01710769,0.00387204,0.00734342,-0.00373297,-0.00085229,-0.01969594,-0.00734572,0.02087353,0.02763842,0.01700341,-0.11952573,0.06251604,0.01960288],"last_embed":{"hash":"cabsew","tokens":462}}},"last_read":{"hash":"cabsew","at":1774951888887},"class_name":"SmartSource","last_import":{"mtime":1774951819558,"size":2267,"at":1774951884795,"hash":"cabsew"},"blocks":{"#---frontmatter---":[1,49],"#Antimicrobial resistance: a global multifaceted phenomenon.":[51,55],"#Antimicrobial resistance: a global multifaceted phenomenon.#{1}":[53,55]},"outlinks":[{"title":"Author/Francesca Prestinaci","target":"Author/Francesca Prestinaci","line":39},{"title":"Author/Francesca Prestinaci","target":"Author/Francesca Prestinaci","line":40},{"title":"Author/Patrizio Pezzotti","target":"Author/Patrizio Pezzotti","line":41},{"title":"Author/Patrizio Pezzotti","target":"Author/Patrizio Pezzotti","line":42},{"title":"Author/Annalisa Pantosti","target":"Author/Annalisa Pantosti","line":43},{"title":"Author/Annalisa Pantosti","target":"Author/Annalisa Pantosti","line":44},{"title":"PDF","target":"biblib/prestinaci_antimicrobial_2015/prestinaci_antimicrobial_2015.pdf","line":46}],"metadata":{"id":"prestinaci_antimicrobial_2015","type":"article-journal","title":"Antimicrobial resistance: a global multifaceted phenomenon.","issued":{"date-parts":[[2015]]},"DOI":"10.1179/2047773215y.0000000030","container-title":"Pathogens and Global Health","abstract":"Antimicrobial resistance (AMR) is one of the most serious global public health threats in this century. The first World Health Organization (WHO) Global report on surveillance of AMR, published in April 2014, collected for the first time data from national and international surveillance networks, showing the extent of this phenomenon in many parts of the world and also the presence of large gaps in the existing surveillance. In this review, we focus on antibacterial resistance (ABR), which represents at the moment the major problem, both for the high rates of resistance observed in bacteria that cause common infections and for the complexity of the consequences of ABR. We describe the health and economic impact of ABR, the principal risk factors for its emergence and, in particular, we illustrate the highlights of four antibiotic-resistant pathogens of global concern – Staphylococcus aureus, Klebsiella pneumoniae, non-typhoidal Salmonella and Mycobacterium tuberculosis – for whom we report resistance data...","tags":["#literature_note"],"author":[{"family":"Prestinaci","given":"Francesca","literal":""},{"family":"Prestinaci","given":"Francesca","literal":""},{"family":"Pezzotti","given":"Patrizio","literal":""},{"family":"Pezzotti","given":"Patrizio","literal":""},{"family":"Pantosti","given":"Annalisa","literal":""},{"family":"Pantosti","given":"Annalisa","literal":""}],"citation-key":"prestinaci_antimicrobial_2015","year":"2015","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Antimicrobial resistance: a global multifaceted phenomenon."],"author-links":["[[Author/Francesca Prestinaci]]","[[Author/Francesca Prestinaci]]","[[Author/Patrizio Pezzotti]]","[[Author/Patrizio Pezzotti]]","[[Author/Annalisa Pantosti]]","[[Author/Annalisa Pantosti]]"],"attachment":["[[biblib/prestinaci_antimicrobial_2015/prestinaci_antimicrobial_2015.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"cabsew","at":1774951888878}},"smart_blocks:Research/@prestinaci_antimicrobial_2015.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.0066907,0.03398694