0.00528477,-0.00181669,0.15891197,-0.01111239,-0.05298153,0.0331644,-0.04781507,0.02583761,-0.02359724,0.05643836,-0.02807477,0.01370547,0.10994998,-0.03970885,0.03678426,0.06681593,-0.06243966,0.00896998,-0.04064478,-0.03615774,0.02380525,-0.05073116,-0.15216303,-0.07593568,0.11706369,-0.07526887,0.00066885,-0.03460043,-0.04191702,-0.03788527,-0.04178612,-0.03287524,-0.02862586,0.02572459,-0.01115519,-0.02497056,-0.03885993,0.01325437,-0.03116221,0.00923304,-0.00868851,0.01348725,-0.01966671,0.09488922,0.06085079],"last_embed":{"hash":"11huegf","tokens":499}}},"last_read":{"hash":"11huegf","at":1774951886247},"class_name":"SmartSource","last_import":{"mtime":1774951814878,"size":3785,"at":1774951884769,"hash":"11huegf"},"blocks":{"#---frontmatter---":[1,73],"#Antioxidant activity of edible fungi (truffles and mushrooms): losses during industrial processing.":[75,79],"#Antioxidant activity of edible fungi (truffles and mushrooms): losses during industrial processing.#{1}":[77,79]},"outlinks":[{"title":"Author/M. Antonia Murcia","target":"Author/M. Antonia Murcia","line":57},{"title":"Author/M. Antonia Murcia","target":"Author/M. Antonia Murcia","line":58},{"title":"Author/Magdalena Martı́nez-Tomé","target":"Author/Magdalena Martı́nez-Tomé","line":59},{"title":"Author/Magdalena Martínez-Tomé","target":"Author/Magdalena Martínez-Tomé","line":60},{"title":"Author/Ana María Millán Jiménez","target":"Author/Ana María Millán Jiménez","line":61},{"title":"Author/Antonia M. Jiménez","target":"Author/Antonia M. Jiménez","line":62},{"title":"Author/Antonio Vera","target":"Author/Antonio Vera","line":63},{"title":"Author/Ana Vera","target":"Author/Ana Vera","line":64},{"title":"Author/M. Honrubia","target":"Author/M. Honrubia","line":65},{"title":"Author/Mario Honrubia","target":"Author/Mario Honrubia","line":66},{"title":"Author/Pilar Parras","target":"Author/Pilar Parras","line":67},{"title":"Author/Pilar Parras","target":"Author/Pilar Parras","line":68},{"title":"PDF","target":"biblib/murcia_antioxidant_2002/murcia_antioxidant_2002.pdf","line":70}],"metadata":{"id":"murcia_antioxidant_2002","type":"article-journal","title":"Antioxidant activity of edible fungi (truffles and mushrooms): losses during industrial processing.","issued":{"date-parts":[[2002]]},"DOI":"10.4315/0362-028x-65.10.1614","container-title":"Journal of Food Protection","abstract":"The antioxidant properties of two raw truffles (Terfezia claveryi Chatin and Picoa juniperi Vittadini) and five raw mushrooms (Lepista nuda, Lentinus edodes, Agrocybe cylindracea, Cantharellus lutescens, and Hydnum repandum) were tested by subjecting these truffles and mushrooms to different industrial processes (freezing and canning) and comparing them with common food antioxidants (α-tocopherol [E-307], BHA [E-320], BHT [E-321], and propyl gallate [E-310]) with regard to their ability to inhibit lipid oxidation. All of the truffles and mushrooms analyzed exhibited higher percentages of oxidation inhibition than did the food antioxidants according to assays based on lipid peroxidation (LOO'), deoxyribose (OH'), and peroxidase (H 2 O 2 ). Frozen samples exhibited a small reduction in free radical scavenger activity, but the results did not show a significant difference (P < 0.05) with respect to the raw samples, while canned truffles and mushrooms lost some antioxidant activity as a consequence of industrial processing. All of the raw and frozen truffles and mushrooms except frozen Cantharellus improved the stability of oil against oxidation (100°C Rancimat), while canned samples accelerated oil degradation. Antioxidant activity during 30 days of storage was measured by the linoleic acid assay, and all of the samples except canned Terfezia, Picoa, and Hydnum showed high or medium antioxidant activity. The Trolox equivalent antioxidant capacity assay was used to provide a ranking order of antioxidant activity as measured against that of Trolox (a standard solution used to evaluate equivalent antioxidant capacity). The order of raw samples with regard to antioxidant capacity was as follows (in decreasing order): Cantharellus, Agrocybe, Lentinus, Terfezia, Picoa, Lepista, and Hydnum. Losses of antioxidant activity were detected in the processed samples of these truffles and mushrooms.","tags":["#literature_note"],"author":[{"family":"Murcia","given":"M. Antonia","literal":""},{"family":"Murcia","given":"M. Antonia","literal":""},{"family":"Martı́nez-Tomé","given":"Magdalena","literal":""},{"family":"Martínez-Tomé","given":"Magdalena","literal":""},{"family":"Jiménez","given":"Ana María Millán","literal":""},{"family":"Jiménez","given":"Antonia M.","literal":""},{"family":"Vera","given":"Antonio","literal":""},{"family":"Vera","given":"Ana","literal":""},{"family":"Honrubia","given":"M.","literal":""},{"family":"Honrubia","given":"Mario","literal":""},{"family":"Parras","given":"Pilar","literal":""},{"family":"Parras","given":"Pilar","literal":""}],"citation-key":"murcia_antioxidant_2002","year":"2002","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Antioxidant activity of edible fungi (truffles and mushrooms): losses during industrial processing."],"author-links":["[[Author/M. Antonia Murcia]]","[[Author/M. Antonia Murcia]]","[[Author/Magdalena Martı́nez-Tomé]]","[[Author/Magdalena Martínez-Tomé]]","[[Author/Ana María Millán Jiménez]]","[[Author/Antonia M. Jiménez]]","[[Author/Antonio Vera]]","[[Author/Ana Vera]]","[[Author/M. Honrubia]]","[[Author/Mario Honrubia]]","[[Author/Pilar Parras]]","[[Author/Pilar Parras]]"],"attachment":["[[biblib/murcia_antioxidant_2002/murcia_antioxidant_2002.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"11huegf","at":1774951886236}},"smart_blocks:Research/@murcia_antioxidant_2002.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.02730021,-0.02483093,-0.00235647,0.0083297,0.04792612,0.01074111,0.0271446,0.05505978,-0.07