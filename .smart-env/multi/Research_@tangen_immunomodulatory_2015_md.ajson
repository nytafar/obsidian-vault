296359,-0.00333025,0.01263545,0.00092895,0.15169767,-0.01987033,-0.00196448,0.01381034,-0.04496211,0.01950135,-0.00469442,0.05829586,0.0108831,0.01333174,0.05807336,-0.00674196,0.06813045,0.03970751,-0.028909,-0.01935695,-0.00490297,0.03467157,0.01329478,0.00691749,-0.06422535,-0.05796606,0.12593332,-0.08287147,-0.01474607,-0.04473805,-0.03436184,-0.00992972,-0.07361203,0.01242649,0.00756843,0.04201295,-0.04350214,0.01375366,0.02726116,0.00403459,-0.04322733,-0.01890952,0.01354565,0.01044673,-0.08680497,0.07498175,0.01843684],"last_embed":{"hash":"9655cj","tokens":445}}},"last_read":{"hash":"9655cj","at":1774951894233},"class_name":"SmartSource","last_import":{"mtime":1774951827136,"size":4295,"at":1774951884824,"hash":"9655cj"},"blocks":{"#---frontmatter---":[1,101],"#Immunomodulatory Effects of the Agaricus blazei Murrill-Based Mushroom Extract AndoSan in Patients with Multiple Myeloma Undergoing High Dose Chemotherapy and Autologous Stem Cell Transplantation: A Randomized, Double Blinded Clinical Study":[103,107],"#Immunomodulatory Effects of the Agaricus blazei Murrill-Based Mushroom Extract AndoSan in Patients with Multiple Myeloma Undergoing High Dose Chemotherapy and Autologous Stem Cell Transplantation: A Randomized, Double Blinded Clinical Study#{1}":[105,107]},"outlinks":[{"title":"Author/Jon-Magnus Tangen","target":"Author/Jon-Magnus Tangen","line":78},{"title":"Author/Jon-Magnus Tangen","target":"Author/Jon-Magnus Tangen","line":79},{"title":"Author/Jon-Magnus Tangen","target":"Author/Jon-Magnus Tangen","line":80},{"title":"Author/Anne Tierens","target":"Author/Anne Tierens","line":81},{"title":"Author/Anne Tierens","target":"Author/Anne Tierens","line":82},{"title":"Author/Jo Caers","target":"Author/Jo Caers","line":83},{"title":"Author/Jo Caers","target":"Author/Jo Caers","line":84},{"title":"Author/Marilène Binsfeld","target":"Author/Marilène Binsfeld","line":85},{"title":"Author/Marilène Binsfeld","target":"Author/Marilène Binsfeld","line":86},{"title":"Author/Ole Kristoffer Olstad","target":"Author/Ole Kristoffer Olstad","line":87},{"title":"Author/Ole Kristoffer Olstad","target":"Author/Ole Kristoffer Olstad","line":88},{"title":"Author/Anne-Marie Siebke Trøseid","target":"Author/Anne-Marie Siebke Trøseid","line":89},{"title":"Author/Anne-Marie Siebke Trøseid","target":"Author/Anne-Marie Siebke Trøseid","line":90},{"title":"Author/Junbai Wang","target":"Author/Junbai Wang","line":91},{"title":"Author/Junbai Wang","target":"Author/Junbai Wang","line":92},{"title":"Author/Geir E. Tjønnfjord","target":"Author/Geir E. Tjønnfjord","line":93},{"title":"Author/Geir E. Tjønnfjord","target":"Author/Geir E. Tjønnfjord","line":94},{"title":"Author/Geir Hetland","target":"Author/Geir Hetland","line":95},{"title":"Author/Geir Hetland","target":"Author/Geir Hetland","line":96},{"title":"PDF","target":"biblib/tangen_immunomodulatory_2015/tangen_immunomodulatory_2015.pdf","line":98}],"metadata":{"id":"tangen_immunomodulatory_2015","type":"article-journal","title":"Immunomodulatory Effects of the Agaricus blazei Murrill-Based Mushroom Extract AndoSan in Patients with Multiple Myeloma Undergoing High Dose Chemotherapy and Autologous Stem Cell Transplantation: A Randomized, Double Blinded Clinical Study","issued":{"date-parts":[[2015]]},"DOI":"10.1155/2015/718539","container-title":"BioMed Research International","abstract":"Forty patients with multiple myeloma scheduled to undergo high dose chemotherapy with autologous stem cell support were randomized in a double blinded fashion to receive adjuvant treatment with the mushroom extract AndoSan, containing 82% of Agaricus blazei Murrill (19 patients) or placebo (21 patients). Intake of the study product started on the day of stem cell mobilizing chemotherapy and continued until the end of aplasia after high dose chemotherapy, a period of about seven weeks. Thirty-three patients were evaluable for all study endpoints, while all 40 included patients were evaluable for survival endpoints. In the leukapheresis product harvested after stem cell mobilisation, increased percentages of Treg cells and plasmacytoid dendritic cells were found in patients receiving AndoSan. Also, in this group, a significant increase of serum levels of IL-1ra, IL-5, and IL-7 at the end of treatment was found. Whole genome microarray showed increased expression of immunoglobulin genes, Killer Immunoglobulin Receptor (KIR) genes, and HLA genes in the Agaricus group. Furthermore, AndoSan displayed a concentration dependent antiproliferative effect on mouse myeloma cells in vitro. There were no statistically significant differences in treatment response, overall survival, and time to new treatment. The study was registered with Clinicaltrials.gov NCT00970021.","tags":["#literature_note"],"author":[{"family":"Tangen","given":"Jon-Magnus","literal":""},{"family":"Tangen","given":"Jon-Magnus","literal":""},{"family":"Tangen","given":"Jon-Magnus","literal":""},{"family":"Tierens","given":"Anne","literal":""},{"family":"Tierens","given":"Anne","literal":""},{"family":"Caers","given":"Jo","literal":""},{"family":"Caers","given":"Jo","literal":""},{"family":"Binsfeld","given":"Marilène","literal":""},{"family":"Binsfeld","given":"Marilène","literal":""},{"family":"Olstad","given":"Ole Kristoffer","literal":""},{"family":"Olstad","given":"Ole Kristoffer","literal":""},{"family":"Trøseid","given":"Anne-Marie Siebke","literal":""},{"family":"Trøseid","given":"Anne-Marie Siebke","literal":""},{"family":"Wang","given":"Junbai","literal":""},{"family":"Wang","given":"Junbai","literal":""},{"family":"Tjønnfjord","given":"Geir E.","literal":""},{"family":"Tjønnfjord","given":"Geir E.","literal":""},{"family":"Hetland","given":"Geir","literal":""},{"family":"Hetland","given":"Geir","literal":""}],"citation-key":"tangen_immunomodulatory_2015","year":"2015","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Immunomodulatory Effects of the Agaricus blazei Murrill-Based Mushroom Extract AndoSan in Patients with Multiple Myeloma Undergoing High Dose Chemotherapy and Autologous Stem Cell Transplantation: A Randomized, Double Blinded Clinical Study"],"author-links":["[[Author/Jon-Magnus Tangen]]","[[Author/Jon-Magnus Tangen]]","[[Author/Jon-Magnus Tangen]]","[[Author/Anne Tierens]]","[[Author/Anne Tierens]]","[[Author/Jo Caers]]","[[Author/Jo Caers]]","[[Author/Marilène Binsfeld]]","[[Author/Marilène Binsfeld]]","[[Author/Ole Kristoffer Olstad]]","[[Author/Ole Kristoffer Olstad]]","[[Author/Anne-Marie Siebke Trøseid]]","[[Author/Anne-Marie Siebke Trøseid]]","[[Author/Junbai Wang]]","[[Author/Junbai Wang]]","[[Author/Geir E. Tjønnfjord]]","[[Author/Geir E. Tjønnfjord]]","[[Author/Geir Hetland]]","[[Author/Geir Hetland]]"],"attachment":["[[biblib/tangen_immunomodulatory_2015/tangen_immunomodulatory_2015.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"9655cj","at":1774951894213}},"smart_blocks:Research/@tangen_immunomodulatory_2015.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.04016536,0.01544792,-0.00303697,-0.06333495,-0.00530988,-0.03669516,0.03416472,0.02759005,-0.08098535,-0.0336222,0.04332269,-0.08862394,0.0165958,-0.00370366,0.00919474,0.04089524,0.0350015,0.00725549,-0.11434996,-0.00473403,-0.03075546,-0.0728361,0.01555263,-0.01964025,0.08486757,0.02846911,-0.06586847,-0.00412472,-0.04694993,-0.24884574,0.0533786,-0.00352077,0.00993609,-0.05216641,-0.01641733,-0.04140777,-0.00801628,0.0662161,-0.04769789,0.03615135,0.05937235,0.08475052,0.00377076,0.04539597,0.00798554,-0.06047403,-0.07830573,-0.06929626,0.03287814,0.00638849,0.0016806,-0.03828917,0.05231623,0.06530993,-0.03000122,0.01319009,-0.02792698,0.05414246,0.00641754,0.1063247,0.03123308,0.10535394,-0.18823104,0.06485979,0.0849394,-0.04057195,-0.07789538,-0.00545294,0.07221131,0.07031292,-0.03791935,0.02720596,0.03305915,0.06897288,0.03190295,-0.04441663,0.02681348,-0.01342895,-0.01308368,