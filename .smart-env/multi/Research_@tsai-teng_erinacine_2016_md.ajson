hor/Chi Ying F. Huang","target":"Author/Chi Ying F. Huang","line":87},{"title":"Author/Huang F. Chi-Ying","target":"Author/Huang F. Chi-Ying","line":88},{"title":"Author/Chien-Chih Chen","target":"Author/Chien-Chih Chen","line":89},{"title":"Author/Chen Chien-Chih","target":"Author/Chen Chien-Chih","line":90},{"title":"Author/Young-Ji Shiao","target":"Author/Young-Ji Shiao","line":91},{"title":"Author/Young Ji Shiao","target":"Author/Young Ji Shiao","line":92},{"title":"PDF","target":"biblib/tsai-teng_erinacine_2016/tsai-teng_erinacine_2016.pdf","line":94}],"metadata":{"id":"tsai-teng_erinacine_2016","type":"article-journal","title":"Erinacine A-enriched Hericium erinaceus mycelium ameliorates Alzheimer’s disease-related pathologies in APPswe/PS1dE9 transgenic mice","issued":{"date-parts":[[2016]]},"DOI":"10.1186/s12929-016-0266-z","container-title":"Journal of Biomedical Science","abstract":"Background The fruiting body of Hericium erinaceus has been demonstrated to possess anti-dementia activity in mouse model of Alzheimer’s disease and people with mild cognitive impairment. However, the therapeutic potential of Hericium erinaceus mycelia on Alzheimer’s disease remains unclear. In this study, the effects of erinacine A-enriched Hericium erinaceus mycelia (HE-My) on the pathological changes in APPswe/PS1dE9 transgenic mouse model of Alzheimer’s disease are studied.","tags":["#literature_note"],"author":[{"family":"Tsai-Teng","given":"Tzeng","literal":""},{"family":"Tsai-Teng","given":"Tzeng","literal":""},{"family":"Chen","given":"Chin-Chu","literal":""},{"family":"Chin-Chu","given":"Chen","literal":""},{"family":"Lee","given":"Li-Ya","literal":""},{"family":"Li-Ya","given":"Lee","literal":""},{"family":"Chen","given":"Wanping","literal":""},{"family":"Wan-Ping","given":"Chen","literal":""},{"family":"Lu","given":"Chung-Kuang","literal":""},{"family":"Chung-Kuang","given":"Lu","literal":""},{"family":"Chien-Chang","given":"Shen","literal":""},{"family":"Chien-Chang","given":"Shen","literal":""},{"family":"Huang","given":"Chi Ying F.","literal":""},{"family":"Chi-Ying","given":"Huang F.","literal":""},{"family":"Chen","given":"Chien-Chih","literal":""},{"family":"Chien-Chih","given":"Chen","literal":""},{"family":"Shiao","given":"Young-Ji","literal":""},{"family":"Shiao","given":"Young Ji","literal":""}],"citation-key":"tsai-teng_erinacine_2016","year":"2016","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Erinacine A-enriched Hericium erinaceus mycelium ameliorates Alzheimer’s disease-related pathologies in APPswe/PS1dE9 transgenic mice"],"author-links":["[[Author/Tzeng Tsai-Teng]]","[[Author/Tzeng Tsai-Teng]]","[[Author/Chin-Chu Chen]]","[[Author/Chen Chin-Chu]]","[[Author/Li-Ya Lee]]","[[Author/Lee Li-Ya]]","[[Author/Wanping Chen]]","[[Author/Chen Wan-Ping]]","[[Author/Chung-Kuang Lu]]","[[Author/Lu Chung-Kuang]]","[[Author/Shen Chien-Chang]]","[[Author/Shen Chien-Chang]]","[[Author/Chi Ying F. Huang]]","[[Author/Huang F. Chi-Ying]]","[[Author/Chien-Chih Chen]]","[[Author/Chen Chien-Chih]]","[[Author/Young-Ji Shiao]]","[[Author/Young Ji Shiao]]"],"attachment":["[[biblib/tsai-teng_erinacine_2016/tsai-teng_erinacine_2016.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"6rey6d","at":1774951887544}},"smart_blocks:Research/@tsai-teng_erinacine_2016.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.02257322,0.00127984,0.05212009,-0.02898156,-0.03537071,0.01635654,0.04381109,0.04098068,-0.01315047,-0.04482396,0.02395136,-0.09484334,0.04330309,0.00544675,0.05059874,0.0180509,-0.03765308,0.00137237,-0.08911598,-0.0154904,0.00967295,-0.05448482,0.05312146,0.00015097,0.0485533,0.00365057,-0.0098319,-0.00013885,-0.02595101,-0.20654798,-0.04402216,-0.02153997,0.00112574,0.00993805,-0.02093269,-0.00590044,-0.03504543,0.02390687,-0.02629932,-0.04617226,0.0769362,0.03608366,0.02633855,-0.03070815,0.0008885,-0.04335869,-0.02249265,-0.06565