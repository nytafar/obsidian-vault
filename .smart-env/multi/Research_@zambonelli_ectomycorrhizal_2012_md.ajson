.01655457,-0.05087984,0.04102943,0.01138153,0.17978193,0.03312612,-0.05189706,0.02658179,-0.02485805,0.00548188,-0.00529819,0.01949758,0.00611512,0.06723151,0.08588436,-0.00587323,0.03045665,-0.00038717,-0.00370809,-0.04018803,-0.00831982,-0.00397953,-0.04495705,-0.054103,-0.1083646,-0.01019174,0.07225073,-0.05780097,-0.00399615,-0.07166851,0.0196983,0.0114347,-0.03751111,-0.01575217,-0.04202335,0.02526854,-0.03200164,0.04014108,-0.01269654,-0.04006461,-0.08092964,-0.01505179,-0.00415965,0.00143538,-0.07182006,0.06108684,0.0412985],"last_embed":{"hash":"d80j83","tokens":452}}},"last_read":{"hash":"d80j83","at":1774951889127},"class_name":"SmartSource","last_import":{"mtime":1774951819907,"size":2944,"at":1774951884796,"hash":"d80j83"},"blocks":{"#---frontmatter---":[1,73],"#Ectomycorrhizal Fungal Communities of Edible Ectomycorrhizal Mushrooms":[75,79],"#Ectomycorrhizal Fungal Communities of Edible Ectomycorrhizal Mushrooms#{1}":[77,79]},"outlinks":[{"title":"Author/Alessandra Zambonelli","target":"Author/Alessandra Zambonelli","line":57},{"title":"Author/Alessandra Zambonelli","target":"Author/Alessandra Zambonelli","line":58},{"title":"Author/Mirco Iotti","target":"Author/Mirco Iotti","line":59},{"title":"Author/Mirco Iotti","target":"Author/Mirco Iotti","line":60},{"title":"Author/Siham Boutahir","target":"Author/Siham Boutahir","line":61},{"title":"Author/Siham Boutahir","target":"Author/Siham Boutahir","line":62},{"title":"Author/Enrico Lancellotti","target":"Author/Enrico Lancellotti","line":63},{"title":"Author/Enrico Lancellotti","target":"Author/Enrico Lancellotti","line":64},{"title":"Author/Claudia Perini","target":"Author/Claudia Perini","line":65},{"title":"Author/Claudia Perini","target":"Author/Claudia Perini","line":66},{"title":"Author/Giovanni Pacioni","target":"Author/Giovanni Pacioni","line":67},{"title":"Author/Giovanni Pacioni","target":"Author/Giovanni Pacioni","line":68},{"title":"PDF","target":"biblib/zambonelli_ectomycorrhizal_2012/zambonelli_ectomycorrhizal_2012.pdf","line":70}],"metadata":{"id":"zambonelli_ectomycorrhizal_2012","type":"article-journal","title":"Ectomycorrhizal Fungal Communities of Edible Ectomycorrhizal Mushrooms","issued":{"date-parts":[[2012]]},"DOI":"10.1007/978-3-642-33823-6_7","container-title":"null","abstract":"Edible ectomycorrhizal mushrooms (EEMMs) live in the soil in association with the roots of plants, other ectomycorrhizal fungi, and soil organisms, all of which compete for space and nutrients. Consequently, the success of introducing an edible ectomycorrhizal (EEM) fungus into soils with the intention of cultivation is entirely dependent on its ability to survive in this competitive environment. Studies on the composition and structure of ectomycorrhizal (EM) communities in both productive and nonproductive EEMM areas have contributed to a better understanding of the relationship that EEMMs establish with other EM fungi and the environment. These have included morphological studies, the use of molecular tools, and most recently metagenomic methodologies leading to new insights into soil EEMM ecology. In this chapter, we briefly describe the methods that have been used to study EM fungal communities and Web databases that can be used for the identification of ectomycorrhizas such as the recently released eMyCo. We also illustrate the studies that have been conducted on the EM communities in natural and cultivated ecosystems where the most important EEMMs are found.","tags":["#literature_note"],"author":[{"family":"Zambonelli","given":"Alessandra","literal":""},{"family":"Zambonelli","given":"Alessandra","literal":""},{"family":"Iotti","given":"Mirco","literal":""},{"family":"Iotti","given":"Mirco","literal":""},{"family":"Boutahir","given":"Siham","literal":""},{"family":"Boutahir","given":"Siham","literal":""},{"family":"Lancellotti","given":"Enrico","literal":""},{"family":"Lancellotti","given":"Enrico","literal":""},{"family":"Perini","given":"Claudia","literal":""},{"family":"Perini","given":"Claudia","literal":""},{"family":"Pacioni","given":"Giovanni","literal":""},{"family":"Pacioni","given":"Giovanni","literal":""}],"citation-key":"zambonelli_ectomycorrhizal_2012","year":"2012","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Ectomycorrhizal Fungal Communities of Edible Ectomycorrhizal Mushrooms"],"author-links":["[[Author/Alessandra Zambonelli]]","[[Author/Alessandra Zambonelli]]","[[Author/Mirco Iotti]]","[[Author/Mirco Iotti]]","[[Author/Siham Boutahir]]","[[Author/Siham Boutahir]]","[[Author/Enrico Lancellotti]]","[[Author/Enrico Lancellotti]]","[[Author/Claudia Perini]]","[[Author/Claudia Perini]]","[[Author/Giovanni Pacioni]]","[[Author/Giovanni Pacioni]]"],"attachment":["[[biblib/zambonelli_ectomycorrhizal_2012/zambonelli_ectomycorrhizal_2012.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"d80j83","at":1774951889119}},"smart_blocks:Research/@zambonelli_ectomycorrhizal_2012.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.04018741,-0.03660349,0.03302333,0.00838602,0.05964527,-0.02216925,-0.04625934,0.00287885,-0.0450833,0.0348141,0.01037736,-0.0662939,0.03278814,0.01485422,-0.03830209,0.02171015,-0.03370418,0.06693734,-0.03657027,0.02719839,0.07713655,-0.02211115,0.0484111,0.00238139,0.02676306,0.03719547,-0.03826608,-0.01127166,-0.0587249,-0.21335879,0.00551545,0.04809371,0.07605045,-0.01124933,-0.01380788,-0.02297167,-0.00423629,-0.05226586,-0.01572993,0.02922962,0.0301508,0.02626086,-0.01925166,0.02428573,-0.03883323,-0.07572068,-0.02314285,-0.00854961,0.00844035,-0.06133505,-0.01649013,-0.05959484,-0.03056153,0.02193532,0.0036613,0.0386215,0.03308265,0.04127826,0.02589837,0.03140869,0.06721704,0.06399471,-0.15919453,0.05858645,0.05681252,0.00704264,-0.10168903,0.01140348,0.12822123,-0.03959094,0.0041894,0.06885511,0.01598973,0.05087273,0.07751945,0.01198898,0.02707403,-0.04040194,-0.05615693,-0.03305091,-0.04