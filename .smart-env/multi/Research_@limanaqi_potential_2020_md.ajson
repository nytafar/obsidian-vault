4737,-0.01774927,0.0344611,0.17916717,-0.00714458,0.01337746,-0.02836761,-0.00109495,-0.01846079,-0.0251849,-0.00427019,0.00785806,0.02046114,0.13293274,-0.04868523,0.05536363,0.03728725,-0.11549934,-0.02704487,-0.00981094,-0.03191469,0.04626662,0.01860999,-0.08106419,-0.03285859,0.08825161,-0.0806834,-0.06315521,-0.04305065,-0.04576828,0.02854276,0.01051245,0.04242355,0.0432292,0.03975236,0.00723885,0.0222726,-0.00112171,-0.0373128,0.00977752,-0.02784797,-0.00327459,-0.03264076,-0.08809365,0.12519665,0.06067238],"last_embed":{"hash":"1t3e228","tokens":415}}},"last_read":{"hash":"1t3e228","at":1774951893635},"class_name":"SmartSource","last_import":{"mtime":1774951826439,"size":3271,"at":1774951884822,"hash":"1t3e228"},"blocks":{"#---frontmatter---":[1,73],"#Potential Antidepressant Effects of Scutellaria baicalensis, Hericium erinaceus and Rhodiola rosea.":[75,79],"#Potential Antidepressant Effects of Scutellaria baicalensis, Hericium erinaceus and Rhodiola rosea.#{1}":[77,79]},"outlinks":[{"title":"Author/Fiona Limanaqi","target":"Author/Fiona Limanaqi","line":57},{"title":"Author/Fiona Limanaqi","target":"Author/Fiona Limanaqi","line":58},{"title":"Author/Francesca Biagioni","target":"Author/Francesca Biagioni","line":59},{"title":"Author/Francesca Biagioni","target":"Author/Francesca Biagioni","line":60},{"title":"Author/Carla Letizia Busceti","target":"Author/Carla Letizia Busceti","line":61},{"title":"Author/Carla L. Busceti","target":"Author/Carla L. Busceti","line":62},{"title":"Author/Maico Polzella","target":"Author/Maico Polzella","line":63},{"title":"Author/Maico Polzella","target":"Author/Maico Polzella","line":64},{"title":"Author/Cinzia Fabrizi","target":"Author/Cinzia Fabrizi","line":65},{"title":"Author/Cinzia Fabrizi","target":"Author/Cinzia Fabrizi","line":66},{"title":"Author/Cinzia Fabrizi","target":"Author/Cinzia Fabrizi","line":67},{"title":"Author/Francesco Fornai","target":"Author/Francesco Fornai","line":68},{"title":"PDF","target":"biblib/limanaqi_potential_2020/limanaqi_potential_2020.pdf","line":70}],"metadata":{"id":"limanaqi_potential_2020","type":"article-journal","title":"Potential Antidepressant Effects of Scutellaria baicalensis, Hericium erinaceus and Rhodiola rosea.","issued":{"date-parts":[[2020]]},"DOI":"10.3390/antiox9030234","container-title":"Antioxidants","abstract":"Recent studies focused on the pharmacology and feasibility of herbal compounds as a potential strategy to target a variety of human diseases ranging from metabolic to brain disorders. Accordingly, bioactive ingredients which are found within a variety of herbal compounds are reported to produce both neuroprotective and psychotropic activities which may help to combat mental disorders such as depression, anxiety, sleep disturbances and cognitive alterations. In the present manuscript, we focus on three herbs which appear effective in mitigating anxiety or depression with favourable risk-benefit profiles, namely Scutellaria baicalensis (S. baicalensis), Hericium erinaceus (H. erinaceus) and Rhodiola rosea (R. rosea). These three traditional folk medicinal herbs target the main biochemical events that are implicated in mental disorders, mimicking, to some extent, the mechanisms of action of conventional antidepressants and mood stabilizers with a wide margin of tolerability. In detail, they rescue alterations in neurotransmitter and neuro-endocrine systems, stimulate neurogenesis and the synthesis of neurotrophic factors, and they counteract oxidative stress, mitochondrial dysfunction and inflammation. Albeit the encouraging results that emerge from both experimental and clinical evidence, further studies are needed to confirm and better understand the mental-health promoting, and specifically, the antidepressant effects of these herbs.","tags":["#literature_note"],"author":[{"family":"Limanaqi","given":"Fiona","literal":""},{"family":"Limanaqi","given":"Fiona","literal":""},{"family":"Biagioni","given":"Francesca","literal":""},{"family":"Biagioni","given":"Francesca","literal":""},{"family":"Busceti","given":"Carla Letizia","literal":""},{"family":"Busceti","given":"Carla L.","literal":""},{"family":"Polzella","given":"Maico","literal":""},{"family":"Polzella","given":"Maico","literal":""},{"family":"Fabrizi","given":"Cinzia","literal":""},{"family":"Fabrizi","given":"Cinzia","literal":""},{"family":"Fabrizi","given":"Cinzia","literal":""},{"family":"Fornai","given":"Francesco","literal":""}],"citation-key":"limanaqi_potential_2020","year":"2020","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Potential Antidepressant Effects of Scutellaria baicalensis, Hericium erinaceus and Rhodiola rosea."],"author-links":["[[Author/Fiona Limanaqi]]","[[Author/Fiona Limanaqi]]","[[Author/Francesca Biagioni]]","[[Author/Francesca Biagioni]]","[[Author/Carla Letizia Busceti]]","[[Author/Carla L. Busceti]]","[[Author/Maico Polzella]]","[[Author/Maico Polzella]]","[[Author/Cinzia Fabrizi]]","[[Author/Cinzia Fabrizi]]","[[Author/Cinzia Fabrizi]]","[[Author/Francesco Fornai]]"],"attachment":["[[biblib/limanaqi_potential_2020/limanaqi_potential_2020.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"1t3e228","at":1774951893625}},"smart_blocks:Research/@limanaqi_potential_2020.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.02146389,-0.00778823,0.0424966,0.01571875,0.00970539,0.04881461,0.02001792,0.03785526,-0.0174115,-0.04165857,-0.0253839,-0.03073207,0.03394822,0.05670298,0.00226522,0.04213735,0.03661861,-0.01051504,-0.10412724,-0.00065327,-0.0208314,-0.04435653,0.02831039,0.00804733,0.00337949,0.03751285,-0.00758607,-0.0100081,-0.0518569,-0.16092347,0.02848124,0.01803776,0.03749959,-0.01282824,-0.01600802,0.01294955,-0.06628521,0.05471828,-0.01091014,0.00981352,0.06149532,0.04924228,0.02968043,0.04172574,-0.01104949,-0.05414369,0.01850824,-0.00289283,0.01805783,-0.04687626,-0.00549559,-0.01463348,0.0