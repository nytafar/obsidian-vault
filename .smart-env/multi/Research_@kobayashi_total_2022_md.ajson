ction 2 Pioneering Synthetic Study 3 Total Synthesis of Geranyl-Resorcinol with a Geranyl Side Chain (Types 1, 3 and 6) 4 Total Synthesis of Geranyl-Resorcinol with an Oxidized Geranyl-derived Side Chain (Types 2, 4 and 7) 5 Conclusion","tags":["#literature_note"],"author":[{"family":"Kobayashi","given":"Shoji","literal":""},{"family":"Kobayashi","given":"Shōji","literal":""}],"citation-key":"kobayashi_total_2022","year":"2022","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Total Synthesis of Geranyl-Resorcinols Isolated from Mushrooms of genus Hericium"],"author-links":["[[Author/Shoji Kobayashi]]","[[Author/Shōji Kobayashi]]"],"attachment":["[[biblib/kobayashi_total_2022/kobayashi_total_2022.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"1wt0qwo","at":1774951888566}},"smart_blocks:Research/@kobayashi_total_2022.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.02016117,-0.05367015,0.01338049,-0.04188396,0.01985007,0.00750701,-0.07255317,0.032582,-0.06895906,0.05018966,-0.01418268,-0.06836376,0.02611024,-0.02756309,0.00005064,0.00628801,-0.00750048,-0.00081077,-0.01814088,-0.02542626,0.06491841,-0.02207952,0.01556051,-0.00072289,0.06560675,0.00644492,0.01624491,-0.01427906,-0.04266623,-0.23302089,-0.01303138,0.03783176,-0.03514444,-0.04882382,0.00193537,-0.02196395,-0.02659739,0.02446388,-0.03753034,0.0116267,-0.02546213,0.00558171,0.06397762,0.0038831,0.01519929,-0.05573335,-0.06195334,0.01336044,0.00964672,-0.00801583,-0.05701368,-0.04167837,0.00367271,0.03562367,0.05025924,-0.00863569,0.02754205,0.03673838,0.03588432,0.01433554,0.06422292,0.10616826,-0.1712196,0.01293472,0.00108642,0.02844661,-0.10419545,-0.05283055,0.06950006,0.05459029,-0.01801276,0.06132106,0.01383861,0.01646547,0.04062976,-0.0499974,0.0320453,-0.02140074,-0.02086492,0.00249887,0.00953675,0.03800146,0.01442238,-0.01865011,-0.02833513,-0.04254591,0.03818253,-0.03320456,0.03406306,0.0543446