.00462705,-0.00592561,0.19487688,0.06983417,-0.01515814,-0.00205493,-0.04029376,0.0225835,0.01799331,-0.01227722,-0.01147103,0.03739898,0.08415154,-0.04190455,0.08959071,0.04862733,-0.05995082,-0.01129323,-0.02728353,-0.02089036,-0.00499741,-0.01844394,-0.09604942,-0.01125932,0.12169988,-0.0646734,-0.04189389,-0.01695141,-0.02930151,0.01334306,-0.00462245,0.00009129,0.01309488,0.04431919,0.00821361,0.00839948,-0.00234078,-0.04959211,-0.03313841,0.01361824,0.00452302,-0.01746237,-0.02502776,0.11606715,0.02454405],"last_embed":{"hash":"1r8bneo","tokens":481}}},"last_read":{"hash":"1r8bneo","at":1774951887771},"class_name":"SmartSource","last_import":{"mtime":1774951817645,"size":3365,"at":1774951884784,"hash":"1r8bneo"},"blocks":{"#---frontmatter---":[1,93],"#Chemical Constituents from Hericium erinaceus Promote Neuronal Survival and Potentiate Neurite Outgrowth via the TrkA/Erk1/2 Pathway.":[95,99],"#Chemical Constituents from Hericium erinaceus Promote Neuronal Survival and Potentiate Neurite Outgrowth via the TrkA/Erk1/2 Pathway.#{1}":[97,99]},"outlinks":[{"title":"Author/Cheng-Chen Zhang","target":"Author/Cheng-Chen Zhang","line":72},{"title":"Author/Cheng-Chen Zhang","target":"Author/Cheng-Chen Zhang","line":73},{"title":"Author/Cheng-Chen Zhang","target":"Author/Cheng-Chen Zhang","line":74},{"title":"Author/Chenyu Cao","target":"Author/Chenyu Cao","line":75},{"title":"Author/Chen-Yu Cao","target":"Author/Chen-Yu Cao","line":76},{"title":"Author/Chen-Yu Cao","target":"Author/Chen-Yu Cao","line":77},{"title":"Author/Miwa Kubo","target":"Author/Miwa Kubo","line":78},{"title":"Author/Kenichi Harada","target":"Author/Kenichi Harada","line":79},{"title":"Author/Miwa Kubo","target":"Author/Miwa Kubo","line":80},{"title":"Author/Kenichi Harada","target":"Author/Kenichi Harada","line":81},{"title":"Author/Xi-Tao Yan","target":"Author/Xi-Tao Yan","line":82},{"title":"Author/Xiaohai Yan","target":"Author/Xiaohai Yan","line":83},{"title":"Author/Xi-Tao Yan","target":"Author/Xi-Tao Yan","line":84},{"title":"Author/Yoshiyasu Fukuyama","target":"Author/Yoshiyasu Fukuyama","line":85},{"title":"Author/Yoshiyasu Fukuyama","target":"Author/Yoshiyasu Fukuyama","line":86},{"title":"Author/Jin-Ming Gao","target":"Author/Jin-Ming Gao","line":87},{"title":"Author/Jin-Ming Gao","target":"Author/Jin-Ming Gao","line":88},{"title":"PDF","target":"biblib/zhang_chemical_2017/zhang_chemical_2017.pdf","line":90}],"metadata":{"id":"zhang_chemical_2017","type":"article-journal","title":"Chemical Constituents from Hericium erinaceus Promote Neuronal Survival and Potentiate Neurite Outgrowth via the TrkA/Erk1/2 Pathway.","issued":{"date-parts":[[2017]]},"DOI":"10.3390/ijms18081659","container-title":"International Journal of Molecular Sciences","abstract":"Hericium erinaceus is a culinary-medicinal mushroom used traditionally in Eastern Asia to improve memory. In this work, we investigated the neuroprotective and neuritogenic effects of the secondary metabolites isolated from the MeOH extract of cultured mycelium of H. erinaceus and the primary mechanisms involved. One new dihydropyridine compound (6) and one new natural product (2) together with five known compounds (1,3–5,7) were obtained and their structures were elucidated by spectroscopic analysis, including 2D NMR and HRMS. The cell-based screening for bioactivity showed that 4-chloro-3,5-dimethoxybenzoic methyl ester (1) and a cyathane diterpenoid, erincine A (3), not only potentiated NGF-induced neurite outgrowth but also protected neuronally-differentiated cells against deprivation of NGF in PC12 pheochromocytoma cells. Additionally, compound 3 induced neuritogenesis in primary rat cortex neurons. Furthermore, our results revealed that TrkA-mediated and Erk1/2-dependant pathways could be involved in 1 and 3-promoted NGF-induced neurite outgrowth in PC12 cells.","tags":["#literature_note"],"author":[{"family":"Zhang","given":"Cheng-Chen","literal":""},{"family":"Zhang","given":"Cheng-Chen","literal":""},{"family":"Zhang","given":"Cheng-Chen","literal":""},{"family":"Cao","given":"Chenyu","literal":""},{"family":"Cao","given":"Chen-Yu","literal":""},{"family":"Cao","given":"Chen-Yu","literal":""},{"family":"Kubo","given":"Miwa","literal":""},{"family":"Harada","given":"Kenichi","literal":""},{"family":"Kubo","given":"Miwa","literal":""},{"family":"Harada","given":"Kenichi","literal":""},{"family":"Yan","given":"Xi-Tao","literal":""},{"family":"Yan","given":"Xiaohai","literal":""},{"family":"Yan","given":"Xi-Tao","literal":""},{"family":"Fukuyama","given":"Yoshiyasu","literal":""},{"family":"Fukuyama","given":"Yoshiyasu","literal":""},{"family":"Gao","given":"Jin-Ming","literal":""},{"family":"Gao","given":"Jin-Ming","literal":""}],"citation-key":"zhang_chemical_2017","year":"2017","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Chemical Constituents from Hericium erinaceus Promote Neuronal Survival and Potentiate Neurite Outgrowth via the TrkA/Erk1/2 Pathway."],"author-links":["[[Author/Cheng-Chen Zhang]]","[[Author/Cheng-Chen Zhang]]","[[Author/Cheng-Chen Zhang]]","[[Author/Chenyu Cao]]","[[Author/Chen-Yu Cao]]","[[Author/Chen-Yu Cao]]","[[Author/Miwa Kubo]]","[[Author/Kenichi Harada]]","[[Author/Miwa Kubo]]","[[Author/Kenichi Harada]]","[[Author/Xi-Tao Yan]]","[[Author/Xiaohai Yan]]","[[Author/Xi-Tao Yan]]","[[Author/Yoshiyasu Fukuyama]]","[[Author/Yoshiyasu Fukuyama]]","[[Author/Jin-Ming Gao]]","[[Author/Jin-Ming Gao]]"],"attachment":["[[biblib/zhang_chemical_2017/zhang_chemical_2017.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"1r8bneo","at":1774951887760}},"smart_blocks:Research/@zhang_chemical_2017.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.02352482,-0.0352257,0.02397193,-0.01508184,-0.00468088,0.04801935,0.00076553,0.03813482,-0.06666522,-0.02033611,0.0138298,-0.04782067,0.03763429,0.03822237,0.02801703,0.02184723,-0.02974613,0.01200205,-0.0742