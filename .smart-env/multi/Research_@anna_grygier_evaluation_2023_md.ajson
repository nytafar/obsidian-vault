02625446,-0.0267919,-0.02362743,0.00228617,0.18284816,0.04723231,-0.07442867,0.01686292,-0.06595466,-0.02109018,-0.0421661,-0.01155996,0.04443531,0.03702338,0.13114116,-0.05325533,0.02456966,0.10532465,-0.00805521,-0.02924817,-0.03740559,-0.00710671,0.02686361,-0.00947885,-0.10245965,-0.01136902,0.07091808,-0.12893325,-0.00946948,-0.02316451,-0.00746665,0.01330795,0.02099351,-0.00147001,-0.01997588,0.01386572,0.00008686,0.01219807,0.01321705,0.0255581,-0.04020078,-0.03920929,-0.01697227,-0.02034524,-0.0463516,0.1015349,0.07396576],"last_embed":{"hash":"bq6py7","tokens":457}}},"last_read":{"hash":"bq6py7","at":1774951884985},"class_name":"SmartSource","last_import":{"mtime":1774951813698,"size":3837,"at":1774951884752,"hash":"bq6py7"},"blocks":{"#---frontmatter---":[1,61],"#Evaluation of Selected Medicinal, Timber and Ornamental Legume Species’ Seed Oils as Sources of Bioactive Lipophilic Compounds":[63,67],"#Evaluation of Selected Medicinal, Timber and Ornamental Legume Species’ Seed Oils as Sources of Bioactive Lipophilic Compounds#{1}":[65,67]},"outlinks":[{"title":"Author/Anna Grygier","target":"Author/Anna Grygier","line":49},{"title":"Author/Suryakant Chakradhari","target":"Author/Suryakant Chakradhari","line":50},{"title":"Author/Katarzyna Ratusz","target":"Author/Katarzyna Ratusz","line":51},{"title":"Author/Magdalena Rudzińska","target":"Author/Magdalena Rudzińska","line":52},{"title":"Author/Khageshwar Singh Patel","target":"Author/Khageshwar Singh Patel","line":53},{"title":"Author/Danija Lazdiņa","target":"Author/Danija Lazdiņa","line":54},{"title":"Author/Dalija Segliņa","target":"Author/Dalija Segliņa","line":55},{"title":"Author/Paweł Górnaś","target":"Author/Paweł Górnaś","line":56},{"title":"PDF","target":"biblib/anna_grygier_evaluation_2023/anna_grygier_evaluation_2023.pdf","line":58}],"metadata":{"id":"anna_grygier_evaluation_2023","type":"article-journal","title":"Evaluation of Selected Medicinal, Timber and Ornamental Legume Species’ Seed Oils as Sources of Bioactive Lipophilic Compounds","issued":{"date-parts":[[2023,5]]},"page":"3994-3994","DOI":"10.3390/molecules28103994","container-title":"Molecules (Basel, Switzerland)","volume":28,"number":10,"abstract":"Bioactive lipophilic compounds were investigated in 14 leguminous tree species of timber, agroforestry, medicinal or ornamental use but little industrial significance to elucidate their potential in food additive and supplement production. The tree species investigated were: Acacia auriculiformis, Acacia concinna, Albizia lebbeck, Albizia odoratissima, Bauhinia racemosa, Cassia fistula, Dalbergia latifolia, Delonix regia, Entada phaseoloides, Hardwickia binata, Peltophorum pterocarpum, Senegalia catechu, Sesbania sesban and Vachellia nilotica. The hexane-extracted oils of ripe seeds were chromatographically analysed for their fatty acid composition (GC-MS), tocochromanol (RP-HPLC/FLD), squalene and sterol (GC-FID) content. A spectrophotometrical method was used to determine total carotenoid content. The results showed generally low oil yield (1.75-17.53%); the highest was from H. binata. Linoleic acid constituted the largest proportion in all samples (40.78 to 62.28% of total fatty acids), followed by oleic (14.57-34.30%) and palmitic (5.14-23.04%) acid. The total tocochromanol content ranged from 100.3 to 367.6 mg 100 g-1 oil. D. regia was the richest and the only to contain significant amount of tocotrienols while other oils contained almost exclusively tocopherols, dominated by either α-tocopherol or γ-tocopherol. The total carotenoid content was highest in A. auriculiformis (23.77 mg 100 g-1), S. sesban (23.57 mg 100 g-1) and A. odoratissima (20.37 mg 100 g-1), and ranged from 0.7 to 23.7 mg 100 g-1 oil. The total sterol content ranged from 240.84 to 2543 mg 100 g-1; A. concinna seed oil was the richest by a wide margin; however, its oil yield was very low (1.75%). Either β-sitosterol or Δ5-stigmasterol dominated the sterol fraction. Only C. fistula oil contained a significant amount of squalene (303.1 mg 100 g-1) but was limited by the low oil yield as an industrial source of squalene. In conclusion, A. auriculiformis seeds may hold potential for the production of carotenoid-rich oil, and H. binata seed oil has relatively high yield and tocopherol content, marking it as a potential source of these compounds.","tags":["#literature_note"],"author":[{"family":"Anna Grygier","given":"","literal":""},{"family":"Suryakant Chakradhari","given":"","literal":""},{"family":"Katarzyna Ratusz","given":"","literal":""},{"family":"Magdalena Rudzińska","given":"","literal":""},{"family":"Khageshwar Singh Patel","given":"","literal":""},{"family":"Danija Lazdiņa","given":"","literal":""},{"family":"Dalija Segliņa","given":"","literal":""},{"family":"Paweł Górnaś","given":"","literal":""}],"citation-key":"anna_grygier_evaluation_2023","year":"2023","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Evaluation of Selected Medicinal, Timber and Ornamental Legume Species’ Seed Oils as Sources of Bioactive Lipophilic Compounds"],"author-links":["[[Author/Anna Grygier]]","[[Author/Suryakant Chakradhari]]","[[Author/Katarzyna Ratusz]]","[[Author/Magdalena Rudzińska]]","[[Author/Khageshwar Singh Patel]]","[[Author/Danija Lazdiņa]]","[[Author/Dalija Segliņa]]","[[Author/Paweł Górnaś]]"],"attachment":["[[biblib/anna_grygier_evaluation_2023/anna_grygier_evaluation_2023.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"bq6py7","at":1774951884972}},"smart_blocks:Research/@anna_grygier_evaluation_2023.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.00915012,0.0019178,0.02859339,-0.01185491,0.06441535,-0.00446793,-0.039836,0.04873002,-0.03741443,0.00224254,0.01412025,-0.07985046,0.03038393,-0.03221912,-0.00561386,-0.03261473,0.03807754,0.01865855,-0.12027305,-0.01660536,0.09955175,-0.04790538,0.02414656,-0.00329151,0.05643393,0.04018652,-