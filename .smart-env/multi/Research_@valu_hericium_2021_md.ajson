,0.00547367,0.00382422,0.15995087,0.01845142,-0.03944283,-0.0080402,0.0239785,0.02635449,0.02677399,0.01651509,-0.018467,0.01850214,0.0874445,-0.01085221,0.08043258,0.03559732,-0.0779606,-0.0623136,0.00820145,-0.02283734,0.02965878,-0.00495318,-0.11510005,-0.03961037,0.08431546,-0.02473922,-0.02069966,0.00673479,-0.04930721,0.0146891,0.01719334,-0.0269626,0.01375263,0.01377912,-0.00629285,0.02793795,-0.01546333,-0.04180291,-0.01542447,0.0142518,-0.02325222,-0.01400315,-0.04995123,0.10936444,0.05830948],"last_embed":{"hash":"10u9i05","tokens":448}}},"last_read":{"hash":"10u9i05","at":1774951893271},"class_name":"SmartSource","last_import":{"mtime":1774951825787,"size":4161,"at":1774951884819,"hash":"10u9i05"},"blocks":{"#---frontmatter---":[1,121],"#Hericium erinaceus (Bull.) Pers. Ethanolic Extract with Antioxidant Properties on Scopolamine-Induced Memory Deficits in a Zebrafish Model of Cognitive Impairment":[123,127],"#Hericium erinaceus (Bull.) Pers. Ethanolic Extract with Antioxidant Properties on Scopolamine-Induced Memory Deficits in a Zebrafish Model of Cognitive Impairment#{1}":[125,127]},"outlinks":[{"title":"Author/Mihai-Vlad Valu","target":"Author/Mihai-Vlad Valu","line":93},{"title":"Author/Mihai-Vlad Valu","target":"Author/Mihai-Vlad Valu","line":94},{"title":"Author/Liliana Cristina Soare","target":"Author/Liliana Cristina Soare","line":95},{"title":"Author/Liliana Cristina Soare","target":"Author/Liliana Cristina Soare","line":96},{"title":"Author/Cătălin Ducu","target":"Author/Cătălin Ducu","line":97},{"title":"Author/Catalin Ducu","target":"Author/Catalin Ducu","line":98},{"title":"Author/Sorin Georgian Moga","target":"Author/Sorin Georgian Moga","line":99},{"title":"Author/Sorin Moga","target":"Author/Sorin Moga","line":100},{"title":"Author/Denis Negrea","target":"Author/Denis Negrea","line":101},{"title":"Author/Denis Negrea","target":"Author/Denis Negrea","line":102},{"title":"Author/Emanuel Vamanu","target":"Author/Emanuel Vamanu","line":103},{"title":"Author/Emanuel Vamanu","target":"Author/Emanuel Vamanu","line":104},{"title":"Author/Emanuel Vamanu","target":"Author/Emanuel Vamanu","line":105},{"title":"Author/Emanuel Vamanu","target":"Author/Emanuel Vamanu","line":106},{"title":"Author/Tudor-Adrian Bălşeanu","target":"Author/Tudor-Adrian Bălşeanu","line":107},{"title":"Author/Tudor-Adrian Balseanu","target":"Author/Tudor-Adrian Balseanu","line":108},{"title":"Author/Tudor-Adrian Balseanu","target":"Author/Tudor-Adrian Balseanu","line":109},{"title":"Author/Luisa Mannina","target":"Author/Luisa Mannina","line":110},{"title":"Author/Simone Carradori","target":"Author/Simone Carradori","line":111},{"title":"Author/Simone Carradori","target":"Author/Simone Carradori","line":112},{"title":"Author/Lucian Hrițcu","target":"Author/Lucian Hrițcu","line":113},{"title":"Author/Lucian Hritcu","target":"Author/Lucian Hritcu","line":114},{"title":"Author/Răzvan Ştefan Boiangiu","target":"Author/Răzvan Ştefan Boiangiu","line":115},{"title":"Author/Razvan Stefan Boiangiu","target":"Author/Razvan Stefan Boiangiu","line":116},{"title":"PDF","target":"biblib/valu_hericium_2021/valu_hericium_2021.pdf","line":118}],"metadata":{"id":"valu_hericium_2021","type":"article-journal","title":"Hericium erinaceus (Bull.) Pers. Ethanolic Extract with Antioxidant Properties on Scopolamine-Induced Memory Deficits in a Zebrafish Model of Cognitive Impairment","issued":{"date-parts":[[2021]]},"DOI":"10.3390/jof7060477","container-title":"Journal of Fungi","abstract":"Hericium erinaceus (H. erinaceus) is a rare and appreciated fungal species belonging to the division Basidiomycota used for centuries in traditional Chinese medicine for its medicinal value. This species of mushrooms brings the most diverse benefits for the human body, and can have beneficial effects for treating Alzheimer's disease (AD). This study investigated whether ethanolic extract from the fungal biomass of H. erinaceus enhances cognitive function via the action on cholinergic neurons using the scopolamine (SCOP)-induced zebrafish (Danio rerio) model of memory impairment. The ethanolic extract from the fungal biomass of H. erinaceus was previously obtained using an ultrasonic extraction method (UE). The administration of H. erinaceus extract to zebrafish, with a pattern of AD induced by scopolamine, showed an improvement in memory evaluated by behavioral and biochemical tests on brain tissue. These results suggest that H. erinaceus has preventive and therapeutic potentials in managing memory deficits and brain oxidative stress in zebrafish with AD.","tags":["#literature_note"],"author":[{"family":"Valu","given":"Mihai-Vlad","literal":""},{"family":"Valu","given":"Mihai-Vlad","literal":""},{"family":"Soare","given":"Liliana Cristina","literal":""},{"family":"Soare","given":"Liliana Cristina","literal":""},{"family":"Ducu","given":"Cătălin","literal":""},{"family":"Ducu","given":"Catalin","literal":""},{"family":"Moga","given":"Sorin Georgian","literal":""},{"family":"Moga","given":"Sorin","literal":""},{"family":"Negrea","given":"Denis","literal":""},{"family":"Negrea","given":"Denis","literal":""},{"family":"Vamanu","given":"Emanuel","literal":""},{"family":"Vamanu","given":"Emanuel","literal":""},{"family":"Vamanu","given":"Emanuel","literal":""},{"family":"Vamanu","given":"Emanuel","literal":""},{"family":"Bălşeanu","given":"Tudor-Adrian","literal":""},{"family":"Balseanu","given":"Tudor-Adrian","literal":""},{"family":"Balseanu","given":"Tudor-Adrian","literal":""},{"family":"Mannina","given":"Luisa","literal":""},{"family":"Carradori","given":"Simone","literal":""},{"family":"Carradori","given":"Simone","literal":""},{"family":"Hrițcu","given":"Lucian","literal":""},{"family":"Hritcu","given":"Lucian","literal":""},{"family":"Boiangiu","given":"Răzvan Ştefan","literal":""},{"family":"Boiangiu","given":"Razvan Stefan","literal":""}],"citation-key":"valu_hericium_2021","year":"2021","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Hericium erinaceus (Bull.) Pers. Ethanolic Extract with Antioxidant Properties on Scopolamine-Induced Memory Deficits in a Zebrafish Model of Cognitive Impairment"],"author-links":["[[Author/Mihai-Vlad Valu]]","[[Author/Mihai-Vlad Valu]]","[[Author/Liliana Cristina Soare]]","[[Author/Liliana Cristina Soare]]","[[Author/Cătălin Ducu]]","[[Author/Catalin Ducu]]","[[Author/Sorin Georgian Moga]]","[[Author/Sorin Moga]]","[[Author/Denis Negrea]]","[[Author/Denis Negrea]]","[[Author/Emanuel Vamanu]]","[[Author/Emanuel Vamanu]]","[[Author/Emanuel Vamanu]]","[[Author/Emanuel Vamanu]]","[[Author/Tudor-Adrian Bălşeanu]]","[[Author/Tudor-Adrian Balseanu]]","[[Author/Tudor-Adrian Balseanu]]","[[Author/Luisa Mannina]]","[[Author/Simone Carradori]]","[[Author/Simone Carradori]]","[[Author/Lucian Hrițcu]]","[[Author/Lucian Hritcu]]","[[Author/Răzvan Ştefan Boiangiu]]","[[Author/Razvan Stefan Boiangiu]]"],"attachment":["[[biblib/valu_hericium_2021/valu_hericium_2021.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"10u9i05","at":1774951893263}},"smart_blocks:Research/@valu_hericium_2021.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[0.0036714,-0.01698582,0.05041268,-0.03615269,-0.02286721,-0.00245897,0.02807416,0.07495372,-0.03925179,-0.02453096,-0.0007683,-0.06304928,0.00118106,0.04758222,0.00123793,-0.0197144,-0.01882998,0.03793703,-0.11578018,0.02241938,0.0457785,-0.05250067,-0.00678116,0.01112973,0.03383006,0.01848242,-0.03519499,0.02692681,-0.01119656,-0.21561539,0.00006347,-0.03927089,0.00680364,-0.00894528,-0.02397547,-0.04842035,-0.00535468,0.0414657,-0.02193868,-0.00091012,0.10190901,0.06862217,-0.01007063,0.01231934,-0.02440898,-0.06100146,-0.01150062,-0.02844659,0.0496158,-0.03232387,-0.05340531,-0.03311631,0.03080556,0.03445921,0.03869199,0.02206833,0.02100806,0.04152928,-0.02257979,0.04520403,0.06371071,0.07000085,-0.15480411,0.06653173,0.03265427,-0.03717437,-0.1