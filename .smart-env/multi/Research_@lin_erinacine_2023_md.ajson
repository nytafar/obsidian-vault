-0.03086348,0.18791009,0.04046445,0.01924256,-0.00248577,-0.05702803,0.03949006,0.0156987,-0.01430312,-0.00902723,0.04395915,0.03869484,-0.00641595,0.04863806,0.02960704,-0.06451795,-0.01676233,-0.0068715,-0.05471577,-0.00611519,0.00165312,-0.05583263,-0.00787699,0.10757356,-0.01313581,-0.04163023,-0.00338752,-0.02174653,0.02622894,-0.02813858,0.00282086,0.01304412,-0.0126554,-0.00292569,0.01084751,-0.00298193,-0.02154,-0.02393617,0.03339909,-0.01100821,-0.01768852,-0.00282228,0.10946748,0.05492711],"last_embed":{"hash":"1a8h0p9","tokens":489}}},"last_read":{"hash":"1a8h0p9","at":1774951893321},"class_name":"SmartSource","last_import":{"mtime":1774951825891,"size":2510,"at":1774951884819,"hash":"1a8h0p9"},"blocks":{"#---frontmatter---":[1,73],"#Erinacine S from Hericium erinaceus mycelium promotes neuronal regeneration by inducing neurosteroids accumulation":[75,79],"#Erinacine S from Hericium erinaceus mycelium promotes neuronal regeneration by inducing neurosteroids accumulation#{1}":[77,79]},"outlinks":[{"title":"Author/Chun-Yu Lin","target":"Author/Chun-Yu Lin","line":57},{"title":"Author/Yi-Ju Chen","target":"Author/Yi-Ju Chen","line":58},{"title":"Author/Chih-Hsuan Hsu","target":"Author/Chih-Hsuan Hsu","line":59},{"title":"Author/Yu-Hsuan Lin","target":"Author/Yu-Hsuan Lin","line":60},{"title":"Author/Peng-Tzu Chen","target":"Author/Peng-Tzu Chen","line":61},{"title":"Author/Ting-Han Kuo","target":"Author/Ting-Han Kuo","line":62},{"title":"Author/Chris T. Ho","target":"Author/Chris T. Ho","line":63},{"title":"Author/Hsin-Hua Chen","target":"Author/Hsin-Hua Chen","line":64},{"title":"Author/Sih-Jia Huang","target":"Author/Sih-Jia Huang","line":65},{"title":"Author/Ho-Chieh Chiu","target":"Author/Ho-Chieh Chiu","line":66},{"title":"Author/Chin-Chu Chen","target":"Author/Chin-Chu Chen","line":67},{"title":"Author/Eric Hwang","target":"Author/Eric Hwang","line":68},{"title":"PDF","target":"biblib/lin_erinacine_2023/lin_erinacine_2023.pdf","line":70}],"metadata":{"id":"lin_erinacine_2023","type":"article-journal","title":"Erinacine S from Hericium erinaceus mycelium promotes neuronal regeneration by inducing neurosteroids accumulation","issued":{"date-parts":[[2023]]},"DOI":"10.38212/2224-6614.3446","container-title":"Journal of food and drug analysis","abstract":"Erinacines derived from Hericium erinaceus have been shown to possess various health benefits including neuroprotective effect against neurodegenerative diseases, yet the underlying mechanism remains unknown. Here we found that erinacine S enhances neurite outgrowth in a cell autonomous fashion. It promotes post-injury axon regeneration of PNS neurons and enhances regeneration on inhibitory substrates of CNS neurons. Using RNA-seq and bioinformatic analyses, erinacine S was found to cause the accumulation of neurosteroids in neurons. ELISA and neurosteroidogenesis inhibitor assays were performed to validate this effect. This research uncovers a previously unknown effect of erinacine S on raising the level of neurosteroids.","tags":["#literature_note"],"author":[{"family":"Lin","given":"Chun-Yu","literal":""},{"family":"Chen","given":"Yi-Ju","literal":""},{"family":"Hsu","given":"Chih-Hsuan","literal":""},{"family":"Lin","given":"Yu-Hsuan","literal":""},{"family":"Chen","given":"Peng-Tzu","literal":""},{"family":"Kuo","given":"Ting-Han","literal":""},{"family":"Ho","given":"Chris T.","literal":""},{"family":"Chen","given":"Hsin-Hua","literal":""},{"family":"Huang","given":"Sih-Jia","literal":""},{"family":"Chiu","given":"Ho-Chieh","literal":""},{"family":"Chen","given":"Chin-Chu","literal":""},{"family":"Hwang","given":"Eric","literal":""}],"citation-key":"lin_erinacine_2023","year":"2023","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Erinacine S from Hericium erinaceus mycelium promotes neuronal regeneration by inducing neurosteroids accumulation"],"author-links":["[[Author/Chun-Yu Lin]]","[[Author/Yi-Ju Chen]]","[[Author/Chih-Hsuan Hsu]]","[[Aut