63,0.02799735,-0.08969069,-0.01725654,0.03959737,0.14347212,-0.01569644,-0.01912378,-0.01071286,-0.04698509,-0.03374797,-0.00975376,0.03525111,-0.04625468,0.04359241,0.11193072,-0.06824022,0.08627507,0.07127542,-0.09205898,-0.03744146,-0.01931151,-0.01501244,0.0418443,0.06110604,-0.07812167,-0.06049434,0.09404758,-0.08078574,-0.05894018,-0.07860834,-0.00824484,0.00468517,-0.02942074,0.00414795,-0.00898303,0.03556172,-0.01154113,0.03144038,0.02364516,-0.00413762,0.0024046,-0.04736731,0.00197437,-0.03530553,-0.03687604,0.11276824,0.00487351],"last_embed":{"hash":"hjzjvu","tokens":447}}},"last_read":{"hash":"hjzjvu","at":1774951891100},"class_name":"SmartSource","last_import":{"mtime":1774951821926,"size":3307,"at":1774951884805,"hash":"hjzjvu"},"blocks":{"#---frontmatter---":[1,65],"#Neuropharmacological and Toxicity Evaluations of Ethanol Extract from RhodiolaRosea":[67,71],"#Neuropharmacological and Toxicity Evaluations of Ethanol Extract from RhodiolaRosea#{1}":[69,71]},"outlinks":[{"title":"Author/Rosa Mariana Montiel-Ruiz","target":"Author/Rosa Mariana Montiel-Ruiz","line":51},{"title":"Author/Rosa Mariana Montiel-Ruiz","target":"Author/Rosa Mariana Montiel-Ruiz","line":52},{"title":"Author/José Eduardo Roa-Coria","target":"Author/José Eduardo Roa-Coria","line":53},{"title":"Author/José Eduardo Roa-Coria","target":"Author/José Eduardo Roa-Coria","line":54},{"title":"Author/Selene Isabel Patiño-Camacho","target":"Author/Selene Isabel Patiño-Camacho","line":55},{"title":"Author/Selene Isabel Patiño-Camacho","target":"Author/Selene Isabel Patiño-Camacho","line":56},{"title":"Author/Francisco J. Flores‐Murrieta","target":"Author/Francisco J. Flores‐Murrieta","line":57},{"title":"Author/Francisco J. Flores-Murrieta","target":"Author/Francisco J. Flores-Murrieta","line":58},{"title":"Author/Myrna Déciga-Campos","target":"Author/Myrna Déciga-Campos","line":59},{"title":"Author/Myrna Déciga-Campos","target":"Author/Myrna Déciga-Campos","line":60},{"title":"PDF","target":"biblib/montiel-ruiz_neuropharmacological_2012/montiel-ruiz_neuropharmacological_2012.pdf","line":62}],"metadata":{"id":"montiel-ruiz_neuropharmacological_2012","type":"article-journal","title":"Neuropharmacological and Toxicity Evaluations of Ethanol Extract from RhodiolaRosea","issued":{"date-parts":[[2012]]},"DOI":"10.1002/ddr.21001","container-title":"Drug Development Research","abstract":"Strategy, Management and Health Policy Enabling Technology, Genomics, Proteomics Preclinical Research Preclinical Development Toxicology, Formulation Drug Delivery, Pharmacokinetics Clinical Development Phases I-III Regulatory, Quality, Manufacturing Postmarketing Phase IV Rhodiola rosea is a popular medicinal plant that is commonly used as an adaptogen in folklore medicine in Europe and Asia due to its ability to increase an organism's resistance to physical, chemical and biological stress. The aim of this study was to determine the central nervous system activity and toxicity parameters of R. rosea. An ethanol extract from the roots of R. rosea was orally (p.o.) administered to mice (10–316 mg/kg); exploratory activity, anti-anxiety, behavior, sodium pentobarbital-induced hypnosis, antinociceptive effects, and pentylenetetrazole-induced seizures were tested. The results from the experimental models tested showed a significant reduction in exploratory behavior and in the number of rearings and head dippings, but no change in the sedative-hypnotic and anticonvulsant response with respect to vehicle. Moreover, R. rosea reduced the licking time in the formalin test. R. rosea was not toxic in Artemia salina and in mice. The present results confirm some preclinical and clinical studies that indicate stimulating, anxiolytic-like effects and present new evidence of the antinociceptive effect of and very low risk of toxicity from R. rosea.","tags":["#literature_note"],"author":[{"family":"Montiel-Ruiz","given":"Rosa Mariana","literal":""},{"family":"Montiel-Ruiz","given":"Rosa Mariana","literal":""},{"family":"Roa-Coria","given":"José Eduardo","literal":""},{"family":"Roa-Coria","given":"José Eduardo","literal":""},{"family":"Patiño-Camacho","given":"Selene Isabel","literal":""},{"family":"Patiño-Camacho","given":"Selene Isabel","literal":""},{"family":"Flores‐Murrieta","given":"Francisco J.","literal":""},{"family":"Flores-Murrieta","given":"Francisco J.","literal":""},{"family":"Déciga-Campos","given":"Myrna","literal":""},{"family":"Déciga-Campos","given":"Myrna","literal":""}],"citation-key":"montiel-ruiz_neuropharmacological_2012","year":"2012","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Neuropharmacological and Toxicity Evaluations of Ethanol Extract from RhodiolaRosea"],"author-links":["[[Author/Rosa Mariana Montiel-Ruiz]]","[[Author/Rosa Mariana Montiel-Ruiz]]","[[Author/José Eduardo Roa-Coria]]","[[Author/José Eduardo Roa-Coria]]","[[Author/Selene Isabel Patiño-Camacho]]","[[Author/Selene Isabel Patiño-Camacho]]","[[Author/Francisco J. Flores‐Murrieta]]","[[Author/Francisco J. Flores-Murrieta]]","[[Author/Myrna Déciga-Campos]]","[[Author/Myrna Déciga-Campos]]"],"attachment":["[[biblib/montiel-ruiz_neuropharmacological_2012/montiel-ruiz_neuropharmacological_2012.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"hjzjvu","at":1774951890905}},"smart_blocks:Research/@montiel-ruiz_neuropharmacological_2012.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.05412256,-0.02816034,0.01104036,-0.00218342,0.01959469,-0.02642484,0.04272397,0.07561774,0.00390035,0.00235538,-0.03304949,-0.04444248,-0.02810429,0.02505507,0.02181496,0.03290235,-0.00634595,0.00139565,-0.04487604,-0.00615721,0.0162965,-0.01857578,0.05545426,-0.02451526,0.00323606,0.03005073,-0.05972591,0.02231911,-0.09674429,-0.21158537,0.01246559,0.01912606,0.04029636,-0.05335582,-0.04268317,0.0248013,-0.03457362,0.01119735,-0.03058283,-0.00496931,0.01690193,0.03102326,-0.00304413,0.