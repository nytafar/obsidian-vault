203272,0.04276648,0.20751728,0.03110117,-0.02416164,0.00143191,-0.0292155,0.05130929,-0.05557523,0.02275346,0.06077658,0.02461715,0.1053672,-0.02322906,0.0322338,0.05485515,-0.05885148,-0.04520814,-0.0380822,0.01712806,-0.02890567,-0.02636504,-0.10102858,0.03200386,0.12312199,-0.09171498,-0.0543503,-0.08121075,0.00708039,-0.02120006,-0.01974002,0.02934962,-0.02572796,0.03242868,-0.02660693,0.00157072,0.0377726,-0.03108107,-0.05581115,-0.03366299,0.00198663,0.01622995,-0.08670895,0.09624846,0.03689871],"last_embed":{"hash":"7qx18x","tokens":483}}},"last_read":{"hash":"7qx18x","at":1774951889552},"class_name":"SmartSource","last_import":{"mtime":1774951820711,"size":1940,"at":1774951884799,"hash":"7qx18x"},"blocks":{"#---frontmatter---":[1,41],"#Nature’s Own Pharmacy: Mushroom-Based Chemical Scaffolds and Their Therapeutic Implications":[43,47],"#Nature’s Own Pharmacy: Mushroom-Based Chemical Scaffolds and Their Therapeutic Implications#{1}":[45,47]},"outlinks":[{"title":"Author/Mubashir Hassan","target":"Author/Mubashir Hassan","line":33},{"title":"Author/Saba Shahzadi","target":"Author/Saba Shahzadi","line":34},{"title":"Author/Richard F. Ransom","target":"Author/Richard F. Ransom","line":35},{"title":"Author/Andrzej Kloczkowski","target":"Author/Andrzej Kloczkowski","line":36},{"title":"PDF","target":"biblib/hassan_natures_2023/hassan_natures_2023.pdf","line":38}],"metadata":{"id":"hassan_natures_2023","type":"article-journal","title":"Nature’s Own Pharmacy: Mushroom-Based Chemical Scaffolds and Their Therapeutic Implications","issued":{"date-parts":[[2023]]},"DOI":"10.3390/ijms242115596","container-title":"null","abstract":"Mushrooms are new potential sources of valuable medicines, long neglected because of difficulties experienced in their cultivation. There is a large variety of medicinal mushrooms which possess significant therapeutic properties and are used as medications for various diseases because they contain several novel highly bioactive components. Medicinal mushrooms can be identified based on their morphology, size, mass, and the color of the stalk, cap and spore, and attachment to the stalk. Medicinal mushrooms possess a variety of important biological activities and are used as antioxidants, hepatoprotectors, anticancer, antidiabetic, anti-inflammatory, antiaging, antiviral, antiparasitic, and antimicrobial agents, among others. This review provides a basic overview of the chemical scaffolds present in mushrooms and their therapeutic implications in the human body.","tags":["#literature_note"],"author":[{"family":"Hassan","given":"Mubashir","literal":""},{"family":"Shahzadi","given":"Saba","literal":""},{"family":"Ransom","given":"Richard F.","literal":""},{"family":"Kloczkowski","given":"Andrzej","literal":""}],"citation-key":"hassan_natures_2023","year":"2023","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Nature’s Own Pharmacy: Mushroom-Based Chemical Scaffolds and Their Therapeutic Implications"],"author-links":["[[Author/Mubashir Hassan]]","[[Author/Saba Shahzadi]]","[[Author/Richard F. Ransom]]","[[Author/Andrzej Kloczkowski]]"],"attachment":["[[biblib/hassan_natures_2023/hassan_natures_2023.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"7qx18x","at":1774951889539}},"smart_blocks:Research/@hassan_natures_2023.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.00218786,-0.03283698,0.02811619,-0.0303252,0.06331463,0.01117939,0.04081878,0.00665268,-0.04014632,0.00651699,0.03276807,-0.04595239,0.03172083,0.01282683,0.04691245,0.01323442,0.04362074,-0.00731065,-0.05364206,0.03312634,0.0668383,0.03317051,0.01507615,-0.0024324,0.02165732,0.03388085,-0.01527282,-0.01550709,-0.06816138,-0.18077213,-0.00752894,0.01840751,0.02608748,-0.02218216,-0.02464109,-0.02101816,0.0091712,0.05988096,-0.00324803,0.05970095,0.05285455,0.01049038,-0.00582786,0.06371292,-0.02334651,-0.06477261,-0.04810726,-0.02173455,0.0115103