9,-0.05386224,0.02374575,0.0251044,0.17283902,-0.03586134,0.03380315,0.03465932,-0.01126199,0.022556,-0.02268413,0.02808478,0.01299818,0.07699946,0.09623484,-0.0373873,0.07248182,0.05527725,0.01559915,-0.0387123,-0.01918137,-0.02472907,-0.00920986,-0.01611071,-0.06700146,-0.04135412,0.11107416,-0.05306194,-0.046532,-0.09702891,0.01442986,-0.01594395,-0.03892516,-0.01105485,0.00432899,0.04426506,-0.01328301,0.01007392,0.05231036,0.02545837,-0.04964304,-0.01523104,-0.0434146,0.01717301,-0.0279873,0.11130576,0.00877409],"last_embed":{"hash":"6z8j2e","tokens":436}}},"last_read":{"hash":"6z8j2e","at":1774951885462},"class_name":"SmartSource","last_import":{"mtime":1774951813920,"size":2052,"at":1774951884759,"hash":"6z8j2e"},"blocks":{"#---frontmatter---":[1,49],"#Ergothioneine – a diet‐derived antioxidant with therapeutic potential":[51,55],"#Ergothioneine – a diet‐derived antioxidant with therapeutic potential#{1}":[53,55]},"outlinks":[{"title":"Author/Barry Halliwell","target":"Author/Barry Halliwell","line":39},{"title":"Author/Barry Halliwell","target":"Author/Barry Halliwell","line":40},{"title":"Author/Irwin K. Cheah","target":"Author/Irwin K. Cheah","line":41},{"title":"Author/Irwin K. Cheah","target":"Author/Irwin K. Cheah","line":42},{"title":"Author/Richard Ming Yi Tang","target":"Author/Richard Ming Yi Tang","line":43},{"title":"Author/Richard M. Y. Tang","target":"Author/Richard M. Y. Tang","line":44},{"title":"PDF","target":"biblib/halliwell_ergothioneine_2018/halliwell_ergothioneine_2018.pdf","line":46}],"metadata":{"id":"halliwell_ergothioneine_2018","type":"article-journal","title":"Ergothioneine – a diet‐derived antioxidant with therapeutic potential","issued":{"date-parts":[[2018]]},"DOI":"10.1002/1873-3468.13123","container-title":"FEBS Letters","abstract":"Ergothioneine is a thiol/thione molecule synthesised only by some fungi and bacteria. Nonetheless, it is avidly taken up from the diet by humans and other animals through a transporter, OCTN1, and accumulates to high levels in certain tissues. Ergothioneine is not rapidly metabolised, or excreted in urine and is present in many, if not all, human tissues and body fluids. Ergothioneine has powerful antioxidant and cytoprotective properties in vitro and there is evidence that the body may concentrate it at sites of tissue injury by raising OCTN1 levels. Decreased blood and/or plasma levels of ergothioneine have been observed in some diseases, suggesting that a deficiency could be relevant to the disease onset or progression. This brief Review explores the possible roles of ergothioneine in human health and disease.","tags":["#literature_note"],"author":[{"family":"Halliwell","given":"Barry","literal":""},{"family":"Halliwell","given":"Barry","literal":""},{"family":"Cheah","given":"Irwin K.","literal":""},{"family":"Cheah","given":"Irwin K.","literal":""},{"family":"Tang","given":"Richard Ming Yi","literal":""},{"family":"Tang","given":"Richard M. Y.","literal":""}],"citation-key":"halliwell_ergothioneine_2018","year":"2018","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Ergothioneine – a diet‐derived antioxidant with therapeutic potential"],"author-links":["[[Author/Barry Halliwell]]","[[Author/Barry Halliwell]]","[[Author/Irwin K. Cheah]]","[[Author/Irwin K. Cheah]]","[[Author/Richard Ming Yi Tang]]","[[Author/Richard M. Y. Tang]]"],"attachment":["[[biblib/halliwell_ergothioneine_2018/halliwell_ergothioneine_2018.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"6z8j2e","at":1774951885453}},"smart_blocks:Research/@halliwell_ergothioneine_2018.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.05950578,0.04873077,0.04360667,0.02484885,0.00951562,0.00187551,0.03451914,0.04194504,-0.0343858,0.04201566,-0.00798112,-0.08675281,0.02076838,0.04434028,-0.01808516,-0.01550279,-0.00412133,0.01879712,-0.07063261,0.02321283,0.05064874,-0.01610367,0.05770374,-0.01490604,0