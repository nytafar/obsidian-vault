,-0.01835162,0.17535767,0.04407973,-0.07292239,-0.03598171,-0.0043736,-0.02414491,0.04465254,0.03379985,-0.0108964,0.02712441,0.10508516,0.01194772,0.08447099,0.06317202,-0.07846693,-0.01731045,-0.00825933,-0.01474253,0.01100973,-0.00476379,-0.0892145,-0.03486266,0.08877875,-0.03346063,-0.01723328,-0.01937869,-0.07426423,-0.02355856,0.0118613,-0.04387708,-0.01379923,0.01647631,0.03539841,-0.00714489,0.03507626,-0.02089869,-0.03801913,0.00444209,0.0392382,0.00681657,-0.02720422,0.08665115,0.00001048],"last_embed":{"hash":"1vd3h0e","tokens":406}}},"last_read":{"hash":"1vd3h0e","at":1774951893254},"class_name":"SmartSource","last_import":{"mtime":1774951825747,"size":4003,"at":1774951884819,"hash":"1vd3h0e"},"blocks":{"#---frontmatter---":[1,112],"#Dietary Supplementation of Lion's Mane Medicinal Mushroom, Hericium erinaceus (Agaricomycetes), and Spatial Memory in Wild-Type Mice.":[114,118],"#Dietary Supplementation of Lion's Mane Medicinal Mushroom, Hericium erinaceus (Agaricomycetes), and Spatial Memory in Wild-Type Mice.#{1}":[116,118]},"outlinks":[{"title":"Author/Paola Rossi","target":"Author/Paola Rossi","line":87},{"title":"Author/Paola Rossi","target":"Author/Paola Rossi","line":88},{"title":"Author/Paola Rossi","target":"Author/Paola Rossi","line":89},{"title":"Author/Paola Rossi","target":"Author/Paola Rossi","line":90},{"title":"Author/Valentina Cesaroni","target":"Author/Valentina Cesaroni","line":91},{"title":"Author/Valentina Cesaroni","target":"Author/Valentina Cesaroni","line":92},{"title":"Author/Federico Brandalise","target":"Author/Federico Brandalise","line":93},{"title":"Author/Federico Brandalise","target":"Author/Federico Brandalise","line":94},{"title":"Author/Alessandra Occhinegro","target":"Author/Alessandra Occhinegro","line":95},{"title":"Author/A. Occhinegro","target":"Author/A. Occhinegro","line":96},{"title":"Author/Daniela Ratto","target":"Author/Daniela Ratto","line":97},{"title":"Author/Daniela Ratto","target":"Author/Daniela Ratto","line":98},{"title":"Author/Fabio Perrucci","target":"Author/Fabio Perrucci","line":99},{"title":"Author/Fabio Perrucci","target":"Author/Fabio Perrucci","line":100},{"title":"Author/Veralice Lanaia","target":"Author/Veralice Lanaia","line":101},{"title":"Author/Veralice Lanaia","target":"Author/Veralice Lanaia","line":102},{"title":"Author/Carolina Elena Girometta","target":"Author/Carolina Elena Girometta","line":103},{"title":"Author/Carolina Girometta","target":"Author/Carolina Girometta","line":104},{"title":"Author/Germano Orrù","target":"Author/Germano Orrù","line":105},{"title":"Author/Germano Orrù","target":"Author/Germano Orrù","line":106},{"title":"Author/Elena Savino","target":"Author/Elena Savino","line":107},{"title":"Author/Elena Savino","target":"Author/Elena Savino","line":108}],"metadata":{"id":"rossi_dietary_2018","type":"article-journal","title":"Dietary Supplementation of Lion's Mane Medicinal Mushroom, Hericium erinaceus (Agaricomycetes), and Spatial Memory in Wild-Type Mice.","issued":{"date-parts":[[2018]]},"DOI":"10.1615/intjmedmushrooms.2018026241","container-title":"International Journal of Medicinal Mushrooms","abstract":"Hericium erinaceus is an edible and medicinal mushroom with potential neuroprotective effects. The study of H. erinaceus has attracted considerable attention during the past 10 years, particularly with regard to its potential utility in the treatment of motor dysfunction, Alzheimer disease, and other forms of dementia. We previously determined that oral supplementation with H. erinaceus results in significant improvements in novelty-seeking behavior and novel object recognition in mice. In this study, H. erinaceus was added to the diets of wild-type mice for 2 months, and effects on spatial memory were evaluated by means of a Y maze and an object location task. We found that H. erinaceus increased general locomotor activity but had no effect on spatial memory. Thus, oral supplementation with H. erinaceus yields specific and selective improvements in recognition memory without altering spatial working memory, which supports the hypothesis that recognition memory can be modeled as a dual process. In this model, the perirhinal cortex supports the recognition of individual items as part of a circuit involved in familiarity with an encountered stimulus, whereas the hippocampus supports recollected associations and relationships between stimuli.","tags":["#literature_note"],"author":[{"family":"Rossi","given":"Paola","literal":""},{"family":"Rossi","given":"Paola","literal":""},{"family":"Rossi","given":"Paola","literal":""},{"family":"Rossi","given":"Paola","literal":""},{"family":"Cesaroni","given":"Valentina","literal":""},{"family":"Cesaroni","given":"Valentina","literal":""},{"family":"Brandalise","given":"Federico","literal":""},{"family":"Brandalise","given":"Federico","literal":""},{"family":"Occhinegro","given":"Alessandra","literal":""},{"family":"Occhinegro","given":"A.","literal":""},{"family":"Ratto","given":"Daniela","literal":""},{"family":"Ratto","given":"Daniela","literal":""},{"family":"Perrucci","given":"Fabio","literal":""},{"family":"Perrucci","given":"Fabio","literal":""},{"family":"Lanaia","given":"Veralice","literal":""},{"family":"Lanaia","given":"Veralice","literal":""},{"family":"Girometta","given":"Carolina Elena","literal":""},{"family":"Girometta","given":"Carolina","literal":""},{"family":"Orrù","given":"Germano","literal":""},{"family":"Orrù","given":"Germano","literal":""},{"family":"Savino","given":"Elena","literal":""},{"family":"Savino","given":"Elena","literal":""}],"citation-key":"rossi_dietary_2018","year":"2018","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Dietary Supplementation of Lion's Mane Medicinal Mushroom, Hericium erinaceus (Agaricomycetes), and Spatial Memory in Wild-Type Mice."],"author-links":["[[Author/Paola Rossi]]","[[Author/Paola Rossi]]","[[Author/Paola Rossi]]","[[Author/Paola Rossi]]","[[Author/Valentina Cesaro