,0.04491521,0.17983356,0.00167489,-0.01211555,0.04665204,-0.02358216,0.024569,-0.00369928,0.09632669,0.02931026,0.04012512,0.10088383,0.02195963,0.05921776,0.07864293,-0.02149805,-0.00333949,-0.05443329,-0.02386088,0.03709064,-0.0700985,-0.13354324,-0.02795621,0.09129266,-0.08399863,-0.040189,-0.01736866,-0.03189965,-0.00155127,-0.01325372,0.02879559,0.03871421,0.05442656,-0.02702729,-0.04384945,-0.0040692,-0.00526807,-0.02857373,-0.00101973,-0.00706546,0.01514404,-0.0904934,0.10923024,0.00774255],"last_embed":{"hash":"hqxe16","tokens":458}}},"last_read":{"hash":"hqxe16","at":1774951890742},"class_name":"SmartSource","last_import":{"mtime":1774951821602,"size":2381,"at":1774951884802,"hash":"hqxe16"},"blocks":{"#---frontmatter---":[1,53],"#THE NUTRITIONAL AND MEDICAL BENEFITS OF AGARICUS BISPORUS : A REVIEW":[55,59],"#THE NUTRITIONAL AND MEDICAL BENEFITS OF AGARICUS BISPORUS : A REVIEW#{1}":[57,59]},"outlinks":[{"title":"Author/Funda Atíla","target":"Author/Funda Atíla","line":42},{"title":"Author/Funda Atila","target":"Author/Funda Atila","line":43},{"title":"Author/Funda Atila","target":"Author/Funda Atila","line":44},{"title":"Author/Mustafa Nadhim Owaid","target":"Author/Mustafa Nadhim Owaid","line":45},{"title":"Author/Mustafa Nadhim Owaid","target":"Author/Mustafa Nadhim Owaid","line":46},{"title":"Author/Mohammad Ali Shariati","target":"Author/Mohammad Ali Shariati","line":47},{"title":"Author/Mohammad Ali Shariati","target":"Author/Mohammad Ali Shariati","line":48},{"title":"PDF","target":"biblib/atila_nutritional_2017/atila_nutritional_2017.pdf","line":50}],"metadata":{"id":"atila_nutritional_2017","type":"article-journal","title":"THE NUTRITIONAL AND MEDICAL BENEFITS OF AGARICUS BISPORUS : A REVIEW","issued":{"date-parts":[[2017]]},"DOI":"10.15414/jmbfs.2017/18.7.3.281-286","container-title":"The Journal of Microbiology, Biotechnology and Food Sciences","abstract":"Mushrooms are considered as potential source of many essential nutrients and therapeutic bioactive compounds. Agaricus bisporus belongs to Basidiomycetes family and the most important commercially cultivated mushroom in the world. The rich nutrients like carbohydrates, proteins, lipids, fibers, minerals, and vitamins present this mushroom as famous healthy food. Moreover, because of the presence of some active ingredients, such as polysaccharides, lipopolysaccharides, essential amino acids, peptides, glycoproteins, nucleosides, triterpenoids, lectins, fatty acids and their derivatives, these mushrooms have been reported to have antimicrobial, anticancer, antidiabetic, antihypercholesterolemic, antihypertensive, hepatoprotective and antioxidant activities. This study is focused on reviewing the recent studies published in the medical and nutritional properties of Agaricus bisporus. Investigations on the mushroom have accelerated during the last ten years so that only reports published after 2006 have been considered.","tags":["#literature_note"],"author":[{"family":"Atíla","given":"Funda","literal":""},{"family":"Atila","given":"Funda","literal":""},{"family":"Atila","given":"Funda","literal":""},{"family":"Owaid","given":"Mustafa Nadhim","literal":""},{"family":"Owaid","given":"Mustafa Nadhim","literal":""},{"family":"Shariati","given":"Mohammad Ali","literal":""},{"family":"Shariati","given":"Mohammad Ali","literal":""}],"citation-key":"atila_nutritional_2017","year":"2017","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["THE NUTRITIONAL AND MEDICAL BENEFITS OF AGARICUS BISPORUS : A REVIEW"],"author-links":["[[Author/Funda Atíla]]","[[Author/Funda Atila]]","[[Author/Funda Atila]]","[[Author/Mustafa Nadhim Owaid]]","[[Author/Mustafa Nadhim Owaid]]","[[Author/Mohammad Ali Shariati]]","[[Author/Mohammad Ali Shariati]]"],"attachment":["[[biblib/atila_nutritional_2017/atila_nutritional_2017.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"hqxe16","at":1774951890729}},"smart_blocks:Research/@ati