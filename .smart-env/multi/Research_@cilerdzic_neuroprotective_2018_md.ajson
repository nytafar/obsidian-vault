renić","given":"Ivana","literal":""},{"family":"Sofrenić","given":"Ivana","literal":""},{"family":"Tešević","given":"Vele","literal":""},{"family":"Tešević","given":"Vele","literal":""},{"family":"Brčeski","given":"Ilija","literal":""},{"family":"Brčeski","given":"Ilija","literal":""},{"family":"Duletić-Laušević","given":"Sonja","literal":""},{"family":"Duletić-Laušević","given":"Sonja","literal":""},{"family":"Vukojević","given":"Jelena","literal":""},{"family":"Vukojević","given":"Jelena","literal":""},{"family":"Stajić","given":"Mirjana","literal":""},{"family":"Stajic","given":"Mirjana","literal":""}],"citation-key":"cilerdzic_neuroprotective_2018","year":"2018","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Neuroprotective Potential and Chemical Profile of Alternatively Cultivated Ganoderma lucidum Basidiocarps."],"author-links":["[[Author/Jasmina Ćilerdžić]]","[[Author/Jasmina Ćilerdžić]]","[[Author/Ivana Sofrenić]]","[[Author/Ivana Sofrenić]]","[[Author/Vele Tešević]]","[[Author/Vele Tešević]]","[[Author/Ilija Brčeski]]","[[Author/Ilija Brčeski]]","[[Author/Sonja Duletić-Laušević]]","[[Author/Sonja Duletić-Laušević]]","[[Author/Jelena Vukojević]]","[[Author/Jelena Vukojević]]","[[Author/Mirjana Stajić]]","[[Author/Mirjana Stajic]]"],"attachment":["[[biblib/cilerdzic_neuroprotective_2018/cilerdzic_neuroprotective_2018.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"v5c65s","at":1774951896662}},"smart_blocks:Research/@cilerdzic_neuroprotective_2018.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.01999664,-0.02270599,0.05031414,-0.02795478,0.07141846,0.03621628,0.00830026,0.02957019,-0.03914632,-0.02003586,-0.023975,-0.04673503,0.01395308,0.05981881,-0.02016477,0.04718879,-0.00364139,0.04417323,-0.02873233,0.01409118,0.04160411,-0.04101388,0.01815753,0.01465432,0.03563699,-0.00144865,-0.01770726,-0.0109151,-0.02298062,-0.19824082,0.00314172,-0.0031586,0.001