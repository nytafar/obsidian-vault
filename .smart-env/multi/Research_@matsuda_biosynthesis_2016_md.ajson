verage of literature by Geris and Simpson in Nat. Prod. Rep., 2009, 26, 1063–1094.)","tags":["#literature_note"],"author":[{"family":"Matsuda","given":"Yudai","literal":""},{"family":"Matsuda","given":"Yudai","literal":""},{"family":"Abe","given":"Ikuro","literal":""},{"family":"Abe","given":"Ikuro","literal":""}],"citation-key":"matsuda_biosynthesis_2016","year":"2016","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Biosynthesis of fungal meroterpenoids"],"author-links":["[[Author/Yudai Matsuda]]","[[Author/Yudai Matsuda]]","[[Author/Ikuro Abe]]","[[Author/Ikuro Abe]]"],"attachment":["[[biblib/matsuda_biosynthesis_2016/matsuda_biosynthesis_2016.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"2j4i31","at":1774951888897}},"smart_blocks:Research/@matsuda_biosynthesis_2016.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.05209076,-0.00304975,0.01385281,-0.0329897,0.04944572,0.00164917,-0.06455521,0.04390386,-0.00662235,0.03483926,0.00727059,-0.08554819,0.01625456,-0.03276968,0.04751846,-0.02793686,0.00786976,0.04879482,-0.03221524,0.03135083,0.04813584,-0.03361136,0.01262698,-0.01626235,0.06818633,0.08337639,0.02747439,0.02171247,-0.03268334,-0.24162199,-0.00732235,0.06723125,0.00612307,-0.01359398,0.00994655,0.00797439,-0.05698644,0.03512584,0.00395626,0.01408025,-0.00161049,0.02787746,0.02098407,-0.01839418,-0.03284753,-0.03841776,-0.04554446,0.05236077,-0.00201521,-0.03075538,-0.05767591,-0.00249776,0.06361103,0.01521031,0.06201277,0.03367637,0.04159749,0.02223205,-0.01339841,0.03885369,0.05026801,0.07099243,-0.1722215,0.05103913,0.05917455,0.01384511,-0.08003052,-0.05794205,0.05897588,0.00578567,-0.05315127,-0.01574187,-0.00914931,0.02173871,0.05412436,0.01124369,-0.0122899,-0.07121379,-0.01993524,-0.02956007,0.00226455,0.05907302,-0.03493048,0.02251576,-0.04761958,0.01156324,0.02655541,-0.06694715,0.01255184,0.06998317,0.00759439,-0.03978474,0.00913473,0.028483