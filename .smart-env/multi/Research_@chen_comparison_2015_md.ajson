terature_note"],"author":[{"family":"Chen","given":"Pei-Ying","literal":""},{"family":"Chen","given":"Peiying","literal":""},{"family":"Yong","given":"Yangyang","literal":""},{"family":"Yong","given":"Yangyang","literal":""},{"family":"Gu","given":"Yifan","literal":""},{"family":"Gu","given":"Yifan","literal":""},{"family":"Wang","given":"Zeliang","literal":""},{"family":"Wang","given":"Zeliang","literal":""},{"family":"Zhang","given":"Shizhu","literal":""},{"family":"Zhang","given":"Shizhu","literal":""},{"family":"Lü","given":"Ling","literal":""},{"family":"Lu","given":"Ling","literal":""}],"citation-key":"chen_comparison_2015","year":"2015","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Comparison of antioxidant and antiproliferation activities of polysaccharides from eight species of medicinal mushrooms."],"author-links":["[[Author/Pei-Ying Chen]]","[[Author/Peiying Chen]]","[[Author/Yangyang Yong]]","[[Author/Yangyang Yong]]","[[Author/Yifan Gu]]","[[Author/Yifan Gu]]","[[Author/Zeliang Wang]]","[[Author/Zeliang Wang]]","[[Author/Shizhu Zhang]]","[[Author/Shizhu Zhang]]","[[Author/Ling Lü]]","[[Author/Ling Lu]]"],"attachment":["[[biblib/chen_comparison_2015/chen_comparison_2015.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"1d2m56d","at":1774951896276}},"smart_blocks:Research/@chen_comparison_2015.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.03829691,-0.04902476,0.02362293,-0.0336177,0.05674258,0.01709927,0.02574178,0.01557932,-0.05951085,-0.01478522,0.01542002,-0.05014994,0.05719765,-0.01729131,0.00457864,0.03268881,0.01634225,0.00654659,-0.13359539,0.04695253,0.07210241,-0.03320514,-0.01496984,-0.01194362,0.08597638,0.06605082,-0.01866455,-0.03266837,-0.02315075,-0.2086678,-0.02690966,-0.03644086,0.02696369,-0.01797188,-0.02847558,-0.00941177,-0.02219849,0.02083206,-0.03447036,0.03178392,0.03903228,0.03311732,0.00887903,0.07386774,-0.01427406,-0.0427