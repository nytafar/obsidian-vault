,-0.00320245,0.17782146,0.0306586,-0.04139788,0.05013584,0.01538255,0.04437469,-0.0232723,0.03802858,0.00540789,0.02259788,0.10751956,0.00402813,0.04339222,0.03840427,-0.04785518,-0.01936864,-0.02799345,-0.00886572,-0.03793872,-0.00047573,-0.07303815,-0.04213272,0.09909115,-0.0540449,-0.0147244,-0.05213958,-0.00764472,-0.00879471,-0.00465725,0.01709568,0.02735441,0.05297158,0.01250897,-0.03652153,-0.01853525,0.02685362,-0.06322173,0.03256905,0.01891032,-0.02425377,-0.07712924,0.11180829,0.05371645],"last_embed":{"hash":"a5z1ux","tokens":466}}},"last_read":{"hash":"a5z1ux","at":1774951886910},"class_name":"SmartSource","last_import":{"mtime":1774951815947,"size":2708,"at":1774951884775,"hash":"a5z1ux"},"blocks":{"#---frontmatter---":[1,61],"#Hericium erinaceus Mushroom Extracts Protect Infected Mice against Salmonella Typhimurium-Induced Liver Damage and Mortality by Stimulation of Innate Immune Cells":[63,67],"#Hericium erinaceus Mushroom Extracts Protect Infected Mice against Salmonella Typhimurium-Induced Liver Damage and Mortality by Stimulation of Innate Immune Cells#{1}":[65,67]},"outlinks":[{"title":"Author/Sung Phil Kim","target":"Author/Sung Phil Kim","line":48},{"title":"Author/Sung Phil Kim","target":"Author/Sung Phil Kim","line":49},{"title":"Author/Eunpyo Moon","target":"Author/Eunpyo Moon","line":50},{"title":"Author/Eunpyo Moon","target":"Author/Eunpyo Moon","line":51},{"title":"Author/Eunpyo Moon","target":"Author/Eunpyo Moon","line":52},{"title":"Author/Sung Min Nam","target":"Author/Sung Min Nam","line":53},{"title":"Author/Seok Hyun Nam","target":"Author/Seok Hyun Nam","line":54},{"title":"Author/Mendel Friedman","target":"Author/Mendel Friedman","line":55},{"title":"Author/Mendel Friedman","target":"Author/Mendel Friedman","line":56},{"title":"PDF","target":"biblib/kim_hericium_2012/kim_hericium_2012.pdf","line":58}],"metadata":{"id":"kim_hericium_2012","type":"article-journal","title":"Hericium erinaceus Mushroom Extracts Protect Infected Mice against Salmonella Typhimurium-Induced Liver Damage and Mortality by Stimulation of Innate Immune Cells","issued":{"date-parts":[[2012]]},"DOI":"10.1021/jf300897w","container-title":"Journal of Agricultural and Food Chemistry","abstract":"The present study investigated the antibacterial effect of four extracts from the fruitbody of the edible medicinal mushroom Hericium erinaceus (hot water extract, HWE; microwave/50% ethanol extract, MWE; acid extract, ACE; and alkaline extract, AKE) against murine salmonellosis. The extracts had no effect on Salmonella ser. Typhimurium growth in culture. Nor were the extracts toxic to murine macrophage cells, RAW 264.7. HWE and MWE stimulated uptake of the bacteria into the macrophage cells as indicated by increased colony-forming unit (CFU) counts of the contents of the lysed macrophages infected with Salmonella Typhimurium for 30 and 60 min. Two hours postinfection, the bacterial counts increased in the macrophages, but 4 and 8 h postinfection the HWE- and MWE-treated cells showed greater activity against the bacteria than the control. HWE- and MWE-treated noninfected macrophages had altered morphology and elevated inducible nitric oxide (NO) synthase (iNOS) mRNA expression. In the presence of S. Typhi...","tags":["#literature_note"],"author":[{"family":"Kim","given":"Sung Phil","literal":""},{"family":"Kim","given":"Sung Phil","literal":""},{"family":"Moon","given":"Eunpyo","literal":""},{"family":"Moon","given":"Eunpyo","literal":""},{"family":"Moon","given":"Eunpyo","literal":""},{"family":"Nam","given":"Sung Min","literal":""},{"family":"Nam","given":"Seok Hyun","literal":""},{"family":"Friedman","given":"Mendel","literal":""},{"family":"Friedman","given":"Mendel","literal":""}],"citation-key":"kim_hericium_2012","year":"2012","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Hericium erinaceus Mushroom Extracts Protect Infected Mice against Salmonella Typhimurium-Induced Liver Damage and Mortality by Stimulation of Innate Immune Cells"],"author-links":["[[Author/Sung Phil Kim]]","[[Author/Sung Phil Kim]]","[[Author/Eunpyo Moon]]","[[Author/Eunpyo Moon]]","[[Author/Eunpyo Moon]]","[[Author/Sung Min Nam]]","[[Author/Seok Hyun Nam]]","[[Author/Mendel Friedman]]","[[Author/Mendel Friedman]]"],"attachment":["[[biblib/kim_hericium_2012/kim_hericium_2012.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"a5z1ux","at":1774951886901}},"smart_blocks:Research/@kim_hericium_2012.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.01574999,-0.04189841,0.04272497,-0.04654825,0.03671765,-0.03608234,0.05877634,0.08589536,-0.06966586,0.0035739,0.01937085,-0.07764269,0.04466099,-0.0108304,0.02824196,0.01248027,-0.02839357,-0.01386617,-0.14406477,0.02841679,0.01754812,-0.04101444,0.00609173,-0.00108913,0.04351367,-0.00302381,0.02564519,0.02371583,-0.03757856,-0.21868575,-0.0199957,-0.01563949,0.0193307,-0.05979368,-0.01721033,-0.00641958,-0.01889628,0.00798109,-0.01333549,-0.03905497,0.0477876,0.03380748,0.06482328,0.01329236,0.0026767,-0.07329304,0.00962764,-0.07152661,0.06672981,-0.07197244,-0.07272696,-0.08948379,0.03876519,0.10426304,0.0672111,-0.02220089,0.01852355,0.03160331,0.05060254,0.0477383,0.00626058,0.00143427,-0.17855325,0.08719323,0.03981238,-0.00902303,-0.08910602,-0.06334236,0.06893465,0.01164032,-0.05749429,0.02744477,0.05743479,0.02768042,0.01860395,-0.00871302,0.00625399,-0.0426098,-0.01225257,0.02654643,0.01402248,0.03265879,0.07076926,0.0151252,-0.0310878,-0.02413765,-0.02356787,-0.0687575,0.04572885,0.02293959,-0.01385854,-0.02804577,-0.00806125,0.0064887,-0.04913393,0.00934346,-0.0126859,-0.00763498,-0.03858078,0.1312785,-0.09553298,0.00231462,-0.05172709,-0.05822722,0.02501812,-0.02841828,0.01408699,-0.02380301,0.03613598,0.00365702,0.05701282,-0.02696657,-0.05007312,-0.00455009,-0.0220446,0.05121586,0.16472396,0.00392614,-0.02708543,-0.01386112,0.02608242,-0.00836906,0.04726445,0.0094