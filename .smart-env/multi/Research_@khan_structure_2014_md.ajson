03005341,0.01507794,0.17595093,-0.00629474,-0.00520836,0.00078163,-0.0088091,-0.00505447,-0.05438909,0.05895744,-0.00246041,0.04190016,0.11485656,-0.02439599,0.02790361,0.0370991,0.01912904,-0.03668913,-0.01819455,0.01275463,0.0110161,-0.02746203,-0.11650014,-0.03588627,0.11059919,-0.07022262,-0.02489999,-0.08522335,0.02676772,-0.00896924,-0.00206479,-0.03360705,-0.02702378,0.02852502,-0.07094441,-0.02256097,0.00530472,-0.02968634,-0.04009466,0.02041618,-0.02544768,0.05222492,-0.08151942,0.10315643,0.01974766],"last_embed":{"hash":"jcqygg","tokens":475}}},"last_read":{"hash":"jcqygg","at":1774951889163},"class_name":"SmartSource","last_import":{"mtime":1774951819991,"size":2256,"at":1774951884796,"hash":"jcqygg"},"blocks":{"#---frontmatter---":[1,65],"#Structure and Bioactivities of Fungal Polysaccharides":[67,71],"#Structure and Bioactivities of Fungal Polysaccharides#{1}":[69,71]},"outlinks":[{"title":"Author/Muhammad Saeed Khan","target":"Author/Muhammad Saeed Khan","line":51},{"title":"Author/Muhammad Saeed Khan","target":"Author/Muhammad Saeed Khan","line":52},{"title":"Author/Xuewu Zhang","target":"Author/Xuewu Zhang","line":53},{"title":"Author/Xuewu Zhang","target":"Author/Xuewu Zhang","line":54},{"title":"Author/Lijun You","target":"Author/Lijun You","line":55},{"title":"Author/Lijun You","target":"Author/Lijun You","line":56},{"title":"Author/X. Fu","target":"Author/X. Fu","line":57},{"title":"Author/Xiong Fu","target":"Author/Xiong Fu","line":58},{"title":"Author/Arshad Mehmood Abbasi","target":"Author/Arshad Mehmood Abbasi","line":59},{"title":"Author/Arshad Mehmood Abbasi","target":"Author/Arshad Mehmood Abbasi","line":60},{"title":"PDF","target":"biblib/khan_structure_2014/khan_structure_2014.pdf","line":62}],"metadata":{"id":"khan_structure_2014","type":"article-journal","title":"Structure and Bioactivities of Fungal Polysaccharides","issued":{"date-parts":[[2014]]},"DOI":"10.1007/978-3-319-03751-6_28-1","container-title":"null","abstract":"AbstractEdible fungi have been consumed as medicines and food in Asian countries since time immemorial. Health benefits of edible fungi are mainly associated to polysaccharides, which are major bioactive components. Contemporary phytochemical and pharmacological studies have proved that polysaccharides are one of the major active ingredients in different types of edible and medicinal fungi. It has been demonstrated that polysaccharides exhibit significant biological activities, including immunomodulation, antitumor, antioxidant, anticancer, and antiviral activities. The purpose of the present review was to summarize previous and current references regarding structural characterization and biological activities of different fungal polysaccharides.KeywordsPolysaccharidesFungusStructureAnticancerBioactivities","tags":["#literature_note"],"author":[{"family":"Khan","given":"Muhammad Saeed","literal":""},{"family":"Khan","given":"Muhammad Saeed","literal":""},{"family":"Zhang","given":"Xuewu","literal":""},{"family":"Zhang","given":"Xuewu","literal":""},{"family":"You","given":"Lijun","literal":""},{"family":"You","given":"Lijun","literal":""},{"family":"Fu","given":"X.","literal":""},{"family":"Fu","given":"Xiong","literal":""},{"family":"Abbasi","given":"Arshad Mehmood","literal":""},{"family":"Abbasi","given":"Arshad Mehmood","literal":""}],"citation-key":"khan_structure_2014","year":"2014","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Structure and Bioactivities of Fungal Polysaccharides"],"author-links":["[[Author/Muhammad Saeed Khan]]","[[Author/Muhammad Saeed Khan]]","[[Author/Xuewu Zhang]]","[[Author/Xuewu Zhang]]","[[Author/Lijun You]]","[[Author/Lijun You]]","[[Author/X. Fu]]","[[Author/Xiong Fu]]","[[Author/Arshad Mehmood Abbasi]]","[[Author/Arshad Mehmood Abbasi]]"],"attachment":["[[biblib/khan_structure_2014/khan_structure_2014.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"jcqygg","at":1774951889