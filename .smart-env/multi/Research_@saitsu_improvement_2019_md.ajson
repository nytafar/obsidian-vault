0.08971275,0.03726368,0.04458531,0.19135982,0.01692312,-0.04506424,0.00562083,0.04625785,-0.01986388,0.04226267,0.03164004,0.01026818,0.01617848,0.10608433,0.00254366,0.05882866,0.07154683,-0.08826613,-0.0384234,0.01274888,-0.00785508,0.01799524,-0.01885511,-0.08213668,-0.0371271,0.12591328,-0.01411145,0.0228885,-0.0430935,-0.02997244,-0.02117805,-0.02078902,-0.00551656,0.05034281,0.02807125,0.03106904,0.01036555,0.01055424,-0.03893927,-0.02862336,0.00804632,0.0362386,-0.00887458,-0.01053318,0.13299569,0.01763502],"last_embed":{"hash":"1hhlld8","tokens":435}}},"last_read":{"hash":"1hhlld8","at":1774951893372},"class_name":"SmartSource","last_import":{"mtime":1774951825994,"size":2583,"at":1774951884820,"hash":"1hhlld8"},"blocks":{"#---frontmatter---":[1,69],"#Improvement of cognitive functions by oral intake of Hericium erinaceus.":[71,75],"#Improvement of cognitive functions by oral intake of Hericium erinaceus.#{1}":[73,75]},"outlinks":[{"title":"Author/Yuusuke Saitsu","target":"Author/Yuusuke Saitsu","line":54},{"title":"Author/Yuusuke Saitsu","target":"Author/Yuusuke Saitsu","line":55},{"title":"Author/Akemi Nishide","target":"Author/Akemi Nishide","line":56},{"title":"Author/Akemi Nishide","target":"Author/Akemi Nishide","line":57},{"title":"Author/Kenji Kikushima","target":"Author/Kenji Kikushima","line":58},{"title":"Author/Kenji Kikushima","target":"Author/Kenji Kikushima","line":59},{"title":"Author/Kuniyoshi Shimizu","target":"Author/Kuniyoshi Shimizu","line":60},{"title":"Author/Kuniyoshi Shimizu","target":"Author/Kuniyoshi Shimizu","line":61},{"title":"Author/Koichiro Ohnuki","target":"Author/Koichiro Ohnuki","line":62},{"title":"Author/Koichiro Ohnuki","target":"Author/Koichiro Ohnuki","line":63},{"title":"Author/Koichiro Ohnuki","target":"Author/Koichiro Ohnuki","line":64},{"title":"PDF","target":"biblib/saitsu_improvement_2019/saitsu_improvement_2019.pdf","line":66}],"metadata":{"id":"saitsu_improvement_2019","type":"article-journal","title":"Improvement of cognitive functions by oral intake of Hericium erinaceus.","issued":{"date-parts":[[2019]]},"DOI":"10.2220/biomedres.40.125","container-title":"Biomedical Research-tokyo","abstract":"Hericium erinaceus has been recognized as medical mushroom since ancient time, but its scientific evidence for human health has been still uncertain. In this study, we tested a randomized, double-blind, placebo-controlled parallel-group comparative study to evaluate the improvement of the cognitive functions by taking supplements containing fruiting body of H. erinaceus for 12 weeks. We performed three kinds of tests: Mini Mental State Examination (MMSE), Benton visual retention test, and Standard verbal paired-associate learning test (S-PA). MMSE alone showed that oral intake of H. erinaceus significantly improved cognitive functions and prevented from the deterioration. We speculate that various chemical compounds, including hericenones, in the mushroom have multiple effects to the brain neural networks and improve cognitive functions. Oral intake of H.erinaceus is safe and convenient method for dementia prevention so far.","tags":["#literature_note"],"author":[{"family":"Saitsu","given":"Yuusuke","literal":""},{"family":"Saitsu","given":"Yuusuke","literal":""},{"family":"Nishide","given":"Akemi","literal":""},{"family":"Nishide","given":"Akemi","literal":""},{"family":"Kikushima","given":"Kenji","literal":""},{"family":"Kikushima","given":"Kenji","literal":""},{"family":"Shimizu","given":"Kuniyoshi","literal":""},{"family":"Shimizu","given":"Kuniyoshi","literal":""},{"family":"Ohnuki","given":"Koichiro","literal":""},{"family":"Ohnuki","given":"Koichiro","literal":""},{"family":"Ohnuki","given":"Koichiro","literal":""}],"citation-key":"saitsu_improvement_2019","year":"2019","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Improvement of cognitive functions by oral intake of Hericium erinaceus."],"author-links":["[[Author/Yuusuke Saitsu]]","[[Author/Yuusuke Sai