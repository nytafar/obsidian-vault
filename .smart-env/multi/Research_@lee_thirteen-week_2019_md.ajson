
"smart_sources:Research/@lee_thirteen-week_2019.md": {"path":"Research/@lee_thirteen-week_2019.md","last_embed":{"hash":null},"embeddings":{},"last_read":{"hash":"7ofbgp","at":1774951884834},"class_name":"SmartSource","last_import":{"mtime":1774951829844,"size":3299,"at":1774951884834,"hash":"7ofbgp"},"blocks":{"#---frontmatter---":[1,84],"#Thirteen-Week Oral Toxicity Evaluation of Erinacine AEnriched Lion's Mane Medicinal Mushroom, Hericium erinaceus (Agaricomycetes), Mycelia in Sprague-Dawley Rats.":[86,90],"#Thirteen-Week Oral Toxicity Evaluation of Erinacine AEnriched Lion's Mane Medicinal Mushroom, Hericium erinaceus (Agaricomycetes), Mycelia in Sprague-Dawley Rats.#{1}":[88,90]},"outlinks":[{"title":"Author/Li-Ya Lee","target":"Author/Li-Ya Lee","line":66},{"title":"Author/Lee Li-Ya","target":"Author/Lee Li-Ya","line":67},{"title":"Author/Li-Ya Lee","target":"Author/Li-Ya Lee","line":68},{"title":"Author/I.-Chen Li","target":"Author/I.-Chen Li","line":69},{"title":"Author/I.-Chen Li","target":"Author/I.-Chen Li","line":70},{"title":"Author/I.-Chen Li","target":"Author/I.-Chen Li","line":71},{"title":"Author/Wanping Chen","target":"Author/Wanping Chen","line":72},{"title":"Author/Wan-Ping Chen","target":"Author/Wan-Ping Chen","line":73},{"title":"Author/Wan-Ping Chen","target":"Author/Wan-Ping Chen","line":74},{"title":"Author/Yi Yu Tsai","target":"Author/Yi Yu Tsai","line":75},{"title":"Author/Yueh-Ting Tsai","target":"Author/Yueh-Ting Tsai","line":76},{"title":"Author/Chin-Chu Chen","target":"Author/Chin-Chu Chen","line":77},{"title":"Author/Chin-Chu Chen","target":"Author/Chin-Chu Chen","line":78},{"title":"Author/Kwong-Chung Tung","target":"Author/Kwong-Chung Tung","line":79},{"title":"Author/Kwong-Chung Tung","target":"Author/Kwong-Chung Tung","line":80}],"metadata":{"id":"lee_thirteen-week_2019","type":"article-journal","title":"Thirteen-Week Oral Toxicity Evaluation of Erinacine AEnriched Lion's Mane Medicinal Mushroom, Hericium erinaceus (Agaricomycetes), Mycelia in Sprague-Dawley Rats.","issued":{"date-parts":[[2019]]},"DOI":"10.1615/intjmedmushrooms.2019030320","container-title":"International Journal of Medicinal Mushrooms","abstract":"Recently, erinacine A-enriched Hericium erinaceus (EAHE) mycelia have demonstrated therapeutic efficacy in animal models of neurodegenerative disease, including Alzheimer and Parkinson disease. Despite promising results from animal models, there have been no reports on its toxicity after long-term consumption. Hence, the present study was designed to evaluate the safety of EAHE mycelia through a 13-week subchronic rodent feeding study. Following 13 weeks of EAHE mycelia feeding at dosages of 0, 875, 1750, and 2625 mg/kg body weight in both male and female Sprague-Dawley rats, findings revealed neither any mortalities nor noticeable toxicological effects in all the rats during the investigation period. Physiological parameters including body weight and feed consumption patterns were unaffected by EAHE mycelia administration. The hematological and biochemical parameters as well as histopathological studies revealed no significant differences between the treatment and control groups. Conclusively, the obtained results suggested that EAHE mycelia could be relatively unharmful when used over an extended period, supporting its safe use in food preparation.","tags":["#literature_note"],"author":[{"family":"Lee","given":"Li-Ya","literal":""},{"family":"Li-Ya","given":"Lee","literal":""},{"family":"Lee","given":"Li-Ya","literal":""},{"family":"Li","given":"I.-Chen","literal":""},{"family":"Li","given":"I.-Chen","literal":""},{"family":"Li","given":"I.-Chen","literal":""},{"family":"Chen","given":"Wanping","literal":""},{"family":"Chen","given":"Wan-Ping","literal":""},{"family":"Chen","given":"Wan-Ping","literal":""},{"family":"Tsai","given":"Yi Yu","literal":""},{"family":"Tsai","given":"Yueh-Ting","literal":""},{"family":"Chen","given":"Chin-Chu","literal":""},{"family":"Chen","given":"Chin-Chu","literal":""},{"family":"Tung","given":"Kwong-Chung","literal":""},{"family":"Tung","given":"Kwong-Chung","literal":""}],"citation-key":"lee_thirteen-week_2019","year":"2019","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Thirteen-Week Oral Toxicity Evaluation of Erinacine AEnriched Lion's Mane Medicinal Mushroom, Hericium erinaceus (Agaricomycetes), Mycelia in Sprague-Dawley Rats."],"author-links":["[[Author/Li-Ya Lee]]","[[Author/Lee Li-Ya]]","[[Author/Li-Ya Lee]]","[[Author/I.-Chen Li]]","[[Author/I.-Chen Li]]","[[Author/I.-Chen Li]]","[[Author/Wanping Chen]]","[[Author/Wan-Ping Chen]]","[[Author/Wan-Ping Chen]]","[[Author/Yi Yu Tsai]]","[[Author/Yueh-Ting Tsai]]","[[Author/Chin-Chu Chen]]","[[Author/Chin-Chu Chen]]","[[Author/Kwong-Chung Tung]]","[[Author/Kwong-Chung Tung]]"],"attachment":[],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[]},
