,0.01508056,0.04471444,0.16758806,-0.0332645,-0.02291249,-0.00048469,-0.03577753,0.01527169,-0.01500426,0.02781708,-0.06117576,-0.00960457,0.12720099,-0.02419204,0.07534104,0.08097107,-0.07599618,-0.0661175,0.00278335,-0.02995498,0.03299375,-0.04105344,-0.07720342,-0.03406801,0.07101118,-0.05406103,-0.05089597,0.01324817,-0.03007936,0.00880726,0.02445547,-0.04072787,0.00537786,0.01891269,-0.00779715,-0.03570546,0.00377057,-0.02444862,-0.04806895,0.01995089,-0.03427332,0.03348227,-0.09941734,0.13485843,-0.01742136],"last_embed":{"hash":"udhz6w","tokens":436}}},"last_read":{"hash":"udhz6w","at":1774951887919},"class_name":"SmartSource","last_import":{"mtime":1774951817975,"size":4609,"at":1774951884785,"hash":"udhz6w"},"blocks":{"#---frontmatter---":[1,137],"#Anti-Aging and Neuroprotective Properties of Grifola frondosa and Hericium erinaceus Extracts":[139,143],"#Anti-Aging and Neuroprotective Properties of Grifola frondosa and Hericium erinaceus Extracts#{1}":[141,143]},"outlinks":[{"title":"Author/Farida Tripodi","target":"Author/Farida Tripodi","line":105},{"title":"Author/Farida Tripodi","target":"Author/Farida Tripodi","line":106},{"title":"Author/Ermelinda Falletta","target":"Author/Ermelinda Falletta","line":107},{"title":"Author/Ermelinda Falletta","target":"Author/Ermelinda Falletta","line":108},{"title":"Author/Manuela Leri","target":"Author/Manuela Leri","line":109},{"title":"Author/Manuela Leri","target":"Author/Manuela Leri","line":110},{"title":"Author/Cristina Angeloni","target":"Author/Cristina Angeloni","line":111},{"title":"Author/Cristina Angeloni","target":"Author/Cristina Angeloni","line":112},{"title":"Author/Daniela Beghelli","target":"Author/Daniela Beghelli","line":113},{"title":"Author/Daniela Beghelli","target":"Author/Daniela Beghelli","line":114},{"title":"Author/Laura Giusti","target":"Author/Laura Giusti","line":115},{"title":"Author/Laura Giusti","target":"Author/Laura Giusti","line":116},{"title":"Author/Riccardo Milanesi","target":"Author/Riccardo Milanesi","line":117},{"title":"Author/Riccardo Milanesi","target":"Author/Riccardo Milanesi","line":118},{"title":"Author/Belém Sampaio-Marques","target":"Author/Belém Sampaio-Marques","line":119},{"title":"Author/Belém Sampaio‐Marques","target":"Author/Belém Sampaio‐Marques","line":120},{"title":"Author/Paula Ludovico","target":"Author/Paula Ludovico","line":121},{"title":"Author/Paula Ludovico","target":"Author/Paula Ludovico","line":122},{"title":"Author/Lorenzo Goppa","target":"Author/Lorenzo Goppa","line":123},{"title":"Author/Lorenzo Goppa","target":"Author/Lorenzo Goppa","line":124},{"title":"Author/Paola Rossi","target":"Author/Paola Rossi","line":125},{"title":"Author/Paola Rossi","target":"Author/Paola Rossi","line":126},{"title":"Author/Elena Savino","target":"Author/Elena Savino","line":127},{"title":"Author/Elena Savino","target":"Author/Elena Savino","line":128},{"title":"Author/Monica Bucciantini","target":"Author/Monica Bucciantini","line":129},{"title":"Author/Monica Bucciantini","target":"Author/Monica Bucciantini","line":130},{"title":"Author/Paola Coccetti","target":"Author/Paola Coccetti","line":131},{"title":"Author/Paola Coccetti","target":"Author/Paola Coccetti","line":132},{"title":"PDF","target":"biblib/tripodi_anti-aging_2022/tripodi_anti-aging_2022.pdf","line":134}],"metadata":{"id":"tripodi_anti-aging_2022","type":"article-journal","title":"Anti-Aging and Neuroprotective Properties of Grifola frondosa and Hericium erinaceus Extracts","issued":{"date-parts":[[2022]]},"DOI":"10.3390/nu14204368","container-title":"Nutrients","abstract":"Nutrition has relevant consequences for human health and increasing pieces of evidence indicate that medicinal mushrooms have several beneficial effects. One of the main issues in Western countries is represented by the challenges of aging and age-related diseases, such as neurodegenerative disorders. Among these, Parkinson's disease (PD) affects 10 million people worldwide and is associated with α-synuclein misfolding, also found in other pathologies collectively called synucleinopathies. Here, we show that aqueous extracts of two edible mushrooms, Grifola frondosa and Hericium erinaceus, represent a valuable source of β-glucans and exert anti-aging effects in yeast. Their beneficial effects are mediated through the inhibition of the Ras/PKA pathway, with increased expression of heat shock proteins, along with a consistent increase of both mean and maximal lifespans. These fungal extracts also reduce the toxicity of α-synuclein heterologously expressed in yeast cells, resulting in reduced ROS levels, lower α-synuclein membrane localization, and protein aggregation. The neuroprotective activity of G. frondosa extract was also confirmed in a PD model of Drosophila melanogaster. Taken together, our data suggest the use of G. frondosa and H. erinaceus as functional food to prevent aging and age-related disorders, further supporting the neuro-healthy properties of these medicinal mushroom extracts.","tags":["#literature_note"],"author":[{"family":"Tripodi","given":"Farida","literal":""},{"family":"Tripodi","given":"Farida","literal":""},{"family":"Falletta","given":"Ermelinda","literal":""},{"family":"Falletta","given":"Ermelinda","literal":""},{"family":"Leri","given":"Manuela","literal":""},{"family":"Leri","given":"Manuela","literal":""},{"family":"Angeloni","given":"Cristina","literal":""},{"family":"Angeloni","given":"Cristina","literal":""},{"family":"Beghelli","given":"Daniela","literal":""},{"family":"Beghelli","given":"Daniela","literal":""},{"family":"Giusti","given":"Laura","literal":""},{"family":"Giusti","given":"Laura","literal":""},{"family":"Milanesi","given":"Riccardo","literal":""},{"family":"Milanesi","given":"Riccardo","literal":""},{"family":"Sampaio-Marques","given":"Belém","literal":""},{"family":"Sampaio‐Marques","given":"Belém","literal":""},{"family":"Ludovico","given":"Paula","literal":""},{"family":"Ludovico","given":"Paula","literal":""},{"family":"Goppa","given":"Lorenzo","literal":""},{"family":"Goppa","given":"Lorenzo","literal":""},{"family":"Rossi","given":"Paola","literal":""},{"family":"Rossi","given":"Paola","literal":""},{"family":"Savino","given":"Elena","literal":""},{"family":"Savino","given":"Elena","literal":""},{"family":"Bucciantini","given":"Monica","literal":""},{"family":"Bucciantini","given":"Monica","literal":""},{"family":"Coccetti","given":"Paola","literal":""},{"family":"Coccetti","given":"Paola","literal":""}],"citation-key":"tripodi_anti-aging_2022","year":"2022","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Anti-Aging and Neuroprotective Properties of Grifola frondosa and Hericium erinaceus Extracts"],"author-links":["[[Author/Farida Tripodi]]","[[Author/Farida Tripodi]]","[[Author/Ermelinda Falletta]]","[[Author/Ermelinda Falletta]]","[[Author/Manuela Leri]]","[[Author/Manuela Leri]]","[[Author/Cristina Angeloni]]","[[Author/Cristina Angeloni]]","[[Author/Daniela Beghelli]]","[[Author/Daniela Beghelli]]","[[Author/Laura Giusti]]","[[Author/Laura Giusti]]","[[Author/Riccardo Milanesi]]","[[Author/Riccardo Milanesi]]","[[Author/Belém Sampaio-Marques]]","[[Author/Belém Sampaio‐Marques]]","[[Author/Paula Ludovico]]","[[Author/Paula Ludovico]]","[[Author/Lorenzo Goppa]]","[[Author/Lorenzo Goppa]]","[[Author/Paola Rossi]]","[[Author/Paola Rossi]]","[[Author/Elena Savino]]","[[Author/Elena Savino]]","[[Author/Monica Bucciantini]]","[[Author/Monica Bucciantini]]","[[Author/Paola Coccetti]]","[[Author/Paola Coccetti]]"],"attachment":["[[biblib/tripodi_anti-aging_2022/tripodi_anti-aging_2022.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"udhz6w","at":1774951887908}},"smart_blocks:Research/@tripodi_anti-aging_2022.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.01813373,-0.05150059,0.06886601,-0.02303264,0.01660123,0.00247936,0.01975206,0.04175081,-0.08473154,-0.031