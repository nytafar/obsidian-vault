-0.13112532,-0.01457764,0.02492625,0.17288998,0.03178937,-0.00415199,0.00250555,-0.03414007,0.00928965,0.00333142,-0.0332835,0.05252049,0.0096687,0.08596712,-0.02290319,0.09577772,0.03633903,-0.05925662,0.0154985,0.00703267,-0.03924286,0.01360297,-0.04121076,-0.09782075,-0.00973668,0.10669434,-0.02960705,-0.05929162,-0.0134831,-0.02206646,-0.00067926,0.00428557,0.03689874,0.04654135,0.02812228,-0.00104497,-0.02059844,0.0026284,-0.01272564,-0.05858785,-0.00411969,0.04333343,0.02377528,-0.06596734,0.11807097,0.04129649],"last_embed":{"hash":"5gza8x","tokens":432}}},"last_read":{"hash":"5gza8x","at":1774951886943},"class_name":"SmartSource","last_import":{"mtime":1774951816044,"size":3540,"at":1774951884776,"hash":"5gza8x"},"blocks":{"#---frontmatter---":[1,65],"#Neuroregenerative potential of lion's mane mushroom, Hericium erinaceus (Bull.: Fr.) Pers. (higher Basidiomycetes), in the treatment of peripheral nerve injury (review).":[67,71],"#Neuroregenerative potential of lion's mane mushroom, Hericium erinaceus (Bull.: Fr.) Pers. (higher Basidiomycetes), in the treatment of peripheral nerve injury (review).#{1}":[69,71]},"outlinks":[{"title":"Author/Kah-Hui Wong","target":"Author/Kah-Hui Wong","line":51},{"title":"Author/Kah-Hui Wong","target":"Author/Kah-Hui Wong","line":52},{"title":"Author/Murali Naidu","target":"Author/Murali Naidu","line":53},{"title":"Author/Murali Naidu","target":"Author/Murali Naidu","line":54},{"title":"Author/Rosie Pamela David","target":"Author/Rosie Pamela David","line":55},{"title":"Author/Rosie Pamela David","target":"Author/Rosie Pamela David","line":56},{"title":"Author/Robiah Bakar","target":"Author/Robiah Bakar","line":57},{"title":"Author/Robiah Bakar","target":"Author/Robiah Bakar","line":58},{"title":"Author/Vikineswary Sabaratnam","target":"Author/Vikineswary Sabaratnam","line":59},{"title":"Author/Vikineswary Sabaratnam","target":"Author/Vikineswary Sabaratnam","line":60},{"title":"PDF","target":"biblib/wong_neuroregenerative_2012/wong_neuroregenerative_2012.pdf","line":62}],"metadata":{"id":"wong_neuroregenerative_2012","type":"article-journal","title":"Neuroregenerative potential of lion's mane mushroom, Hericium erinaceus (Bull.: Fr.) Pers. (higher Basidiomycetes), in the treatment of peripheral nerve injury (review).","issued":{"date-parts":[[2012]]},"DOI":"10.1615/intjmedmushr.v14.i5.10","container-title":"International Journal of Medicinal Mushrooms","abstract":"We present a model case study of the activity of aqueous extract of Hericium erinaceus fresh fruit bodies in promoting functional recovery following crush injury to the peroneal nerve in adult female Sprague-Dawley rats. The aim was to explore the possible use of this mushroom in nerve repair. The activities of aqueous extract were compared to activities exhibited by mecobalamin (vitamin B12), which has been widely used in the treatment of peripheral nerve disorders. Analysis of walking track indicated that return of hind limb function and normal toe spreading occurred earlier in treated groups than in the negative control (non-treated) group. Regeneration of axons and reinnervation of motor endplates/neuromuscular junction in extensor digitorum longus muscle of rats in treated groups developed better than in the negative control group. Further, immunofluorescence studies also showed that dorsal root ganglia neurons ipsilateral to the crush injury in rats of treated groups expressed higher immunoreactivities for Akt and MAPK signaling pathways as well as c-Jun and c-Fos genes compared to the negative control group. Akt cascade plays a major role in mediating neurotrophin-promoted cell survival, while MAPK cascade is involved in mediating neurite outgrowth. Immediate early gene expression was also involved in the cascade of events leading to regeneration. Local axonal protein synthetic machinery was also enhanced in the distal segments of crushed nerves in treated groups. Therefore, daily oral administration of H. erinaceus could promote the regeneration of injured rat peroneal nerve in the early stage of recovery.","tags":["#literature_note"],"author":[{"family":"Wong","given":"Kah-Hui","literal":""},{"family":"Wong","given":"Kah-Hui","literal":""},{"family":"Naidu","given":"Murali","literal":""},{"family":"Naidu","given":"Murali","literal":""},{"family":"David","given":"Rosie Pamela","literal":""},{"family":"David","given":"Rosie Pamela","literal":""},{"family":"Bakar","given":"Robiah","literal":""},{"family":"Bakar","given":"Robiah","literal":""},{"family":"Sabaratnam","given":"Vikineswary","literal":""},{"family":"Sabaratnam","given":"Vikineswary","literal":""}],"citation-key":"wong_neuroregenerative_2012","year":"2012","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Neuroregenerative potential of lion's mane mushroom, Hericium erinaceus (Bull.: Fr.) Pers. (higher Basidiomycetes), in the treatment of peripheral nerve injury (review)."],"author-links":["[[Author/Kah-Hui Wong]]","[[Author/Kah-Hui Wong]]","[[Author/Murali Naidu]]","[[Author/Murali Naidu]]","[[Author/Rosie Pamela David]]","[[Author/Rosie Pamela David]]","[[Author/Robiah Bakar]]","[[Author/Robiah Bakar]]","[[Author/Vikineswary Sabaratnam]]","[[Author/Vikineswary Sabaratnam]]"],"attachment":["[[biblib/wong_neuroregenerative_2012/wong_neuroregenerative_2012.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"5gza8x","at":1774951886935}},"smart_blocks:Research/@wong_neuroregenerative_2012.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[0.00012645,-0.06437917,0.03575398,-0.04669858,-0.00890519,0.02923932,0.0016229,0.07190976,-0.03665622,-0.0043844,0.00223135,-0.07421384,0.04027108,0.01885924,0.00800834,0.06326572,-0.00662818,0.04204321,-0.09261884,-0.01694133,0.0036675,-0.06687979,-0.01100085,0.0079495,0.01307387,0.01349903,-0.03143143,0.00202533,-0.04552538,-0.2222736,-0.03098575,0.01390467,-0.02189274,-0.03075673,-0.04039698,0.