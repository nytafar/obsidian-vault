10990258,0.05989423,0.00408321,0.16234651,-0.01089043,-0.03629936,0.04973642,-0.00541014,0.04191564,0.08783606,-0.076367,-0.00300075,0.0113675,0.08077202,0.00699345,0.06695103,0.05935724,-0.09323112,0.01158967,-0.03726392,-0.00394079,0.02095138,0.01948004,-0.08966968,-0.04613247,0.10635204,-0.01565927,-0.05655455,0.00524546,-0.03691972,0.00611828,-0.02604546,-0.05050082,0.01943108,0.00786946,-0.00648478,0.02294246,0.01964723,-0.00199,-0.02049391,0.00377332,-0.00169467,0.01648473,-0.01388624,0.11244509,0.07000434],"last_embed":{"hash":"19diufi","tokens":466}}},"last_read":{"hash":"19diufi","at":1774951887070},"class_name":"SmartSource","last_import":{"mtime":1774951816262,"size":3548,"at":1774951884776,"hash":"19diufi"},"blocks":{"#---frontmatter---":[1,85],"#Erinacine A-Enriched Hericium erinaceus Mycelium Delays Progression of Age-Related Cognitive Decline in Senescence Accelerated Mouse Prone 8 (SAMP8) Mice.":[87,91],"#Erinacine A-Enriched Hericium erinaceus Mycelium Delays Progression of Age-Related Cognitive Decline in Senescence Accelerated Mouse Prone 8 (SAMP8) Mice.#{1}":[89,91]},"outlinks":[{"title":"Author/Li-Ya Lee","target":"Author/Li-Ya Lee","line":66},{"title":"Author/Lee Li-Ya","target":"Author/Lee Li-Ya","line":67},{"title":"Author/Wayne Chou","target":"Author/Wayne Chou","line":68},{"title":"Author/Wayne Chou","target":"Author/Wayne Chou","line":69},{"title":"Author/Wanping Chen","target":"Author/Wanping Chen","line":70},{"title":"Author/Wan-Ping Chen","target":"Author/Wan-Ping Chen","line":71},{"title":"Author/Mingfu Wang","target":"Author/Mingfu Wang","line":72},{"title":"Author/Ming-Fu Wang","target":"Author/Ming-Fu Wang","line":73},{"title":"Author/Ying-Ju Chen","target":"Author/Ying-Ju Chen","line":74},{"title":"Author/Ying-Ju Chen","target":"Author/Ying-Ju Chen","line":75},{"title":"Author/Chen Chin-Chu","target":"Author/Chen Chin-Chu","line":76},{"title":"Author/Chin-Chu Chen","target":"Author/Chin-Chu Chen","line":77},{"title":"Author/Chin-Chu Chen","target":"Author/Chin-Chu Chen","line":78},{"title":"Author/Kwong-Chung Tung","target":"Author/Kwong-Chung Tung","line":79},{"title":"Author/Kwong-Chung Tung","target":"Author/Kwong-Chung Tung","line":80},{"title":"PDF","target":"biblib/lee_erinacine_2021/lee_erinacine_2021.pdf","line":82}],"metadata":{"id":"lee_erinacine_2021","type":"article-journal","title":"Erinacine A-Enriched Hericium erinaceus Mycelium Delays Progression of Age-Related Cognitive Decline in Senescence Accelerated Mouse Prone 8 (SAMP8) Mice.","issued":{"date-parts":[[2021]]},"DOI":"10.3390/nu13103659","container-title":"Nutrients","abstract":"There have been many reports on the neuroprotective effects of Hericium erinaceus mycelium, in which the most well-known active compounds found are diterpenoids, such as erinacine A. Previously, erinacine A-enriched Hericeum erinaceus mycelium (EAHEM) was shown to decrease amyloid plaque aggregation and improve cognitive disability in Alzheimer’s disease model APP/PS1 mice. However, its effects on brain aging have not yet been touched upon. Here, we used senescence accelerated mouse prone 8 (SAMP8) mice as a model to elucidate the mechanism by which EAHEM delays the aging of the brain. Three-month-old SAMP8 mice were divided into three EAHEM dosage groups, administered at 108, 215 and 431 mg/kg/BW/day, respectively. During the 12th week of EAHEM feeding, learning and memory of the mice were evaluated by single-trial passive avoidance and active avoidance test. After sacrifice, the amyloid plaques, induced nitric oxidase synthase (iNOS) activity, thiobarbituric acid-reactive substances (TBARS) and 8-OHdG levels were analyzed. We found that the lowest dose of 108 mg/kg/BW EAHEM was sufficient to significantly improve learning and memory in the passive and active avoidance tests. In all three EAHEM dose groups, iNOS, TBARS and 8-OHdG levels all decreased significantly and showed a dose-dependent response. The results indicate that EAHEM improved learning and memory and delayed degenerative aging in mice brains.","tags":["#literature_note"],"author":[{"family":"Lee","given":"Li-Ya","literal":""},{"family":"Li-Ya","given":"Lee","literal":""},{"family":"Chou","given":"Wayne","literal":""},{"family":"Chou","given":"Wayne","literal":""},{"family":"Chen","given":"Wanping","literal":""},{"family":"Chen","given":"Wan-Ping","literal":""},{"family":"Wang","given":"Mingfu","literal":""},{"family":"Wang","given":"Ming-Fu","literal":""},{"family":"Chen","given":"Ying-Ju","literal":""},{"family":"Chen","given":"Ying-Ju","literal":""},{"family":"Chin-Chu","given":"Chen","literal":""},{"family":"Chen","given":"Chin-Chu","literal":""},{"family":"Chen","given":"Chin-Chu","literal":""},{"family":"Tung","given":"Kwong-Chung","literal":""},{"family":"Tung","given":"Kwong-Chung","literal":""}],"citation-key":"lee_erinacine_2021","year":"2021","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Erinacine A-Enriched Hericium erinaceus Mycelium Delays Progression of Age-Related Cognitive Decline in Senescence Accelerated Mouse Prone 8 (SAMP8) Mice."],"author-links":["[[Author/Li-Ya Lee]]","[[Author/Lee Li-Ya]]","[[Author/Wayne Chou]]","[[Author/Wayne Chou]]","[[Author/Wanping Chen]]","[[Author/Wan-Ping Chen]]","[[Author/Mingfu Wang]]","[[Author/Ming-Fu Wang]]","[[Author/Ying-Ju Chen]]","[[Author/Ying-Ju Chen]]","[[Author/Chen Chin-Chu]]","[[Author/Chin-Chu Chen]]","[[Author/Chin-Chu Chen]]","[[Author/Kwong-Chung Tung]]","[[Author/Kwong-Chung Tung]]"],"attachment":["[[biblib/lee_erinacine_2021/lee_erinacine_2021.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"19diufi","at":1774951887058}},"smart_blocks:Research/@lee_erinacine_2021.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.0631502,-0.04561758,0.00092653,-0.01064187,-0.01317745,0.07060164,-0.01560626,0.02625765,-0.04685886,-0.04975229,0.04373741,-0.06470513,0.05178966,0.01245871,-0.0