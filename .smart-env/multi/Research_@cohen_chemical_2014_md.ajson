481,0.19327047,-0.00812431,-0.01652025,0.00346377,-0.03625035,0.03336938,-0.03848148,0.04317318,0.02670823,0.06576557,0.12652044,0.00589853,0.03356698,0.12681261,-0.01201164,-0.06494404,-0.05662197,-0.01128627,0.03610624,-0.02658729,-0.17140684,-0.00918776,0.08416254,-0.0801619,-0.04381773,-0.03907916,0.01331098,-0.03094585,-0.03395051,0.00534039,-0.04408593,0.03513018,-0.05632368,-0.00264714,0.01607125,0.03060103,-0.06651936,-0.00281304,-0.0160317,0.04342509,-0.08648918,0.11017214,0.01776687],"last_embed":{"hash":"7rm4vm","tokens":434}}},"last_read":{"hash":"7rm4vm","at":1774951891830},"class_name":"SmartSource","last_import":{"mtime":1774951823235,"size":4431,"at":1774951884810,"hash":"7rm4vm"},"blocks":{"#---frontmatter---":[1,97],"#Chemical composition and nutritional and medicinal value of fruit bodies and submerged cultured mycelia of culinary-medicinal higher Basidiomycetes mushrooms.":[99,103],"#Chemical composition and nutritional and medicinal value of fruit bodies and submerged cultured mycelia of culinary-medicinal higher Basidiomycetes mushrooms.#{1}":[101,103]},"outlinks":[{"title":"Author/N. Cohen","target":"Author/N. Cohen","line":75},{"title":"Author/Nachshol Cohen","target":"Author/Nachshol Cohen","line":76},{"title":"Author/J. Cohen","target":"Author/J. Cohen","line":77},{"title":"Author/Jacob Cohen","target":"Author/Jacob Cohen","line":78},{"title":"Author/Mikheil D. Asatiani","target":"Author/Mikheil D. Asatiani","line":79},{"title":"Author/Mikheil D. Asatiani","target":"Author/Mikheil D. Asatiani","line":80},{"title":"Author/V. K. Varshney","target":"Author/V. K. Varshney","line":81},{"title":"Author/Vinay K. Varshney","target":"Author/Vinay K. Varshney","line":82},{"title":"Author/Hui-Tzu Yu","target":"Author/Hui-Tzu Yu","line":83},{"title":"Author/Hui-Tzu Yu","target":"Author/Hui-Tzu Yu","line":84},{"title":"Author/Yi-Chi Yang","target":"Author/Yi-Chi Yang","line":85},{"title":"Author/Yi-Chi Yang","target":"Author/Yi-Chi Yang","line":86},{"title":"Author/Yu-Hsuan Li","target":"Author/Yu-Hsuan Li","line":87},{"title":"Author/Yu-Hsuan Li","target":"Author/Yu-Hsuan Li","line":88},{"title":"Author/Jeng-Leun Mau","target":"Author/Jeng-Leun Mau","line":89},{"title":"Author/Jeng-Leun Mau","target":"Author/Jeng-Leun Mau","line":90},{"title":"Author/Solomon P. Wasser","target":"Author/Solomon P. Wasser","line":91},{"title":"Author/Solomon P. Wasser","target":"Author/Solomon P. Wasser","line":92},{"title":"PDF","target":"biblib/cohen_chemical_2014/cohen_chemical_2014.pdf","line":94}],"metadata":{"id":"cohen_chemical_2014","type":"article-journal","title":"Chemical composition and nutritional and medicinal value of fruit bodies and submerged cultured mycelia of culinary-medicinal higher Basidiomycetes mushrooms.","issued":{"date-parts":[[2014]]},"DOI":"10.1615/intjmedmushr.v16.i3.80","container-title":"International Journal of Medicinal Mushrooms","abstract":"This research gives the results of a proximate analysis (moisture, ash, crude protein, fat, total carbohydrates, and total energy); a bioactive compounds analysis (γ-aminobutyric acid (GABA), ergothioneine, lovastatin, and cordycepin); fatty acid and amino acid analysis; and an analysis of macro- and microelement content of fruit bodies and mycelia of 15 higher Basidiomycetes medicinal mushroom strains belonging to 12 species. The results obtained demonstrate that almost all investigated mushrooms were found to be good sources of proteins and carbohydrates, with content varying in the ranges of 8.6-42.5% and 42.9-83.6%, respectively. Different species exhibited distinct free amino acid profiles. The total amino acid content was highest in Ophiocordyceps sinensis (MB) (23.84 mg/g) and Cordyceps militaris (FB) (23.69 mg/g). The quantification of the identified fatty acids indicated that, in general, palmitic acid, oleic acid, stearic acid, and linoleic acid were the major fatty acids. The micro- and macroelement compositions were studied, and the highest results were (as milligrams per kilogram) 224-7307 for calcium, 1668-38564 for potassium, 1091-11676 for phosphorus, and 5-97 for zinc. Bioactive components were lovastatin, GABA, and ergothioneine, which are commonly found in most mushrooms. C. militaris (FB), Pleurotus ostreatus (FB), and Coprinus comatus (FB) were most abundant and contained a high amount of GABA and ergothioneine (756.30-409.88, 1304.99-2443.53, 1092.45-764.35 µg/g, respectively). The highest lovastatin content was observed in Hericium erinaceus (FB) (14.38 µg/g) and Ganoderma lucidum (FB) (11.54 µg/g). In contrast to C. militaris (FB), cordycepin was not detected in O. sinensis (MB). The fruit body biomass of C. militaris cordycepin content reached 1.743 mg/g dry weight. The nutritional values of the mushroom species studied here could potentially be used in well-balanced diets and as sources of bioactive compounds.","tags":["#literature_note"],"author":[{"family":"Cohen","given":"N.","literal":""},{"family":"Cohen","given":"Nachshol","literal":""},{"family":"Cohen","given":"J.","literal":""},{"family":"Cohen","given":"Jacob","literal":""},{"family":"Asatiani","given":"Mikheil D.","literal":""},{"family":"Asatiani","given":"Mikheil D.","literal":""},{"family":"Varshney","given":"V. K.","literal":""},{"family":"Varshney","given":"Vinay K.","literal":""},{"family":"Yu","given":"Hui-Tzu","literal":""},{"family":"Yu","given":"Hui-Tzu","literal":""},{"family":"Yang","given":"Yi-Chi","literal":""},{"family":"Yang","given":"Yi-Chi","literal":""},{"family":"Li","given":"Yu-Hsuan","literal":""},{"family":"Li","given":"Yu-Hsuan","literal":""},{"family":"Mau","given":"Jeng-Leun","literal":""},{"family":"Mau","given":"Jeng-Leun","literal":""},{"family":"Wasser","given":"Solomon P.","literal":""},{"family":"Wasser","given":"Solomon P.","literal":""}],"citation-key":"cohen_chemical_2014","year":"2014","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Chemical composition and nutritional and medicinal value of fruit bodies and submerged cultured mycelia of culinary-medicinal higher Basidiomycetes mushrooms."],"author-links":["[[Author/N. Cohen]]","[[Author/Nachshol Cohen]]","[[Author/J. Cohen]]","[[Author/Jacob Cohen]]","[[Author/Mikheil D. Asatiani]]","[[Author/Mikheil D. Asatiani]]","[[Author/V. K. Varshney]]","[[Author/Vinay K. Varshney]]","[[Author/Hui-Tzu Yu]]","[[Author/Hui-Tzu Yu]]","[[Author/Yi-Chi Yang]]","[[Author/Yi-Chi Yang]]","[[Author/Yu-Hsuan Li]]","[[Author/Yu-Hsuan Li]]","[[Author/Jeng-Leun Mau]]","[[Author/Jeng-Leun Mau]]","[[Author/Solomon P. Wasser]]","[[Author/Solomon P. Wasser]]"],"attachment":["[[biblib/cohen_chemical_2014/cohen_chemical_2014.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"7rm4vm","at":1774951891820}},"smart_blocks:Research/@cohen_chemical_2014.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.01421115,-0.02602387,-0.00825589,-0.05445442,0.03489751,0.00027192,0.04130413,0.0326038,-0.02200857,-0.0008572,0.02600696,-0.09325663,0.02623508,0.0150128,0.03996677,-0.000559,0.0401609,0.01398014,-0.10172475,-0.02434161,0.07083397,-0.02901999,0.01475641,-0.01088292,0.08560597,0.04661659,-0.05492626,0.00936363,-0.05944518,-0.23053338,-0.02172506,0.0095211,0.06548188,-0.06543064,0.01441517,0.01089701,0.01823162,0.01261003,-0.03113411,0.0286501,0.0792235,0.00543075,0.00347217,0.02526773,0.0596712,-0.02144823,-0.02499712,0.00614283,0.0628789,-0.03253637,-0.04890104,-0.03759502,0.01552219,0.01834802,0.01731914,-0.01053608,0.0062425,0.03876043,-0.01411373,0.04432837,0.03435886,0.04916723,-0.1712748,0.06340818,0.06359462,0.00706006,-0.06967872,-0.00118555,0.04895351,-0.02169175,-0.03958366,0.04485586,0.04953246,0.0386285,0.02630395,-0.03477427,0.0019998,-0.02483181,-0.03497381,0.01066547,-0.01350363,0.04978544,0.05373307,-0.01092991,-0.00944349,-0.06856729,-0.03192601,-0.01767289,0.04869204,0.03886072,0.03752412,-0.04652733,0.00296327,0.0317862,-0.08096