103,0.03611974,0.17251757,0.01019288,-0.04985604,-0.01023045,-0.0081048,0.03321853,-0.01409944,0.02387355,-0.00901812,0.05067798,0.09766272,-0.03074426,0.09815417,0.10728278,-0.07120559,-0.05715961,-0.03312358,0.00333086,-0.00423611,-0.05925382,-0.13228373,-0.00924948,0.09934001,-0.04083265,-0.00530778,-0.03208169,-0.04577263,0.00020154,-0.001629,-0.0179547,0.01438965,0.05631493,0.00235634,-0.03666655,0.01180853,-0.05409218,-0.04050561,-0.00295364,0.0262383,0.01836817,-0.03333975,0.09880538,0.01529888],"last_embed":{"hash":"196xrkc","tokens":457}}},"last_read":{"hash":"196xrkc","at":1774951886855},"class_name":"SmartSource","last_import":{"mtime":1774951815837,"size":2785,"at":1774951884775,"hash":"196xrkc"},"blocks":{"#---frontmatter---":[1,65],"#Therapeutic potential of culinary-medicinal mushrooms for the management of neurodegenerative diseases: diversity, metabolite, and mechanism.":[67,71],"#Therapeutic potential of culinary-medicinal mushrooms for the management of neurodegenerative diseases: diversity, metabolite, and mechanism.#{1}":[69,71]},"outlinks":[{"title":"Author/Chia Wei Phan","target":"Author/Chia Wei Phan","line":51},{"title":"Author/Chia-Wei Phan","target":"Author/Chia-Wei Phan","line":52},{"title":"Author/Pamela David","target":"Author/Pamela David","line":53},{"title":"Author/Pamela David","target":"Author/Pamela David","line":54},{"title":"Author/Murali Naidu","target":"Author/Murali Naidu","line":55},{"title":"Author/Murali Naidu","target":"Author/Murali Naidu","line":56},{"title":"Author/Kah-Hui Wong","target":"Author/Kah-Hui Wong","line":57},{"title":"Author/Kah-Hui Wong","target":"Author/Kah-Hui Wong","line":58},{"title":"Author/Vikineswary Sabaratnam","target":"Author/Vikineswary Sabaratnam","line":59},{"title":"Author/Vikineswary Sabaratnam","target":"Author/Vikineswary Sabaratnam","line":60},{"title":"PDF","target":"biblib/phan_therapeutic_2015/phan_therapeutic_2015.pdf","line":62}],"metadata":{"id":"phan_therapeutic_2015","type":"article-journal","title":"Therapeutic potential of culinary-medicinal mushrooms for the management of neurodegenerative diseases: diversity, metabolite, and mechanism.","issued":{"date-parts":[[2015]]},"DOI":"10.3109/07388551.2014.887649","container-title":"Critical Reviews in Biotechnology","abstract":"AbstractMushrooms have long been used not only as food but also for the treatment of various ailments. Although at its infancy, accumulated evidence suggested that culinary-medicinal mushrooms may play an important role in the prevention of many age-associated neurological dysfunctions, including Alzheimer’s and Parkinson’s diseases. Therefore, efforts have been devoted to a search for more mushroom species that may improve memory and cognition functions. Such mushrooms include Hericium erinaceus, Ganoderma lucidum, Sarcodon spp., Antrodia camphorata, Pleurotus giganteus, Lignosus rhinocerotis, Grifola frondosa, and many more. Here, we review over 20 different brain-improving culinary-medicinal mushrooms and at least 80 different bioactive secondary metabolites isolated from them. The mushrooms (either extracts from basidiocarps/mycelia or isolated compounds) reduced beta amyloid-induced neurotoxicity and had anti-acetylcholinesterase, neurite outgrowth stimulation, nerve growth factor (NGF) synthesis, ne...","tags":["#literature_note"],"author":[{"family":"Phan","given":"Chia Wei","literal":""},{"family":"Phan","given":"Chia-Wei","literal":""},{"family":"David","given":"Pamela","literal":""},{"family":"David","given":"Pamela","literal":""},{"family":"Naidu","given":"Murali","literal":""},{"family":"Naidu","given":"Murali","literal":""},{"family":"Wong","given":"Kah-Hui","literal":""},{"family":"Wong","given":"Kah-Hui","literal":""},{"family":"Sabaratnam","given":"Vikineswary","literal":""},{"family":"Sabaratnam","given":"Vikineswary","literal":""}],"citation-key":"phan_therapeutic_2015","year":"2015","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Therapeutic potential of culinary-medicinal mushrooms for the management of neurodegenerative diseases: diversity, metabolite, and mechanism."],"author-links":["[[Author/Chia Wei Phan]]","[[Author/Chia-Wei Phan]]","[[Author/Pamela David]]","[[Author/Pamela David]]","[[Author/Murali Naidu]]","[[Author/Murali Naidu]]","[[Author/Kah-Hui Wong]]","[[Author/Kah-Hui Wong]]","[[Author/Vikineswary Sabaratnam]]","[[Author/Vikineswary Sabaratnam]]"],"attachment":["[[biblib/phan_therapeutic_2015/phan_therapeutic_2015.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"196xrkc","at":1774951886846}},"smart_blocks:Research/@phan_therapeutic_2015.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[0.0165951,-0.01784297,0.0249488,-0.05216318,0.00237884,0.03270183,0.0297555,0.03434047,-0.04158371,-0.03078589,-0.00838343,-0.04921248,0.00809023,0.07111937,0.04281055,0.02476673,0.02599003,0.01546148,-0.03308449,0.00451128,0.03220377,-0.00525571,0.00871947,0.01917413,0.04956568,0.05247134,-0.03754967,-0.00558657,-0.06033079,-0.20796038,-0.02186513,0.01115666,0.00101455,-0.05551964,-0.03352062,0.01274106,-0.00249778,0.03302605,0.00983242,0.03401512,0.06902905,0.03723836,0.01507716,0.0230793,0.04313903,-0.03706867,-0.06219932,-0.07283945,0.02689006,-0.05011912,-0.06084833,-0.02679043,0.0348884,0.00712109,0.03511404,-0.03181254,-0.0259322,0.03728474,0.02580253,0.08367265,0.0794832,0.04287304,-0.18914527,0.05668917,0.01105534,-0.02092065,-0.07557636,0.02788176,0.05192132,0.03287033,-0.0519515,0.01742735,0.06050364,0.05884289,0.02708228,-0.00270249,-0.02870494,-0.05031678,-0.01935883,0.00139446,0.07583322,0.08450263,0.01502609,-0.02203982,-0.03967008,-0.02883633,-0.00877854,-0.03834774,-0.01584142,0.02286171,0.00600022,-0.0054865,0.00202003,-0.00183217,-0.05697216,0.02971012,-0.0345513,-0.03042135,-0.08432959,0.12431518,-0.04400991,-0.00912456,-0.00028675,-0.01967054,-0.00335979,-0.00233001,-0.02779703,-0.08160076,0.01276