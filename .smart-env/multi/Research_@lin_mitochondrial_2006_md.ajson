,-0.05326577,0.03228361,0.05602361,0.1621504,0.014534,0.07716734,0.06210547,-0.01729324,0.06313498,0.05232386,-0.02102464,-0.01841039,-0.02591029,0.07606982,-0.02332369,-0.00078841,0.07619738,-0.04234666,-0.00056522,-0.00533936,-0.0198723,0.04246305,0.0275411,-0.02955485,-0.01716028,0.09572919,0.01651612,-0.06281019,-0.00337314,-0.00649812,0.00370296,-0.0247223,-0.01752421,0.02979251,0.03484582,-0.00652214,-0.02341136,0.03656703,-0.05802644,-0.010791,-0.02643744,0.01015394,0.05605874,-0.0399927,0.13680662,-0.01839589],"last_embed":{"hash":"1g99zst","tokens":445}}},"last_read":{"hash":"1g99zst","at":1774951889387},"class_name":"SmartSource","last_import":{"mtime":1774951820408,"size":1787,"at":1774951884798,"hash":"1g99zst"},"blocks":{"#---frontmatter---":[1,41],"#Mitochondrial dysfunction and oxidative stress in neurodegenerative diseases":[43,47],"#Mitochondrial dysfunction and oxidative stress in neurodegenerative diseases#{1}":[45,47]},"outlinks":[{"title":"Author/Michael Lin","target":"Author/Michael Lin","line":33},{"title":"Author/Michael T. Lin","target":"Author/Michael T. Lin","line":34},{"title":"Author/M. Flint Beal","target":"Author/M. Flint Beal","line":35},{"title":"Author/M. Flint Beal","target":"Author/M. Flint Beal","line":36},{"title":"PDF","target":"biblib/lin_mitochondrial_2006/lin_mitochondrial_2006.pdf","line":38}],"metadata":{"id":"lin_mitochondrial_2006","type":"article-journal","title":"Mitochondrial dysfunction and oxidative stress in neurodegenerative diseases","issued":{"date-parts":[[2006]]},"DOI":"10.1038/nature05292","container-title":"Nature","abstract":"Many lines of evidence suggest that mitochondria have a central role in ageing-related neurodegenerative diseases. Mitochondria are critical regulators of cell death, a key feature of neurodegeneration. Mutations in mitochondrial DNA and oxidative stress both contribute to ageing, which is the greatest risk factor for neurodegenerative diseases. In all major examples of these diseases there is strong evidence that mitochondrial dysfunction occurs early and acts causally in disease pathogenesis. Moreover, an impressive number of disease-specific proteins interact with mitochondria. Thus, therapies targeting basic mitochondrial processes, such as energy metabolism or free-radical generation, or specific interactions of disease-related proteins with mitochondria, hold great promise.","tags":["#literature_note"],"author":[{"family":"Lin","given":"Michael","literal":""},{"family":"Lin","given":"Michael T.","literal":""},{"family":"Beal","given":"M. Flint","literal":""},{"family":"Beal","given":"M. Flint","literal":""}],"citation-key":"lin_mitochondrial_2006","year":"2006","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Mitochondrial dysfunction and oxidative stress in neurodegenerative diseases"],"author-links":["[[Author/Michael Lin]]","[[Author/Michael T. Lin]]","[[Author/M. Flint Beal]]","[[Author/M. Flint Beal]]"],"attachment":["[[biblib/lin_mitochondrial_2006/lin_mitochondrial_2006.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"1g99zst","at":1774951889377}},"smart_blocks:Research/@lin_mitochondrial_2006.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.04284389,0.01138,0.02645632,-0.04031156,0.03638543,0.05248562,0.04037383,0.0111613,-0.01951529,-0.04419864,0.00907891,-0.0222075,0.05045172,0.07368237,-0.0391471,0.05643659,-0.03287391,0.06505805,-0.0794782,0.03333636,0.04895287,-0.02234778,0.05254427,-0.04082516,-0.008229,0.03065382,-0.00111112,-0.02102135,-0.05332436,-0.19765431,0.00742916,0.02630256,0.00106832,-0.01684843,-0.03713477,-0.01304446,-0.02330668,0.00283503,-0.02258449,-0.04295037,0.09472173,0.04443354,-0.03210852,-0.0004495,-0.01862782,-0.04659825,-0.01034619,-0.04441232,0.00434932,-0.02549761,-0.00698234,0.02048247,0.02793564,0.0176589,0.05902289,0.00360249,0.0328308,0.08472618,0.02884712,0.04355384,0.01110109,0.03675736,-0.19860