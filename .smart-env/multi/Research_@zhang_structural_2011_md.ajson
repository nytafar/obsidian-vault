,0.00066005,0.19120969,-0.00589714,-0.04168678,0.01060129,0.00009571,0.0060128,-0.0594606,0.0363463,-0.01014508,0.04860076,0.14163363,-0.05609635,0.05111868,0.06164521,-0.01650331,-0.02130772,0.01390404,-0.02378291,0.01556247,-0.03520059,-0.12456727,-0.05125571,0.09738088,-0.04524063,-0.0299585,-0.03898366,0.03099664,0.01433741,-0.00928168,-0.01740357,-0.0118442,-0.00724819,-0.01416273,-0.02930351,-0.01914983,-0.03579883,-0.05854705,-0.0039915,-0.0191261,0.02756147,-0.10645868,0.0658168,0.03187549],"last_embed":{"hash":"q673x6","tokens":416}}},"last_read":{"hash":"q673x6","at":1774951896336},"class_name":"SmartSource","last_import":{"mtime":1774951829573,"size":3416,"at":1774951884833,"hash":"q673x6"},"blocks":{"#---frontmatter---":[1,69],"#STRUCTURAL ELUCIDATION OF A NEUTRAL WATER-SOLUBLE α-D-GLUCAN FROM THE FUNGUS OF HERICIUM ERINACEUS":[71,75],"#STRUCTURAL ELUCIDATION OF A NEUTRAL WATER-SOLUBLE α-D-GLUCAN FROM THE FUNGUS OF HERICIUM ERINACEUS#{1}":[73,75]},"outlinks":[{"title":"Author/Anqiang Zhang","target":"Author/Anqiang Zhang","line":54},{"title":"Author/An-qiang Zhang","target":"Author/An-qiang Zhang","line":55},{"title":"Author/Ying-lin Deng","target":"Author/Ying-lin Deng","line":56},{"title":"Author/Ying-lin Deng","target":"Author/Ying-lin Deng","line":57},{"title":"Author/Peilong Sun","target":"Author/Peilong Sun","line":58},{"title":"Author/Peilong Sun","target":"Author/Peilong Sun","line":59},{"title":"Author/Xianghe Meng","target":"Author/Xianghe Meng","line":60},{"title":"Author/Xianghe Meng","target":"Author/Xianghe Meng","line":61},{"title":"Author/Xianghe Meng","target":"Author/Xianghe Meng","line":62},{"title":"Author/Jingsong Zhang","target":"Author/Jingsong Zhang","line":63},{"title":"Author/Jing-song Zhang","target":"Author/Jing-song Zhang","line":64},{"title":"PDF","target":"biblib/zhang_structural_2011/zhang_structural_2011.pdf","line":66}],"metadata":{"id":"zhang_structural_2011","type":"article-journal","title":"STRUCTURAL ELUCIDATION OF A NEUTRAL WATER-SOLUBLE α-D-GLUCAN FROM THE FUNGUS OF HERICIUM ERINACEUS","issued":{"date-parts":[[2011]]},"DOI":"10.1111/j.1745-4514.2010.00492.x","container-title":"Journal of Food Biochemistry","abstract":"A new α-D-glucan (HEPF5), with a molecular weight of 4.23×105 Da as determined by high-performance liquid chromatography, was isolated from the water extract of the fruiting bodies of Hericium erinaceus. Its chemical structure was characterized by sugar and methylation analysis along with infrared (IR), 1H and 13C nuclear magnetic resonance spectroscopy, including correlated spectroscopy, total correlation spectroscopy, heteronuclear multiple quantum correlation spectroscopy and nuclear Overhauser enhancement spectroscopy experiments for linkage and sequence analysis. The polysaccharide is composed of a multibranch tetrasaccharide repeating unit with the following structure: PRACTICAL APPLICATIONS Mushroom-derived polysaccharides have emerged as an important class of bioactive substances, to which numerous medicinal and therapeutic properties have been attributed. Hericium erinaceus is a traditional Chinese medicinal fungus distributed throughout China. It is used to treat gastric ulcers, chronic gastritis and other digestive tract-related diseases. As the function is intimately related to the structure, characterization of highly complex and diverse polysaccharides is highly desirable. Despite the large amount of knowledge on the structure of polysaccharide, elucidation of the fine structures of heteropolysaccharide from varied sources and diverse conditions still remains as a matter of immense interest and importance. This paper describes the structure of a novel water-soluble heteropolysaccharide isolated from the fruiting bodies of H. erinaceus. It should help in correlating the structure and function relationship, which is significant for its utilization both in pharmaceutical and food industries.","tags":["#literature_note"],"author":[{"family":"Zhang","given":"Anqiang","literal":""},{"family":"Zhang","given":"An-qiang","literal":""},{"family":"Deng","given":"Ying-lin","literal":""},{"family":"Deng","given":"Ying-lin","literal":""},{"family":"Sun","given":"Peilong","literal":""},{"family":"Sun","given":"Peilong","literal":""},{"family":"Meng","given":"Xianghe","literal":""},{"family":"Meng","given":"Xianghe","literal":""},{"family":"Meng","given":"Xianghe","literal":""},{"family":"Zhang","given":"Jingsong","literal":""},{"family":"Zhang","given":"Jing-song","literal":""}],"citation-key":"zhang_structural_2011","year":"2011","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["STRUCTURAL ELUCIDATION OF A NEUTRAL WATER-SOLUBLE α-D-GLUCAN FROM THE FUNGUS OF HERICIUM ERINACEUS"],"author-links":["[[Author/Anqiang Zhang]]","[[Author/An-qiang Zhang]]","[[Author/Ying-lin Deng]]","[[Author/Ying-lin Deng]]","[[Author/Peilong Sun]]","[[Author/Peilong Sun]]","[[Author/Xianghe Meng]]","[[Author/Xianghe Meng]]","[[Author/Xianghe Meng]]","[[Author/Jingsong Zhang]]","[[Author/Jing-song Zhang]]"],"attachment":["[[biblib/zhang_structural_2011/zhang_structural_2011.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"q673x6","at":1774951896328}},"smart_blocks:Research/@zhang_structural_2011.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.02633832,-0.04724457,0.07293971,-0.04844019,0.01162888,-0.01434493,-0.00196209,0.01730221,-0.0503676,-0.03493888,0.01703823,-0.12262178,0.01736839,-0.01903885,0.02384759,0.0007697,0.00781242,0.03140358,-0.08449761,0.01436145,0.08507837,-0.05927633,0.01687174,-0.03707879,0.0664992,0.07332641,-0.00889369,-0.02077935,-0.01515232,-0.22723019,-0.04320722,-0.02780821,0.02964626,0.02022834,-0.01208649,-0.04345291,-0.05715423,0.03077763,-0.01970869,-0.00336405,0.07527377,0.04842569,0.02892878,0.04023719,-0.02944008,-0.0630588,-0.05508509,-0.00449802,0.0147846,0.02341187,-0.03785026,0.00391272,0.0052368,0.05754354,0.