672739,-0.02921848,0.18572727,-0.02211909,0.04075526,0.02277009,-0.06997363,0.02337692,-0.0311411,-0.01057541,-0.00512255,0.0563896,0.05503249,-0.0683759,0.03707461,0.09297725,-0.03754713,-0.02176946,-0.0053455,-0.04063828,0.0017729,-0.06633791,-0.06380276,-0.00393456,0.10436141,-0.07496175,-0.0271999,-0.03720557,-0.01148516,0.0136408,0.00012037,-0.01539093,-0.0084306,0.05721255,-0.00973572,0.00677311,0.01554823,-0.06217977,0.01116312,-0.00112086,-0.01792607,-0.01034597,-0.00285604,0.11145853,0.00493023],"last_embed":{"hash":"7o19c0","tokens":467}}},"last_read":{"hash":"7o19c0","at":1774951890531},"class_name":"SmartSource","last_import":{"mtime":1774951821242,"size":2924,"at":1774951884801,"hash":"7o19c0"},"blocks":{"#---frontmatter---":[1,65],"#Uridine from Pleurotus giganteus and Its Neurite Outgrowth Stimulatory Effects with Underlying Mechanism":[67,71],"#Uridine from Pleurotus giganteus and Its Neurite Outgrowth Stimulatory Effects with Underlying Mechanism#{1}":[69,71]},"outlinks":[{"title":"Author/Chia Wei Phan","target":"Author/Chia Wei Phan","line":51},{"title":"Author/Chia-Wei Phan","target":"Author/Chia-Wei Phan","line":52},{"title":"Author/Pamela David","target":"Author/Pamela David","line":53},{"title":"Author/Pamela David","target":"Author/Pamela David","line":54},{"title":"Author/Kah-Hui Wong","target":"Author/Kah-Hui Wong","line":55},{"title":"Author/Kah-Hui Wong","target":"Author/Kah-Hui Wong","line":56},{"title":"Author/Murali Naidu","target":"Author/Murali Naidu","line":57},{"title":"Author/Murali Naidu","target":"Author/Murali Naidu","line":58},{"title":"Author/Vikineswary Sabaratnam","target":"Author/Vikineswary Sabaratnam","line":59},{"title":"Author/Vikineswary Sabaratnam","target":"Author/Vikineswary Sabaratnam","line":60},{"title":"PDF","target":"biblib/phan_uridine_2015/phan_uridine_2015.pdf","line":62}],"metadata":{"id":"phan_uridine_2015","type":"article-journal","title":"Uridine from Pleurotus giganteus and Its Neurite Outgrowth Stimulatory Effects with Underlying Mechanism","issued":{"date-parts":[[2015]]},"DOI":"10.1371/journal.pone.0143004","container-title":"PLOS ONE","abstract":"Neurodegenerative diseases are linked to neuronal cell death and impairment of neurite outgrowth. An edible mushroom, Pleurotus giganteus was found to stimulate neurite outgrowth in vitro but the chemical constituents and the underlying mechanism is yet to be elucidated. The chemical constituents of P. giganteus (linoleic acid, oleic acid, cinnamic acid, caffeic acid, p-coumaric acid, succinic acid, benzoic acid, and uridine) were tested for neurite outgrowth activity. Uridine (100 μM) was found to increase the percentage of neurite-bearing cells of differentiating neuroblastoma (N2a) cells by 43.1±0.5%, which was 1.8-fold higher than NGF (50 ng/mL)-treated cells. Uridine which was present in P. giganteus (1.80±0.03 g/100g mushroom extract) increased the phosphorylation of extracellular-signal regulated kinases (ERKs) and protein kinase B (Akt). Further, phosphorylation of the mammalian target of rapamycin (mTOR) was also increased. MEK/ERK and PI3K-Akt-mTOR further induced phosphorylation of cAMP-response element binding protein (CREB) and expression of growth associated protein 43 (GAP43); all of which promoted neurite outgrowth of N2a cells. This study demonstrated that P. giganteus may enhance neurite outgrowth and one of the key bioactive molecules responsible for neurite outgrowth is uridine.","tags":["#literature_note"],"author":[{"family":"Phan","given":"Chia Wei","literal":""},{"family":"Phan","given":"Chia-Wei","literal":""},{"family":"David","given":"Pamela","literal":""},{"family":"David","given":"Pamela","literal":""},{"family":"Wong","given":"Kah-Hui","literal":""},{"family":"Wong","given":"Kah-Hui","literal":""},{"family":"Naidu","given":"Murali","literal":""},{"family":"Naidu","given":"Murali","literal":""},{"family":"Sabaratnam","given":"Vikineswary","literal":""},{"family":"Sabaratnam","given":"Vikineswary","literal":""}],"citation-key":"phan_uridine_2015","year":"2015","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Uridine from Pleurotus giganteus and Its Neurite Outgrowth Stimulatory Effects with Underlying Mechanism"],"author-links":["[[Author/Chia Wei Phan]]","[[Author/Chia-Wei Phan]]","[[Author/Pamela David]]","[[Author/Pamela David]]","[[Author/Kah-Hui Wong]]","[[Author/Kah-Hui Wong]]","[[Author/Murali Naidu]]","[[Author/Murali Naidu]]","[[Author/Vikineswary Sabaratnam]]","[[Author/Vikineswary Sabaratnam]]"],"attachment":["[[biblib/phan_uridine_2015/phan_uridine_2015.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"7o19c0","at":1774951890521}},"smart_blocks:Research/@phan_uridine_2015.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.01571385,-0.03735817,0.06086853,-0.03926624,0.01052865,0.03756446,0.00534691,0.04689065,-0.01615275,0.02101483,0.05253164,-0.04622499,0.02263921,0.03028709,0.0166715,-0.03949964,-0.02864795,0.07056306,-0.09626926,-0.02617287,0.06286018,-0.03113939,0.0397996,0.00131056,0.0551317,0.02294172,-0.00249349,0.01424199,-0.04131342,-0.23888235,0.02413359,0.02406389,0.0251734,-0.03322081,-0.03582726,-0.00956103,-0.031559,-0.00059643,-0.01659536,0.01253001,0.05353463,0.0342754,-0.01952638,0.032427,0.04129766,-0.0366715,-0.01262726,-0.05751554,0.05951005,-0.03183597,0.00869355,-0.0713423,0.01812983,0.00573522,0.03232436,-0.06407037,0.01867419,0.04136121,0.06582354,0.05423969,0.03424107,0.06266197,-0.19521718,0.04189691,0.08070991,-0.05047665,-0.05812152,0.02615628,0.06546065,0.057503,-0.04683714,0.05760771,0.07232991,0.04979035,0.04480172,-0.0089241,-0.04916935,-0.07151183,0.04121061,0.05494241,0.03855481,0.03706235,-0.05081077,-0.03332739,-0.02395997,-0.0675118,-0.05219397,-0.08408974,-0.00527436,0.06066792,0.01131771,-0.03563451,-0.03330777,-0.04887302,-0.0017713,0.02789086,0.04396901,-0.00511497,-0.07577942,0.12969866,-0.05063824,0.