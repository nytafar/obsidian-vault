06847784,0.02785415,0.00065918,0.15906836,0.02248694,-0.00125676,0.00217484,0.00253178,0.04890508,-0.00652522,0.00209086,-0.0223978,-0.00930303,0.03328682,-0.02312827,0.08053373,0.08111635,-0.10318271,-0.03031224,0.03107212,-0.0317711,0.05389181,0.01189465,-0.06988089,-0.02226111,0.11849964,-0.04949285,-0.02933863,-0.01819532,-0.03158743,0.02873876,-0.00154891,-0.03043821,-0.00128523,-0.00378991,-0.00769898,0.00602694,0.04350126,-0.04214269,-0.01145894,0.00967708,-0.00867162,-0.03905912,-0.01565272,0.11529928,0.01481497],"last_embed":{"hash":"1hv0rtc","tokens":492}}},"last_read":{"hash":"1hv0rtc","at":1774951891555},"class_name":"SmartSource","last_import":{"mtime":1774951822722,"size":3331,"at":1774951884808,"hash":"1hv0rtc"},"blocks":{"#---frontmatter---":[1,81],"#The Neuroprotective Effect of Hericium erinaceus Extracts in Mouse Hippocampus after Pilocarpine-Induced Status Epilepticus.":[83,87],"#The Neuroprotective Effect of Hericium erinaceus Extracts in Mouse Hippocampus after Pilocarpine-Induced Status Epilepticus.#{1}":[85,87]},"outlinks":[{"title":"Author/Hyun-Jong Jang","target":"Author/Hyun-Jong Jang","line":63},{"title":"Author/Hyun-Jong Jang","target":"Author/Hyun-Jong Jang","line":64},{"title":"Author/Jieun Kim","target":"Author/Jieun Kim","line":65},{"title":"Author/Ji-Eun Kim","target":"Author/Ji-Eun Kim","line":66},{"title":"Author/Jieun Kim","target":"Author/Jieun Kim","line":67},{"title":"Author/Kiho Jeong","target":"Author/Kiho Jeong","line":68},{"title":"Author/Kyoung Hoon Jeong","target":"Author/Kyoung Hoon Jeong","line":69},{"title":"Author/Sung Chul Lim","target":"Author/Sung Chul Lim","line":70},{"title":"Author/Sung Chul Lim","target":"Author/Sung Chul Lim","line":71},{"title":"Author/Sung Chul Lim","target":"Author/Sung Chul Lim","line":72},{"title":"Author/Seong Yun Kim","target":"Author/Seong Yun Kim","line":73},{"title":"Author/Seong Yun Kim","target":"Author/Seong Yun Kim","line":74},{"title":"Author/Kyung-Ok Cho","target":"Author/Kyung-Ok Cho","line":75},{"title":"Author/Kyung-Ok Cho","target":"Author/Kyung-Ok Cho","line":76},{"title":"PDF","target":"biblib/jang_neuroprotective_2019/jang_neuroprotective_2019.pdf","line":78}],"metadata":{"id":"jang_neuroprotective_2019","type":"article-journal","title":"The Neuroprotective Effect of Hericium erinaceus Extracts in Mouse Hippocampus after Pilocarpine-Induced Status Epilepticus.","issued":{"date-parts":[[2019]]},"DOI":"10.3390/ijms20040859","container-title":"International Journal of Molecular Sciences","abstract":"Hericium erinaceus (HE), a culinary-medicinal mushroom, has shown therapeutic potential in many brain diseases. However, the role of HE in status epilepticus (SE)-mediated neuronal death and its underlying mechanisms remain unclear. We investigated the neuroprotective effects of HE using a pilocarpine-induced SE model. Male C57BL/6 mice received crude extracts of HE (60 mg/kg, 120 mg/kg, or 300 mg/kg, p.o.) for 21 d from 14 d before SE to 6 d after SE. At 7 d after SE, cresyl violet and immunohistochemistry of neuronal nuclei revealed improved hippocampal neuronal survival in animals treated with 60 mg/kg and 120 mg/kg of HE, whereas those treated with 300 mg/kg of HE showed similar neuronal death to that of vehicle-treated controls. While seizure-induced reactive gliosis, assessed by immunohistochemistry, was not altered by HE, the number of hippocampal cyclooxygenase 2 (COX2)-expressing cells was significantly reduced by 60 and 120 mg/kg of HE. Triple immunohistochemistry demonstrated no overlap of COX2 labeling with Ox42, in addition to a decrease in COX2/GFAP-co-immunoreactivity in the group treated with 60 mg/kg HE, suggesting that the reduction of COX2 by HE promotes neuroprotection after SE. Our findings highlight the potential application of HE for preventing neuronal death after seizures.","tags":["#literature_note"],"author":[{"family":"Jang","given":"Hyun-Jong","literal":""},{"family":"Jang","given":"Hyun-Jong","literal":""},{"family":"Kim","given":"Jieun","literal":""},{"family":"Kim","given":"Ji-Eun","literal":""},{"family":"Kim","given":"Jieun","literal":""},{"family":"Jeong","given":"Kiho","literal":""},{"family":"Jeong","given":"Kyoung Hoon","literal":""},{"family":"Lim","given":"Sung Chul","literal":""},{"family":"Lim","given":"Sung Chul","literal":""},{"family":"Lim","given":"Sung Chul","literal":""},{"family":"Kim","given":"Seong Yun","literal":""},{"family":"Kim","given":"Seong Yun","literal":""},{"family":"Cho","given":"Kyung-Ok","literal":""},{"family":"Cho","given":"Kyung-Ok","literal":""}],"citation-key":"jang_neuroprotective_2019","year":"2019","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["The Neuroprotective Effect of Hericium erinaceus Extracts in Mouse Hippocampus after Pilocarpine-Induced Status Epilepticus."],"author-links":["[[Author/Hyun-Jong Jang]]","[[Author/Hyun-Jong Jang]]","[[Author/Jieun Kim]]","[[Author/Ji-Eun Kim]]","[[Author/Jieun Kim]]","[[Author/Kiho Jeong]]","[[Author/Kyoung Hoon Jeong]]","[[Author/Sung Chul Lim]]","[[Author/Sung Chul Lim]]","[[Author/Sung Chul Lim]]","[[Author/Seong Yun Kim]]","[[Author/Seong Yun Kim]]","[[Author/Kyung-Ok Cho]]","[[Author/Kyung-Ok Cho]]"],"attachment":["[[biblib/jang_neuroprotective_2019/jang_neuroprotective_2019.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"1hv0rtc","at":1774951891545}},"smart_blocks:Research/@jang_neuroprotective_2019.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.04258386,-0.01245406,0.03766774,-0.03496186,-0.04788938,0.03958326,0.05158547,0.05224671,-0.04107979,-0.01099314,0.01150702,-0.0381122,0.01787333,0.04879963,0.0176341,0.02109668,-0.01620295,0.02027415,-0.1162488,-0.02134304,0.00535075,-0.02571967,0.02028007,0.02929255,0.01880479,0.02185141,-0.05640052,0.01492835,-0.0393498,-0.21001855,0.02353806,-0.00763616,0.01511665,-0.0797555,-0.02230479,-0.00837858,-0.03085786,-0.00750809,-0.03092