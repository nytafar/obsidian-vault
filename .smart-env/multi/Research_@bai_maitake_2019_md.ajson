263,0.16415757,-0.00360894,0.00609962,-0.00094172,0.01420405,0.02410394,0.0501167,0.04478437,-0.0167494,-0.00520135,0.11864212,-0.03955157,0.07403077,0.1139729,-0.0737187,-0.0210727,-0.00617131,-0.02638937,0.06337035,0.0110403,-0.08960022,-0.02343458,0.04985214,-0.04838942,-0.04703672,-0.01128866,-0.00844705,-0.02871376,-0.01764781,-0.02601742,0.00328786,0.02230599,0.02163603,-0.0237222,0.01743392,-0.06107957,0.00087038,-0.01345821,0.00118238,0.06515922,-0.08652011,0.13534503,0.00417986],"last_embed":{"hash":"622qzi","tokens":469}}},"last_read":{"hash":"622qzi","at":1774951890454},"class_name":"SmartSource","last_import":{"mtime":1774951821046,"size":4082,"at":1774951884800,"hash":"622qzi"},"blocks":{"#---frontmatter---":[1,113],"#A Maitake ( Grifola frondosa ) polysaccharide ameliorates Alzheimer's disease-like pathology and cognitive impairments by enhancing microglial amyloid-β clearance":[115,119],"#A Maitake ( Grifola frondosa ) polysaccharide ameliorates Alzheimer's disease-like pathology and cognitive impairments by enhancing microglial amyloid-β clearance#{1}":[117,119]},"outlinks":[{"title":"Author/Yao Bai","target":"Author/Yao Bai","line":87},{"title":"Author/Yao Bai","target":"Author/Yao Bai","line":88},{"title":"Author/Yao Bai","target":"Author/Yao Bai","line":89},{"title":"Author/Lingling Chen","target":"Author/Lingling Chen","line":90},{"title":"Author/Lingling Chen","target":"Author/Lingling Chen","line":91},{"title":"Author/Chi Yao","target":"Author/Chi Yao","line":92},{"title":"Author/Yao Chen","target":"Author/Yao Chen","line":93},{"title":"Author/Xinmeng Chen","target":"Author/Xinmeng Chen","line":94},{"title":"Author/Xinmeng Chen","target":"Author/Xinmeng Chen","line":95},{"title":"Author/Yilong Dong","target":"Author/Yilong Dong","line":96},{"title":"Author/Yilong Dong","target":"Author/Yilong Dong","line":97},{"title":"Author/Shangyong Zheng","target":"Author/Shangyong Zheng","line":98},{"title":"Author/Shangyong Zheng","target":"Author/Shangyong Zheng","line":99},{"title":"Author/Lei Zhang","target":"Author/Lei Zhang","line":100},{"title":"Author/Lei Zhang","target":"Author/Lei Zhang","line":101},{"title":"Author/Lei Zhang","target":"Author/Lei Zhang","line":102},{"title":"Author/Weiyuan Li","target":"Author/Weiyuan Li","line":103},{"title":"Author/Weiyuan Li","target":"Author/Weiyuan Li","line":104},{"title":"Author/Jing Du","target":"Author/Jing Du","line":105},{"title":"Author/Jing Du","target":"Author/Jing Du","line":106},{"title":"Author/Hongliang Li","target":"Author/Hongliang Li","line":107},{"title":"Author/Hongliang Li","target":"Author/Hongliang Li","line":108},{"title":"PDF","target":"biblib/bai_maitake_2019/bai_maitake_2019.pdf","line":110}],"metadata":{"id":"bai_maitake_2019","type":"article-journal","title":"A Maitake ( Grifola frondosa ) polysaccharide ameliorates Alzheimer's disease-like pathology and cognitive impairments by enhancing microglial amyloid-β clearance","issued":{"date-parts":[[2019]]},"DOI":"10.1039/c9ra08245j","container-title":"RSC Advances","abstract":"Alzheimer's disease (AD) is characterized by the deposition of amyloid-β (Aβ) plaques, neuronal loss and neurofibrillary tangles. In addition, neuroinflammatory processes are thought to contribute to AD pathophysiology. Maitake (Grifola frondosa), an edible/medicinal mushroom, exhibits high nutritional value and contains a great amount of health-beneficial, bioactive compounds. It has been reported that proteo-β-glucan, a polysaccharide derived from Maitake (PGM), possesses strong immunomodulatory activities. However, whether PGM is responsible for the immunomodulatory and neuroprotection effects on APPswe/PS1ΔE9 (APP/PS1) transgenic mice, a widely used animal model of AD, remains unclear. In the present study, the results demonstrated that PGM could improve learning and memory impairment, attenuate neuron loss and histopathological abnormalities in APP/PS1 mice. In addition, PGM treatment could activate microglia and astrocytes and promote microglial recruitment to the Aβ plaques. Also, PGM could enhance Aβ phagocytosis, and thereby alleviate Aβ burden and the pathological changes in the cortex and hippocampus in APP/PS1 mice. Moreover, PGM showed no significant effect on mice body weight. In conclusion, these findings indicated that administration of PGM could improve memory impairment via immunomodulatory action, and dietary supplementation with PGM may provide potential benefits on brain aging related memory dysfunction.","tags":["#literature_note"],"author":[{"family":"Bai","given":"Yao","literal":""},{"family":"Bai","given":"Yao","literal":""},{"family":"Bai","given":"Yao","literal":""},{"family":"Chen","given":"Lingling","literal":""},{"family":"Chen","given":"Lingling","literal":""},{"family":"Yao","given":"Chi","literal":""},{"family":"Chen","given":"Yao","literal":""},{"family":"Chen","given":"Xinmeng","literal":""},{"family":"Chen","given":"Xinmeng","literal":""},{"family":"Dong","given":"Yilong","literal":""},{"family":"Dong","given":"Yilong","literal":""},{"family":"Zheng","given":"Shangyong","literal":""},{"family":"Zheng","given":"Shangyong","literal":""},{"family":"Zhang","given":"Lei","literal":""},{"family":"Zhang","given":"Lei","literal":""},{"family":"Zhang","given":"Lei","literal":""},{"family":"Li","given":"Weiyuan","literal":""},{"family":"Li","given":"Weiyuan","literal":""},{"family":"Du","given":"Jing","literal":""},{"family":"Du","given":"Jing","literal":""},{"family":"Li","given":"Hongliang","literal":""},{"family":"Li","given":"Hongliang","literal":""}],"citation-key":"bai_maitake_2019","year":"2019","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["A Maitake ( Grifola frondosa ) polysaccharide ameliorates Alzheimer's disease-like pathology and cognitive impairments by enhancing microglial amyloid-β clearance"],"author-links":["[[Author/Yao Bai]]","[[Author/Yao Bai]]","[[Author/Yao Bai]]","[[Author/Lingling Chen]]","[[Author/Lingling Chen]]