.10442201,0.0343594,0.06774124,0.1819015,0.02473504,0.00491964,-0.00344793,-0.04808477,-0.02707162,0.00263431,-0.01750311,-0.01388832,0.04041466,0.08603083,-0.04531197,0.08651848,0.11984207,-0.03876745,-0.02454843,-0.02698801,-0.03759339,0.00361677,-0.02739742,-0.1035035,0.01651155,0.1120019,-0.06790568,-0.0275851,-0.00985469,-0.02531233,-0.00139883,-0.0190539,-0.00205897,0.03612876,0.02864545,0.01192957,-0.01819394,0.02343771,-0.06222209,0.00511583,0.00861586,0.01338175,-0.00410481,-0.02829371,0.12293625,-0.02292508],"last_embed":{"hash":"1561klo","tokens":478}}},"last_read":{"hash":"1561klo","at":1774951891870},"class_name":"SmartSource","last_import":{"mtime":1774951823290,"size":4069,"at":1774951884810,"hash":"1561klo"},"blocks":{"#---frontmatter---":[1,65],"#Potentiation of neuritogenic activity of medicinal mushrooms in rat pheochromocytoma cells":[67,71],"#Potentiation of neuritogenic activity of medicinal mushrooms in rat pheochromocytoma cells#{1}":[69,71]},"outlinks":[{"title":"Author/Syntyche Ling-Sing Seow","target":"Author/Syntyche Ling-Sing Seow","line":51},{"title":"Author/Syntyche Ling-Sing Seow","target":"Author/Syntyche Ling-Sing Seow","line":52},{"title":"Author/Murali Naidu","target":"Author/Murali Naidu","line":53},{"title":"Author/Murali Naidu","target":"Author/Murali Naidu","line":54},{"title":"Author/Pamela David","target":"Author/Pamela David","line":55},{"title":"Author/Pamela David","target":"Author/Pamela David","line":56},{"title":"Author/Kah-Hui Wong","target":"Author/Kah-Hui Wong","line":57},{"title":"Author/Kah-Hui Wong","target":"Author/Kah-Hui Wong","line":58},{"title":"Author/Vikineswary Sabaratnam","target":"Author/Vikineswary Sabaratnam","line":59},{"title":"Author/Vikineswary Sabaratnam","target":"Author/Vikineswary Sabaratnam","line":60},{"title":"PDF","target":"biblib/seow_potentiation_2013/seow_potentiation_2013.pdf","line":62}],"metadata":{"id":"seow_potentiation_2013","type":"article-journal","title":"Potentiation of neuritogenic activity of medicinal mushrooms in rat pheochromocytoma cells","issued":{"date-parts":[[2013]]},"DOI":"10.1186/1472-6882-13-157","container-title":"BMC Complementary and Alternative Medicine","abstract":"Senescence of the neurons is believed to be a focal factor in the development of age-related neurodegenerative diseases such as Alzheimer’s disease. Diminutions in the levels of nerve growth factor (NGF) lead to major declines in brain cell performance. Functional foods, believed to mitigate this deficiency, will be reaching a plateau in the near future market of alternative and preventive medicine. In the search for neuroactive compounds that mimic the NGF activity for the prevention of neurodegenerative diseases, the potential medicinal values of culinary and medicinal mushrooms attract intense interest. Cytotoxic effects of aqueous extracts of three medicinal mushrooms basidiocarps, Ganoderma lucidum, Ganoderma neo-japonicum and Grifola frondosa towards rat pheochromocytoma (PC-12) cells were determined by 3-(4,5-dimethythiazol-2-yl)-2,5-diphenyltetrazolium bromide (MTT) assay. The potentiation of neuritogenic activity was assessed by neurite outgrowth stimulation assay. Involvement of cellular signaling pathways, mitogen-activated protein kinase kinase/extracellular signal-regulated kinase (MEK/ERK1/2) and phosphoinositide-3-kinase/protein kinase B (PI3K/Akt) in mushrooms-stimulated neuritogenesis were examined by using specific pharmacological inhibitors. Alteration of neuronal morphology by inhibitors was visualized by immunofluorescence staining of the neurofilament. All the aqueous extracts tested caused a marked stimulation of neuritogenesis with no detectable cytotoxic effects towards PC-12 cells. The aqueous extract of G. neo-japonicum triggered maximal stimulation of neurite outgrowth at a lower concentration (50μg/ml) with 14.22 ± 0.43% of neurite-bearing cells, compared to G. lucidum and G. frondosa that act at a higher concentration (75μg/ml), with 12.61 ± 0.11% and 12.07 ± 0.46% of neurite-bearing cells, respectively. The activation of MEK/ERK1/2 and PI3K/Akt signaling pathways were necessary for the NGF and aqueous extracts to promote neuritogenesis. Ganoderma lucidum, G. neo-japonicum and G. frondosa may contain NGF-like bioactive compound(s) for maintaining and regenerating the neuronal communications network. The present study reports the first evidence of the neuritogenic effects of aqueous extracts of basidiocarps of G. neo-japonicum in-vitro and showed the involvement of MEK/ERK1/2 and P13K/Akt signaling pathways for neuritogenesis in PC-12 cells.","tags":["#literature_note"],"author":[{"family":"Seow","given":"Syntyche Ling-Sing","literal":""},{"family":"Seow","given":"Syntyche Ling-Sing","literal":""},{"family":"Naidu","given":"Murali","literal":""},{"family":"Naidu","given":"Murali","literal":""},{"family":"David","given":"Pamela","literal":""},{"family":"David","given":"Pamela","literal":""},{"family":"Wong","given":"Kah-Hui","literal":""},{"family":"Wong","given":"Kah-Hui","literal":""},{"family":"Sabaratnam","given":"Vikineswary","literal":""},{"family":"Sabaratnam","given":"Vikineswary","literal":""}],"citation-key":"seow_potentiation_2013","year":"2013","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Potentiation of neuritogenic activity of medicinal mushrooms in rat pheochromocytoma cells"],"author-links":["[[Author/Syntyche Ling-Sing Seow]]","[[Author/Syntyche Ling-Sing Seow]]","[[Author/Murali Naidu]]","[[Author/Murali Naidu]]","[[Author/Pamela David]]","[[Author/Pamela David]]","[[Author/Kah-Hui Wong]]","[[Author/Kah-Hui Wong]]","[[Author/Vikineswary Sabaratnam]]","[[Author/Vikineswary Sabaratnam]]"],"attachment":["[[biblib/seow_potentiation_2013/seow_potentiation_2013.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"1561klo","at":1774951891859}},"smart_blocks:Research/@seow_potentiation_2013.md#---frontmatter---": {"p