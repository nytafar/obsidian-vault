sibilities of the influence of Hericium erinaceus on cognitive functions were shown in patients with cerebrovascular and neurodegenerative diseases.","tags":["#literature_note"],"author":[{"family":"Mishchenko","given":"Valeriia","literal":""},{"family":"Mishchenko","given":"V. M.","literal":""},{"family":"Забродіна","given":"Л. П.","literal":""},{"family":"Zabrodina","given":"L. P.","literal":""}],"citation-key":"mishchenko__2020","year":"2020","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Нейропластичность и постинсультные когнитивные нарушения (терапевтические возможности)"],"author-links":["[[Author/Valeriia Mishchenko]]","[[Author/V. M. Mishchenko]]","[[Author/Л. П. Забродіна]]","[[Author/L. P. Zabrodina]]"],"attachment":["[[biblib/mishchenko__2020/mishchenko__2020.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"yuoiom","at":1774951895037}},"smart_blocks:Research/@mishchenko__2020.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[0.01123472,-0.03173482,0.00139012,0.01488454,-0.04418268,0.05690959,0.0216068,0.09900225,0.01888614,0.00409589,0.00645491,-0.0480544,0.02856412,0.05256078,-0.01937326,0.04976846,-0.04804645,-0.00614466,-0.0553243,0.02832717,0.04094406,-0.0567392,0.05554063,-0.00506035,-0.02411779,0.00768031,-0.03946539,-0.04056152,-0.03066909,-0.22706737,-0.05668427,-0.00268299,0.04808814,-0.04780621,-0.03941923,-0.02232694,0.00675822,-0.0136791,0.00310284,0.00500273,0.056866,0.01421841,0.02498773,0.01016398,0.03143063,-0.03398107,-0.02472555,0.00924475,-0.01942075,-0.02291496,-0.091474,-0.00653112,0.00845258,0.07046025,0.04230282,-0.00566142,0.02092548,-0.04086844,0.03066219,0.10784331,0.08752703,0.01202499,-0.23101601,0.04983701,-0.01157787,-0.01248236,-0.01656921,-0.04226185,0.04837792,0.00219415,-0.04922626,0.03410297,0.01438873,0.04161222,0.02224649,-0.00188861,0.03054932,-0.04317143,0.04032694,-0.05620319,0.07903001,0.11891151,0.00881224,-0.0402