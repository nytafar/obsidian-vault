014099,0.02464787,0.02776026,0.18894762,0.0582212,-0.03079093,0.00303093,-0.03778106,0.00110017,0.01901203,-0.00421549,0.01947561,0.03757269,0.09419066,-0.02518619,0.0627274,0.04117809,-0.07586352,-0.00893658,-0.01504516,-0.03120099,0.01784914,-0.00139751,-0.07975098,0.00059356,0.09374731,-0.08752291,-0.02181298,0.00879752,-0.0321495,0.03732632,-0.02124819,0.01518729,0.03770952,0.03769917,-0.00061006,-0.03332386,0.01988465,-0.03420081,0.01089673,0.01836622,0.01479136,-0.02882066,-0.03876208,0.09115189,0.04102924],"last_embed":{"hash":"rvbapr","tokens":485}}},"last_read":{"hash":"rvbapr","at":1774951885351},"class_name":"SmartSource","last_import":{"mtime":1774951813831,"size":3312,"at":1774951884759,"hash":"rvbapr"},"blocks":{"#---frontmatter---":[1,63],"#Neurotrophic properties of the Lion's mane medicinal mushroom, Hericium erinaceus (Higher Basidiomycetes) from Malaysia":[65,69],"#Neurotrophic properties of the Lion's mane medicinal mushroom, Hericium erinaceus (Higher Basidiomycetes) from Malaysia#{1}":[67,69]},"outlinks":[{"title":"Author/Puei-Lene Lai","target":"Author/Puei-Lene Lai","line":51},{"title":"Author/Murali Naidu","target":"Author/Murali Naidu","line":52},{"title":"Author/Vikineswary Sabaratnam","target":"Author/Vikineswary Sabaratnam","line":53},{"title":"Author/Kah-Hui Wong","target":"Author/Kah-Hui Wong","line":54},{"title":"Author/Rosie Pamela David","target":"Author/Rosie Pamela David","line":55},{"title":"Author/Umah Rani Kuppusamy","target":"Author/Umah Rani Kuppusamy","line":56},{"title":"Author/Noorlidah Abdullah","target":"Author/Noorlidah Abdullah","line":57},{"title":"Author/Sri Nurestri A. Malek","target":"Author/Sri Nurestri A. Malek","line":58},{"title":"PDF","target":"biblib/lai_neurotrophic_2013/lai_neurotrophic_2013.pdf","line":60}],"metadata":{"id":"lai_neurotrophic_2013","type":"article-journal","title":"Neurotrophic properties of the Lion's mane medicinal mushroom, Hericium erinaceus (Higher Basidiomycetes) from Malaysia","issued":{"date-parts":[[2013]]},"page":"539-554","DOI":"10.1615/intjmedmushr.v15.i6.30","container-title":"International Journal of Medicinal Mushrooms","volume":15,"number":6,"language":"eng","abstract":"Neurotrophic factors are important in promoting the growth and differentiation of neurons. Nerve growth factor (NGF) is essential for the maintenance of the basal forebrain cholinergic system. Hericenones and erinacines isolated from the medicinal mushroom Hericium erinaceus can induce NGF synthesis in nerve cells. In this study, we evaluated the synergistic interaction between H. erinaceus aqueous extract and exogenous NGF on the neurite outgrowth stimulation of neuroblastoma-glioma cell NG108-15. The neuroprotective effect of the mushroom extract toward oxidative stress was also studied. Aqueous extract of H. erinaceus was shown to be non-cytotoxic to human lung fibroblast MRC-5 and NG108-15 cells. The combination of 10 ng/mL NGF with 1 μg/mL mushroom extract yielded the highest percentage increase of 60.6% neurite outgrowth. The extract contained neuroactive compounds that induced the secretion of extracellular NGF in NG108-15 cells, thereby promoting neurite outgrowth activity. However, the H. erinaceus extract failed to protect NG108-15 cells subjected to oxidative stress when applied in pre-treatment and co-treatment modes. In conclusion, the aqueous extract of H. erinaceus contained neuroactive compounds which induced NGF-synthesis and promoted neurite outgrowth in NG108-15 cells. The extract also enhanced the neurite outgrowth stimulation activity of NGF when applied in combination. The aqueous preparation of H. erinaceus had neurotrophic but not neuroprotective activities.","tags":["#literature_note"],"author":[{"family":"Lai","given":"Puei-Lene","literal":""},{"family":"Naidu","given":"Murali","literal":""},{"family":"Sabaratnam","given":"Vikineswary","literal":""},{"family":"Wong","given":"Kah-Hui","literal":""},{"family":"David","given":"Rosie Pamela","literal":""},{"family":"Kuppusamy","given":"Umah Rani","literal":""},{"family":"Abdullah","given":"Noorlidah","literal":""},{"family":"Malek","given":"Sri Nurestri A.","literal":""}],"citation-key":"lai_neurotrophic_2013","ISSN":"1940-4344","keyword":"Basidiomycota,Biological Products,Cell Line,Tumor,Drug Synergism,Fibroblasts,Humans,Malaysia,Nerve Growth Factor,Nerve Growth Factors,Neurites,Oxidative Stress","year":"2013","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Neurotrophic properties of the Lion's mane medicinal mushroom, Hericium erinaceus (Higher Basidiomycetes) from Malaysia"],"author-links":["[[Author/Puei-Lene Lai]]","[[Author/Murali Naidu]]","[[Author/Vikineswary Sabaratnam]]","[[Author/Kah-Hui Wong]]","[[Author/Rosie Pamela David]]","[[Author/Umah Rani Kuppusamy]]","[[Author/Noorlidah Abdullah]]","[[Author/Sri Nurestri A. Malek]]"],"attachment":["[[biblib/lai_neurotrophic_2013/lai_neurotrophic_2013.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"rvbapr","at":1774951885338}},"smart_blocks:Research/@lai_neurotrophic_2013.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.01379621,-0.0463447,0.00671035,-0.03102617,0.00729628,0.0568012,0.05517232,0.02851872,-0.05267337,0.01033262,-0.02068455,-0.02335044,0.05401958,0.03234499,0.00628032,0.03972296,-0.02671646,0.0234989,-0.14661811,-0.00336423,0.03171572,-0.0195403,0.01695239,0.01647503,0.00847543,0.03177573,-0.0645816,-0.03773469,-0.01984541,-0.21759963,-0.04794738,0.0054328,0.03255108,-0.05566591,-0.02676039,0.00217478,-0.02778901,-0.02300528,-0.0180146,0.02536437,0.03598782,0.0445638,0.01792728,0.02193894,-0.01234892,-0.06380346,-0.01401658,-0.03576966,0.01246303,-0.0492533,0.00922104,-0.06782541,0.02976333,0.03878816,0.06256526,-0.01953672,-0.01256952,0.03645837,0.02740041,0.05550861,0.06293442,0.07624692,-0.19189951,0.04675877,0.05381469,-0.03938264,-0.05830608,-0.06466498,0.09415174,0.01861233,-0.019979