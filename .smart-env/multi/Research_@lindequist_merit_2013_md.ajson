ted, with an aim toward supporting the development of legalized pharmaceutical preparations of medicinal mushrooms in Europe.","tags":["#literature_note"],"author":[{"family":"Lindequist","given":"Ulrike","literal":""},{"family":"Lindequist","given":"Ulrike","literal":""}],"citation-key":"lindequist_merit_2013","year":"2013","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["The merit of medicinal mushrooms from a pharmaceutical point of view."],"author-links":["[[Author/Ulrike Lindequist]]","[[Author/Ulrike Lindequist]]"],"attachment":[],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"1savdan","at":1774951891672}},"smart_blocks:Research/@lindequist_merit_2013.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.05896677,-0.02876327,0.03003652,-0.08721794,0.05950041,0.01339215,0.01498373,0.04981557,-0.02229661,0.02797107,0.00900424,-0.03131292,0.0055225,0.01735785,-0.00483998,0.03280108,0.00826496,-0.00839354,-0.08855567,0.02633576,0.02955375,-0.03379937,0.00713755,-0.00321981,0.05547042,0.05311197,-0.0010296,-0.03120295,-0.02560066,-0.17520899,-0.03116419,-0.01801929,0.04345406,-0.00440906,-0.0250252,-0.04304167,-0.00609567,-0.00880256,-0.00039104,-0.02187359,0.07201739,0.04757412,-0.02889919,0.07947879,-0.02556418,-0.05504408,-0.07457989,-0.00672564,-0.04298383,-0.02882236,-0.00298827,-0.02450627,0.01771729,-0.01053208,0.01134735,0.07432555,-0.02542464,-0.00395009,0.03490113,0.12002878,0.04552821,0.05121231,-0.21648562,0.04460359,-0.01562569,-0.01981103,-0.08048947,-0.01502388,0.04122089,-0.01892702,0.05658162,0.00677538,0.05207407,0.03168475,0.05812275,-0.03979373,-0.00013287,-0.01231239,-0.05407856,-0.03550599,0.01748631,0.07603619,0.01372737,-0.01334013,-0.07281077,-0.04396378,0.05240443,-0.07006117,0.03474937,0.00848455,-0.00729303,-0.04315783,-0.01830596,0.01636243,-0.08925673,-0.00540119,-0.02411057,-0.01714476,-0.02064316,0.09249805,-0.06435023,0.01120973,-0.00688974,-0.03