.03512463,-0.0217422,0.20633675,0.05850592,0.06691302,0.00724222,-0.08471639,0.03283997,0.05624551,-0.04772493,0.00095475,0.07790019,0.02232156,-0.02593134,0.0034206,0.00850516,-0.03157877,-0.00472956,0.02012708,0.02878924,0.06226784,-0.01732633,-0.01816097,-0.0228857,0.09620038,-0.06139409,-0.09413379,0.00836824,0.04049948,0.02558491,-0.02086731,0.03614232,-0.05346606,0.03783746,0.03182752,0.03889655,0.00303787,-0.03317823,-0.02998175,0.02204533,0.02171334,-0.03840534,-0.0572715,0.09808714,0.01636724],"last_embed":{"hash":"4j9qcw","tokens":475}}},"last_read":{"hash":"4j9qcw","at":1774951891340},"class_name":"SmartSource","last_import":{"mtime":1774951822347,"size":3078,"at":1774951884806,"hash":"4j9qcw"},"blocks":{"#---frontmatter---":[1,89],"#TIP150 interacts with and targets MCAK at the microtubule plus ends":[91,95],"#TIP150 interacts with and targets MCAK at the microtubule plus ends#{1}":[93,95]},"outlinks":[{"title":"Author/Kai Jiang","target":"Author/Kai Jiang","line":69},{"title":"Author/Kai Jiang","target":"Author/Kai Jiang","line":70},{"title":"Author/Yunlong Wang","target":"Author/Yunlong Wang","line":71},{"title":"Author/Jianyu Wang","target":"Author/Jianyu Wang","line":72},{"title":"Author/Jing Liu","target":"Author/Jing Liu","line":73},{"title":"Author/Jing Liu","target":"Author/Jing Liu","line":74},{"title":"Author/Tarsha Ward","target":"Author/Tarsha Ward","line":75},{"title":"Author/Tarsha Ward","target":"Author/Tarsha Ward","line":76},{"title":"Author/Linda Wordeman","target":"Author/Linda Wordeman","line":77},{"title":"Author/Linda Wordeman","target":"Author/Linda Wordeman","line":78},{"title":"Author/Alec J. Davidson","target":"Author/Alec J. Davidson","line":79},{"title":"Author/Alec J. Davidson","target":"Author/Alec J. Davidson","line":80},{"title":"Author/Fengsong Wang","target":"Author/Fengsong Wang","line":81},{"title":"Author/Fengsong Wang","target":"Author/Fengsong Wang","line":82},{"title":"Author/Xuebiao Yao","target":"Author/Xuebiao Yao","line":83},{"title":"Author/Xuebiao Yao","target":"Author/Xuebiao Yao","line":84},{"title":"PDF","target":"biblib/jiang_tip150_2009/jiang_tip150_2009.pdf","line":86}],"metadata":{"id":"jiang_tip150_2009","type":"article-journal","title":"TIP150 interacts with and targets MCAK at the microtubule plus ends","issued":{"date-parts":[[2009]]},"DOI":"10.1038/embor.2009.94","container-title":"EMBO Reports","abstract":"The microtubule (MT) cytoskeleton orchestrates the cellular plasticity and dynamics that underlie morphogenesis and cell division. Growing MT plus ends have emerged as dynamic regulatory machineries in which specialized proteins—called plus-end tracking proteins (+TIPs)—bind to and control the plus-end dynamics that are essential for cell division and migration. However, the molecular mechanisms underlying the plus-end regulation by +TIPs at spindle and astral MTs have remained elusive. Here, we show that TIP150 is a new +TIP that binds to end-binding protein 1 (EB1) in vitro and co-localizes with EB1 at the MT plus ends in vivo. Suppression of EB1 eliminates the plus-end localization of TIP150. Interestingly, TIP150 also binds to mitotic centromere-associated kinesin (MCAK), an MT depolymerase that localizes to the plus end of MTs. Suppression of TIP150 diminishes the plus-end localization of MCAK. Importantly, aurora B-mediated phosphorylation disrupts the TIP150–MCAK association in vitro. We reason that TIP150 facilitates the EB1-dependent loading of MCAK onto MT plus ends and orchestrates the dynamics at the plus end of MTs.","tags":["#literature_note"],"author":[{"family":"Jiang","given":"Kai","literal":""},{"family":"Jiang","given":"Kai","literal":""},{"family":"Wang","given":"Yunlong","literal":""},{"family":"Wang","given":"Jianyu","literal":""},{"family":"Liu","given":"Jing","literal":""},{"family":"Liu","given":"Jing","literal":""},{"family":"Ward","given":"Tarsha","literal":""},{"family":"Ward","given":"Tarsha","literal":""},{"family":"Wordeman","given":"Linda","literal":""},{"family":"Wordeman","given":"Linda","literal":""},{"family":"Davidson","given":"Alec J.","literal":""},{"family":"Davidson","given":"Alec J.","literal":""},{"family":"Wang","given":"Fengsong","literal":""},{"family":"Wang","given":"Fengsong","literal":""},{"family":"Yao","given":"Xuebiao","literal":""},{"family":"Yao","given":"Xuebiao","literal":""}],"citation-key":"jiang_tip150_2009","year":"2009","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["TIP150 interacts with and targets MCAK at the microtubule plus ends"],"author-links":["[[Author/Kai Jiang]]","[[Author/Kai Jiang]]","[[Author/Yunlong Wang]]","[[Author/Jianyu Wang]]","[[Author/Jing Liu]]","[[Author/Jing Liu]]","[[Author/Tarsha Ward]]","[[Author/Tarsha Ward]]","[[Author/Linda Wordeman]]","[[Author/Linda Wordeman]]","[[Author/Alec J. Davidson]]","[[Author/Alec J. Davidson]]","[[Author/Fengsong Wang]]","[[Author/Fengsong Wang]]","[[Author/Xuebiao Yao]]","[[Author/Xuebiao Yao]]"],"attachment":["[[biblib/jiang_tip150_2009/jiang_tip150_2009.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"4j9qcw","at":1774951891331}},"smart_blocks:Research/@jiang_tip150_2009.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.10492121,-0.04206382,0.03206353,-0.0272034,-0.04578539,-0.0463512,0.03085282,0.02687825,0.02649336,0.04899307,0.03803552,-0.05454419,0.02236108,0.00978322,0.0393922,0.02366271,-0.06714104,0.05254423,-0.06529371,-0.01639816,-0.00266903,-0.03045292,-0.02747656,-0.06407486,0.01703735,0.0843685,-0.05047025,-0.02750408,-0.01834597,-0.27415437,0.02741961,0.0050986,-0.06596122,-0.0042498,-0.03499291,-0.05462228,-0.03542717,-0.01283708,-0.05522029,0.01468054,0.04705844,0.04333496,0.01840436,-0.05118678,0.02653278,-0.01809281,0.04350401,-0.02049876,0.00018017,-0.00510207,0.00303022,-0.01605195,0.0423055,0.02002695,0.03323956,0.07152058,0.05521314,0.01310391,-0.00193506,0.05077574,0.09302