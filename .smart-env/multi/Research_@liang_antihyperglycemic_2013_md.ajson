title":"BMC Complementary and Alternative Medicine","abstract":"Background Hericium erinaceus, as a commonly used medicine or food, has attracted much attention due to its health effects when used as a home remedy for some diseases. The aim of this work was to investigate the hypoglycemic and hypolipidemic effects of aqueous extract of Hericium erinaceus (AEHE) in streptozotocin (STZ)-induced diabetic rats.","tags":["#literature_note"],"author":[{"family":"Liang","given":"Bin","literal":""},{"family":"Liang","given":"Bin","literal":""},{"family":"Guo","given":"Zhiliang","literal":""},{"family":"Guo","given":"Zhengdong","literal":""},{"family":"Xie","given":"Fang","literal":""},{"family":"Xie","given":"Fang","literal":""},{"family":"Zhao","given":"Ainong","literal":""},{"family":"Zhao","given":"Ainong","literal":""}],"citation-key":"liang_antihyperglycemic_2013","year":"2013","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Antihyperglycemic and antihyperlipidemic activities of aqueous extract of Hericium erinaceus in experimental diabetic rats."],"author-links":["[[Author/Bin Liang]]","[[Author/Bin Liang]]","[[Author/Zhiliang Guo]]","[[Author/Zhengdong Guo]]","[[Author/Fang Xie]]","[[Author/Fang Xie]]","[[Author/Ainong Zhao]]","[[Author/Ainong Zhao]]"],"attachment":["[[biblib/liang_antihyperglycemic_2013/liang_antihyperglycemic_2013.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"b4egyu","at":1774951887194}},"smart_blocks:Research/@liang_antihyperglycemic_2013.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.00009114,-0.00482219,0.03193647,-0.01329511,0.00531225,-0.01486174,0.02294103,0.06237318,-0.07427554,-0.03203209,0.00360803,-0.08526977,0.02516604,-0.01209619,0.00541475,-0.02956572,-0.00856697,0.00134399,-0.12855126,-0.02391936,0.00557096,-0.05766744,0.00964091,0.00637827,0.037234,0.05394699,0.00197071,-0.01700199,-0.06500562,-0.19634673,-0.00764869,0.0540687