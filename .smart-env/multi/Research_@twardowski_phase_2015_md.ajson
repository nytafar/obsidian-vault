69,0.02220924,0.16048031,-0.01356409,-0.00561979,0.01171158,0.00956003,0.08449055,-0.01570641,0.02264936,-0.00870814,0.03202966,0.09279688,0.0067882,0.05500116,0.02006659,-0.06377329,0.0185131,-0.01705711,-0.0245145,0.02385052,-0.02635871,-0.06360722,-0.07643949,0.10978482,-0.10150204,-0.03249443,-0.03290537,-0.00535434,-0.02545473,-0.01223679,-0.04179849,0.02467056,0.060798,-0.03594776,-0.01912156,-0.02957351,-0.07045376,-0.00771998,-0.01839839,0.03023751,0.05306643,-0.08234468,0.05321153,-0.03377554],"last_embed":{"hash":"10ydcl7","tokens":432}}},"last_read":{"hash":"10ydcl7","at":1774951891387},"class_name":"SmartSource","last_import":{"mtime":1774951822411,"size":4743,"at":1774951884807,"hash":"10ydcl7"},"blocks":{"#---frontmatter---":[1,117],"#A phase I trial of mushroom powder in patients with biochemically recurrent prostate cancer: Roles of cytokines and myeloid-derived suppressor cells for Agaricus bisporus-induced prostate-specific antigen responses.":[119,123],"#A phase I trial of mushroom powder in patients with biochemically recurrent prostate cancer: Roles of cytokines and myeloid-derived suppressor cells for Agaricus bisporus-induced prostate-specific antigen responses.#{1}":[121,123]},"outlinks":[{"title":"Author/Przemyslaw Twardowski","target":"Author/Przemyslaw Twardowski","line":90},{"title":"Author/Przemyslaw Twardowski","target":"Author/Przemyslaw Twardowski","line":91},{"title":"Author/Noriko Kanaya","target":"Author/Noriko Kanaya","line":92},{"title":"Author/Noriko Kanaya","target":"Author/Noriko Kanaya","line":93},{"title":"Author/Paul Frankel","target":"Author/Paul Frankel","line":94},{"title":"Author/Paul Frankel","target":"Author/Paul Frankel","line":95},{"title":"Author/Timothy W. Synold","target":"Author/Timothy W. Synold","line":96},{"title":"Author/Timothy W. Synold","target":"Author/Timothy W. Synold","line":97},{"title":"Author/Christopher Ruel","target":"Author/Christopher Ruel","line":98},{"title":"Author/Christopher Ruel","target":"Author/Christopher Ruel","line":99},{"title":"Author/Sumanta K. Pal","target":"Author/Sumanta K. Pal","line":100},{"title":"Author/Sumanta K. Pal","target":"Author/Sumanta K. Pal","line":101},{"title":"Author/Maribel Junqueira","target":"Author/Maribel Junqueira","line":102},{"title":"Author/Maribel Junqueira","target":"Author/Maribel Junqueira","line":103},{"title":"Author/Manisha Prajapati","target":"Author/Manisha Prajapati","line":104},{"title":"Author/Manisha R. Prajapati","target":"Author/Manisha R. Prajapati","line":105},{"title":"Author/Tina Moore","target":"Author/Tina Moore","line":106},{"title":"Author/Tina Moore","target":"Author/Tina Moore","line":107},{"title":"Author/P. Tryon","target":"Author/P. Tryon","line":108},{"title":"Author/P. Tryon","target":"Author/P. Tryon","line":109},{"title":"Author/Pamela Renee Tryon","target":"Author/Pamela Renee Tryon","line":110},{"title":"Author/Shiuan Chen","target":"Author/Shiuan Chen","line":111},{"title":"Author/Shiuan Chen","target":"Author/Shiuan Chen","line":112},{"title":"PDF","target":"biblib/twardowski_phase_2015/twardowski_phase_2015.pdf","line":114}],"metadata":{"id":"twardowski_phase_2015","type":"article-journal","title":"A phase I trial of mushroom powder in patients with biochemically recurrent prostate cancer: Roles of cytokines and myeloid-derived suppressor cells for Agaricus bisporus-induced prostate-specific antigen responses.","issued":{"date-parts":[[2015]]},"DOI":"10.1002/cncr.29421","container-title":"Cancer","abstract":"BACKGROUND Each year in the United States, nearly 50,000 prostate cancer patients exhibit a rise in prostate-specific antigen (PSA) levels, which can indicate disease recurrence. For patients with biochemically recurrent prostate cancer, we evaluated the effects of white button mushroom (WBM) powder on serum PSA levels and determined the tolerability and biological activity of WBM. METHODS Patients with continuously rising PSA levels were enrolled in the study. Dose escalation was conducted in cohorts of 6; this ensured that no more than 1 patient per cohort experienced dose-limiting toxicity (DLT). The primary objective was to evaluate treatment feasibility and associated toxicity. The secondary objectives were to determine WBM's effect on serum PSA/androgen levels; myeloid-derived suppressor cells (MDSCs); and cytokine levels. RESULTS Thirty-six patients were treated; no DLTs were encountered. The overall PSA response rate was 11%. Two patients receiving 8 and 14 g/d demonstrated complete response (CR): their PSA declined to undetectable levels that continued for 49 and 30 months. Two patients who received 8 and 12 g/d experienced partial response (PR). After 3 months of therapy, 13 (36%) patients experienced some PSA decrease below baseline. Patients with CR and PR demonstrated higher levels of baseline interleukin-15 than nonresponders; for this group, we observed therapy-associated declines in MDSCs. CONCLUSIONS Therapy with WBM appears to both impact PSA levels and modulate the biology of biochemically recurrent prostate cancer by decreasing immunosuppressive factors. Cancer 2015;121:2942–2950. © 2015 American Cancer Society.","tags":["#literature_note"],"author":[{"family":"Twardowski","given":"Przemyslaw","literal":""},{"family":"Twardowski","given":"Przemyslaw","literal":""},{"family":"Kanaya","given":"Noriko","literal":""},{"family":"Kanaya","given":"Noriko","literal":""},{"family":"Frankel","given":"Paul","literal":""},{"family":"Frankel","given":"Paul","literal":""},{"family":"Synold","given":"Timothy W.","literal":""},{"family":"Synold","given":"Timothy W.","literal":""},{"family":"Ruel","given":"Christopher","literal":""},{"family":"Ruel","given":"Christopher","literal":""},{"family":"Pal","given":"Sumanta K.","literal":""},{"family":"Pal","given":"Sumanta K.","literal":""},{"family":"Junqueira","given":"Maribel","literal":""},{"family":"Junqueira","given":"Maribel","literal":""},{"family":"Prajapati","given":"Manisha","literal":""},{"family":"Prajapati","given":"Manisha R.","literal":""},{"family":"Moore","given":"Tina","literal":""},{"family":"Moore","given":"Tina","literal":""},{"family":"Tryon","given":"P.","literal":""},{"family":"Tryon","given":"P.","literal":""},{"family":"Tryon","given":"Pamela Renee","literal":""},{"family":"Chen","given":"Shiuan","literal":""},{"family":"Chen","given":"Shiuan","literal":""}],"citation-key":"twardowski_phase_2015","year":"2015","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["A phase I trial of mushroom powder in patients with biochemically recurrent prostate cancer: Roles of cytokines and myeloid-derived suppressor cells for Agaricus bisporus-induced prostate-specific antigen responses."],"author-links":["[[Author/Przemyslaw Twardowski]]","[[Author/Przemyslaw Twardowski]]","[[Author/Noriko Kanaya]]","[[Author/Noriko Kanaya]]","[[Author/Paul Frankel]]","[[Author/Paul Frankel]]","[[Author/Timothy W. Synold]]","[[Author/Timothy W. Synold]]","[[Author/Christopher Ruel]]","[[Author/Christopher Ruel]]","[[Author/Sumanta K. Pal]]","[[Author/Sumanta K. Pal]]","[[Author/Maribel Junqueira]]","[[Author/Maribel Junqueira]]","[[Author/Manisha Prajapati]]","[[Author/Manisha R. Prajapati]]","[[Author/Tina Moore]]","[[Author/Tina Moore]]","[[Author/P. Tryon]]","[[Author/P. Tryon]]","[[Author/Pamela Renee Tryon]]","[[Author/Shiuan Chen]]","[[Author/Shiuan Chen]]"],"attachment":["[[biblib/twardowski_phase_2015/twardowski_phase_2015.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"10ydcl7","at":1774951891370}},"smart_blocks:Research/@twardowski_phase_2015.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.05010261,-0.03845786,0.02276269,-0.06884748,-0.03862638,0.00639213,0.03548527,0.05670807,-0.02549636,-0.01133901,0.03510993,-0.0602663,0.02277149,0.04699983,-0.03258327,0.0576464,0.03234958,0.01436696,-0.05229231,0.00489413,0.00307039,-0.07052454,0.0372273