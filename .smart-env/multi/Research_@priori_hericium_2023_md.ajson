619,0.00069984,0.15422262,0.0505215,-0.00305495,0.01054524,0.02820068,0.01971619,0.04758916,0.01420051,0.01344494,0.00462334,0.11775821,-0.00154936,0.08722363,0.04002126,-0.07412519,-0.0570185,0.02593467,-0.0046618,0.02512523,0.02370249,-0.05279382,-0.04076915,0.08507587,-0.05497799,0.01679632,-0.04499796,-0.05724749,-0.00779253,-0.03423778,-0.01266129,0.03123678,-0.01278192,0.00081764,-0.00874869,0.00860475,-0.02936953,-0.03159272,-0.02413295,0.00665634,-0.02118504,-0.08458133,0.12800862,-0.0131539],"last_embed":{"hash":"18vqy2e","tokens":424}}},"last_read":{"hash":"18vqy2e","at":1774951893337},"class_name":"SmartSource","last_import":{"mtime":1774951825925,"size":3069,"at":1774951884819,"hash":"18vqy2e"},"blocks":{"#---frontmatter---":[1,65],"#Hericium erinaceus Extract Exerts Beneficial Effects on Gut-Neuroinflammaging-Cognitive Axis in Elderly Mice.":[67,71],"#Hericium erinaceus Extract Exerts Beneficial Effects on Gut-Neuroinflammaging-Cognitive Axis in Elderly Mice.#{1}":[69,71]},"outlinks":[{"title":"Author/E. C. Priori","target":"Author/E. C. Priori","line":51},{"title":"Author/D. Ratto","target":"Author/D. Ratto","line":52},{"title":"Author/F. Luca De","target":"Author/F. Luca De","line":53},{"title":"Author/A. Sandionigi","target":"Author/A. Sandionigi","line":54},{"title":"Author/E. Savino","target":"Author/E. Savino","line":55},{"title":"Author/F. Giammello","target":"Author/F. Giammello","line":56},{"title":"Author/M. Romeo","target":"Author/M. Romeo","line":57},{"title":"Author/F. Brandalise","target":"Author/F. Brandalise","line":58},{"title":"Author/E. Roda","target":"Author/E. Roda","line":59},{"title":"Author/P. Rossi","target":"Author/P. Rossi","line":60},{"title":"PDF","target":"biblib/priori_hericium_2023/priori_hericium_2023.pdf","line":62}],"metadata":{"id":"priori_hericium_2023","type":"article-journal","title":"Hericium erinaceus Extract Exerts Beneficial Effects on Gut-Neuroinflammaging-Cognitive Axis in Elderly Mice.","issued":{"date-parts":[[2023]]},"DOI":"10.3390/biology13010018","container-title":"Biology","abstract":"Ageing is a biological phenomenon that determines the impairment of cognitive performances, in particular, affecting memory. Inflammation and cellular senescence are known to be involved in the pathogenesis of cognitive decline. The gut microbiota-brain axis could exert a critical role in influencing brain homeostasis during ageing, modulating neuroinflammation, and possibly leading to inflammaging. Due to their anti-ageing properties, medicinal mushrooms can be utilised as a resource for developing pharmaceuticals and functional foods. Specifically, Hericium erinaceus (He), thanks to its bioactive metabolites, exerts numerous healthy beneficial effects, such as reinforcing the immune system, counteracting ageing, and improving cognitive performance. Our previous works demonstrated the capabilities of two months of He1 standardised extract oral supplementation in preventing cognitive decline in elderly frail mice. Herein, we showed that this treatment did not change the overall gut microbiome composition but significantly modified the relative abundance of genera specifically involved in cognition and inflammation. Parallelly, a significant decrease in crucial markers of inflammation and cellular senescence, i.e., CD45, GFAP, IL6, p62, and γH2AX, was demonstrated in the dentate gyrus and Cornus Ammonis hippocampal areas through immunohistochemical experiments. In summary, we suggested beneficial and anti-inflammatory properties of He1 in mouse hippocampus through the gut microbiome-brain axis modulation.","tags":["#literature_note"],"author":[{"family":"Priori","given":"E. C.","literal":""},{"family":"Ratto","given":"D.","literal":""},{"family":"De","given":"F. Luca","literal":""},{"family":"Sandionigi","given":"A.","literal":""},{"family":"Savino","given":"E.","literal":""},{"family":"Giammello","given":"F.","literal":""},{"family":"Romeo","given":"M.","literal":""},{"family":"Brandalise","given":"F.","literal":""},{"family":"Roda","given":"E.","literal":""},{"family":"Rossi","given":"P.","literal":""}],"citation-key":"priori_hericium_2023","year":"2023","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Hericium erinaceus Extract Exerts Beneficial Effects on Gut-Neuroinflammaging-Cognitive Axis in Elderly Mice."],"author-links":["[[Author/E. C. Priori]]","[[Author/D. Ratto]]","[[Author/F. Luca De]]","[[Author/A. Sandionigi]]","[[Author/E. Savino]]","[[Author/F. Giammello]]","[[Author/M. Romeo]]","[[Author/F. Brandalise]]","[[Author/E. Roda]]","[[Author/P. Rossi]]"],"attachment":["[[biblib/priori_hericium_2023/priori_hericium_2023.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"18vqy2e","at":1774951893329}},"smart_blocks:Research/@priori_hericium_2023.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.00663262,-0.02985618,0.03350244,-0.00698366,-0.00860827,0.05921363,-0.02055875,0.02651133,-0.04802626,-0.0336828,-0.00255051,-0.05077348,0.03024641,0.02998993,0.01243818,0.02006756,-0.02558283,0.04654057,-0.10900237,-0.03556354,-0.01116659,-0.04610891,0.01788046,0.03815808,0.01354922,0.04925754,-0.03493261,-0.02005585,-0.09077277,-0.22029792,-0.00334624,-0.02539374,0.0407769,-0.03263116,-0.05612519,0.02155409,0.00333401,0.03797228,-0.01843346,0.01507824,0.09726132,0.06694689,0.01771069,-0.00243686,-0.01065652,-0.05796712,-0.04227549,-0.06464384,0.0158517,0.00116255,-0.01481404,-0.05831448,-0.01554761,0.08277458,0.03073508,0.03937176,-0.03191756,0.03772308,0.02213372,0.06822292,0.06006287,0.0083161,-0.17183071,0.07954225,0.03164415,-0.04090881,-0.04110654,-0.02225419,0.04802443,0.00275602,-0.09903494,0.0324236,0.05319893,0.06124439,0.05057929,0.01725104,-0.0011684,-0.06722151,0.03786335,0.00984313,0.07181209,0.13585573,-0.00368123,0.00953317,0.00110341,-0.05230884,-0.05025309,-0.09603297,0.01290183,-0.00102964,-0.00853141,0.00020439,-0.03291721,0.02