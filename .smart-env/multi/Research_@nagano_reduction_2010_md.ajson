31,0.00153935,0.16999555,0.01813017,-0.07474032,0.02498824,-0.0006532,0.0149692,0.00425205,0.01819751,0.00992027,0.00881561,0.09801821,-0.01898761,0.06074853,0.00098683,-0.12430029,0.00805225,0.01892884,-0.00420241,-0.03490213,-0.00357466,-0.024962,-0.08660973,0.12547025,-0.03400662,-0.05092248,-0.00079757,0.01298817,0.03242718,0.04180345,0.03825469,0.02721723,0.01547323,0.03334677,-0.00405075,-0.01123675,-0.00700521,0.00553637,0.01120295,0.01013001,-0.03300393,-0.07449611,0.09469382,0.02002425],"last_embed":{"hash":"1er5y4c","tokens":460}}},"last_read":{"hash":"1er5y4c","at":1774951893615},"class_name":"SmartSource","last_import":{"mtime":1774951826405,"size":3132,"at":1774951884821,"hash":"1er5y4c"},"blocks":{"#---frontmatter---":[1,80],"#Reduction of depression and anxiety by 4 weeks Hericium erinaceus intake.":[82,86],"#Reduction of depression and anxiety by 4 weeks Hericium erinaceus intake.#{1}":[84,86]},"outlinks":[{"title":"Author/Mayumi Nagano","target":"Author/Mayumi Nagano","line":63},{"title":"Author/Mayumi Nagano","target":"Author/Mayumi Nagano","line":64},{"title":"Author/Kuniyoshi Shimizu","target":"Author/Kuniyoshi Shimizu","line":65},{"title":"Author/Kuniyoshi Shimizu","target":"Author/Kuniyoshi Shimizu","line":66},{"title":"Author/Ryuichiro Kondo","target":"Author/Ryuichiro Kondo","line":67},{"title":"Author/Ryuichiro Kondo","target":"Author/Ryuichiro Kondo","line":68},{"title":"Author/Chickako Hayashi","target":"Author/Chickako Hayashi","line":69},{"title":"Author/Chickako Hayashi","target":"Author/Chickako Hayashi","line":70},{"title":"Author/Daisuke Sato","target":"Author/Daisuke Sato","line":71},{"title":"Author/Daigo Sato","target":"Author/Daigo Sato","line":72},{"title":"Author/Katsuyuki Kitagawa","target":"Author/Katsuyuki Kitagawa","line":73},{"title":"Author/Katsuyuki Kitagawa","target":"Author/Katsuyuki Kitagawa","line":74},{"title":"Author/Koichiro Ohnuki","target":"Author/Koichiro Ohnuki","line":75},{"title":"Author/Koichiro Ohnuki","target":"Author/Koichiro Ohnuki","line":76}],"metadata":{"id":"nagano_reduction_2010","type":"article-journal","title":"Reduction of depression and anxiety by 4 weeks Hericium erinaceus intake.","issued":{"date-parts":[[2010]]},"DOI":"10.2220/biomedres.31.231","container-title":"Biomedical Research-tokyo","abstract":"Hericium erinaceus, a well known edible mashroom, has numerous biological activities. Especially hericenones and erinacines isolated from its fruiting body stimulate nerve growth factor (NGF) synthesis, which expects H. erinaceus to have some effects on brain functions and autonomic nervous system. Herein, we investigated the clinical effects of H. erinaceus on menopause, depression, sleep quality and indefinite complaints, using the Kupperman Menopausal Index (KMI), the Center for Epidemiologic Studies Depression Scale (CES-D), the Pittsburgh Sleep Quality Index (PSQI), and the Indefinite Complaints Index (ICI). Thirty females were randomly assigned to either the H. erinaceus (HE) group or the placebo group and took HE cookies or placebo cookies for 4 weeks. Each of the CES-D and the ICI score after the HE intake was significantly lower than that before. In two terms of the ICI, “insentive” and “palpitatio”, each of the mean score of the HE group was significantly lower than the placebo group. “Concentration”, “irritating” and “anxious” tended to be lower than the placebo group. Our results show that HE intake has the possibility to reduce depression and anxiety and these results suggest a different mechanism from NGF-enhancing action of H. erinaceus.","tags":["#literature_note"],"author":[{"family":"Nagano","given":"Mayumi","literal":""},{"family":"Nagano","given":"Mayumi","literal":""},{"family":"Shimizu","given":"Kuniyoshi","literal":""},{"family":"Shimizu","given":"Kuniyoshi","literal":""},{"family":"Kondo","given":"Ryuichiro","literal":""},{"family":"Kondo","given":"Ryuichiro","literal":""},{"family":"Hayashi","given":"Chickako","literal":""},{"family":"Hayashi","given":"Chickako","literal":""},{"family":"Sato","given":"Daisuke","literal":""},{"family":"Sato","given":"Daigo","literal":""},{"family":"Kitagawa","given":"Katsuyuki","literal":""},{"family":"Kitagawa","given":"Katsuyuki","literal":""},{"family":"Ohnuki","given":"Koichiro","literal":""},{"family":"Ohnuki","given":"Koichiro","literal":""}],"citation-key":"nagano_reduction_2010","year":"2010","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Reduction of depression and anxiety by 4 weeks Hericium erinaceus intake."],"author-links":["[[Author/Mayumi Nagano]]","[[Author/Mayumi Nagano]]","[[Author/Kuniyoshi Shimizu]]","[[Author/Kuniyoshi Shimizu]]","[[Author/Ryuichiro Kondo]]","[[Author/Ryuichiro Kondo]]","[[Author/Chickako Hayashi]]","[[Author/Chickako Hayashi]]","[[Author/Daisuke Sato]]","[[Author/Daigo Sato]]","[[Author/Katsuyuki Kitagawa]]","[[Author/Katsuyuki Kitagawa]]","[[Author/Koichiro Ohnuki]]","[[Author/Koichiro Ohnuki]]"],"attachment":[],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"1er5y4c","at":1774951893606}},"smart_blocks:Research/@nagano_reduction_2010.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.01283658,0.04977201,0.005577,0.0120611,0.01338742,0.05645019,0.01960787,0.04343951,-0.03536568,-0.0376453,-0.00462489,-0.03793449,0.07688081,0.05661565,0.00814158,-0.04847853,0.00076145,-0.00372746,-0.12127979,0.00237655,0.00021025,-0.0529548,0.05343441,-0.00175322,0.02569975,0.00584514,-0.02134564,-0.01074891,-0.05671598,-0.19683814,0.01324592,-0.04065106,0.08245423,-0.00654625,-0.00411036,0.02773474,-0.04042965,0.04666043,-0.02509913,0.05181308,0.11404975,0.02289925,0.04606029,0.01454275,0.01144529,-0.02984406,-0.03011877,-0.02701198,0.00810441,0.01237737,-0.01805611,-0.03206365,0.02561942,0.06599061,0.05299002,0.01256814,0.00601533,0.03813543,0.0114804,0.08250128,0.03042662,0.07863092,-0.21441782,0.03688425,0.08431055,-0.05354833,-0.08744274,-0.04