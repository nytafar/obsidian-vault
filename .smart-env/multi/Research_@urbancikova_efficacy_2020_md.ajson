6647,-0.00489044,0.00623543,0.15073168,-0.03903991,-0.01386316,0.03446513,-0.06691892,0.01222214,0.00502927,0.05595577,-0.01331349,-0.04636625,0.07857104,-0.0317146,0.10220755,0.10492398,-0.0660181,-0.00906537,0.02503894,0.00474433,-0.00090651,0.02040555,-0.03913942,-0.00253414,0.08869769,-0.05933585,-0.02423571,-0.01738231,-0.02899586,0.00342954,-0.01895998,-0.04643544,0.0723521,0.04669737,-0.01857057,-0.03214003,0.0354578,0.02279251,-0.01647643,-0.02835319,-0.00323604,-0.02933578,-0.02330959,0.09972112,0.06156658],"last_embed":{"hash":"1140u14","tokens":433}}},"last_read":{"hash":"1140u14","at":1774951885406},"class_name":"SmartSource","last_import":{"mtime":1774951813878,"size":3551,"at":1774951884759,"hash":"1140u14"},"blocks":{"#---frontmatter---":[1,73],"#Efficacy of Pleuran (β-Glucan from Pleurotus ostreatus) in the Management of Herpes Simplex Virus Type 1 Infection.":[75,79],"#Efficacy of Pleuran (β-Glucan from Pleurotus ostreatus) in the Management of Herpes Simplex Virus Type 1 Infection.#{1}":[77,79]},"outlinks":[{"title":"Author/Ingrid Urbančíková","target":"Author/Ingrid Urbančíková","line":57},{"title":"Author/Ingrid Urbancikova","target":"Author/Ingrid Urbancikova","line":58},{"title":"Author/Dana Hudackova","target":"Author/Dana Hudackova","line":59},{"title":"Author/Dana Hudackova","target":"Author/Dana Hudackova","line":60},{"title":"Author/Juraj Majtán","target":"Author/Juraj Majtán","line":61},{"title":"Author/Juraj Majtan","target":"Author/Juraj Majtan","line":62},{"title":"Author/Zuzana Rennerova","target":"Author/Zuzana Rennerova","line":63},{"title":"Author/Zuzana Rennerova","target":"Author/Zuzana Rennerova","line":64},{"title":"Author/Peter Bánovčin","target":"Author/Peter Bánovčin","line":65},{"title":"Author/Peter Banovcin","target":"Author/Peter Banovcin","line":66},{"title":"Author/Miloš Jeseňák","target":"Author/Miloš Jeseňák","line":67},{"title":"Author/Milos Jesenak","target":"Author/Milos Jesenak","line":68},{"title":"PDF","target":"biblib/urbancikova_efficacy_2020/urbancikova_efficacy_2020.pdf","line":70}],"metadata":{"id":"urbancikova_efficacy_2020","type":"article-journal","title":"Efficacy of Pleuran (β-Glucan from Pleurotus ostreatus) in the Management of Herpes Simplex Virus Type 1 Infection.","issued":{"date-parts":[[2020]]},"DOI":"10.1155/2020/8562309","container-title":"Evidence-based Complementary and Alternative Medicine","abstract":"One of the highly prevalent viral pathogens among children and adults causing infection, clinically presenting as herpes labialis, is herpes simplex virus type 1 (HSV-1). The long-term administration of acyclovir, a standard regimen for therapy against HSV-1 infections, can cause viral resistance against this drug. Therefore, the development of natural drugs with low toxicity that are able to enhance host antiviral defense against HSV infection is needed. β-Glucans represent a type of biologically active molecules possessing antiviral properties. The goal of this study was to investigate the clinical and immunomodulatory effect of β-glucan pleuran (insoluble β-1,3/1,6-D-glucan isolated from Pleurotus ostreatus) based supplements on the duration and intensity of herpes symptoms and on the incidence rate and duration of acute respiratory symptoms and intercurrent diseases in HSV-1 positive patients. Ninety patients were randomised into active and placebo groups. Active treatment with pleuran in systemic application caused a significantly shorter duration of herpes simplex symptoms compared to the placebo group. During the preventive phase (120 days), the duration and severity of respiratory symptoms were lower in the active group compared to the placebo group; however, a significant difference was found only in the case of cough. No significant side effects were observed during both phases of the clinical trial (acute and preventive). Obtained results suggest that the use of pleuran seems to be a promising approach in the treatment of acute HSV-1 with beneficial effect on the respiratory tract symptoms and infections.","tags":["#literature_note"],"author":[{"family":"Urbančíková","given":"Ingrid","literal":""},{"family":"Urbancikova","given":"Ingrid","literal":""},{"family":"Hudackova","given":"Dana","literal":""},{"family":"Hudackova","given":"Dana","literal":""},{"family":"Majtán","given":"Juraj","literal":""},{"family":"Majtan","given":"Juraj","literal":""},{"family":"Rennerova","given":"Zuzana","literal":""},{"family":"Rennerova","given":"Zuzana","literal":""},{"family":"Bánovčin","given":"Peter","literal":""},{"family":"Banovcin","given":"Peter","literal":""},{"family":"Jeseňák","given":"Miloš","literal":""},{"family":"Jesenak","given":"Milos","literal":""}],"citation-key":"urbancikova_efficacy_2020","year":"2020","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Efficacy of Pleuran (β-Glucan from Pleurotus ostreatus) in the Management of Herpes Simplex Virus Type 1 Infection."],"author-links":["[[Author/Ingrid Urbančíková]]","[[Author/Ingrid Urbancikova]]","[[Author/Dana Hudackova]]","[[Author/Dana Hudackova]]","[[Author/Juraj Majtán]]","[[Author/Juraj Majtan]]","[[Author/Zuzana Rennerova]]","[[Author/Zuzana Rennerova]]","[[Author/Peter Bánovčin]]","[[Author/Peter Banovcin]]","[[Author/Miloš Jeseňák]]","[[Author/Milos Jesenak]]"],"attachment":["[[biblib/urbancikova_efficacy_2020/urbancikova_efficacy_2020.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"1140u14","at":1774951885397}},"smart_blocks:Research/@urbancikova_efficacy_2020.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[0.01978165,-0.00956719,0.03013476,-0.02462732,-0.02729568,-0.01269129,0.00711161,0.05766035,-0.03117772,-0.02208753,0.01791953,-0.07284524,0.02441846,0.02037048,-0.01229017,-0.02572553,0.04273317,-0.00686156,-0.06881172,0.01470577,-0.04532701,-0.0568772,-0.00278914,-0.04561326,0.08283906,0.01456302,0.00854214,0.01297977,-0.05001063,-0.22