
"smart_sources:Research/@rubel_immunomodulatory_2018.md": {"path":"Research/@rubel_immunomodulatory_2018.md","last_embed":{"hash":null},"embeddings":{},"last_read":{"hash":"1wj4e20","at":1774951884835},"class_name":"SmartSource","last_import":{"mtime":1774951830058,"size":3246,"at":1774951884835,"hash":"1wj4e20"},"blocks":{"#---frontmatter---":[1,76],"#Immunomodulatory and Antitumoral Properties of Ganoderma lucidum and Agaricus brasiliensis (Agaricomycetes) Medicinal Mushrooms.":[78,82],"#Immunomodulatory and Antitumoral Properties of Ganoderma lucidum and Agaricus brasiliensis (Agaricomycetes) Medicinal Mushrooms.#{1}":[80,82]},"outlinks":[{"title":"Author/Rosália Rubel","target":"Author/Rosália Rubel","line":60},{"title":"Author/Rosália Rubel","target":"Author/Rosália Rubel","line":61},{"title":"Author/Herta Stutz Dalla Santa","target":"Author/Herta Stutz Dalla Santa","line":62},{"title":"Author/Herta Stutz Dalla Santa","target":"Author/Herta Stutz Dalla Santa","line":63},{"title":"Author/Leandro Freire dos Santos","target":"Author/Leandro Freire dos Santos","line":64},{"title":"Author/Leandro Freire dos Santos","target":"Author/Leandro Freire dos Santos","line":65},{"title":"Author/Luíz Cláudio Fernandes","target":"Author/Luíz Cláudio Fernandes","line":66},{"title":"Author/Luiz Claudio Fernandes","target":"Author/Luiz Claudio Fernandes","line":67},{"title":"Author/Bonald C. Figueiredo","target":"Author/Bonald C. Figueiredo","line":68},{"title":"Author/Bonald C. Figueiredo","target":"Author/Bonald C. Figueiredo","line":69},{"title":"Author/Bonald Cavalcante Figueiredo","target":"Author/Bonald Cavalcante Figueiredo","line":70},{"title":"Author/Carlos Ricardo Soccol","target":"Author/Carlos Ricardo Soccol","line":71},{"title":"Author/Carlos Ricardo Soccol","target":"Author/Carlos Ricardo Soccol","line":72}],"metadata":{"id":"rubel_immunomodulatory_2018","type":"article-journal","title":"Immunomodulatory and Antitumoral Properties of Ganoderma lucidum and Agaricus brasiliensis (Agaricomycetes) Medicinal Mushrooms.","issued":{"date-parts":[[2018]]},"DOI":"10.1615/intjmedmushrooms.2018025979","container-title":"International Journal of Medicinal Mushrooms","abstract":"Medicinal mushrooms are used in popular medicine largely as health promoters, mainly because of their antitumor and immunomodulatory activities. Ganoderma lucidum (lingzhi or reishi) and Agaricus brasiliensis are mushrooms that have long been used for medicinal purposes. This study evaluated their immunomodulatory and antitumor effects on mice fed a diet supplemented with G. lucidum and A. brasiliensis mycelia obtained from solid-state fermentation. For 14 weeks the mice were fed chow containing 50% A. brasiliensis and G. lucidum mycelia, using ground wheat as an excipient. The consumption of the supplemented diet inhibited Sarcoma 180 tumor growth and caused important changes in the immune system. The pattern of immune response shifted, increasing CD4+ and CD8+ and decreasing CD19+ cell populations. The restoration of a proper balance between cellular and humoral immunity is an essential process for restraining tumor growth. These results suggest that polysaccharides, such as β-glucans and other mushroom metabolites, possibly promote the T-cell dominance that is imperative to restrain tumor growth.","tags":["#literature_note"],"author":[{"family":"Rubel","given":"Rosália","literal":""},{"family":"Rubel","given":"Rosália","literal":""},{"family":"Santa","given":"Herta Stutz Dalla","literal":""},{"family":"Santa","given":"Herta Stutz Dalla","literal":""},{"family":"Santos","given":"Leandro Freire dos","literal":""},{"family":"Santos","given":"Leandro Freire dos","literal":""},{"family":"Fernandes","given":"Luíz Cláudio","literal":""},{"family":"Fernandes","given":"Luiz Claudio","literal":""},{"family":"Figueiredo","given":"Bonald C.","literal":""},{"family":"Figueiredo","given":"Bonald C.","literal":""},{"family":"Figueiredo","given":"Bonald Cavalcante","literal":""},{"family":"Soccol","given":"Carlos Ricardo","literal":""},{"family":"Soccol","given":"Carlos Ricardo","literal":""}],"citation-key":"rubel_immunomodulatory_2018","year":"2018","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Immunomodulatory and Antitumoral Properties of Ganoderma lucidum and Agaricus brasiliensis (Agaricomycetes) Medicinal Mushrooms."],"author-links":["[[Author/Rosália Rubel]]","[[Author/Rosália Rubel]]","[[Author/Herta Stutz Dalla Santa]]","[[Author/Herta Stutz Dalla Santa]]","[[Author/Leandro Freire dos Santos]]","[[Author/Leandro Freire dos Santos]]","[[Author/Luíz Cláudio Fernandes]]","[[Author/Luiz Claudio Fernandes]]","[[Author/Bonald C. Figueiredo]]","[[Author/Bonald C. Figueiredo]]","[[Author/Bonald Cavalcante Figueiredo]]","[[Author/Carlos Ricardo Soccol]]","[[Author/Carlos Ricardo Soccol]]"],"attachment":[],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[]},
