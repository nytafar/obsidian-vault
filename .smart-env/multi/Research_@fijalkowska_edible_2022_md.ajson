62169,0.01743452,0.0356011,0.18071865,-0.022631,-0.03612786,-0.00396045,-0.00372863,0.03160021,0.00779095,0.01165657,0.04588231,0.03683947,0.13083676,-0.00613251,0.05180544,0.0327923,-0.07143654,-0.01607338,0.00141819,0.01023902,0.02129296,-0.03550677,-0.04493327,-0.02205552,0.08775865,-0.0267863,-0.00710987,-0.05320694,-0.05476993,0.02651674,0.03489826,0.00548193,0.03545646,0.02905559,-0.03145709,-0.03421501,0.02854948,-0.00219724,-0.02988496,-0.04014778,0.01704736,0.01726461,-0.08964294,0.12790225,0.01610834],"last_embed":{"hash":"j7gcjb","tokens":451}}},"last_read":{"hash":"j7gcjb","at":1774951888261},"class_name":"SmartSource","last_import":{"mtime":1774951818476,"size":3296,"at":1774951884788,"hash":"j7gcjb"},"blocks":{"#---frontmatter---":[1,73],"#Edible Mushrooms as a Potential Component of Dietary Interventions for Major Depressive Disorder":[75,79],"#Edible Mushrooms as a Potential Component of Dietary Interventions for Major Depressive Disorder#{1}":[77,79]},"outlinks":[{"title":"Author/Agata Fijałkowska","target":"Author/Agata Fijałkowska","line":57},{"title":"Author/Agata Fijałkowska","target":"Author/Agata Fijałkowska","line":58},{"title":"Author/Karol Jędrejko","target":"Author/Karol Jędrejko","line":59},{"title":"Author/Karol Jędrejko","target":"Author/Karol Jędrejko","line":60},{"title":"Author/Katarzyna Sułkowska-Ziaja","target":"Author/Katarzyna Sułkowska-Ziaja","line":61},{"title":"Author/Katarzyna Sułkowska-Ziaja","target":"Author/Katarzyna Sułkowska-Ziaja","line":62},{"title":"Author/Marek Ziaja","target":"Author/Marek Ziaja","line":63},{"title":"Author/Marek Ziaja","target":"Author/Marek Ziaja","line":64},{"title":"Author/Katarzyna Kała","target":"Author/Katarzyna Kała","line":65},{"title":"Author/Katarzyna Kała","target":"Author/Katarzyna Kała","line":66},{"title":"Author/Bożena Muszyńska","target":"Author/Bożena Muszyńska","line":67},{"title":"Author/Bożena Muszyńska","target":"Author/Bożena Muszyńska","line":68},{"title":"PDF","target":"biblib/fijalkowska_edible_2022/fijalkowska_edible_2022.pdf","line":70}],"metadata":{"id":"fijalkowska_edible_2022","type":"article-journal","title":"Edible Mushrooms as a Potential Component of Dietary Interventions for Major Depressive Disorder","issued":{"date-parts":[[2022]]},"DOI":"10.3390/foods11101489","container-title":"Foods","abstract":"Dietary interventions for people suffering from major depressive disorder (MDD) are an ongoing field of research. In this article, we present a comprehensive background for understanding the possibility of using edible medicinal mushrooms as an adjunctive treatment for MDD. We start with a brief history of MDD, its diagnosis, epidemiology and treatment, and the effects of diet on depression symptoms, followed by a review of neurobiological, behavioral, and clinical studies of medicinal mushrooms. We specifically highlight the results of preclinical and clinical studies on dietary supplementation with three selected mushroom species: Lion’s mane (Hericium erinaceus), Caterpillar mushroom (Cordyceps militaris), and Lingzhi/Reishi (Ganoderma lucidum). Preliminary small-sample clinical studies suggest that Lion’s mane can influence well-being of humans. In the case of Reishi, the results of clinical studies are equivocal, while in the case of Caterpillar Mushroom, such studies are underway. Edible mushrooms contain 5-hydroxy-L-tryptophan (5-HTP), which is a direct precursor of serotonin—a neurotransmitter targeted in pharmacotherapy of MDD. Therefore, in light of the well-recognized role of stress as a pathogenic factor of MDD, we also describe the neurobiological mechanisms of the interaction between stress and serotonergic neurotransmission; and summarize the current state of knowledge on dietary supplementation with 5-HTP in MDD.","tags":["#literature_note"],"author":[{"family":"Fijałkowska","given":"Agata","literal":""},{"family":"Fijałkowska","given":"Agata","literal":""},{"family":"Jędrejko","given":"Karol","literal":""},{"family":"Jędrejko","given":"Karol","literal":""},{"family":"Sułkowska-Ziaja","given":"Katarzyna","literal":""},{"family":"Sułkowska-Ziaja","given":"Katarzyna","literal":""},{"family":"Ziaja","given":"Marek","literal":""},{"family":"Ziaja","given":"Marek","literal":""},{"family":"Kała","given":"Katarzyna","literal":""},{"family":"Kała","given":"Katarzyna","literal":""},{"family":"Muszyńska","given":"Bożena","literal":""},{"family":"Muszyńska","given":"Bożena","literal":""}],"citation-key":"fijalkowska_edible_2022","year":"2022","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Edible Mushrooms as a Potential Component of Dietary Interventions for Major Depressive Disorder"],"author-links":["[[Author/Agata Fijałkowska]]","[[Author/Agata Fijałkowska]]","[[Author/Karol Jędrejko]]","[[Author/Karol Jędrejko]]","[[Author/Katarzyna Sułkowska-Ziaja]]","[[Author/Katarzyna Sułkowska-Ziaja]]","[[Author/Marek Ziaja]]","[[Author/Marek Ziaja]]","[[Author/Katarzyna Kała]]","[[Author/Katarzyna Kała]]","[[Author/Bożena Muszyńska]]","[[Author/Bożena Muszyńska]]"],"attachment":["[[biblib/fijalkowska_edible_2022/fijalkowska_edible_2022.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"j7gcjb","at":1774951888250}},"smart_blocks:Research/@fijalkowska_edible_2022.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.00061448,0.00694334,0.03291091,-0.01137582,0.00247969,0.04145508,0.00723183,0.02601072,-0.0417125,-0.00906094,0.03664954,-0.05770524,0.04392722,0.00272237,0.06461093,0.01145854,0.0449262,0.01059914,-0.09340547,-0.00357074,0.02353262,-0.00478221,0.01464278,-0.02987891,0.03254284,0.06447268,-0.02626066,-0.0323634,-0.05307071,-0.18131781,0.02158454,0.00218009,0.03159789,-0.04392509,-0.02770931,0.01138072,-0.01247049,0.00507606,-0.01478481,0.04950355,0.07835091,0.01458564,-0.01209433,0.03613988,-0.01651504,-0.08113113,-0.06428197,-0.06573578,0.02310588,-0.05161925,-0.03094364,-0.0559883,0.0