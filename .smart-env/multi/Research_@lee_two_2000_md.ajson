uma","given":"Takahiro","literal":""},{"family":"Inakuma","given":"Takahiro","literal":""},{"family":"Li","given":"Jingxuan","literal":""},{"family":"Li","given":"Jingxuan","literal":""},{"family":"Li","given":"Jingxuan","literal":""},{"family":"Ohnishi‐Kameyama","given":"Mayumi","literal":""},{"family":"Ohnishi-Kameyama","given":"Mayumi","literal":""},{"family":"Nagata","given":"Takayuki","literal":""},{"family":"Nagata","given":"Tadahiro","literal":""},{"family":"Furukawa","given":"Shoei","literal":""},{"family":"Furukawa","given":"Shoei","literal":""},{"family":"Kawagishi","given":"Hirokazu","literal":""},{"family":"Kawagishi","given":"Hirokazu","literal":""},{"family":"Kawagishi","given":"Hirokazu","literal":""}],"citation-key":"lee_two_2000","year":"2000","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Two Novel Diterpenoids, Erinacines H and I from the Mycelia of Hericium erinaceum"],"author-links":["[[Author/Eun Woo Lee]]","[[Author/Eun Woo Lee]]","[[Author/Kazue Shizuki]]","[[Author/Kazue Shizuki]]","[[Author/Satoshi Hosokawa]]","[[Author/Satoshi Hosokawa]]","[[Author/Masami Suzuki]]","[[Author/Masami Suzuki]]","[[Author/Hiroyuki Suganuma]]","[[Author/Hiroyuki Suganuma]]","[[Author/Takahiro Inakuma]]","[[Author/Takahiro Inakuma]]","[[Author/Jingxuan Li]]","[[Author/Jingxuan Li]]","[[Author/Jingxuan Li]]","[[Author/Mayumi Ohnishi‐Kameyama]]","[[Author/Mayumi Ohnishi-Kameyama]]","[[Author/Takayuki Nagata]]","[[Author/Tadahiro Nagata]]","[[Author/Shoei Furukawa]]","[[Author/Shoei Furukawa]]","[[Author/Hirokazu Kawagishi]]","[[Author/Hirokazu Kawagishi]]","[[Author/Hirokazu Kawagishi]]"],"attachment":[],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"l8llwg","at":1774951887245}},"smart_blocks:Research/@lee_two_2000.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.04884622,0.00655388,-0.0197609,-0.02863313,0.01471119,0.0049485,-0.0214437,0.04576798,-0.02087184,-0.01215343