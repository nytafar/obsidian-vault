00846,0.18451279,-0.00630678,0.02645029,-0.01287465,-0.01494502,-0.00616325,0.02157956,0.01774866,-0.03143801,0.01382571,0.09411307,0.01843338,0.06470234,0.04107204,-0.06932582,0.00005642,-0.01861575,-0.00691832,0.04349278,0.03018051,-0.12211256,0.00954519,0.1040981,-0.04369045,-0.05338984,-0.03726101,-0.03342549,-0.01149636,-0.0327977,-0.06931332,0.03250783,0.02732001,-0.00992629,0.023074,-0.01426716,-0.00898748,-0.0507972,0.01468575,0.04766972,-0.01032333,-0.02978261,0.10040346,0.04193758],"last_embed":{"hash":"tk16ai","tokens":454}}},"last_read":{"hash":"tk16ai","at":1774951886133},"class_name":"SmartSource","last_import":{"mtime":1774951814734,"size":2730,"at":1774951884768,"hash":"tk16ai"},"blocks":{"#---frontmatter---":[1,57],"#Gotu Kola (Centella Asiatica) extract enhances phosphorylation of cyclic AMP response element binding protein in neuroblastoma cells expressing amyloid beta peptide.":[59,63],"#Gotu Kola (Centella Asiatica) extract enhances phosphorylation of cyclic AMP response element binding protein in neuroblastoma cells expressing amyloid beta peptide.#{1}":[61,63]},"outlinks":[{"title":"Author/Yanan Xu","target":"Author/Yanan Xu","line":45},{"title":"Author/Yanan Xu","target":"Author/Yanan Xu","line":46},{"title":"Author/Zhiming Cao","target":"Author/Zhiming Cao","line":47},{"title":"Author/Zhiming Cao","target":"Author/Zhiming Cao","line":48},{"title":"Author/Ikhlas A. Khan","target":"Author/Ikhlas A. Khan","line":49},{"title":"Author/Ikhlas A. Khan","target":"Author/Ikhlas A. Khan","line":50},{"title":"Author/Yuan Luo","target":"Author/Yuan Luo","line":51},{"title":"Author/Yuan Luo","target":"Author/Yuan Luo","line":52},{"title":"PDF","target":"biblib/xu_gotu_2008/xu_gotu_2008.pdf","line":54}],"metadata":{"id":"xu_gotu_2008","type":"article-journal","title":"Gotu Kola (Centella Asiatica) extract enhances phosphorylation of cyclic AMP response element binding protein in neuroblastoma cells expressing amyloid beta peptide.","issued":{"date-parts":[[2008]]},"DOI":"10.3233/jad-2008-13311","container-title":"Journal of Alzheimer's Disease","abstract":"Alzheimer's disease (AD) is a progressive neurodegenerative disorder that shows cognitive deficits and memory impairment. Extract from the leaves of Gotu Kola (Centella Asiatica) have been used as an alternative medicine for memory improvement in Indian Ayurvedic system of medicine for a long time. Although several studies have revealed its effect in ameliorating the cognitive impairment in rat models of AD and stimulating property on neuronal dendrites of hippocampal region, the molecular mechanism of Gotu Kola on neuroprotection still remains to be elucidated. In this study, we report that phosphorylation of cyclic AMP response element binding protein (CREB) is enhanced in both a neuroblastoma cell line expressing amyloid beta 1-42 (Abeta) and in rat embryonic cortical primary cell culture. In addition, the contribution of two major single components to the enhanced CREB phosphorylatioin was examined. Furthermore, inhibitors were applied in this study revealing that ERK/RSK signaling pathway might mediate this effect of Gotu Kola extract. Taken together, we provide a possible molecular mechanism for memory enhancing property of Gotu Kola extract for the first time.","tags":["#literature_note"],"author":[{"family":"Xu","given":"Yanan","literal":""},{"family":"Xu","given":"Yanan","literal":""},{"family":"Cao","given":"Zhiming","literal":""},{"family":"Cao","given":"Zhiming","literal":""},{"family":"Khan","given":"Ikhlas A.","literal":""},{"family":"Khan","given":"Ikhlas A.","literal":""},{"family":"Luo","given":"Yuan","literal":""},{"family":"Luo","given":"Yuan","literal":""}],"citation-key":"xu_gotu_2008","year":"2008","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Gotu Kola (Centella Asiatica) extract enhances phosphorylation of cyclic AMP response element binding protein in neuroblastoma cells expressing amyloid beta peptide."],"author-links"