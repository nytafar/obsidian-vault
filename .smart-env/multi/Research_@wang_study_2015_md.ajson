ntainer-title":"BMC Immunology","abstract":"Background Polysaccharopeptide (PSP), isolated from Coriolus versicolor COV-1 strain, is a protein-bound polysaccharide widely used as immunoadjuvant for cancer immunotherapy. Although the immunomodulatory activity of PSP has been well established, the precise molecule mechanisms of its biological activity have yet to be fully elucidated.","tags":["#literature_note"],"author":[{"family":"Wang","given":"Zhixue","literal":""},{"family":"Wang","given":"Zhixue","literal":""},{"family":"Dong","given":"Bing","literal":""},{"family":"Dong","given":"Bing","literal":""},{"family":"Feng","given":"Zifang","literal":""},{"family":"Feng","given":"Zifang","literal":""},{"family":"Yu","given":"Shuang","literal":""},{"family":"Yu","given":"Shuang","literal":""},{"family":"Bao","given":"Yixi","literal":""},{"family":"Bao","given":"Yixi","literal":""}],"citation-key":"wang_study_2015","year":"2015","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["A study on immunomodulatory mechanism of Polysaccharopeptide mediated by TLR4 signaling pathway"],"author-links":["[[Author/Zhixue Wang]]","[[Author/Zhixue Wang]]","[[Author/Bing Dong]]","[[Author/Bing Dong]]","[[Author/Zifang Feng]]","[[Author/Zifang Feng]]","[[Author/Shuang Yu]]","[[Author/Shuang Yu]]","[[Author/Yixi Bao]]","[[Author/Yixi Bao]]"],"attachment":["[[biblib/wang_study_2015/wang_study_2015.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"1cb035v","at":1774951891112}},"smart_blocks:Research/@wang_study_2015.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.06263452,-0.03642711,0.00580058,-0.04189316,-0.02093177,-0.02886984,0.05868997,0.02813333,-0.06216675,-0.01728098,0.0544836,-0.07731011,0.07247809,0.03822994,0.02162258,0.01372715,-0.00784951,0.00066921,-0.02926907,0.00566317,0.0503749,-0.10704044,-0.01452764,-0.01601121,0.08119208,0.0606438,0.02970587,-0.05364823,-0.01560383,-0.2293