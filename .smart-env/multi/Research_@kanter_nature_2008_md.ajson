63677,0.16623046,-0.02038593,0.04925678,0.01750955,0.04317557,-0.00378562,-0.013386,-0.03939577,0.03628681,0.03319214,0.13653119,-0.02335305,0.03935889,0.02269214,-0.04454947,0.00862746,0.0061765,-0.02781526,0.02369457,0.02255924,0.02934662,-0.04130121,0.10163897,-0.04460596,-0.06009682,-0.02211869,-0.00862369,0.04539035,0.01768179,0.02141053,-0.00145866,0.0202588,0.09059073,0.02464281,0.00010763,-0.02595783,-0.02853938,-0.05271144,-0.00337142,0.00706244,-0.03948588,0.04391315,0.05287658],"last_embed":{"hash":"1bv9xel","tokens":427}}},"last_read":{"hash":"1bv9xel","at":1774951894852},"class_name":"SmartSource","last_import":{"mtime":1774951827563,"size":2271,"at":1774951884826,"hash":"1bv9xel"},"blocks":{"#---frontmatter---":[1,57],"#The nature of clinical depression: Symptoms, syndromes, and behavior analysis":[59,63],"#The nature of clinical depression: Symptoms, syndromes, and behavior analysis#{1}":[61,63]},"outlinks":[{"title":"Author/Jonathan W. Kanter","target":"Author/Jonathan W. Kanter","line":45},{"title":"Author/Jonathan W. Kanter","target":"Author/Jonathan W. Kanter","line":46},{"title":"Author/Andrew M. Busch","target":"Author/Andrew M. Busch","line":47},{"title":"Author/Andrew M. Busch","target":"Author/Andrew M. Busch","line":48},{"title":"Author/Cristal E. Weeks","target":"Author/Cristal E. Weeks","line":49},{"title":"Author/Cristal E. Weeks","target":"Author/Cristal E. Weeks","line":50},{"title":"Author/Sara J. Landes","target":"Author/Sara J. Landes","line":51},{"title":"Author/Sara J. Landes","target":"Author/Sara J. Landes","line":52},{"title":"PDF","target":"biblib/kanter_nature_2008/kanter_nature_2008.pdf","line":54}],"metadata":{"id":"kanter_nature_2008","type":"article-journal","title":"The nature of clinical depression: Symptoms, syndromes, and behavior analysis","issued":{"date-parts":[[2008]]},"DOI":"10.1007/bf03392158","container-title":"Behavior Analyst","abstract":"In this article we discuss the traditional behavioral models of depression and some of the challenges analyzing a phenomenon with such complex and varied features. We present the traditional model and suggest that it does not capture the complexity of the phenomenon, nor do syndromal models of depression that dominate the mainstream conceptualization of depression. Instead, we emphasize ideographic analysis and present depression as a maladaptive dysregulation of an ultimately adaptive elicited emotional response. We emphasize environmental factors, specifically aversive control and private verbal events, in terms of relational frame theory, that may transform an adaptive response into a maladaptive disorder. We consider the role of negative thought processes and rumination, common and debilitating aspects of depression that have traditionally been neglected by behavior analysts.","tags":["#literature_note"],"author":[{"family":"Kanter","given":"Jonathan W.","literal":""},{"family":"Kanter","given":"Jonathan W.","literal":""},{"family":"Busch","given":"Andrew M.","literal":""},{"family":"Busch","given":"Andrew M.","literal":""},{"family":"Weeks","given":"Cristal E.","literal":""},{"family":"Weeks","given":"Cristal E.","literal":""},{"family":"Landes","given":"Sara J.","literal":""},{"family":"Landes","given":"Sara J.","literal":""}],"citation-key":"kanter_nature_2008","year":"2008","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["The nature of clinical depression: Symptoms, syndromes, and behavior analysis"],"author-links":["[[Author/Jonathan W. Kanter]]","[[Author/Jonathan W. Kanter]]","[[Author/Andrew M. Busch]]","[[Author/Andrew M. Busch]]","[[Author/Cristal E. Weeks]]","[[Author/Cristal E. Weeks]]","[[Author/Sara J. Landes]]","[[Author/Sara J. Landes]]"],"attachment":["[[biblib/kanter_nature_2008/kanter_nature_2008.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"1bv9xel","at":1774951894840}},"smart_blocks:Research/@kanter_nature_2008.md#---frontmatter---": {"path":n