569,0.02068669,-0.04582813,0.20726249,-0.0137818,-0.0286667,0.0199107,-0.03285749,0.00807533,0.04923159,-0.02629448,-0.03424777,0.02062615,0.07557273,-0.05307891,0.04736396,-0.00713491,-0.06121843,-0.01849761,0.00308159,-0.03839448,-0.00937566,0.01106453,-0.07608646,-0.05047174,0.06827839,-0.03400986,-0.06532642,0.00314591,0.02989311,-0.00495193,-0.01980202,0.00156742,-0.00829768,-0.03392265,0.01548484,0.03313703,0.01520345,0.00725307,-0.06210024,0.01650679,-0.00938747,-0.00304509,-0.07052772,0.10007884,0.05099787],"last_embed":{"hash":"1037uty","tokens":486}}},"last_read":{"hash":"1037uty","at":1774951887088},"class_name":"SmartSource","last_import":{"mtime":1774951816293,"size":3394,"at":1774951884777,"hash":"1037uty"},"blocks":{"#---frontmatter---":[1,85],"#Preclinical Bioavailability, Tissue Distribution, and Protein Binding Studies of Erinacine A, a Bioactive Compound from Hericium erinaceus Mycelia Using Validated LC-MS/MS Method.":[87,91],"#Preclinical Bioavailability, Tissue Distribution, and Protein Binding Studies of Erinacine A, a Bioactive Compound from Hericium erinaceus Mycelia Using Validated LC-MS/MS Method.#{1}":[89,91]},"outlinks":[{"title":"Author/Pei-Ching Tsai","target":"Author/Pei-Ching Tsai","line":66},{"title":"Author/Pei-Ching Tsai","target":"Author/Pei-Ching Tsai","line":67},{"title":"Author/Yi-Kai Wu","target":"Author/Yi-Kai Wu","line":68},{"title":"Author/Yi-Kai Wu","target":"Author/Yi-Kai Wu","line":69},{"title":"Author/Jun-Hao Hu","target":"Author/Jun-Hao Hu","line":70},{"title":"Author/Jun-Hao Hu","target":"Author/Jun-Hao Hu","line":71},{"title":"Author/I.-Chen Li","target":"Author/I.-Chen Li","line":72},{"title":"Author/I.-Chen Li","target":"Author/I.-Chen Li","line":73},{"title":"Author/Te-Hsien Lin","target":"Author/Te-Hsien Lin","line":74},{"title":"Author/Ting-Wei Lin","target":"Author/Ting-Wei Lin","line":75},{"title":"Author/Chin-Chu Chen","target":"Author/Chin-Chu Chen","line":76},{"title":"Author/Chin-Chu Chen","target":"Author/Chin-Chu Chen","line":77},{"title":"Author/Chen Chin-Chu","target":"Author/Chen Chin-Chu","line":78},{"title":"Author/Chia-Feng Kuo","target":"Author/Chia-Feng Kuo","line":79},{"title":"Author/Chia-Feng Kuo","target":"Author/Chia-Feng Kuo","line":80},{"title":"PDF","target":"biblib/tsai_preclinical_2021/tsai_preclinical_2021.pdf","line":82}],"metadata":{"id":"tsai_preclinical_2021","type":"article-journal","title":"Preclinical Bioavailability, Tissue Distribution, and Protein Binding Studies of Erinacine A, a Bioactive Compound from Hericium erinaceus Mycelia Using Validated LC-MS/MS Method.","issued":{"date-parts":[[2021]]},"DOI":"10.3390/molecules26154510","container-title":"Molecules","abstract":"Erinacine A, derived from the mycelia of Hericium erinaceus, has attracted much attention due to its neuroprotective properties. However, very few studies have been conducted on the bioavailability, tissue distribution, and protein binding of erinacine A. This study aimed to investigate the bioavailability, tissue distribution, and protein binding of erinacine A in Sprague-Dawley rats. After oral administration (po) and intravenous administration (iv) of 2.381 g/kg BW of the H. erinaceus mycelia extract (equivalent to 50 mg/kg BW of erinacine A) and 5 mg/kg BW of erinacine A, respectively, the absolute bioavailability of erinacine A was estimated as 24.39%. Erinacine A was detected in brain at 1 h after oral dosing and reached the peak at 8 h. Protein binding assay showed unbound erinacine A fractions in brain to blood ratio is close to unity, supporting passive diffusion as the dominating transport. Feces was the major route for the elimination of erinacine A. This study is the first to show that erinacine A can penetrate the blood-brain barrier of rats by the means of passive diffusion and thus support the development of H. erinaceus mycelia for the improvement of neurohealth.","tags":["#literature_note"],"author":[{"family":"Tsai","given":"Pei-Ching","literal":""},{"family":"Tsai","given":"Pei-Ching","literal":""},{"family":"Wu","given":"Yi-Kai","literal":""},{"family":"Wu","given":"Yi-Kai","literal":""},{"family":"Hu","given":"Jun-Hao","literal":""},{"family":"Hu","given":"Jun-Hao","literal":""},{"family":"Li","given":"I.-Chen","literal":""},{"family":"Li","given":"I.-Chen","literal":""},{"family":"Lin","given":"Te-Hsien","literal":""},{"family":"Lin","given":"Ting-Wei","literal":""},{"family":"Chen","given":"Chin-Chu","literal":""},{"family":"Chen","given":"Chin-Chu","literal":""},{"family":"Chin-Chu","given":"Chen","literal":""},{"family":"Kuo","given":"Chia-Feng","literal":""},{"family":"Kuo","given":"Chia-Feng","literal":""}],"citation-key":"tsai_preclinical_2021","year":"2021","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Preclinical Bioavailability, Tissue Distribution, and Protein Binding Studies of Erinacine A, a Bioactive Compound from Hericium erinaceus Mycelia Using Validated LC-MS/MS Method."],"author-links":["[[Author/Pei-Ching Tsai]]","[[Author/Pei-Ching Tsai]]","[[Author/Yi-Kai Wu]]","[[Author/Yi-Kai Wu]]","[[Author/Jun-Hao Hu]]","[[Author/Jun-Hao Hu]]","[[Author/I.-Chen Li]]","[[Author/I.-Chen Li]]","[[Author/Te-Hsien Lin]]","[[Author/Ting-Wei Lin]]","[[Author/Chin-Chu Chen]]","[[Author/Chin-Chu Chen]]","[[Author/Chen Chin-Chu]]","[[Author/Chia-Feng Kuo]]","[[Author/Chia-Feng Kuo]]"],"attachment":["[[biblib/tsai_preclinical_2021/tsai_preclinical_2021.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"1037uty","at":1774951887078}},"smart_blocks:Research/@tsai_preclinical_2021.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.03916978,-0.03109643,-0.01327769,-0.06494661,-0.01612773,0.01351239,0.06489148,0.01818028,0.00497491,-0.02377753,0.01606809,-0.13198052,0.03156118,0.00804348,-0.02262807,0.00487836,-0.00358562,-0.00744972,-0.10696199,-0.03485429,0.00248916,-0.06948793,0.0186122,-0.02728624,0.06054058,0.017