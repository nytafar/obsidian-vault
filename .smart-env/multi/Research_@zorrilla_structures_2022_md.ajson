59,-0.01462898,0.01032661,0.04950456,0.21747681,-0.01075861,-0.04352867,0.00379756,-0.01213632,0.01078242,-0.06363246,0.00825473,0.01307238,0.0790538,0.12771535,-0.02216568,0.01179071,0.04982186,-0.01189768,-0.02274144,-0.02290357,-0.04879238,-0.04555631,-0.06149827,-0.14197314,0.00097084,0.12342525,-0.11839095,-0.10107591,-0.04597116,-0.00293911,0.01761986,-0.04049261,0.0087863,-0.03011404,0.01517083,-0.0384179,-0.01447092,-0.00146746,-0.03543461,-0.02591127,0.01206083,-0.06262974,0.00857829,-0.0661333,0.11548126,0.03492147],"last_embed":{"hash":"rafm06","tokens":489}}},"last_read":{"hash":"rafm06","at":1774951894203},"class_name":"SmartSource","last_import":{"mtime":1774951827104,"size":1909,"at":1774951884824,"hash":"rafm06"},"blocks":{"#---frontmatter---":[1,45],"#Structures and Biological Activities of Alkaloids Produced by Mushrooms, a Fungal Subgroup":[47,51],"#Structures and Biological Activities of Alkaloids Produced by Mushrooms, a Fungal Subgroup#{1}":[49,51]},"outlinks":[{"title":"Author/Jesús G. Zorrilla","target":"Author/Jesús G. Zorrilla","line":36},{"title":"Author/Jesús G. Zorrilla","target":"Author/Jesús G. Zorrilla","line":37},{"title":"Author/Marco Masi","target":"Author/Marco Masi","line":38},{"title":"Author/Antonio Evidente","target":"Author/Antonio Evidente","line":39},{"title":"Author/Antonio Evidente","target":"Author/Antonio Evidente","line":40},{"title":"PDF","target":"biblib/zorrilla_structures_2022/zorrilla_structures_2022.pdf","line":42}],"metadata":{"id":"zorrilla_structures_2022","type":"article-journal","title":"Structures and Biological Activities of Alkaloids Produced by Mushrooms, a Fungal Subgroup","issued":{"date-parts":[[2022]]},"DOI":"10.3390/biom12081025","container-title":"Biomolecules","abstract":"Alkaloids are a wide family of basic N-containing natural products, whose research has revealed bioactive compounds of pharmacological interest. Studies on these compounds have focused more attention on those produced by plants, although other types of organisms have also been proven to synthesize bioactive alkaloids, such as animals, marine organisms, bacteria, and fungi. This review covers the findings of the last 20 years (2002–2022) related to the isolation, structures, and biological activities of the alkaloids produced by mushrooms, a fungal subgroup, and their potential to develop drugs and agrochemicals. In some cases, the synthesis of the reviewed compounds and structure−activity relationship studies have been described.","tags":["#literature_note"],"author":[{"family":"Zorrilla","given":"Jesús G.","literal":""},{"family":"Zorrilla","given":"Jesús G.","literal":""},{"family":"Masi","given":"Marco","literal":""},{"family":"Evidente","given":"Antonio","literal":""},{"family":"Evidente","given":"Antonio","literal":""}],"citation-key":"zorrilla_structures_2022","year":"2022","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Structures and Biological Activities of Alkaloids Produced by Mushrooms, a Fungal Subgroup"],"author-links":["[[Author/Jesús G. Zorrilla]]","[[Author/Jesús G. Zorrilla]]","[[Author/Marco Masi]]","[[Author/Antonio Evidente]]","[[Author/Antonio Evidente]]"],"attachment":["[[biblib/zorrilla_structures_2022/zorrilla_structures_2022.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"rafm06","at":1774951894190}},"smart_blocks:Research/@zorrilla_structures_2022.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.03239862,-0.02943902,0.03072263,-0.0183639,0.00941827,-0.02532856,-0.030522,0.01269228,-0.06133176,-0.0053114,0.00475648,-0.02400059,0.02474949,0.00826632,0.03010476,-0.0508476,-0.02310137,0.01606341,-0.04576574,0.01364123,0.06205493,-0.0329181,0.06718073,0.01749198,0.091379,0.07434527,0.01674189,0.02751758,-0.01648713,-0.20349225,-0.02657843,0.04733346,0.05174967,-0.00715619,-0.01014084,-0.01000711,-0.00574739,0.0363597,-0.02911967,0.03611111,0.042818,0.05037499,0.0197