899,0.0267889,0.17668492,0.02920157,0.03707954,0.03281621,-0.06628899,0.00413804,0.03558712,0.00148302,0.01902846,0.05261929,0.05101703,-0.09196236,0.06046202,0.10005968,-0.06180268,0.02850967,-0.06168676,-0.0076312,0.03824664,0.00005795,-0.0587922,-0.00454015,0.13968287,-0.12228779,-0.05912265,-0.00488744,0.01342141,0.00799293,-0.02065512,0.0197991,0.00982885,0.05502343,-0.01235848,0.00717048,0.01387748,-0.05924045,0.01199936,-0.01192287,0.02279556,-0.01122211,-0.04053073,0.09794824,0.00109455],"last_embed":{"hash":"1qfpc1t","tokens":470}}},"last_read":{"hash":"1qfpc1t","at":1774951894871},"class_name":"SmartSource","last_import":{"mtime":1774951827597,"size":2988,"at":1774951884826,"hash":"1qfpc1t"},"blocks":{"#---frontmatter---":[1,85],"#Sarcodonin G Derivatives Exhibit Distinctive Effects on Neurite Outgrowth by Modulating NGF Signaling in PC12 Cells.":[87,91],"#Sarcodonin G Derivatives Exhibit Distinctive Effects on Neurite Outgrowth by Modulating NGF Signaling in PC12 Cells.#{1}":[89,91]},"outlinks":[{"title":"Author/Chenyu Cao","target":"Author/Chenyu Cao","line":66},{"title":"Author/Chen-Yu Cao","target":"Author/Chen-Yu Cao","line":67},{"title":"Author/Cheng-Chen Zhang","target":"Author/Cheng-Chen Zhang","line":68},{"title":"Author/Cheng-Chen Zhang","target":"Author/Cheng-Chen Zhang","line":69},{"title":"Author/Xinwei Shi","target":"Author/Xinwei Shi","line":70},{"title":"Author/Xin-Wei Shi","target":"Author/Xin-Wei Shi","line":71},{"title":"Author/Ding Li","target":"Author/Ding Li","line":72},{"title":"Author/Ding Li","target":"Author/Ding Li","line":73},{"title":"Author/Ding Li","target":"Author/Ding Li","line":74},{"title":"Author/Wei Cao","target":"Author/Wei Cao","line":75},{"title":"Author/Wei Cao","target":"Author/Wei Cao","line":76},{"title":"Author/Xia Yin","target":"Author/Xia Yin","line":77},{"title":"Author/Xia Yin","target":"Author/Xia Yin","line":78},{"title":"Author/Jin-Ming Gao","target":"Author/Jin-Ming Gao","line":79},{"title":"Author/Jin-Ming Gao","target":"Author/Jin-Ming Gao","line":80},{"title":"PDF","target":"biblib/cao_sarcodonin_2018/cao_sarcodonin_2018.pdf","line":82}],"metadata":{"id":"cao_sarcodonin_2018","type":"article-journal","title":"Sarcodonin G Derivatives Exhibit Distinctive Effects on Neurite Outgrowth by Modulating NGF Signaling in PC12 Cells.","issued":{"date-parts":[[2018]]},"DOI":"10.1021/acschemneuro.7b00488","container-title":"ACS Chemical Neuroscience","abstract":"Sarcodonin G, one of the cyathane diterpenoids isolated from the mushroom Sarcodon scabrosus, possesses pronounced neurotrophic activity but ambiguous mechanical understanding. In this work, sarcodonin G was chosen as a lead compound to prepare a series of 19-O-benzoyl derivatives by semisynthesis and their neuritogenic activities were evaluated. 6 and 15 (10 μM) were investigated with opposite effects in PC12 cells. 6 exhibited a superior activity to sarcodonin G by promoting NGF-induced neurite outgrowth, while 15 showed an inhibitory effect. Supportingly, 6 and 15 (20 μM) significantly induced and suppressed neurite extension in primary cultured rat cortical neurons, respectively. In mechanism, the two derivatives were revealed to influence NGF-induced neurite outgrowth in PC12 cells through the regulation of PKC-dependent and -independent ERK/CREB signaling as well as the upstream TrkA receptor phosphorylation. Furthermore, a possible pattern of interaction among NGF, 6/15 and TrkA was presented using...","tags":["#literature_note"],"author":[{"family":"Cao","given":"Chenyu","literal":""},{"family":"Cao","given":"Chen-Yu","literal":""},{"family":"Zhang","given":"Cheng-Chen","literal":""},{"family":"Zhang","given":"Cheng-Chen","literal":""},{"family":"Shi","given":"Xinwei","literal":""},{"family":"Shi","given":"Xin-Wei","literal":""},{"family":"Li","given":"Ding","literal":""},{"family":"Li","given":"Ding","literal":""},{"family":"Li","given":"Ding","literal":""},{"family":"Cao","given":"Wei","literal":""},{"family":"Cao","given":"Wei","literal":""},{"family":"Yin","given":"Xia","literal":""},{"family":"Yin","given":"Xia","literal":""},{"family":"Gao","given":"Jin-Ming","literal":""},{"family":"Gao","given":"Jin-Ming","literal":""}],"citation-key":"cao_sarcodonin_2018","year":"2018","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Sarcodonin G Derivatives Exhibit Distinctive Effects on Neurite Outgrowth by Modulating NGF Signaling in PC12 Cells."],"author-links":["[[Author/Chenyu Cao]]","[[Author/Chen-Yu Cao]]","[[Author/Cheng-Chen Zhang]]","[[Author/Cheng-Chen Zhang]]","[[Author/Xinwei Shi]]","[[Author/Xin-Wei Shi]]","[[Author/Ding Li]]","[[Author/Ding Li]]","[[Author/Ding Li]]","[[Author/Wei Cao]]","[[Author/Wei Cao]]","[[Author/Xia Yin]]","[[Author/Xia Yin]]","[[Author/Jin-Ming Gao]]","[[Author/Jin-Ming Gao]]"],"attachment":["[[biblib/cao_sarcodonin_2018/cao_sarcodonin_2018.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"1qfpc1t","at":1774951894860}},"smart_blocks:Research/@cao_sarcodonin_2018.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.03633463,-0.04774959,0.01735872,-0.02925387,-0.011496,0.00826437,-0.00164063,-0.00705526,-0.0616797,0.00195907,0.02845566,-0.03307025,0.04518956,0.06618239,0.00303539,-0.03254214,-0.01929107,0.03097494,-0.06074978,0.02983748,0.03905131,-0.0823762,0.05428476,-0.00348243,0.06694587,0.02229909,0.02118568,-0.00918716,-0.04731087,-0.22503489,-0.01079233,0.0411613,-0.00287474,-0.04043507,-0.02586103,-0.00473647,-0.06448099,0.01058608,0.00141335,0.04231798,0.01818418,0.03574967,0.02905972,0.02650455,0.02097932,-0.04949986,-0.06883962,-0.03386747,0.02860394,-0.05417277,0.02040496,-0.06726297,-0.0380273,0.01511604,-0.02639413,-0.02507861,0.00597224,0.05048323,0.05287011,0.07685407,0.10128044,0.08808856,-0.19090551,0.0414996,0.04617832,0.04801937,-0.06124756,-0.02942903,0.08102337,0.05997207,-0.00688783,0.03449991,0.0486356,0.0566087,0.03545