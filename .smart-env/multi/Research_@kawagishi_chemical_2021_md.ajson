g causing principles “fairy chemicals” and the biosynthetic routes of the compounds on the purine metabolic pathway in plants and mushrooms.","tags":["#literature_note"],"author":[{"family":"Kawagishi","given":"Hirokazu","literal":""},{"family":"Kawagishi","given":"Hirokazu","literal":""}],"citation-key":"kawagishi_chemical_2021","year":"2021","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Chemical studies on bioactive compounds related to higher fungi"],"author-links":["[[Author/Hirokazu Kawagishi]]","[[Author/Hirokazu Kawagishi]]"],"attachment":["[[biblib/kawagishi_chemical_2021/kawagishi_chemical_2021.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"12q5svp","at":1774951894252}},"smart_blocks:Research/@kawagishi_chemical_2021.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.04069355,-0.0485243,0.04206757,0.00397642,0.01932272,-0.01133931,0.02376249,0.03390715,-0.07259786,0.02224732,0.01418073,-0.05078348,0.07294998,-0.0003339,0.03932014,-0.02995073,-0.00702275,0.01233513,-0.10935862,-0.00802727,0.09273109,0.00190653,0.00039624,0.0342457,0.06949779,0.02561335,0.00486247,-0.02733952,-0.05020551,-0.19292249,-0.04473034,0.02441893,0.03372122,0.00058254,-0.02047795,-0.0216504,-0.01783684,0.04928448,-0.01081256,0.02227059,0.03887453,0.02464055,0.010873,0.0199282,0.00444588,-0.07503998,0.00802939,0.00783115,-0.01021008,-0.04766819,-0.05255571,-0.03797584,0.01908031,0.01028673,0.0625948,0.00294446,0.03798244,0.05678314,0.02066398,0.07077536,0.05749995,0.05767885,-0.18962193,0.03317448,0.00833074,0.01433067,-0.06031665,-0.073089,0.07809769,-0.0182356,0.02315879,-0.00358814,-0.00762499,0.05087858,0.02511911,-0.0736675,-0.02020406,-0.07241085,-0.05341026,-0.01474319,0.0070294,0.08432887,0.02127253,0.01706444,-0.02838604,-0.07072403,-0.0188058,-0.03905005,0.03183749,0.06131492,0.02973435,-0.07443484,0.00247621,0.00906813,-0.09112582,-0.00196486,-0.02518755,-0.03525519,-0.