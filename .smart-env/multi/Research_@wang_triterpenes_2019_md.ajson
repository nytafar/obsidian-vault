2545,-0.05701851,0.03696552,0.03721607,0.17055492,-0.0306563,-0.02764784,0.04128936,-0.02474722,0.01630534,-0.05102925,0.02115956,-0.05525256,0.02212362,0.11064717,-0.04069176,0.04423834,0.12219963,-0.0379605,-0.03100509,0.01470838,-0.03481635,0.02113936,0.02239735,-0.10952446,-0.03365247,0.08001443,-0.10380725,-0.03797754,-0.01017108,-0.04343004,0.02141377,-0.02144308,-0.00619644,0.04623901,0.05148458,-0.04508475,-0.0537333,-0.00568858,-0.05163108,0.00311606,0.0443482,-0.01350287,0.07112487,-0.04410547,0.12047958,0.07533309],"last_embed":{"hash":"1venwai","tokens":467}}},"last_read":{"hash":"1venwai","at":1774951892537},"class_name":"SmartSource","last_import":{"mtime":1774951824406,"size":3141,"at":1774951884814,"hash":"1venwai"},"blocks":{"#---frontmatter---":[1,65],"#Triterpenes and Aromatic Meroterpenoids with Antioxidant Activity and Neuroprotective Effects from Ganoderma lucidum.":[67,71],"#Triterpenes and Aromatic Meroterpenoids with Antioxidant Activity and Neuroprotective Effects from Ganoderma lucidum.#{1}":[69,71]},"outlinks":[{"title":"Author/Cuifang Wang","target":"Author/Cuifang Wang","line":51},{"title":"Author/Cui-Fang Wang","target":"Author/Cui-Fang Wang","line":52},{"title":"Author/Xuemin Liu","target":"Author/Xuemin Liu","line":53},{"title":"Author/Xuemin Liu","target":"Author/Xuemin Liu","line":54},{"title":"Author/Chen-Lei Lian","target":"Author/Chen-Lei Lian","line":55},{"title":"Author/Chen-Lei Lian","target":"Author/Chen-Lei Lian","line":56},{"title":"Author/Jing Ke","target":"Author/Jing Ke","line":57},{"title":"Author/Jiaying Ke","target":"Author/Jiaying Ke","line":58},{"title":"Author/Jie-Qing Liu","target":"Author/Jie-Qing Liu","line":59},{"title":"Author/Jie-Qing Liu","target":"Author/Jie-Qing Liu","line":60},{"title":"PDF","target":"biblib/wang_triterpenes_2019/wang_triterpenes_2019.pdf","line":62}],"metadata":{"id":"wang_triterpenes_2019","type":"article-journal","title":"Triterpenes and Aromatic Meroterpenoids with Antioxidant Activity and Neuroprotective Effects from Ganoderma lucidum.","issued":{"date-parts":[[2019]]},"DOI":"10.3390/molecules24234353","container-title":"Molecules","abstract":"Reactive oxygen/nitrogen species generated in the human body can cause oxidative damage associated with many degenerative diseases such as atherosclerosis, dementia, coronary heart diseases, aging, and cancer. There is a great interest in developing new antioxidants from Ganoderma fungus due to its low toxicity. As part of our ongoing search for antioxidative constituents from the fruiting bodies of Ganoderma lucidum, the chemical constituents were investigated and seven secondary metabolites, including one new lanostane triterpene (1), two known aromatic meroterpenoids (6–7), and four known triterpenes (2–5), were isolated by a series of chromatographic methods. The structures of the seven compounds were elucidated by spectroscopic techniques. The isolated compounds were tested in vitro for antioxidant potencies and neuroprotective activities against H2O2 and aged Aβ-induced cell death in SH-SY5Y cells. As a result, compounds 1, 6, and 7 exhibited potent antioxidant and neuroprotective activities. Additionally, all isolated compounds were tested for radical scavenging activities. Compounds 6 and 7 showed the comparable free radical scavenging activities with the standard drug in both ABTS (2, 2’-azobis (3-ethylbenzothiazole-6-sulfonaic acid)) and ORAC (oxygen radical absorbance capacity) experiments. The results from this study suggested that G. lucidum and its metabolites (especially the meroterpenoids) may be potential functional food ingredients for the antioxidation and prevention of neurogenerative diseases.","tags":["#literature_note"],"author":[{"family":"Wang","given":"Cuifang","literal":""},{"family":"Wang","given":"Cui-Fang","literal":""},{"family":"Liu","given":"Xuemin","literal":""},{"family":"Liu","given":"Xuemin","literal":""},{"family":"Lian","given":"Chen-Lei","literal":""},{"family":"Lian","given":"Chen-Lei","literal":""},{"family":"Ke","given":"Jing","literal":""},{"family":"Ke","given":"Jiaying","literal":""},{"family":"Liu","given":"Jie-Qing","literal":""},{"family":"Liu","given":"Jie-Qing","literal":""}],"citation-key":"wang_triterpenes_2019","year":"2019","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Triterpenes and Aromatic Meroterpenoids with Antioxidant Activity and Neuroprotective Effects from Ganoderma lucidum."],"author-links":["[[Author/Cuifang Wang]]","[[Author/Cui-Fang Wang]]","[[Author/Xuemin Liu]]","[[Author/Xuemin Liu]]","[[Author/Chen-Lei Lian]]","[[Author/Chen-Lei Lian]]","[[Author/Jing Ke]]","[[Author/Jiaying Ke]]","[[Author/Jie-Qing Liu]]","[[Author/Jie-Qing Liu]]"],"attachment":["[[biblib/wang_triterpenes_2019/wang_triterpenes_2019.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"1venwai","at":1774951892527}},"smart_blocks:Research/@wang_triterpenes_2019.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.05769075,0.02314462,-0.00302803,-0.01599872,0.06709984,0.05277838,-0.0020858,0.04866923,-0.06436162,-0.00387747,-0.01160137,-0.00079353,0.03630934,0.01614283,-0.04491103,0.01313805,-0.02933242,0.01536816,-0.07435552,-0.00940984,0.02784297,-0.04231634,0.04710652,0.02753031,0.02884527,0.07808936,-0.00725999,-0.02660271,-0.06306324,-0.17671113,0.01023377,0.01166096,-0.0355508,-0.03216932,-0.0161261,0.02518499,-0.0420576,0.05253484,-0.04799111,0.00605436,0.03256563,0.03894025,-0.01332104,0.02983676,0.00524367,-0.0431857,-0.05208189,-0.03828607,0.06088624,-0.07938807,-0.01038036,-0.0399201,0.03799377,0.00831041,0.05596875,-0.01901288,0.02257068,0.04392486,-0.04298561,0.05942015,0.07390001,0.01512996,-0.1735974,0.03856708,0.02410049,0.02682151,-0.06236047,0.01573805,0.09057303,0.00701528,-0.05810516,0.00757564,0.02146937,0.02821301,-0.00160218,0.02081774,-0.01505683,-0.07451627,-0.04743996,-0.02060775,0.05010777,0.03561519,-0.029