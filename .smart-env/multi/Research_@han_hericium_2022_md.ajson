41859,0.17561364,-0.01363131,0.00182724,-0.00404528,0.02467679,0.01412332,0.02075515,0.01052419,0.00360293,-0.00098425,0.08154321,-0.00753932,0.02655304,0.00869295,-0.06986129,0.00770619,-0.01750767,0.0193259,-0.01276675,0.01620479,-0.07453335,-0.06273371,0.10018313,-0.02427401,0.00840876,-0.03645066,0.03627365,0.01891627,-0.06095475,0.03104503,0.02366294,-0.01058853,-0.04858598,0.0003826,-0.02039427,-0.05212875,-0.00478319,0.03482296,-0.00895875,-0.01170612,-0.10131875,0.09473604,0.09619597],"last_embed":{"hash":"123dq7b","tokens":451}}},"last_read":{"hash":"123dq7b","at":1774951888239},"class_name":"SmartSource","last_import":{"mtime":1774951818441,"size":2488,"at":1774951884788,"hash":"123dq7b"},"blocks":{"#---frontmatter---":[1,53],"#<i>Hericium erinaceus</i>polysaccharide improves the microstructure, immune function, proliferation and reduces apoptosis of thymus and spleen tissue cells of immunosuppressed mice":[55,59],"#<i>Hericium erinaceus</i>polysaccharide improves the microstructure, immune function, proliferation and reduces apoptosis of thymus and spleen tissue cells of immunosuppressed mice#{1}":[57,59]},"outlinks":[{"title":"Author/Yujiao Han","target":"Author/Yujiao Han","line":42},{"title":"Author/Jialiang Huang","target":"Author/Jialiang Huang","line":43},{"title":"Author/Chunfang Zhao","target":"Author/Chunfang Zhao","line":44},{"title":"Author/Feng Zhang","target":"Author/Feng Zhang","line":45},{"title":"Author/Yuchun Gu","target":"Author/Yuchun Gu","line":46},{"title":"Author/Chenfang Wang","target":"Author/Chenfang Wang","line":47},{"title":"Author/Erhui Jin","target":"Author/Erhui Jin","line":48},{"title":"PDF","target":"biblib/han_hericium_2022/han_hericium_2022.pdf","line":50}],"metadata":{"id":"han_hericium_2022","type":"article-journal","title":"<i>Hericium erinaceus</i>polysaccharide improves the microstructure, immune function, proliferation and reduces apoptosis of thymus and spleen tissue cells of immunosuppressed mice","issued":{"date-parts":[[2022]]},"DOI":"10.1093/bbb/zbac198","container-title":"Bioscience, biotechnology, and biochemistry","abstract":"In order to study the effect of Hericium erinaceus polysaccharide (HEP) on the immune and antioxidation functions of immunosuppressed mice. The control group received distilled water orally and the model and experimental groups I, II, and III received 0, 80, 160, and 320 mg/kg HEP respectively for a fortnight after re-molding with cyoclphosphnalide (CTX). Compared with the control group, the secretion of IL-2, IL-4, and IFN-γ, the activity or content of T-AOC, T-SOD, and GSH-PX, and the expression of PCNA mRNA in the thymus and spleen were reduced in immunosuppressed mice (P < .05 or P < .01). Compared with immunosuppressed mice, the levels of IL-2, IFN-γ, and GSH-PX and the PCNA mRNA expression of spleen and thymus were increased (P < .05 or P < .01), and the microstructure were also obviously improved in the experimental group III. Overall, 320 mg/kg of HEP significantly improved the immune and antioxidant functions.","tags":["#literature_note"],"author":[{"family":"Han","given":"Yujiao","literal":""},{"family":"Huang","given":"Jialiang","literal":""},{"family":"Zhao","given":"Chunfang","literal":""},{"family":"Zhang","given":"Feng","literal":""},{"family":"Gu","given":"Yuchun","literal":""},{"family":"Wang","given":"Chenfang","literal":""},{"family":"Jin","given":"Erhui","literal":""}],"citation-key":"han_hericium_2022","year":"2022","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["<i>Hericium erinaceus</i>polysaccharide improves the microstructure, immune function, proliferation and reduces apoptosis of thymus and spleen tissue cells of immunosuppressed mice"],"author-links":["[[Author/Yujiao Han]]","[[Author/Jialiang Huang]]","[[Author/Chunfang Zhao]]","[[Author/Feng Zhang]]","[[Author/Yuchun Gu]]","[[Author/Chenfang Wang]]","[[Author/Erhui Jin]]"],"attachment":["[[biblib/han_hericium_2022/han_hericium_2022.pdf|PDF]]"],"relat