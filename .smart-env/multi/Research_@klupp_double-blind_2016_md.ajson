-0.08747703,0.06232249,0.02187125,0.14806896,-0.03421011,-0.06341316,0.00776337,-0.01748065,0.03767018,-0.0559434,0.04332189,-0.03975248,0.07476808,0.07432668,-0.02978812,0.01439697,0.0814314,-0.06059813,-0.03786917,0.01468586,0.04145076,0.09018721,-0.01091633,-0.0124646,-0.01201629,0.1037654,-0.04651492,-0.01227248,-0.01111446,0.03858612,0.02187128,-0.02674956,-0.07156684,0.00641376,0.06935501,0.01114412,-0.09217464,-0.00701965,-0.06203714,0.02316311,-0.02466796,0.00458343,0.01096826,-0.005977,0.06940307,0.03680841],"last_embed":{"hash":"ek30ge","tokens":492}}},"last_read":{"hash":"ek30ge","at":1774951891745},"class_name":"SmartSource","last_import":{"mtime":1774951823062,"size":3335,"at":1774951884809,"hash":"ek30ge"},"blocks":{"#---frontmatter---":[1,65],"#A double-blind, randomised, placebo-controlled trial of Ganoderma lucidum for the treatment of cardiovascular risk factors of metabolic syndrome.":[67,71],"#A double-blind, randomised, placebo-controlled trial of Ganoderma lucidum for the treatment of cardiovascular risk factors of metabolic syndrome.#{1}":[69,71]},"outlinks":[{"title":"Author/Nerida L. Klupp","target":"Author/Nerida L. Klupp","line":51},{"title":"Author/Nerida L. Klupp","target":"Author/Nerida L. Klupp","line":52},{"title":"Author/Hosen Kiat","target":"Author/Hosen Kiat","line":53},{"title":"Author/Hosen Kiat","target":"Author/Hosen Kiat","line":54},{"title":"Author/Alan Bensoussan","target":"Author/Alan Bensoussan","line":55},{"title":"Author/Alan Bensoussan","target":"Author/Alan Bensoussan","line":56},{"title":"Author/Genevieve Z. Steiner","target":"Author/Genevieve Z. Steiner","line":57},{"title":"Author/Genevieve Z. Steiner","target":"Author/Genevieve Z. Steiner","line":58},{"title":"Author/Dennis Hsu-Tung Chang","target":"Author/Dennis Hsu-Tung Chang","line":59},{"title":"Author/Dennis Hsu-Tung Chang","target":"Author/Dennis Hsu-Tung Chang","line":60},{"title":"PDF","target":"biblib/klupp_double-blind_2016/klupp_double-blind_2016.pdf","line":62}],"metadata":{"id":"klupp_double-blind_2016","type":"article-journal","title":"A double-blind, randomised, placebo-controlled trial of Ganoderma lucidum for the treatment of cardiovascular risk factors of metabolic syndrome.","issued":{"date-parts":[[2016]]},"DOI":"10.1038/srep29540","container-title":"Scientific Reports","abstract":"This study aimed to evaluate the efficacy and safety of Ganoderma lucidum for the treatment of hyperglycaemia and other cardiovascular risk components of metabolic syndrome using a prospective, double-blind, randomised, placebo-controlled trial. Eighty-four participants with type 2 diabetes mellitus and metabolic syndrome were randomised to one of three intervention groups: Ganoderma lucidum, Ganoderma lucidum with Cordyceps sinensis, or placebo. The dosage was 3 g/day of Ganoderma lucidum, with or without Cordyceps sinensis, for 16 weeks. The primary outcome measure was blood glucose (glycosylated haemoglobin [HbA1c] and fasting plasma glucose [FPG]); a number of secondary outcome measures were also tested. Data from the two intervention groups were combined. The combined intervention had no effect on any of the primary (baseline-adjusted difference in means: HbA1c=0.13%, 95% CI [−0.35, 0.60], p=0.60; FPG=0.03mmol/L, 95% CI [−0.90, 0.96], p=0.95) or secondary outcome measures over the course of the 16-week trial, and no overall increased risk of adverse events with either active treatment. Evidence from this randomised clinical trial does not support the use of Ganoderma lucidum for treatment of cardiovascular risk factors in people with diabetes mellitus or metabolic syndrome. This Clinical Trial was registered with the Australian New Zealand Clinical Trials Registry on November 23, 2006. Trial ID: ACTRN12606000485538 and can be accessed here: https://www.anzctr.org.au/Trial/Registration/TrialReview.aspx?id=81705.","tags":["#literature_note"],"author":[{"family":"Klupp","given":"Nerida L.","literal":""},{"family":"Klupp","given":"Nerida L.","literal":""},{"family":"Kiat","given":"Hosen","literal":""},{"family":"Kiat","given":"Hosen","literal":""},{"family":"Bensoussan","given":"Alan","literal":""},{"family":"Bensoussan","given":"Alan","literal":""},{"family":"Steiner","given":"Genevieve Z.","literal":""},{"family":"Steiner","given":"Genevieve Z.","literal":""},{"family":"Chang","given":"Dennis Hsu-Tung","literal":""},{"family":"Chang","given":"Dennis Hsu-Tung","literal":""}],"citation-key":"klupp_double-blind_2016","year":"2016","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["A double-blind, randomised, placebo-controlled trial of Ganoderma lucidum for the treatment of cardiovascular risk factors of metabolic syndrome."],"author-links":["[[Author/Nerida L. Klupp]]","[[Author/Nerida L. Klupp]]","[[Author/Hosen Kiat]]","[[Author/Hosen Kiat]]","[[Author/Alan Bensoussan]]","[[Author/Alan Bensoussan]]","[[Author/Genevieve Z. Steiner]]","[[Author/Genevieve Z. Steiner]]","[[Author/Dennis Hsu-Tung Chang]]","[[Author/Dennis Hsu-Tung Chang]]"],"attachment":["[[biblib/klupp_double-blind_2016/klupp_double-blind_2016.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"ek30ge","at":1774951891737}},"smart_blocks:Research/@klupp_double-blind_2016.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.02364168,0.0113552,0.02813746,-0.00088754,0.02343267,0.02936046,-0.02195293,0.00447388,-0.01362143,-0.01829356,0.03292842,-0.05608443,0.00448318,0.02994525,-0.004051,0.02617311,-0.0019609,-0.01335451,-0.06929907,0.00378888,0.0337395,-0.06617944,0.05347767,0.01589305,0.0503515,0.04190885,-0.03426815,-0.06523,-0.05746241,-0.19694075,-0.00186006,-0.01985698,-0.00423924,0.00046742,-0.0497252,-0.0431883,-0.05112598,0.06635813,-0.03744657,-0.00266156,0.00273204,0.01639785,0.00838549,0.0295742,0.03701286,-0.03282098,-0.05850611,-0.01989467,0.00745762,0.02395196,-0.0498456,-0.01640561,0.0693522,0.05694977,0.04564339,0.016