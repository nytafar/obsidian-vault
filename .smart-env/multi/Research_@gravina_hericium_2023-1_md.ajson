ro Federico","line":68},{"title":"PDF","target":"biblib/gravina_hericium_2023-1/gravina_hericium_2023-1.pdf","line":70}],"metadata":{"id":"gravina_hericium_2023-1","type":"article-journal","title":"<i>Hericium erinaceus</i>, a medicinal fungus with a centuries-old history: Evidence in gastrointestinal diseases","issued":{"date-parts":[[2023]]},"DOI":"10.3748/wjg.v29.i20.3048","container-title":"World journal of gastroenterology","abstract":"Hericium erinaceus is an edible and medicinal mushroom commonly used in traditional Chinese medicine for centuries. Several studies have highlighted its therapeutic potential for gastrointestinal disorders such as gastritis and inflammatory bowel diseases. In addition, some components of this mushroom appear to possess strong antineoplastic capabilities against gastric and colorectal cancer. This review aims to analyse all available evidence on the digestive therapeutic potential of this fungus as well as the possible underlying molecular mechanisms.","tags":["#literature_note"],"author":[{"family":"Gravina","given":"Antonietta Gerarda","literal":""},{"family":"Pellegrino","given":"Raffaele","literal":""},{"family":"Auletta","given":"Salvatore","literal":""},{"family":"Palladino","given":"Giovanna","literal":""},{"family":"Brandimarte","given":"Giovanni","literal":""},{"family":"D’Onofrio","given":"Rossella","literal":""},{"family":"Arboretto","given":"Giusi","literal":""},{"family":"Imperio","given":"Giuseppe","literal":""},{"family":"Ventura","given":"A.","literal":""},{"family":"Cipullo","given":"Marina","literal":""},{"family":"Romano","given":"Marco","literal":""},{"family":"Federico","given":"Alessandro","literal":""}],"citation-key":"gravina_hericium_2023-1","year":"2023","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["<i>Hericium erinaceus</i>, a medicinal fungus with a centuries-old history: Evidence in gastrointestinal diseases"],"author-links":["[[Author/Antonietta Gerarda Gravina]]","[[Author/Raffael