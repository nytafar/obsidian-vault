-0.00250521,0.00788179,0.18151654,0.04362546,-0.05967726,0.01506227,-0.01313201,0.01799001,0.02474186,0.00489509,-0.00774264,0.0038315,0.11416282,-0.03764252,0.12542765,0.05552518,-0.05402581,-0.02352627,-0.03972765,-0.01175438,-0.02571321,0.0025464,-0.14394057,0.0036175,0.10010548,-0.00620037,-0.04803902,-0.05352674,-0.01741752,-0.00493269,-0.02859428,-0.00601281,-0.01161805,0.03394768,-0.00827135,0.01260829,0.02183881,-0.01429609,-0.05526262,0.03933961,0.00748973,-0.01246188,-0.00447896,0.10819179,0.05621364],"last_embed":{"hash":"i1ih4e","tokens":483}}},"last_read":{"hash":"i1ih4e","at":1774951893201},"class_name":"SmartSource","last_import":{"mtime":1774951825694,"size":1747,"at":1774951884818,"hash":"i1ih4e"},"blocks":{"#---frontmatter---":[1,40],"#Compounds for dementia from Hericium erinaceum":[42,46],"#Compounds for dementia from Hericium erinaceum#{1}":[44,46]},"outlinks":[{"title":"Author/Hirokazu Kawagishi","target":"Author/Hirokazu Kawagishi","line":33},{"title":"Author/Hirokazu Kawagishi","target":"Author/Hirokazu Kawagishi","line":34},{"title":"Author/Cun Zhuang","target":"Author/Cun Zhuang","line":35},{"title":"Author/Cun Zhuang","target":"Author/Cun Zhuang","line":36}],"metadata":{"id":"kawagishi_compounds_2008","type":"article-journal","title":"Compounds for dementia from Hericium erinaceum","issued":{"date-parts":[[2008]]},"DOI":"10.1358/dof.2008.033.02.1173290","container-title":"Drugs of The Future","abstract":"Our group has been conducting a search for compounds for dementia derived from medicinal mushrooms since 1991. A series of benzyl alcohol derivatives (named hericenones C to H), as well as a series of diterpenoid derivatives (named erinacines A to I) were isolated from the mushroom Hericium erinaceum. These compounds significantly induced the synthesis of nerve growth factor (NGF) in vitro and in vivo. In a recent study, dilinoleoyl-phosphatidylethanolamine (DLPE) was isolated from the mushroom and was found to protect against neuronal cell death caused by β-amyloid peptide (Aβ) toxicity, endoplasmic reticulum (ER) stress and oxidative stress. Furthermore, the results of preliminary clinical trials showed that the mushroom was effective in patients with dementia in improving the Functional Independence Measure (FIM) score or retarding disease progression.","tags":["#literature_note"],"author":[{"family":"Kawagishi","given":"Hirokazu","literal":""},{"family":"Kawagishi","given":"Hirokazu","literal":""},{"family":"Zhuang","given":"Cun","literal":""},{"family":"Zhuang","given":"Cun","literal":""}],"citation-key":"kawagishi_compounds_2008","year":"2008","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Compounds for dementia from Hericium erinaceum"],"author-links":["[[Author/Hirokazu Kawagishi]]","[[Author/Hirokazu Kawagishi]]","[[Author/Cun Zhuang]]","[[Author/Cun Zhuang]]"],"attachment":[],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"i1ih4e","at":1774951893189}},"smart_blocks:Research/@kawagishi_compounds_2008.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.05273838,-0.03613922,0.00826226,0.00923693,0.00250763,0.03081778,0.03063801,0.00059793,-0.06036189,-0.01198323,0.00588391,-0.01057417,0.06392838,0.02090953,0.03434594,-0.0012942,-0.04401822,-0.02452806,-0.06260005,0.01570999,0.02819521,-0.019483,0.02929444,0.02350437,0.04749638,0.04802191,0.01465827,-0.01294416,-0.02986025,-0.22127259,-0.06639379,0.00138787,-0.01711738,-0.04847158,-0.01178964,-0.0122208,-0.00576322,0.05155759,-0.04031045,-0.02867787,0.0349296,0.03631623,0.03515297,-0.01610292,-0.02876136,-0.07669199,-0.02720041,-0.0204275,0.02692438,-0.06276117,-0.03544083,-0.03880134,0.00983985,0.03558431,0.06512943,-0.02938762,-0.02292584,0.02869652,0.01787108,0.06671295,0.08033758,0.04893733,-0.17822374,0.0352792,-0.01418853,0.00522547,-0.08495407,-0.04412309,0.07482956,0.04920487,-0.00736773,0.01644955,0.03004782,0.04221861,0.04571896,-0.00336684,-0.0