4884429,-0.0129568,0.20049863,0.04622513,0.00338776,-0.0075057,-0.02845646,0.03072304,0.02178847,-0.00995583,0.04771195,0.04081404,0.07567644,-0.0100548,0.05971491,0.05995886,-0.09606358,-0.00412348,-0.02211189,-0.0525301,-0.01151511,0.00241382,-0.09815963,-0.0182953,0.04547378,-0.04919299,-0.01381526,0.01916769,0.00522719,0.02838604,0.01870865,-0.00027096,0.02425879,0.02933383,-0.02734594,-0.01313549,-0.00339514,0.00272467,-0.0450595,0.02550597,0.0141391,-0.0053326,-0.05481962,0.13588163,0.05197664],"last_embed":{"hash":"ka2tmz","tokens":471}}},"last_read":{"hash":"ka2tmz","at":1774951893559},"class_name":"SmartSource","last_import":{"mtime":1774951826331,"size":4785,"at":1774951884821,"hash":"ka2tmz"},"blocks":{"#---frontmatter---":[1,133],"#Hericium erinaceus mycelium and its small bioactive compounds promote oligodendrocyte maturation with an increase in myelin basic protein.":[135,139],"#Hericium erinaceus mycelium and its small bioactive compounds promote oligodendrocyte maturation with an increase in myelin basic protein.#{1}":[137,139]},"outlinks":[{"title":"Author/Hui Huang","target":"Author/Hui Huang","line":102},{"title":"Author/Hui-Ting Huang","target":"Author/Hui-Ting Huang","line":103},{"title":"Author/Hui Ting Huang","target":"Author/Hui Ting Huang","line":104},{"title":"Author/Chia Hsin Ho","target":"Author/Chia Hsin Ho","line":105},{"title":"Author/Chia-Hsin Ho","target":"Author/Chia-Hsin Ho","line":106},{"title":"Author/Chia Hsin Ho","target":"Author/Chia Hsin Ho","line":107},{"title":"Author/Hsin Yu Sung","target":"Author/Hsin Yu Sung","line":108},{"title":"Author/Hsin-Yu Sung","target":"Author/Hsin-Yu Sung","line":109},{"title":"Author/Li Ya Lee","target":"Author/Li Ya Lee","line":110},{"title":"Author/Li-Ya Lee","target":"Author/Li-Ya Lee","line":111},{"title":"Author/Li Ya Lee","target":"Author/Li Ya Lee","line":112},{"title":"Author/Wan Ping Chen","target":"Author/Wan Ping Chen","line":113},{"title":"Author/Wan-Ping Chen","target":"Author/Wan-Ping Chen","line":114},{"title":"Author/Wan-Ping Chen","target":"Author/Wan-Ping Chen","line":115},{"title":"Author/Wan Ping Chen","target":"Author/Wan Ping Chen","line":116},{"title":"Author/Yu Wen Chen","target":"Author/Yu Wen Chen","line":117},{"title":"Author/Yu Wen Chen","target":"Author/Yu Wen Chen","line":118},{"title":"Author/Yu-Wen Chen","target":"Author/Yu-Wen Chen","line":119},{"title":"Author/Chin Chu Chen","target":"Author/Chin Chu Chen","line":120},{"title":"Author/Chen Chin-Chu","target":"Author/Chen Chin-Chu","line":121},{"title":"Author/Chin Chu Chen","target":"Author/Chin Chu Chen","line":122},{"title":"Author/Chu-Sing Yang","target":"Author/Chu-Sing Yang","line":123},{"title":"Author/Chung-Shi Yang","target":"Author/Chung-Shi Yang","line":124},{"title":"Author/C. S. Yang","target":"Author/C. S. Yang","line":125},{"title":"Author/Chung Shi Yang","target":"Author/Chung Shi Yang","line":126},{"title":"Author/Shun Fen Tzeng","target":"Author/Shun Fen Tzeng","line":127},{"title":"Author/Shun Fen Tzeng","target":"Author/Shun Fen Tzeng","line":128},{"title":"PDF","target":"biblib/huang_hericium_2021/huang_hericium_2021.pdf","line":130}],"metadata":{"id":"huang_hericium_2021","type":"article-journal","title":"Hericium erinaceus mycelium and its small bioactive compounds promote oligodendrocyte maturation with an increase in myelin basic protein.","issued":{"date-parts":[[2021]]},"DOI":"10.1038/s41598-021-85972-2","container-title":"Scientific Reports","abstract":"Oligodendrocytes (OLs), myelin-producing glia in the central nervous system (CNS), produce a myelin extension that enwraps axons to facilitate action potential propagation. An effective approach to induce oligodendrogenesis and myelination is important to foster CNS development and promote myelin repair in neurological diseases. Hericium (H.) erinaceus, an edible and culinary-medicinal mushroom, has been characterized as having neuroprotective activities. However, its effect on OL differentiation has not yet been uncovered. In this study using oligodendrocyte precursor cell (OPC) cultures and an ex vivo cerebellar slice system, we found that the extract from H. erinaceus mycelium (HEM) not only promoted the differentiation of OPCs to OLs in the differentiation medium, but also increased the level of myelin basic protein (MBP) on neuronal fibers. Moreover, daily oral administration of HEM into neonatal rat pups for 7days enhanced MBP expression and OLs in the corpus callosum of the postnatal rat brain. The effect of HEM-derived bioactive compounds, the diterpenoid xylosides erinacine A (HeA) and HeC and a sesterterpene with 5 isoprene units called HeS, were further evaluated. The results showed that HeA and HeS more potently stimulated MBP expression in OLs and increased the number of OLs. Moreover, overlap between MBP immunoreactivity and neuronal fibers in cultured cerebellar tissue slices was significantly increased in the presence of HeA and HeS. In summary, our findings indicate that HEM extract and its ingredients HeA and HeS display promising functional effects and promote OL maturation, providing insights into their potential for myelination in neurodevelopmental disorders.","tags":["#literature_note"],"author":[{"family":"Huang","given":"Hui","literal":""},{"family":"Huang","given":"Hui-Ting","literal":""},{"family":"Huang","given":"Hui Ting","literal":""},{"family":"Ho","given":"Chia Hsin","literal":""},{"family":"Ho","given":"Chia-Hsin","literal":""},{"family":"Ho","given":"Chia Hsin","literal":""},{"family":"Sung","given":"Hsin Yu","literal":""},{"family":"Sung","given":"Hsin-Yu","literal":""},{"family":"Lee","given":"Li Ya","literal":""},{"family":"Lee","given":"Li-Ya","literal":""},{"family":"Lee","given":"Li Ya","literal":""},{"family":"Chen","given":"Wan Ping","literal":""},{"family":"Chen","given":"Wan-Ping","literal":""},{"family":"Chen","given":"Wan-Ping","literal":""},{"family":"Chen","given":"Wan Ping","literal":""},{"family":"Chen","given":"Yu Wen","literal":""},{"family":"Chen","given":"Yu Wen","literal":""},{"family":"Chen","given":"Yu-Wen","literal":""},{"family":"Chen","given":"Chin Chu","literal":""},{"family":"Chin-Chu","given":"Chen","literal":""},{"family":"Chen","given":"Chin Chu","literal":""},{"family":"Yang","given":"Chu-Sing","literal":""},{"family":"Yang","given":"Chung-Shi","literal":""},{"family":"Yang","given":"C. S.","literal":""},{"family":"Yang","given":"Chung Shi","literal":""},{"family":"Tzeng","given":"Shun Fen","literal":""},{"family":"Tzeng","given":"Shun Fen","literal":""}],"citation-key":"huang_hericium_2021","year":"2021","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Hericium erinaceus mycelium and its small bioactive compounds promote oligodendrocyte maturation with an increase in myelin basic protein."],"author-links":["[[Author/Hui Huang]]","[[Author/Hui-Ting Huang]]","[[Author/Hui Ting Huang]]","[[Author/Chia Hsin Ho]]","[[Author/Chia-Hsin Ho]]","[[Author/Chia Hsin Ho]]","[[Author/Hsin Yu Sung]]","[[Author/Hsin-Yu Sung]]","[[Author/Li Ya Lee]]","[[Author/Li-Ya Lee]]","[[Author/Li Ya Lee]]","[[Author/Wan Ping Chen]]","[[Author/Wan-Ping Chen]]","[[Author/Wan-Ping Chen]]","[[Author/Wan Ping Chen]]","[[Author/Yu Wen Chen]]","[[Author/Yu Wen Chen]]","[[Author/Yu-Wen Chen]]","[[Author/Chin Chu Chen]]","[[Author/Chen Chin-Chu]]","[[Author/Chin Chu Chen]]","[[Author/Chu-Sing Yang]]","[[Author/Chung-Shi Yang]]","[[Author/C. S. Yang]]","[[Author/Chung Shi Yang]]","[[Author/Shun Fen Tzeng]]","[[Author/Shun Fen Tzeng]]"],"attachment":["[[biblib/huang_hericium_2021/huang_hericium_2021.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"ka2tmz","at":1774951893550}},"smart_blocks:Research/@huang_hericium_2021.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.02233121,-0.06484848,0.03173668,-0.05365986,-0.0059011,0.04023784,-0.01560602,0.07818508,-0.0506798,0.02738349,0.01499687,-0