,0.0243609,0.1818267,0.00358305,-0.03807705,-0.04603481,0.00745701,0.02357991,0.05545208,-0.01177342,-0.007881,0.01079451,0.0790596,0.01319991,0.0735037,0.01970468,-0.11772168,-0.03492045,-0.0204257,0.00841971,0.01454713,0.00293692,-0.07754657,-0.02685734,0.07587365,0.03962228,-0.00211711,-0.00117471,-0.03498793,-0.02014753,0.01683818,-0.03053816,0.04937447,0.01592693,0.03322649,-0.00734212,-0.02179608,-0.06069429,-0.04543461,0.00316259,0.03661902,-0.00638149,-0.03761909,0.09063003,0.04699862],"last_embed":{"hash":"4hz3dr","tokens":450}}},"last_read":{"hash":"4hz3dr","at":1774951887712},"class_name":"SmartSource","last_import":{"mtime":1774951817545,"size":2696,"at":1774951884783,"hash":"4hz3dr"},"blocks":{"#---frontmatter---":[1,64],"#Effects of Hericium erinaceus on amyloid β(25-35) peptide-induced learning and memory deficits in mice.":[66,70],"#Effects of Hericium erinaceus on amyloid β(25-35) peptide-induced learning and memory deficits in mice.#{1}":[68,70]},"outlinks":[{"title":"Author/Koichiro Mori","target":"Author/Koichiro Mori","line":51},{"title":"Author/Koichiro Mori","target":"Author/Koichiro Mori","line":52},{"title":"Author/Yutaro Obara","target":"Author/Yutaro Obara","line":53},{"title":"Author/Takuya Moriya","target":"Author/Takuya Moriya","line":54},{"title":"Author/Yutaro Obara","target":"Author/Yutaro Obara","line":55},{"title":"Author/Satoshi Inatomi","target":"Author/Satoshi Inatomi","line":56},{"title":"Author/Takahiro Moriya","target":"Author/Takahiro Moriya","line":57},{"title":"Author/Satoshi Inatomi","target":"Author/Satoshi Inatomi","line":58},{"title":"Author/Norimichi Nakahata","target":"Author/Norimichi Nakahata","line":59},{"title":"Author/Norimichi Nakahata","target":"Author/Norimichi Nakahata","line":60}],"metadata":{"id":"mori_effects_2011","type":"article-journal","title":"Effects of Hericium erinaceus on amyloid β(25-35) peptide-induced learning and memory deficits in mice.","issued":{"date-parts":[[2011]]},"DOI":"10.2220/biomedres.32.67","container-title":"Biomedical Research-tokyo","abstract":"The mushroom Hericium erinaceus has been used as a food and herbal medicine since ancient times in East Asia. It has been reported that H. erinaceus promotes nerve growth factor secretion in vitro and in vivo. Nerve growth factor is involved in maintaining and organizing cholinergic neurons in the central nervous system. These findings suggest that H. erinaceus may be appropriate for the prevention or treatment of dementia. In the present study, we examined the effects of H. erinaceus on amyloid β(25-35) peptide-induced learning and memory deficits in mice. Mice were administered 10 μg of amyloid β(25-35) peptide intracerebroventricularly on days 7 and 14, and fed a diet containing H. erinaceus over a 23-d experimental period. Memory and learning function was examined using behavioral pharmacological methods including the Y-maze test and the novelobject recognition test. The results revealed that H. erinaceus prevented impairments of spatial short-term and visual recognition memory induced by amyloid β(25-35) peptide. This finding indicates that H. erinaceus may be useful in the prevention of cognitive dysfunction.","tags":["#literature_note"],"author":[{"family":"Mori","given":"Koichiro","literal":""},{"family":"Mori","given":"Koichiro","literal":""},{"family":"Obara","given":"Yutaro","literal":""},{"family":"Moriya","given":"Takuya","literal":""},{"family":"Obara","given":"Yutaro","literal":""},{"family":"Inatomi","given":"Satoshi","literal":""},{"family":"Moriya","given":"Takahiro","literal":""},{"family":"Inatomi","given":"Satoshi","literal":""},{"family":"Nakahata","given":"Norimichi","literal":""},{"family":"Nakahata","given":"Norimichi","literal":""}],"citation-key":"mori_effects_2011","year":"2011","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Effects of Hericium erinaceus on amyloid β(25-35) peptide-induced learning and memory deficits in mice."],"author-links":["[[Author/Koichiro Mori]]","[[Author/Koichiro Mori]]","[[Author/Yutaro Obara]]","[[Author/Takuya Moriya]]","[[Author/Yutaro Obara]]","[[Author/Satoshi Inatomi]]","[[Author/Takahiro Moriya]]","[[Author/Satoshi Inatomi]]","[[Author/Norimichi Nakahata]]","[[Author/Norimichi Nakahata]]"],"attachment":[],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"4hz3dr","at":1774951887703}},"smart_blocks:Research/@mori_effects_2011.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[0.00913124,-0.01244999,0.03898038,-0.01019335,-0.02997342,0.03204907,0.03459454,0.05389861,-0.05463707,-0.02645101,-0.00047596,-0.06375322,0.05337142,0.08817165,-0.01191166,0.00896779,-0.03364046,0.0096892,-0.09261496,-0.01528453,0.04641858,-0.03824541,0.0264722,0.00745015,-0.01801827,0.02188082,-0.0603747,-0.01953919,-0.04264662,-0.22123168,-0.00387889,-0.0240826,0.03209475,-0.00867724,-0.06385882,0.0025475,-0.03300773,0.01950315,-0.02562565,-0.01369197,0.07625455,0.04813957,0.04848886,-0.00102167,0.00117505,-0.04401501,-0.0111759,-0.07283201,0.0297081,-0.00578639,-0.00952743,-0.02773366,0.06713962,0.08276137,0.05232754,0.01512017,-0.02771278,0.05533167,0.01809241,0.07354493,0.0341264,0.07162946,-0.17330846,0.06874585,0.04283604,0.01666825,-0.07595932,-0.00265189,0.08114344,0.01964347,-0.05184233,0.06295877,0.05286533,0.04683141,0.04106576,-0.00577814,-0.03781224,-0.03597935,0.03964601,-0.01988325,0.08102253,0.0649415,0.06034671,-0.02504597,0.01279234,-0.06444214,-0.02025217,-0.06717545,-0.00599162,-0.01051294,-0.03681086,-0.02130535,-0.05524895,0.00468956,-0.02378563,-0.01349542,0.00875645,-0.00994536,-0.14744005,0.11857457,-0.07553377,0.00886622,-0.04180261,-0.08789702,0.02881999,-0.04380811,0.0115879,-0.03809268,-0.0127817,0.03598738,0.05676763,-0.03808479,-0.00179256,0.03683335,0.0217079,0.0201965,0.15250604,0.01818916,-0.0200114,-0.00530779,0.0051494,0.02756123,0.03028132,0.03617477,0.00533947,-0.0435628,-0.02172192,0.06397771,0.0323042