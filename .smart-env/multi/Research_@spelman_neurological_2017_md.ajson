,0.03989949,-0.03142774,0.18054782,0.01282097,-0.06775135,0.00965967,-0.01295111,0.04008982,0.03256722,0.02773203,0.0070753,-0.03759872,0.10471109,0.04255059,0.06781011,0.05988151,-0.07835975,-0.08901577,-0.00733411,-0.01306844,-0.02470817,-0.02287689,-0.09021445,-0.01433119,0.09972164,-0.04931346,-0.06308144,-0.01446363,0.02706599,0.01325175,-0.01383146,-0.04261949,-0.00943383,0.0566355,-0.0017348,0.02808655,0.06691865,-0.03765051,-0.03623052,0.02431566,0.01406881,-0.04854373,-0.04922891,0.09430035,0.05083843],"last_embed":{"hash":"uixc0k","tokens":442}}},"last_read":{"hash":"uixc0k","at":1774951887806},"class_name":"SmartSource","last_import":{"mtime":1774951817744,"size":1958,"at":1774951884784,"hash":"uixc0k"},"blocks":{"#---frontmatter---":[1,53],"#Neurological Activity of Lion’s Mane (Hericium erinaceus)":[55,59],"#Neurological Activity of Lion’s Mane (Hericium erinaceus)#{1}":[57,59]},"outlinks":[{"title":"Author/Kevin Spelman","target":"Author/Kevin Spelman","line":42},{"title":"Author/Kevin Spelman","target":"Author/Kevin Spelman","line":43},{"title":"Author/Kevin Spelman","target":"Author/Kevin Spelman","line":44},{"title":"Author/Elizabeth Sutherland","target":"Author/Elizabeth Sutherland","line":45},{"title":"Author/Elizabeth Sutherland","target":"Author/Elizabeth Sutherland","line":46},{"title":"Author/Aravind Bagade","target":"Author/Aravind Bagade","line":47},{"title":"Author/Aravind Bagade","target":"Author/Aravind Bagade","line":48},{"title":"PDF","target":"biblib/spelman_neurological_2017/spelman_neurological_2017.pdf","line":50}],"metadata":{"id":"spelman_neurological_2017","type":"article-journal","title":"Neurological Activity of Lion’s Mane (Hericium erinaceus)","issued":{"date-parts":[[2017]]},"DOI":"10.14200/jrm.2017.6.0108","container-title":"null","abstract":"Hericium erinaceus, most commonly known as lion’s mane, is an edible fungus, with a long history of use in Traditional Chinese Medicine. The mushroom is abundant in bioactive compounds including β-glucan polysaccharides; hericenones and erinacine terpenoids; isoindolinones; sterols; and myconutrients, which potentially have neuroprotective and neuroregenerative properties. Because of its anti-inflammatory properties and promotion of nerve growth factor gene expression and neurite (axon or dendrite) outgrowth,H. erinaceusmycelium shows great promise for the treatment of Alzheimer’s and Parkinson’s diseases. The fungus was well tolerated in two clinical studies, with few adverse events reported.","tags":["#literature_note"],"author":[{"family":"Spelman","given":"Kevin","literal":""},{"family":"Spelman","given":"Kevin","literal":""},{"family":"Spelman","given":"Kevin","literal":""},{"family":"Sutherland","given":"Elizabeth","literal":""},{"family":"Sutherland","given":"Elizabeth","literal":""},{"family":"Bagade","given":"Aravind","literal":""},{"family":"Bagade","given":"Aravind","literal":""}],"citation-key":"spelman_neurological_2017","year":"2017","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Neurological Activity of Lion’s Mane (Hericium erinaceus)"],"author-links":["[[Author/Kevin Spelman]]","[[Author/Kevin Spelman]]","[[Author/Kevin Spelman]]","[[Author/Elizabeth Sutherland]]","[[Author/Elizabeth Sutherland]]","[[Author/Aravind Bagade]]","[[Author/Aravind Bagade]]"],"attachment":["[[biblib/spelman_neurological_2017/spelman_neurological_2017.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"uixc0k","at":1774951887797}},"smart_blocks:Research/@spelman_neurological_2017.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[0.01743351,-0.03311255,0.02264422,0.00005176,-0.00977318,0.0008399,0.00106197,0.05825049,-0.04335065,0.05288896,0.04187717,-0.08531073,0.03283049,0.01476369,-0.00941999,0.01512986,-0.00050993,0.00970154,-0.07105649,0.01807314,0.04346175,-0.03539745,0.02517633,-0.00647106,0.04070485,0.05231078,-0.00997171,-0.03217684,-0.05268779,-0.2