03370411,-0.01649999,0.1477039,0.02372434,0.03113126,-0.00955612,0.00206881,0.00099041,0.02937619,0.04404736,-0.04365856,0.07480992,0.06610107,-0.01890775,0.05286185,0.06516303,-0.04120534,-0.00563669,-0.04524852,0.0354656,0.03565597,0.02051541,-0.01180118,-0.05515771,0.12023751,-0.06840034,-0.03935358,-0.06373007,-0.00803955,-0.02105994,-0.02331149,-0.00350814,-0.03501583,0.05243064,0.00971566,-0.00527915,0.00163071,-0.05232768,-0.01231061,-0.03984798,0.03268136,0.01142102,-0.05589436,0.09912402,0.0581217],"last_embed":{"hash":"2tc3xk","tokens":474}}},"last_read":{"hash":"2tc3xk","at":1774951891303},"class_name":"SmartSource","last_import":{"mtime":1774951822277,"size":4094,"at":1774951884806,"hash":"2tc3xk"},"blocks":{"#---frontmatter---":[1,105],"#Polysaccharide Krestin is a novel TLR2 agonist that mediates inhibition of tumor growth via stimulation of CD8 T cells and NK cells":[107,111],"#Polysaccharide Krestin is a novel TLR2 agonist that mediates inhibition of tumor growth via stimulation of CD8 T cells and NK cells#{1}":[109,111]},"outlinks":[{"title":"Author/Hailing Lu","target":"Author/Hailing Lu","line":81},{"title":"Author/Hailing Lu","target":"Author/Hailing Lu","line":82},{"title":"Author/Yi Yang","target":"Author/Yi Yang","line":83},{"title":"Author/Yi Yang","target":"Author/Yi Yang","line":84},{"title":"Author/Ekram Gad","target":"Author/Ekram Gad","line":85},{"title":"Author/Ekram Gad","target":"Author/Ekram Gad","line":86},{"title":"Author/Cynthia A. Wenner","target":"Author/Cynthia A. Wenner","line":87},{"title":"Author/Cynthia A. Wenner","target":"Author/Cynthia A. Wenner","line":88},{"title":"Author/Amy Chang","target":"Author/Amy Chang","line":89},{"title":"Author/Amy E. Chang","target":"Author/Amy E. Chang","line":90},{"title":"Author/Emily R. Larson","target":"Author/Emily R. Larson","line":91},{"title":"Author/Emily R. Larson","target":"Author/Emily R. Larson","line":92},{"title":"Author/Yushe Dang","target":"Author/Yushe Dang","line":93},{"title":"Author/Yushe Dang","target":"Author/Yushe Dang","line":94},{"title":"Author/Mark R. Martzen","target":"Author/Mark R. Martzen","line":95},{"title":"Author/Mark R. Martzen","target":"Author/Mark R. Martzen","line":96},{"title":"Author/Leanna J. Standish","target":"Author/Leanna J. Standish","line":97},{"title":"Author/Leanna J. Standish","target":"Author/Leanna J. Standish","line":98},{"title":"Author/Mary L. Disis","target":"Author/Mary L. Disis","line":99},{"title":"Author/Mary L. Disis","target":"Author/Mary L. Disis","line":100},{"title":"PDF","target":"biblib/lu_polysaccharide_2011/lu_polysaccharide_2011.pdf","line":102}],"metadata":{"id":"lu_polysaccharide_2011","type":"article-journal","title":"Polysaccharide Krestin is a novel TLR2 agonist that mediates inhibition of tumor growth via stimulation of CD8 T cells and NK cells","issued":{"date-parts":[[2011]]},"DOI":"10.1158/1078-0432.ccr-10-1763","container-title":"Clinical Cancer Research","abstract":"Purpose: Polysaccharide krestin (PSK) is a mushroom extract that has been long used in Asia and recently in Western countries as a treatment for cancer due to its presumed immune potentiating effects. Although there have been reports of clinical responses after patients have ingested PSK, the mechanism of action of the agent remains undefined. The current study was undertaken to investigate the mechanism of the antitumor actions of PSK. Experimental Design: The immunostimulatory effect of PSK was first evaluated in vitro using splenocytes from neu transgenic mice and Toll-like receptor (TLR) 2 knockout (TLR2 −/− ) mice. Then the immunostimualtory and antitumor effect of PSK was determined using tumor-bearing neu transgenic mice, TLR2 −/− , and wild-type C57BL/6 mice. Results: We demonstrate that PSK is a selective TLR2 agonist, and the activation of dendritic cells (DC) and T cells by PSK is dependent on TLR2. Oral administration of PSK in neu transgenic mice significantly inhibits breast cancer growth. Selective depletion of specific cell populations suggests that the antitumor effect of PSK is dependent on both CD8 + T cell and NK cells, but not CD4 + T cells. PSK does not inhibit tumor growth in TLR2 −/− mice suggesting that the antitumor effect is mediated by TLR2. Conclusion: These results demonstrate that PSK, a natural product commonly used for the treatment of cancer, is a specific TLR2 agonist and has potent antitumor effects via stimulation of both innate and adaptive immune pathways. Clin Cancer Res; 17(1); 67–76. ©2010 AACR .","tags":["#literature_note"],"author":[{"family":"Lu","given":"Hailing","literal":""},{"family":"Lu","given":"Hailing","literal":""},{"family":"Yang","given":"Yi","literal":""},{"family":"Yang","given":"Yi","literal":""},{"family":"Gad","given":"Ekram","literal":""},{"family":"Gad","given":"Ekram","literal":""},{"family":"Wenner","given":"Cynthia A.","literal":""},{"family":"Wenner","given":"Cynthia A.","literal":""},{"family":"Chang","given":"Amy","literal":""},{"family":"Chang","given":"Amy E.","literal":""},{"family":"Larson","given":"Emily R.","literal":""},{"family":"Larson","given":"Emily R.","literal":""},{"family":"Dang","given":"Yushe","literal":""},{"family":"Dang","given":"Yushe","literal":""},{"family":"Martzen","given":"Mark R.","literal":""},{"family":"Martzen","given":"Mark R.","literal":""},{"family":"Standish","given":"Leanna J.","literal":""},{"family":"Standish","given":"Leanna J.","literal":""},{"family":"Disis","given":"Mary L.","literal":""},{"family":"Disis","given":"Mary L.","literal":""}],"citation-key":"lu_polysaccharide_2011","year":"2011","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Polysaccharide Krestin is a novel TLR2 agonist that mediates inhibition of tumor growth via stimulation of CD8 T cells and NK cells"],"author-links":["[[Author/Hailing Lu]]","[[Author/Hailing Lu]]","[[Author/Yi Yang]]","[[Author/Yi Yang]]","[[Author/Ekram Gad]]","[[Author/Ekram Gad]]","[[Author/Cynthia A. We