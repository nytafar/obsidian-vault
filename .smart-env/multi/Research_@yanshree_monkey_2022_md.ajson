259,-0.01003764,0.1794149,0.02634826,-0.03511283,-0.02471408,-0.01135544,0.06560548,0.03251263,0.01174278,0.03604437,0.00894265,0.0996979,0.00345493,0.09668413,0.05617103,-0.09299567,-0.03092019,0.01547761,-0.00394478,0.02374199,0.03124007,-0.07885823,-0.01670744,0.10135573,-0.01318352,0.01247139,0.00906177,-0.04290442,-0.00168417,0.01201954,-0.03065885,0.01910182,0.00620827,0.01625283,-0.0007161,0.04288426,-0.01568306,-0.04080687,-0.00840903,0.01307397,0.02984018,-0.03605276,0.09047491,0.05113016],"last_embed":{"hash":"nqx80t","tokens":409}}},"last_read":{"hash":"nqx80t","at":1774951895070},"class_name":"SmartSource","last_import":{"mtime":1774951827976,"size":2864,"at":1774951884827,"hash":"nqx80t"},"blocks":{"#---frontmatter---":[1,73],"#The Monkey Head Mushroom and Memory Enhancement in Alzheimer’s Disease":[75,79],"#The Monkey Head Mushroom and Memory Enhancement in Alzheimer’s Disease#{1}":[77,79]},"outlinks":[{"title":"Author/None Yanshree","target":"Author/None Yanshree","line":57},{"title":"Author/Yanshree","target":"Author/Yanshree","line":58},{"title":"Author/Wing Shan Yu","target":"Author/Wing Shan Yu","line":59},{"title":"Author/Wing Shan Yu","target":"Author/Wing Shan Yu","line":60},{"title":"Author/Man-Lung Fung","target":"Author/Man-Lung Fung","line":61},{"title":"Author/Man Lung Fung","target":"Author/Man Lung Fung","line":62},{"title":"Author/Chi Wai Lee","target":"Author/Chi Wai Lee","line":63},{"title":"Author/Chi Wai Lee","target":"Author/Chi Wai Lee","line":64},{"title":"Author/Lee Wei Lim","target":"Author/Lee Wei Lim","line":65},{"title":"Author/Lee Wei Lim","target":"Author/Lee Wei Lim","line":66},{"title":"Author/Kah-Hui Wong","target":"Author/Kah-Hui Wong","line":67},{"title":"Author/Kah-Hui Wong","target":"Author/Kah-Hui Wong","line":68},{"title":"PDF","target":"biblib/yanshree_monkey_2022/yanshree_monkey_2022.pdf","line":70}],"metadata":{"id":"yanshree_monkey_2022","type":"article-journal","title":"The Monkey Head Mushroom and Memory Enhancement in Alzheimer’s Disease","issued":{"date-parts":[[2022]]},"DOI":"10.3390/cells11152284","container-title":"Cells","abstract":"Alzheimer’s disease (AD) is a neurodegenerative disorder, and no effective treatments are available to treat this disorder. Therefore, researchers have been investigating Hericium erinaceus, or the monkey head mushroom, an edible medicinal mushroom, as a possible treatment for AD. In this narrative review, we evaluated six preclinical and three clinical studies of the therapeutic effects of Hericium erinaceus on AD. Preclinical trials have successfully demonstrated that extracts and bioactive compounds of Hericium erinaceus have potential beneficial effects in ameliorating cognitive functioning and behavioral deficits in animal models of AD. A limited number of clinical studies have been conducted and several clinical trials are ongoing, which have thus far shown analogous outcomes to the preclinical studies. Nonetheless, future research on Hericium erinaceus needs to focus on elucidating the specific neuroprotective mechanisms and the target sites in AD. Additionally, standardized treatment parameters and universal regulatory systems need to be established to further ensure treatment safety and efficacy. In conclusion, Hericium erinaceus has therapeutic potential and may facilitate memory enhancement in patients with AD.","tags":["#literature_note"],"author":[{"family":"Yanshree","given":"None","literal":""},{"family":"Yanshree","given":"","literal":""},{"family":"Yu","given":"Wing Shan","literal":""},{"family":"Yu","given":"Wing Shan","literal":""},{"family":"Fung","given":"Man-Lung","literal":""},{"family":"Fung","given":"Man Lung","literal":""},{"family":"Lee","given":"Chi Wai","literal":""},{"family":"Lee","given":"Chi Wai","literal":""},{"family":"Lim","given":"Lee Wei","literal":""},{"family":"Lim","given":"Lee Wei","literal":""},{"family":"Wong","given":"Kah-Hui","literal":""},{"family":"Wong","given":"Kah-Hui","literal":""}],