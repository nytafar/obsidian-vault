2,-0.04258178,0.03323272,0.00825097,0.18650466,-0.0216574,-0.00857609,0.00029276,-0.00766908,0.0142309,-0.04034372,0.0509579,-0.0073479,0.06841042,0.14017713,0.01031037,0.03453936,0.04732085,0.02423938,-0.0385736,0.00458455,-0.00499456,0.01847113,-0.03402614,-0.10419533,-0.06542118,0.10436707,-0.07103788,-0.0604853,-0.08043934,0.04345006,-0.03549454,-0.02776131,-0.04229763,-0.05903068,-0.00245496,-0.02655825,-0.05779907,-0.04399098,-0.032822,-0.0463079,-0.00576772,-0.01471534,0.03529225,-0.08052075,0.08494463,0.01881176],"last_embed":{"hash":"1nhlser","tokens":477}}},"last_read":{"hash":"1nhlser","at":1774951891696},"class_name":"SmartSource","last_import":{"mtime":1774951822936,"size":2835,"at":1774951884809,"hash":"1nhlser"},"blocks":{"#---frontmatter---":[1,80],"#Polysaccharides of higher fungi: biological role, structure and antioxidative activity":[82,86],"#Polysaccharides of higher fungi: biological role, structure and antioxidative activity#{1}":[84,86]},"outlinks":[{"title":"Author/Maja Kozarski","target":"Author/Maja Kozarski","line":63},{"title":"Author/Maja Kozarski","target":"Author/Maja Kozarski","line":64},{"title":"Author/Anita Klaus","target":"Author/Anita Klaus","line":65},{"title":"Author/Anita Klaus","target":"Author/Anita Klaus","line":66},{"title":"Author/Miomir Nikšić","target":"Author/Miomir Nikšić","line":67},{"title":"Author/Miomir Niksic","target":"Author/Miomir Niksic","line":68},{"title":"Author/L. J. L. D. van Griensven","target":"Author/L. J. L. D. van Griensven","line":69},{"title":"Author/L. J. L. D. van Griensven","target":"Author/L. J. L. D. van Griensven","line":70},{"title":"Author/L. J. L. D. van Griensven","target":"Author/L. J. L. D. van Griensven","line":71},{"title":"Author/L. J. L. D. van Griensven","target":"Author/L. J. L. D. van Griensven","line":72},{"title":"Author/M. Miroslav Vrvic","target":"Author/M. Miroslav Vrvic","line":73},{"title":"Author/Miroslav M. Vrvić","target":"Author/Miroslav M. Vrvić","line":74},{"title":"Author/Dragica Jakovljević","target":"Author/Dragica Jakovljević","line":75},{"title":"Author/Dragica Jakovljević","target":"Author/Dragica Jakovljević","line":76}],"metadata":{"id":"kozarski_polysaccharides_2014","type":"article-journal","title":"Polysaccharides of higher fungi: biological role, structure and antioxidative activity","issued":{"date-parts":[[2014]]},"DOI":"10.2298/hemind121114056k","container-title":"Hemijska Industrija","abstract":"The fungal polysaccharides attract a lot of attention due to their multiple challenging biological properties, such as: anti-tumor, anti-viral, anticomplementary, anticoagulant, hypolipidemic, immunomodulatory and immune-stimulatory activities, which all together make them suitable for application in many quite distinctive areas, such as food industry, biomedicine, cosmetology, agriculture, environmental protection and waste water management. This article presents results with respect to biological properties, structure and procedures related to the isolation and activation of polysaccharides of higher fungi. It is considered and presented along with a review of the critical antioxidative activity and possible influence of the structural composition of polysaccharide extracts (isolated from these higher fungi) upon their antioxidative properties.","tags":["#literature_note"],"author":[{"family":"Kozarski","given":"Maja","literal":""},{"family":"Kozarski","given":"Maja","literal":""},{"family":"Klaus","given":"Anita","literal":""},{"family":"Klaus","given":"Anita","literal":""},{"family":"Nikšić","given":"Miomir","literal":""},{"family":"Niksic","given":"Miomir","literal":""},{"family":"Griensven","given":"L. J. L. D. van","literal":""},{"family":"Griensven","given":"L. J. L. D. van","literal":""},{"family":"Griensven","given":"L. J. L. D. van","literal":""},{"family":"Griensven","given":"L. J. L. D. van","literal":""},{"family":"Vrvic","given":"M. Miroslav","literal":""},{"family":"Vrvić","given":"Miroslav M.","literal":""},{"family":"Jakovljević","given":"Dragica","literal":""},{"family":"Jakovljević","given":"Dragica","literal":""}],"citation-key":"kozarski_polysaccharides_2014","year":"2014","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Polysaccharides of higher fungi: biological role, structure and antioxidative activity"],"author-links":["[[Author/Maja Kozarski]]","[[Author/Maja Kozarski]]","[[Author/Anita Klaus]]","[[Author/Anita Klaus]]","[[Author/Miomir Nikšić]]","[[Author/Miomir Niksic]]","[[Author/L. J. L. D. van Griensven]]","[[Author/L. J. L. D. van Griensven]]","[[Author/L. J. L. D. van Griensven]]","[[Author/L. J. L. D. van Griensven]]","[[Author/M. Miroslav Vrvic]]","[[Author/Miroslav M. Vrvić]]","[[Author/Dragica Jakovljević]]","[[Author/Dragica Jakovljević]]"],"attachment":[],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"1nhlser","at":1774951891687}},"smart_blocks:Research/@kozarski_polysaccharides_2014.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.06289501,-0.00786879,0.01326045,0.01887034,0.05273267,-0.02848282,0.0385126,0.06073445,-0.03565408,-0.0140867,-0.00799746,-0.08342969,0.01216158,-0.00746936,-0.00477234,0.00939882,0.00786263,0.0573988,-0.09865257,0.02978708,0.07877605,-0.08177381,-0.00233576,-0.04564193,0.09674298,0.0682594,-0.01114759,-0.02400707,-0.02458526,-0.22380452,-0.02532176,0.02005809,0.10538749,-0.02368579,-0.01835866,-0.0092437,-0.08773524,0.02583617,-0.03909865,0.04593154,0.0487378,0.08723824,-0.00754332,0.04897502,-0.02591208,-0.07671306,-0.04421399,-0.0232871,-0.03459169,-0.02362904,-0.02134351,-0.0162262,-0.01415178,-0.00729573,0.01811933,-0.00635452,-0.00451037,0.03225636,0.05730554,0.06466278,0.09860416,0.00943668,-0.12661095,0.07701798,0.06916169,-0.01473451,-0.08816763,0.01867188,0.05121324,0.03295113,-0.03433467,0.03625753,0.05706163,0.04575012,0.0117428,-0.03718488,-0.06487235,-0.06442628,-0.00322674,0.01615666,0.01818971,0.06636546,