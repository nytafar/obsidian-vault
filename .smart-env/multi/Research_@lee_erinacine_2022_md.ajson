03519116,-0.01469169,0.19748768,-0.00340679,-0.01732698,-0.00211649,-0.0117828,0.01284139,0.0327974,0.03412097,-0.02220333,0.01197805,0.0975514,-0.0309968,0.09352584,0.05159399,-0.08274883,0.00408955,-0.02543195,-0.01596529,0.01907114,-0.00076261,-0.07335216,-0.02823033,0.05351444,-0.03475254,-0.02311739,0.00573847,-0.01926779,0.01574735,0.01195585,0.00287847,-0.00106026,0.01131705,-0.03318965,-0.00024086,0.0264778,0.00839313,-0.03035206,0.02004199,0.01216337,0.01418284,-0.04505537,0.12761836,0.06982792],"last_embed":{"hash":"xdrahr","tokens":502}}},"last_read":{"hash":"xdrahr","at":1774951892824},"class_name":"SmartSource","last_import":{"mtime":1774951824936,"size":4172,"at":1774951884816,"hash":"xdrahr"},"blocks":{"#---frontmatter---":[1,73],"#Erinacine A Prevents Lipopolysaccharide-Mediated Glial Cell Activation to Protect Dopaminergic Neurons against Inflammatory Factor-Induced Cell Death In Vitro and In Vivo":[75,79],"#Erinacine A Prevents Lipopolysaccharide-Mediated Glial Cell Activation to Protect Dopaminergic Neurons against Inflammatory Factor-Induced Cell Death In Vitro and In Vivo#{1}":[77,79]},"outlinks":[{"title":"Author/Sang Hun Lee","target":"Author/Sang Hun Lee","line":57},{"title":"Author/Shou-Lun Lee","target":"Author/Shou-Lun Lee","line":58},{"title":"Author/Jing-Ya Hsu","target":"Author/Jing-Ya Hsu","line":59},{"title":"Author/Jing-Ya Hsu","target":"Author/Jing-Ya Hsu","line":60},{"title":"Author/Ting-Chun Chen","target":"Author/Ting-Chun Chen","line":61},{"title":"Author/Ting-Chun Chen","target":"Author/Ting-Chun Chen","line":62},{"title":"Author/Chun-Chih Huang","target":"Author/Chun-Chih Huang","line":63},{"title":"Author/Chun-Chih Huang","target":"Author/Chun-Chih Huang","line":64},{"title":"Author/Tong Wu","target":"Author/Tong Wu","line":65},{"title":"Author/Tzong-Yuan Wu","target":"Author/Tzong-Yuan Wu","line":66},{"title":"Author/Ting-Yu Chin","target":"Author/Ting-Yu Chin","line":67},{"title":"Author/Ting-Yu Chin","target":"Author/Ting-Yu Chin","line":68},{"title":"PDF","target":"biblib/lee_erinacine_2022/lee_erinacine_2022.pdf","line":70}],"metadata":{"id":"lee_erinacine_2022","type":"article-journal","title":"Erinacine A Prevents Lipopolysaccharide-Mediated Glial Cell Activation to Protect Dopaminergic Neurons against Inflammatory Factor-Induced Cell Death In Vitro and In Vivo","issued":{"date-parts":[[2022]]},"DOI":"10.3390/ijms23020810","container-title":"International Journal of Molecular Sciences","abstract":"Hericium erinaceus (HE) is a common edible mushroom consumed in several Asian countries and considered to be a medicinal mushroom with neuroprotective effects. Erinacine A (EA) is a bioactive compound in Hericium erinaceus mycelium (HEM) that has been shown to have a neuroprotective effect against neurodegenerative diseases, e.g., Parkinson’s disease (PD). Although the etiology of PD is still unclear, neuroinflammation may play an important role in causing dopaminergic neuron loss, which is a pathological hallmark of PD. However, glial cell activation has a close relationship with neuroinflammation. Thus, this study aimed to investigate the anti-neuroinflammatory and neuroprotective effects of EA on lipopolysaccharide (LPS)-induced glial cell activation and neural damage in vitro and in vivo. For the in vitro experiments, glial cells, BV-2 microglial cells and CTX TNA2 astrocytes were pretreated with EA and then stimulated with LPS and/or IFN-γ. The expression of proinflammatory factors in the cells and culture medium was analyzed. In addition, differentiated neuro-2a (N2a) cells were pretreated with EA or HEM and then stimulated with LPS-treated BV-2 conditioned medium (CM). The cell viability and the amount of tyrosine hydroxylase (TH) and mitogen-activated protein kinases (MAPKs) were analyzed. In vivo, rats were given EA or HEM by oral gavage prior to injection of LPS into the substantia nigra (SN). Motor coordination of the rats and the expression of proinflammatory mediators in the midbrain were analyzed. EA pretreatment prevented LPS-induced iNOS expression and NO production in BV-2 cells and TNF-α expression in CTX TNA2 cells. In addition, both EA and HEM pretreatment significantly increased cell viability and TH expression and suppressed the phosphorylation of JNK and NF- κB in differentiated N2a cells treated with CM. In vivo, both EA and HEM significantly improved motor dysfunction in the rotarod test and the amphetamine-induced rotation test and reduced the expression of TNF-α, IL-1β and iNOS in the midbrain of rats intranigrally injected with LPS. The results demonstrate that EA ameliorates LPS-induced neuroinflammation and has neuroprotective properties.","tags":["#literature_note"],"author":[{"family":"Lee","given":"Sang Hun","literal":""},{"family":"Lee","given":"Shou-Lun","literal":""},{"family":"Hsu","given":"Jing-Ya","literal":""},{"family":"Hsu","given":"Jing-Ya","literal":""},{"family":"Chen","given":"Ting-Chun","literal":""},{"family":"Chen","given":"Ting-Chun","literal":""},{"family":"Huang","given":"Chun-Chih","literal":""},{"family":"Huang","given":"Chun-Chih","literal":""},{"family":"Wu","given":"Tong","literal":""},{"family":"Wu","given":"Tzong-Yuan","literal":""},{"family":"Chin","given":"Ting-Yu","literal":""},{"family":"Chin","given":"Ting-Yu","literal":""}],"citation-key":"lee_erinacine_2022","year":"2022","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Erinacine A Prevents Lipopolysaccharide-Mediated Glial Cell Activation to Protect Dopaminergic Neurons against Inflammatory Factor-Induced Cell Death In Vitro and In Vivo"],"author-links":["[[Author/Sang Hun Lee]]","[[Author/Shou-Lun Lee]]","[[Author/Jing-Ya Hsu]]","[[Author/Jing-Ya Hsu]]","[[Author/Ting-Chun Chen]]","[[Author/Ting-Chun Chen]]","[[Author/Chun-Chih Huang]]","[[Author/Chun-Chih Huang]]","[[Author/Tong Wu]]","[[Author/Tzong-Yuan Wu]]","[[Author/Ting-Yu Chin]]","[[Author/Ting-Yu Chin]]"],"attachment":["[[biblib/lee_erinacine_2022/lee_erinacine_2022.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"xdrahr","at":1774951892814}},"smart_blocks:Research/@lee_erinacine_2022.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.00848778,-0.04150845,-0.01037583,-0.01309765,-0.04391585,0.038257,0.07866724,0.04717715,-0.04321006,-0.02770414,-0.01166321,-0.05480677,0.03632437,0.01984068,-0.02419141,0.01420715,-0.02811003,0.00039635,-0.11385717,-0.01550762,0.03206552,-0.04931998,0.01599558,-0.00067306,-0.01013505,-0.0027068,-0.03365847,-0.00621082,-0.05242885,-0.20169953,-0.0123591,-0.04826825,0.00998779,-0.04266726,-0.03026492,-0.01106609,-0.00639924,0.01097902,-0.03076096,-0.02265826,0.03267701,0.03296652,-0.02224556,-0.02137684,0.05295988,-0.03009057,-0.01000685,-0.06877219,0.06642312,-0.02642048,0.01532271,-0.04292246,0.04819806,0.05062213,0.04891157,-0.02523062,-0.05991367,0.08111042,0.01814742,0.074416,0.00975034,0.03150212,-0.15454656,0.09366984,0.01310217,-0.03510947,-0.10714483,-0.03444716,0.09073126,0.03950053,-0.07810355,0.03750156,0.05890401,0.060396,-0.0068842,0.00541251,0.01030884,-0.05032878,0.00074531,0.01183094,0.05456166,0.02834437,0.01446172,0.01710384,0.00746649,-0.05825119,-0.01127748,-0.07231578,-0.0017874,0.00210702,-0.01447408,-0.02267878,0.00123196,0.03154768,-0.05089048,-0.05236632,0.00658378,-0.0009705,-0.09171911,0.12787633,-0.0399853,-0.0015191,-0.04239219,-0.02821472,-0.00364529,-0.04588427,-0.01309572,-0.01400035,0.01503151,0.009148,0.08239268,0.040569,-0.06314554,-0.0012165,-0.02419553,0.06018706,0.15743326,0.01193403,0.01372756,-0.00617493,-0.01726347,0.03404293,0.03899408,0.01895259,0.0211127,-0.02671019,-0.00761808,0.05222045,0.01892461,-0.01841232,0.05331705,0.06030722,0.01808656,-0.00581634,0.00839529,0.0142465,0.05113205,-0.02959711,-0.01678049,-0.01373211,-0.03205966,-0.02240068,-0.01813186,-0.06770409,-0.06941143,0.03229678,0.05234932,-0.04930587,-0.04781617,-0.0031997,0.0149679,0.0466267,-0.