18,0.00701169,0.16848424,-0.00401626,-0.04250983,0.04988853,-0.00679971,-0.0139909,-0.04976286,0.01674752,-0.02046209,0.02900149,0.12374723,0.0043126,0.03361501,-0.0189064,-0.09829751,-0.00151585,-0.01910807,-0.0049852,-0.04706826,0.00318611,-0.12633117,0.02470716,0.13193136,-0.07402627,0.00125209,-0.06839973,-0.0034132,0.0284949,-0.04545642,0.01456586,-0.03331427,0.0912886,0.02637807,-0.01246203,0.02535717,-0.02498363,-0.01176153,-0.0440233,-0.02041499,0.0071998,-0.0163509,0.09348976,-0.00530571],"last_embed":{"hash":"1e1nrys","tokens":448}}},"last_read":{"hash":"1e1nrys","at":1774951890371},"class_name":"SmartSource","last_import":{"mtime":1774951820906,"size":1853,"at":1774951884799,"hash":"1e1nrys"},"blocks":{"#---frontmatter---":[1,44],"#Herbal medicines: old and new concepts, truths and misunderstandings":[46,50],"#Herbal medicines: old and new concepts, truths and misunderstandings#{1}":[48,50]},"outlinks":[{"title":"Author/Fábio Carmona","target":"Author/Fábio Carmona","line":36},{"title":"Author/Fabio Carmona","target":"Author/Fabio Carmona","line":37},{"title":"Author/Paulo Pereira","target":"Author/Paulo Pereira","line":38},{"title":"Author/Ana Maria Soares Pereira","target":"Author/Ana Maria Soares Pereira","line":39},{"title":"Author/Ana Maria Soares Pereira","target":"Author/Ana Maria Soares Pereira","line":40}],"metadata":{"id":"carmona_herbal_2013","type":"article-journal","title":"Herbal medicines: old and new concepts, truths and misunderstandings","issued":{"date-parts":[[2013]]},"DOI":"10.1590/s0102-695x2013005000018","container-title":"Revista Brasileira De Farmacognosia-brazilian Journal of Pharmacognosy","abstract":"Men have been using herbal medicines for thousands of years. The advantages of this type of therapeutics include good availability, local cultural aspects, individual preferences, the increasing demand for natural and organic products, and the already validated synergistic effects of herbal medicines. However, ethically, the scope and limits of these drugs need to be established not only by ethnopharmacological evidences but also by scientific investigations, which confirm the therapeutic effects. With this study, we propose to discuss the possible advantages of using herbal medicines instead of purified compounds, the truth and myths about herbal medicines, drug discovery, and the implications for medical education and health care.","tags":["#literature_note"],"author":[{"family":"Carmona","given":"Fábio","literal":""},{"family":"Carmona","given":"Fabio","literal":""},{"family":"Pereira","given":"Paulo","literal":""},{"family":"Pereira","given":"Ana Maria Soares","literal":""},{"family":"Pereira","given":"Ana Maria Soares","literal":""}],"citation-key":"carmona_herbal_2013","year":"2013","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Herbal medicines: old and new concepts, truths and misunderstandings"],"author-links":["[[Author/Fábio Carmona]]","[[Author/Fabio Carmona]]","[[Author/Paulo Pereira]]","[[Author/Ana Maria Soares Pereira]]","[[Author/Ana Maria Soares Pereira]]"],"attachment":[],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"1e1nrys","at":1774951890364}},"smart_blocks:Research/@carmona_herbal_2013.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.00101602,-0.03591968,0.02592738,0.03023097,0.03318924,-0.00014194,0.02928013,0.04140828,-0.04648543,-0.02591214,-0.00219283,0.00118097,0.02786364,0.0816893,0.07373863,0.02805348,-0.0240692,0.00077723,-0.05675375,0.01294762,0.02430325,-0.036526,-0.00745048,0.02013686,0.03365992,0.05569975,-0.02821824,-0.01763221,-0.00570597,-0.20190361,-0.02339561,0.06128341,0.02908899,-0.01196523,-0.05204012,-0.0067031,-0.03719259,-0.00381298,-0.02662191,0.00341004,0.02685604,0.03355313,0.00180293,0.07658868,-0.05549301,-0.00691623,-0.03079273,0.02244279,-0.00482688,-0.05227341,-0.02767193,-0.00128912,-0.01355749,0.03432,-0.03118254,0.00307052,0.01823162,0.041805