72933,-0.02905147,0.0162654,0.02700986,-0.00723734,-0.00908516,0.01054242,0.04484229,-0.03142919,0.02961454,0.06112268,0.01464545,0.03954081,0.03551853,-0.02316456,0.04357919,-0.02046972,-0.01885233,0.0094674,0.018268,-0.02267011,-0.03729661,0.06899503,-0.09159514,-0.01090662,-0.02220437,0.02119881,-0.01413843,-0.02561907,0.02105306,0.03437852,0.03785202,-0.00541638,-0.04088575,-0.01294964,-0.00873233,-0.06813779,-0.06424281,0.01352273,0.03657499,-0.10125208,0.1091873,0.01026248],"last_embed":{"hash":"h0yzd5","tokens":461}}},"last_read":{"hash":"h0yzd5","at":1774951890509},"class_name":"SmartSource","last_import":{"mtime":1774951821210,"size":3725,"at":1774951884800,"hash":"h0yzd5"},"blocks":{"#---frontmatter---":[1,101],"#Lentinan from shiitake selectively attenuates AIM2 and non-canonical inflammasome activation while inducing pro-inflammatory cytokine production.":[103,107],"#Lentinan from shiitake selectively attenuates AIM2 and non-canonical inflammasome activation while inducing pro-inflammatory cytokine production.#{1}":[105,107]},"outlinks":[{"title":"Author/Huijeong Ahn","target":"Author/Huijeong Ahn","line":78},{"title":"Author/Huijeong Ahn","target":"Author/Huijeong Ahn","line":79},{"title":"Author/Eunsaem Jeon","target":"Author/Eunsaem Jeon","line":80},{"title":"Author/Eunsaem Jeon","target":"Author/Eunsaem Jeon","line":81},{"title":"Author/Jin-Chul Kim","target":"Author/Jin-Chul Kim","line":82},{"title":"Author/Jin-Chul Kim","target":"Author/Jin-Chul Kim","line":83},{"title":"Author/Jin-Chul Kim","target":"Author/Jin-Chul Kim","line":84},{"title":"Author/Jin-Chul Kim","target":"Author/Jin-Chul Kim","line":85},{"title":"Author/Jin-Chul Kim","target":"Author/Jin-Chul Kim","line":86},{"title":"Author/Seung Goo Kang","target":"Author/Seung Goo Kang","line":87},{"title":"Author/Seung Goo Kang","target":"Author/Seung Goo Kang","line":88},{"title":"Author/Sung-il Yoon","target":"Author/Sung-il Yoon","line":89},{"title":"Author/Sung-il Yoon","target":"Author/Sung-il Yoon","line":90},{"title":"Author/Hyun-Jeong Ko","target":"Author/Hyun-Jeong Ko","line":91},{"title":"Author/Hyun-Jeong Ko","target":"Author/Hyun-Jeong Ko","line":92},{"title":"Author/Pyeung-Hyeun Kim","target":"Author/Pyeung-Hyeun Kim","line":93},{"title":"Author/Pyeung-Hyeun Kim","target":"Author/Pyeung-Hyeun Kim","line":94},{"title":"Author/Geun-Shik Lee","target":"Author/Geun-Shik Lee","line":95},{"title":"Author/Geun-Shik Lee","target":"Author/Geun-Shik Lee","line":96},{"title":"PDF","target":"biblib/ahn_lentinan_2017/ahn_lentinan_2017.pdf","line":98}],"metadata":{"id":"ahn_lentinan_2017","type":"article-journal","title":"Lentinan from shiitake selectively attenuates AIM2 and non-canonical inflammasome activation while inducing pro-inflammatory cytokine production.","issued":{"date-parts":[[2017]]},"DOI":"10.1038/s41598-017-01462-4","container-title":"Scientific Reports","abstract":"Lentinan extracted from shiitake (Lentinula edodes) is a β-glucan that has been reported as an intravenous anti-tumor polysaccharide via enhancement of the host immune system. In this study, we determined the effect of lentinan on inflammasome activation, a multi-protein platform, in myeloid cells. Mouse bone marrow-derived macrophages were treated with lentinan with/without inflammasome triggers, and maturation of interleukin (IL)-1β, IL-18, or caspase-1 was measured as a readout of inflammasome activation. As a result, lentinan selectively inhibited absent in melanoma 2 (AIM2) inflammasome activation. In addition, lentinan up-regulated pro-inflammatory cytokines and induced expression of inflammasome-related genes through toll-like receptor 4 signaling. Furthermore, we assessed the effect of lentinan on mice treated with Listeria monocytogenes or lipopolysaccharide as an AIM2 or non-canonical inflammasome-mediated model. Lentinan attenuated IL-1β secretion resulting from Listeria-mediated AIM2 inflammasome activation and reduced endotoxin lethality via inhibition of non-canonical inflammasome activation. Thus, lentinan is suggested as an anti-AIM2 and anti-non-canonical inflammasome candidate despite its up-regulation of cytokine expression.","tags":["#literature_note"],"author":[{"family":"Ahn","given":"Huijeong","literal":""},{"family":"Ahn","given":"Huijeong","literal":""},{"family":"Jeon","given":"Eunsaem","literal":""},{"family":"Jeon","given":"Eunsaem","literal":""},{"family":"Kim","given":"Jin-Chul","literal":""},{"family":"Kim","given":"Jin-Chul","literal":""},{"family":"Kim","given":"Jin-Chul","literal":""},{"family":"Kim","given":"Jin-Chul","literal":""},{"family":"Kim","given":"Jin-Chul","literal":""},{"family":"Kang","given":"Seung Goo","literal":""},{"family":"Kang","given":"Seung Goo","literal":""},{"family":"Yoon","given":"Sung-il","literal":""},{"family":"Yoon","given":"Sung-il","literal":""},{"family":"Ko","given":"Hyun-Jeong","literal":""},{"family":"Ko","given":"Hyun-Jeong","literal":""},{"family":"Kim","given":"Pyeung-Hyeun","literal":""},{"family":"Kim","given":"Pyeung-Hyeun","literal":""},{"family":"Lee","given":"Geun-Shik","literal":""},{"family":"Lee","given":"Geun-Shik","literal":""}],"citation-key":"ahn_lentinan_2017","year":"2017","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Lentinan from shiitake selectively attenuates AIM2 and non-canonical inflammasome activation while inducing pro-inflammatory cytokine production."],"author-links":["[[Author/Huijeong Ahn]]","[[Author/Huijeong Ahn]]","[[Author/Eunsaem Jeon]]","[[Author/Eunsaem Jeon]]","[[Author/Jin-Chul Kim]]","[[Author/Jin-Chul Kim]]","[[Author/Jin-Chul Kim]]","[[Author/Jin-Chul Kim]]","[[Author/Jin-Chul Kim]]","[[Author/Seung Goo Kang]]","[[Author/Seung Goo Kang]]","[[Author/Sung-il Yoon]]","[[Author/Sung-il Yoon]]","[[Author/Hyun-Jeong Ko]]","[[Author/Hyun-Jeong Ko]]","[[Author/Pyeung-Hyeun Kim]]","[[Author/Pyeung-Hyeun Kim]]","[[Author/Geun-Shik Lee]]","[[Author/Geun-Shik Lee]]"],"attachment":["[[biblib/ahn_lentinan_2017/ahn_lentinan_2017.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"h0yzd5","at":1774951890499}},"smart_blocks:Research/@ahn_lentinan_2017.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.04711324,-0.02375115,-0.02550356,-0.04561791,-0.02529405,-0.01575403,0.04234727,0.08466014,-0.05446306,-0.0115691,-0.01051039,-0.12160216,0.07297567,0.03735051,0.03644997,0.01755719,-0.00931256,0.04026028,-0.12664419,0.02734278,0.03965374,-0.10463554,0.05898159,-0.05272553,0.02111257,0.07633872,-0.00770054,0.02367798,-0.07632469,-0.23094016,-0.01022817,-0.06858676,0.01396022,-0.01423357,-0.03515974,-0.01349523,-0.00879945,0.03639062,-0.01486617,0.01453305,0.04188208,0.07039776,-0.03240709,0.01283251,0.04633208,-0.07794961,-0.06678999,-0.04399721,0.03413163,-0.01539432,0.02176028,-0.04429198,0.01271339,0.0811519,0.04232458,-0.01639677,-0.05604018,0.0350228,0.01204737,0.08765496,0.0420031,0.07450787,-0.14435144,0.09521004,0.03304321,0.01403658,-0.06251469,-0.02764707,0.05854078,0.08403311,-0.0710811,0.01051016,0.02493483,0.08078984,0.01641052,0.02051247,0.01673512,0.00160446,0.08650427,0.00958358,0.08264592,0.02396378,0.01479355,-0.05400959,-0.0026215,-0.03668001,-0.00846768,-0.09115801,0.00457378,0.01058324,0.00256882,-0.04487545,-0.04212661,0.00644663,-0.08261925,-0.06233699,0.00503186,-0.00279797,-0.01522778,0.1427585,-0.03763077,-0.0037678,-0.07850508,-0.02077534,0.04223804,-0.03491101,-0.00133171,-0.00136698,0.0269863,0.03502988,0.03588156,-0.03031317,-0.03466133,0.02832363,0.00506319,0.05275643,0.1247157,0.02415247,0.02308343,-0.02572167,0.0079221,-0.01709528,0.03451935,-0.02595345,-0.00992895,0.02278119,0.01204053,0.05144133,0.0365169,-0.06261517,0.03917306,0.02001652,-0.02714597,0.01349691,0.00277834,0.01766741,0.00855409,-0.08743334,-0.01531745,0.00377071,-0.0151379,-0.03771377,0.01478325,-0.10059039,-0.04426919,0.07709862,0.00282527,-0.01210374,-0.06844543,0.00461496,-0.01615317,0.04543477,-0.0454541