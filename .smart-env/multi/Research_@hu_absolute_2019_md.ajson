-0.02885783,0.16693333,-0.00440363,-0.07271612,0.02311521,-0.03945961,0.03420191,0.05045038,-0.03838759,-0.00054786,0.04727907,0.02921973,-0.03212633,0.07392818,0.02328311,-0.05725186,0.00029468,-0.01367204,-0.03463046,-0.02726366,0.00319138,-0.09596513,-0.03591802,0.0644175,-0.03684348,-0.04908001,-0.01395729,0.02885903,0.00250054,-0.01912034,-0.02896177,0.03568581,0.0205461,0.04180034,0.00939404,-0.01144233,-0.03423601,-0.00226887,0.00062195,0.01675164,0.04153329,-0.06357308,0.12336918,0.05997374],"last_embed":{"hash":"1582g6f","tokens":476}}},"last_read":{"hash":"1582g6f","at":1774951887170},"class_name":"SmartSource","last_import":{"mtime":1774951816463,"size":3811,"at":1774951884778,"hash":"1582g6f"},"blocks":{"#---frontmatter---":[1,105],"#Absolute Bioavailability, Tissue Distribution, and Excretion of Erinacine S in Hericium erinaceus Mycelia.":[107,111],"#Absolute Bioavailability, Tissue Distribution, and Excretion of Erinacine S in Hericium erinaceus Mycelia.#{1}":[109,111]},"outlinks":[{"title":"Author/Jun-Hao Hu","target":"Author/Jun-Hao Hu","line":81},{"title":"Author/Jun-Hao Hu","target":"Author/Jun-Hao Hu","line":82},{"title":"Author/I.-Chen Li","target":"Author/I.-Chen Li","line":83},{"title":"Author/I.-Chen Li","target":"Author/I.-Chen Li","line":84},{"title":"Author/I.-Chen Li","target":"Author/I.-Chen Li","line":85},{"title":"Author/Te-Hsien Lin","target":"Author/Te-Hsien Lin","line":86},{"title":"Author/Ting-Wei Lin","target":"Author/Ting-Wei Lin","line":87},{"title":"Author/Wanping Chen","target":"Author/Wanping Chen","line":88},{"title":"Author/Wan-Ping Chen","target":"Author/Wan-Ping Chen","line":89},{"title":"Author/Wan-Ping Chen","target":"Author/Wan-Ping Chen","line":90},{"title":"Author/Li-Ya Lee","target":"Author/Li-Ya Lee","line":91},{"title":"Author/Lee Li-Ya","target":"Author/Lee Li-Ya","line":92},{"title":"Author/Li-Ya Lee","target":"Author/Li-Ya Lee","line":93},{"title":"Author/Li-Ya Lee","target":"Author/Li-Ya Lee","line":94},{"title":"Author/Chin-Chu Chen","target":"Author/Chin-Chu Chen","line":95},{"title":"Author/Chin-Chu Chen","target":"Author/Chin-Chu Chen","line":96},{"title":"Author/Chen Chin-Chu","target":"Author/Chen Chin-Chu","line":97},{"title":"Author/Chia-Feng Kuo","target":"Author/Chia-Feng Kuo","line":98},{"title":"Author/Chia-Feng Kuo","target":"Author/Chia-Feng Kuo","line":99},{"title":"Author/Chia-Feng Kuo","target":"Author/Chia-Feng Kuo","line":100},{"title":"PDF","target":"biblib/hu_absolute_2019/hu_absolute_2019.pdf","line":102}],"metadata":{"id":"hu_absolute_2019","type":"article-journal","title":"Absolute Bioavailability, Tissue Distribution, and Excretion of Erinacine S in Hericium erinaceus Mycelia.","issued":{"date-parts":[[2019]]},"DOI":"10.3390/molecules24081624","container-title":"Molecules","abstract":"Erinacine S, so far known to have been produced only in Hericium erinaceus mycelia, has just recently been discovered and is able to reduce amyloid plaque growth and improve neurogenesis in aged brain of rats. However, few investigations have been conducted on the absorption, distribution, and excretion study of Erinacine S. This study aimed to investigate the absolute bioavailability, tissue distribution, and excretion of Erinacine S in H. Erinaceus mycelia in eight-week old Sprague-Dawley rats. After oral administration and intravenous administration of 2.395 g/kg body weight of the H. erinaceus mycelia extract (equivalent to 50 mg/kg body weight Erinacine S) and 5 mg/kg of Erinacine S, respectively, the absolute bioavailability was estimated as 15.13%. In addition, Erinacine S was extensively distributed in organs such as brain, heart, lung, liver, kidney, stomach, small intestine, and large intestine. The maximum concentration of Erinacine S was observed in the stomach, 2 h after the oral administration of H. erinaceus mycelia extract, whereas the maximum amount of Erinacine S found in other tissues were seen after 8 h. Total amount of unconverted Erinacine S eliminated in feces and urine in 24 h was 0.1% of the oral dosage administrated. This study is the first to show that Erinacine S can penetrate the blood–brain barrier of rats and thus support the development of H. erinaceus mycelia, for the treatment of neurological diseases.","tags":["#literature_note"],"author":[{"family":"Hu","given":"Jun-Hao","literal":""},{"family":"Hu","given":"Jun-Hao","literal":""},{"family":"Li","given":"I.-Chen","literal":""},{"family":"Li","given":"I.-Chen","literal":""},{"family":"Li","given":"I.-Chen","literal":""},{"family":"Lin","given":"Te-Hsien","literal":""},{"family":"Lin","given":"Ting-Wei","literal":""},{"family":"Chen","given":"Wanping","literal":""},{"family":"Chen","given":"Wan-Ping","literal":""},{"family":"Chen","given":"Wan-Ping","literal":""},{"family":"Lee","given":"Li-Ya","literal":""},{"family":"Li-Ya","given":"Lee","literal":""},{"family":"Lee","given":"Li-Ya","literal":""},{"family":"Lee","given":"Li-Ya","literal":""},{"family":"Chen","given":"Chin-Chu","literal":""},{"family":"Chen","given":"Chin-Chu","literal":""},{"family":"Chin-Chu","given":"Chen","literal":""},{"family":"Kuo","given":"Chia-Feng","literal":""},{"family":"Kuo","given":"Chia-Feng","literal":""},{"family":"Kuo","given":"Chia-Feng","literal":""}],"citation-key":"hu_absolute_2019","year":"2019","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Absolute Bioavailability, Tissue Distribution, and Excretion of Erinacine S in Hericium erinaceus Mycelia."],"author-links":["[[Author/Jun-Hao Hu]]","[[Author/Jun-Hao Hu]]","[[Author/I.-Chen Li]]","[[Author/I.-Chen Li]]","[[Author/I.-Chen Li]]","[[Author/Te-Hsien Lin]]","[[Author/Ting-Wei Lin]]","[[Author/Wanping Chen]]","[[Author/Wan-Ping Chen]]","[[Author/Wan-Ping Chen]]","[[Author/Li-Ya Lee]]","[[Author/Lee Li-Ya]]","[[Author/Li-Ya Lee]]","[[Author/Li-Ya Lee]]","[[Author/Chin-Chu Chen]]","[[Author/Chin-Chu Chen]]","[[Author/Chen Chin-Chu]]","[[Author/Chia-Feng Kuo]]","[[Author/Chia-Feng Kuo]]","[[Author/Chia-Feng Kuo]]"],"attachment":["[[biblib/hu_absolute_2019/hu_absolute_2019.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"1582g6f","at":1774951887161}},"smart_blocks:Research/@hu_absolute_2019.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.01251773,0.0018933,0.00948912,-0.06474976,-0.0341837,0.02614096,0.01716261,0.04517597,-0.01927481,0.00812321,0.05301134,-0.15321504,0.03189403,0.01184706,-0.0110026,-0.02191924,0.02670525,0.01381365,-0.12992109,-0.00321026,0.02107791,-0.07405353,-0.01627214,-0.00620992,0.02838656,-0.00557425,-0.04493996,-0.03685686,-0.06808028,-0.2364551,-0.01969676,-0.06783919,0.03244247,-0.02255381,-0.00394685,-0.03067752,-0.0123119,0.01007209,0.01639917,0.0488876,0.03223755,0.04623322,0.00383326,-0.03501115,0.02036325,-0.04488594,-0.02946568,0.01462725,0.09196068,0.05531358,0.01979591,0.01522545,0.04829188,0.07699355,0.01211148,-0.0144444,0.00948667,0.02601432,0.01853015,0.07985582,0.0354476,0.06182608,-0.17107259,0.09662623,0.04924366,-0.01736672,-0.06317168,-0.06960564,0.04647758,-0.01947613,-0.07046238,0.04029743,0.04126314,0.06756255,0.01628644,-0.05860487,0.02887166,0.00503028,0.01571108,0.01640015,0.00144867,0.0601591,-0.01100703,-0.00688731,0.01879389,-0.01892006,-0.03703522,-0.06537295,0.03375457,-0.02639198,-0.01832319,-0.03271039,-0.04445269,0.04589387,-0.02284823,-0.0569148,-0.02048051,0.01357003,-0.04929861,0.14500061,-0.03563025,0.00686459,-0.02619828,-0.05809154,0.00141442,0.00499138,-0.02361037,0.00106491,0.00138216,0.00337709,0.02911297,0.02492921,-0.01947869,-0.02269669,-0.00723071,0.07357633,0.08553396,0.02892724,-0.02876792,0.00622276,-0.03368514,0.01174542,0.06188012,-0.00758675,0.02299441,-0.01886833,-0.02117918,0.0662155,-0.00546182,-0.05361878,0.02233795,0.02851861,-0.03133284,-0.02578048,-0.00815418,0.00093959,0.02231073,-0.00488171,-0.02247208,0.02997931,-0.00268866,-0.09048977,-0.02974754,-0.05637288,-0.1009368,0.1136042