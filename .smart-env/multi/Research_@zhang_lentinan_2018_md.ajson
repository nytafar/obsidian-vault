},{"title":"Author/Zhihua Guo","target":"Author/Zhihua Guo","line":125},{"title":"Author/Yajing Chang","target":"Author/Yajing Chang","line":126},{"title":"Author/Yajing Chang","target":"Author/Yajing Chang","line":127},{"title":"Author/Heng Luo","target":"Author/Heng Luo","line":128},{"title":"Author/Heng Luo","target":"Author/Heng Luo","line":129},{"title":"Author/Heng Luo","target":"Author/Heng Luo","line":130},{"title":"Author/Yong Liu","target":"Author/Yong Liu","line":131},{"title":"Author/Yong Liu","target":"Author/Yong Liu","line":132},{"title":"Author/Cui Hao","target":"Author/Cui Hao","line":133},{"title":"Author/Cui Hao","target":"Author/Cui Hao","line":134},{"title":"Author/Hua Wang","target":"Author/Hua Wang","line":135},{"title":"Author/Hua Wang","target":"Author/Hua Wang","line":136},{"title":"Author/Guoqing Zhang","target":"Author/Guoqing Zhang","line":137},{"title":"Author/Guoqing Zhang","target":"Author/Guoqing Zhang","line":138},{"title":"Author/Lijuan Zhang","target":"Author/Lijuan Zhang","line":139},{"title":"Author/Lijuan Zhang","target":"Author/Lijuan Zhang","line":140},{"title":"PDF","target":"biblib/zhang_lentinan_2018/zhang_lentinan_2018.pdf","line":142}],"metadata":{"id":"zhang_lentinan_2018","type":"article-journal","title":"Lentinan as an immunotherapeutic for treating lung cancer: a review of 12 years clinical studies in China.","issued":{"date-parts":[[2018]]},"DOI":"10.1007/s00432-018-2718-1","container-title":"Journal of Cancer Research and Clinical Oncology","abstract":"Purpose Lentinan is a polysaccharide extracted from Shiitake mushrooms that have been used to improve general health for thousands of years in Asia. Lentinan injection is a clinically approved drug in several countries in Asia. The purpose of this study is to review the structure, preclinical and clinical studies, and molecular mechanisms of lentinan. Most importantly, the clinical effectiveness of lentinan as an adjuvant therapeutic drug in treating patients with lung cancer in China during the past 12 years is analyzed statistically.","tags":["#literature_note"],"author":[{"family":"Zhang","given":"Yiran","literal":""},{"family":"Zhang","given":"Yiran","literal":""},{"family":"Zhang","given":"Rui","literal":""},{"family":"Zhang","given":"Meng","literal":""},{"family":"Zhang","given":"Meng","literal":""},{"family":"Jiang","given":"Yifei","literal":""},{"family":"Jiang","given":"Yifei","literal":""},{"family":"Li","given":"Xiulian","literal":""},{"family":"Li","given":"Xiulian","literal":""},{"family":"He","given":"Yong","literal":""},{"family":"He","given":"Yanli","literal":""},{"family":"Zeng","given":"Pengjiao","literal":""},{"family":"Zeng","given":"Pengjiao","literal":""},{"family":"Guo","given":"Zhihua","literal":""},{"family":"Guo","given":"Zhihua","literal":""},{"family":"Chang","given":"Yajing","literal":""},{"family":"Chang","given":"Yajing","literal":""},{"family":"Luo","given":"Heng","literal":""},{"family":"Luo","given":"Heng","literal":""},{"family":"Luo","given":"Heng","literal":""},{"family":"Liu","given":"Yong","literal":""},{"family":"Liu","given":"Yong","literal":""},{"family":"Hao","given":"Cui","literal":""},{"family":"Hao","given":"Cui","literal":""},{"family":"Wang","given":"Hua","literal":""},{"family":"Wang","given":"Hua","literal":""},{"family":"Zhang","given":"Guoqing","literal":""},{"family":"Zhang","given":"Guoqing","literal":""},{"family":"Zhang","given":"Lijuan","literal":""},{"family":"Zhang","given":"Lijuan","literal":""}],"citation-key":"zhang_lentinan_2018","year":"2018","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Lentinan as an immunotherapeutic for treating lung cancer: a review of 12 years clinical studies in China."],"author-links":["[[Author/Yiran Zhang]]","[[Author/Yiran Zhang]]","[[Author/Rui Zhang]]","[[Author/Meng Zhang]]","[[Author/Meng Zhang]]","[[Author/Yifei Jiang]]","[[Author/Yifei Jiang]]","[[Author/Xiulian Li]]","[[Author/Xiulian Li]]","[[Author/Yong He]]"