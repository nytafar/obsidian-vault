55581,-0.06130565,0.02906704,-0.0280878,0.14763142,0.0488963,-0.03056012,0.02233062,0.00771246,0.01349668,-0.05590003,0.05225227,0.00946399,0.00641698,0.15642518,-0.03300566,0.09730778,0.06907709,-0.00230915,-0.02531294,0.00723265,-0.02499044,0.00906263,-0.04769181,-0.14721382,-0.06218194,0.06768365,-0.0693843,-0.01700644,-0.04342909,0.01718432,-0.0091477,-0.02832484,0.0173075,-0.0109445,0.0352284,-0.00893871,0.02275118,-0.0261989,-0.02188356,-0.06296159,-0.01036608,0.01055791,-0.03221828,-0.09317046,0.08223758,0.04324882],"last_embed":{"hash":"19pt2p9","tokens":488}}},"last_read":{"hash":"19pt2p9","at":1774951889531},"class_name":"SmartSource","last_import":{"mtime":1774951820678,"size":3531,"at":1774951884799,"hash":"19pt2p9"},"blocks":{"#---frontmatter---":[1,69],"#Screening of medicinal mushroom strains with antimicrobial activity and polysaccharides production":[71,75],"#Screening of medicinal mushroom strains with antimicrobial activity and polysaccharides production#{1}":[73,75]},"outlinks":[{"title":"Author/Meiramkul Narmuratova","target":"Author/Meiramkul Narmuratova","line":54},{"title":"Author/Nina Bisko","target":"Author/Nina Bisko","line":55},{"title":"Author/Kairat Mustafin","target":"Author/Kairat Mustafin","line":56},{"title":"Author/Galeb Al-Maali","target":"Author/Galeb Al-Maali","line":57},{"title":"Author/Alina Kerner","target":"Author/Alina Kerner","line":58},{"title":"Author/Svitlana Bondaruk","target":"Author/Svitlana Bondaruk","line":59},{"title":"Author/Ж. Б. СУЛЕЙМЕНОВА","target":"Author/Ж. Б. СУЛЕЙМЕНОВА","line":60},{"title":"Author/А. К. КАЛИЕВА","target":"Author/А. К. КАЛИЕВА","line":61},{"title":"Author/Nourlan Akhmetsadykov","target":"Author/Nourlan Akhmetsadykov","line":62},{"title":"Author/Aigerim Zhakipbekova","target":"Author/Aigerim Zhakipbekova","line":63},{"title":"Author/Margarita Lomberg","target":"Author/Margarita Lomberg","line":64},{"title":"PDF","target":"biblib/narmuratova_screening_2023/narmuratova_screening_2023.pdf","line":66}],"metadata":{"id":"narmuratova_screening_2023","type":"article-journal","title":"Screening of medicinal mushroom strains with antimicrobial activity and polysaccharides production","issued":{"date-parts":[[2023]]},"DOI":"10.1515/tjb-2022-0235","container-title":"null","abstract":"Abstract Objectives This study aimed to determine the antimicrobial activity of culture fluid and mycelial mass of selected Hericium strains from the IBK Mushroom Culture Collection (Kyiv, Ukraine) against bacteria and fungi, as well as to evaluate the potential of these mushrooms for biomass and extracellular polysaccharides production. Methods The antimicrobial activity of ethyl acetate extracts of culture fluid and aqueous-ethyl extracts of mycelial mass for three Hericium species: Hericium cirrhatum IBK 2393, Hericium coralloides IBK 2332, and Hericium erinaceus IBK 2530 against Gram-positive Bacillus subtilis , Staphylococcus aureus , and Gram-negative Escherichia coli , Klebsiella pneumoniae , Pseudomonas aureginosa bacteria as well as Aspergillus niger , Penicillium polonicum , and Mucor globosus fungi by the disk diffusion method was conducted. Analysis of the minimum inhibitory concentration was carried out according to the broth dilution method. Results High antimicrobial activity of culture fluid extracts of Hericium mushroom species against S. aureus was established after 14–21 days of cultivation. No effects of Hericium extracts against A. niger , P. polonicum , and M. globosus were observed. On the 7th day of submerged cultivation, the studied strains produced the maximum yield of extracellular polysaccharides. The most promising extracellular polysaccharide (EPS) producers were strains of H. coralloides IBK 2332 (1.89 g/L) and H. erinaceus IBK 2530 (1.90 g/L). The maximal value of biomass was produced by H. cirrhatum IBK 2393 on the 21st day of submerged cultivation (17.45 g/L). Conclusions Hericium mushrooms have significant potential for the development of new drugs with health benefits properties.","tags":["#literature_note"],"author":[{"family":"Narmuratova","given":"Meiramkul","literal":""},{"family":"Bisko","given":"Nina","literal":""},{"family":"Mustafin","given":"Kairat","literal":""},{"family":"Al-Maali","given":"Galeb","literal":""},{"family":"Kerner","given":"Alina","literal":""},{"family":"Bondaruk","given":"Svitlana","literal":""},{"family":"СУЛЕЙМЕНОВА","given":"Ж. Б.","literal":""},{"family":"КАЛИЕВА","given":"А. К.","literal":""},{"family":"Akhmetsadykov","given":"Nourlan","literal":""},{"family":"Zhakipbekova","given":"Aigerim","literal":""},{"family":"Lomberg","given":"Margarita","literal":""}],"citation-key":"narmuratova_screening_2023","year":"2023","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Screening of medicinal mushroom strains with antimicrobial activity and polysaccharides production"],"author-links":["[[Author/Meiramkul Narmuratova]]","[[Author/Nina Bisko]]","[[Author/Kairat Mustafin]]","[[Author/Galeb Al-Maali]]","[[Author/Alina Kerner]]","[[Author/Svitlana Bondaruk]]","[[Author/Ж. Б. СУЛЕЙМЕНОВА]]","[[Author/А. К. КАЛИЕВА]]","[[Author/Nourlan Akhmetsadykov]]","[[Author/Aigerim Zhakipbekova]]","[[Author/Margarita Lomberg]]"],"attachment":["[[biblib/narmuratova_screening_2023/narmuratova_screening_2023.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"19pt2p9","at":1774951889522}},"smart_blocks:Research/@narmuratova_screening_2023.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[0.01191522,-0.01352537,0.03775464,-0.05366984,0.05170919,-0.01366597,-0.01345745,0.02649964,-0.0782773,-0.00546888,-0.019746,-0.10611646,0.01711679,0.00306744,-0.01353718,0.00728113,-0.00369774,-0.01446181,-0.06217279,0.01644563,0.04821045,0.00813318,-0.04003675,-0.0373644,0.05597486,0.03742482,-0.03607605,-0.01427206,-0.104813,-0.20824333,-0.02573076,-0.01076433,0.06632547,-0.02262881,0.0049509,-0.01765037,0.00584672,-0.005