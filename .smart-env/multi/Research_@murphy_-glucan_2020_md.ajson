41715,0.0263289,0.19370045,0.01105557,-0.02434039,-0.01608025,-0.01389974,-0.00844686,-0.03507678,0.07790706,0.04095762,0.01599602,0.10192749,-0.01531408,0.05734048,0.08357048,-0.01666423,0.006413,-0.03992677,0.00081564,-0.00598958,-0.00548223,-0.03991564,-0.06684621,0.04980711,-0.07903682,-0.01782874,-0.04784116,-0.00398766,-0.01694595,-0.0225119,0.00138555,0.05382513,0.03094582,-0.03693206,-0.04499425,0.03035512,0.00481972,-0.06799735,0.0073464,0.02004435,0.05908919,-0.10465251,0.09351455,0.01477765],"last_embed":{"hash":"1mf4lvl","tokens":489}}},"last_read":{"hash":"1mf4lvl","at":1774951890303},"class_name":"SmartSource","last_import":{"mtime":1774951820785,"size":4508,"at":1774951884799,"hash":"1mf4lvl"},"blocks":{"#---frontmatter---":[1,101],"#Β-Glucan extracts from the same edible shiitake mushroom Lentinus edodes produce differential in-vitro immunomodulatory and pulmonary cytoprotective effects — Implications for coronavirus disease (COVID-19) immunotherapies":[103,107],"#Β-Glucan extracts from the same edible shiitake mushroom Lentinus edodes produce differential in-vitro immunomodulatory and pulmonary cytoprotective effects — Implications for coronavirus disease (COVID-19) immunotherapies#{1}":[105,107]},"outlinks":[{"title":"Author/Emma J. Murphy","target":"Author/Emma J. Murphy","line":78},{"title":"Author/Emma J. Murphy","target":"Author/Emma J. Murphy","line":79},{"title":"Author/Claire Masterson","target":"Author/Claire Masterson","line":80},{"title":"Author/Claire Masterson","target":"Author/Claire Masterson","line":81},{"title":"Author/Emanuele Rezoagli","target":"Author/Emanuele Rezoagli","line":82},{"title":"Author/Emanuele Rezoagli","target":"Author/Emanuele Rezoagli","line":83},{"title":"Author/Daniel O’Toole","target":"Author/Daniel O’Toole","line":84},{"title":"Author/Daniel O'Toole","target":"Author/Daniel O'Toole","line":85},{"title":"Author/Ian Major","target":"Author/Ian Major","line":86},{"title":"Author/Ian Major","target":"Author/Ian Major","line":87},{"title":"Author/Gary Stack","target":"Author/Gary Stack","line":88},{"title":"Author/Gary D. Stack","target":"Author/Gary D. Stack","line":89},{"title":"Author/Mark Lynch","target":"Author/Mark Lynch","line":90},{"title":"Author/Mark Lynch","target":"Author/Mark Lynch","line":91},{"title":"Author/Mark Lynch","target":"Author/Mark Lynch","line":92},{"title":"Author/John G. Laffey","target":"Author/John G. Laffey","line":93},{"title":"Author/John G. Laffey","target":"Author/John G. Laffey","line":94},{"title":"Author/Neil J. Rowan","target":"Author/Neil J. Rowan","line":95},{"title":"Author/Neil J. Rowan","target":"Author/Neil J. Rowan","line":96},{"title":"PDF","target":"biblib/murphy_-glucan_2020/murphy_-glucan_2020.pdf","line":98}],"metadata":{"id":"murphy_-glucan_2020","type":"article-journal","title":"Β-Glucan extracts from the same edible shiitake mushroom Lentinus edodes produce differential in-vitro immunomodulatory and pulmonary cytoprotective effects — Implications for coronavirus disease (COVID-19) immunotherapies","issued":{"date-parts":[[2020]]},"DOI":"10.1016/j.scitotenv.2020.139330","container-title":"Science of The Total Environment","abstract":"Abstract Coronavirus pneumonia is accompanied by rapid virus replication, where a large number of inflammatory cell infiltration and cytokine storm may lead to acute lung injury, acute respiratory distress syndrome (ARDS) and death. The uncontrolled release of pro-inflammatory cytokines, including interleukin (IL)-1β and IL-6, is associated with ARDS. This constituted the first study to report on the variability in physicochemical properties of β-glucans extracts from the same edible mushroom Lentinus edodes on reduction of these pro-inflammatory cytokines and oxidative stress. Specifically, the impact on the immunomodulatory and cytoprotective properties of our novel ‘in house’ (IH-Lentinan, IHL) and a commercial (Carbosynth-Lentinan, CL) Lentinan extract were investigated using in vitro models of lung injury and macrophage phagocytosis. CL comprised higher amounts of α-glucans and correspondingly less β-glucans. The two lentinan extracts demonstrated varying immunomodulatory activities. Both Lentinan extracts reduced cytokine induced NF-κB activation in human alveolar epithelial A549 cells, with the IHL extract proving more effective at lower doses. In contract, in activated THP-1 derived macrophages, the CL extract more effectively attenuated pro-inflammatory cytokine production (TNF-α, IL-8, IL-2, IL-6, IL-22) as well as TGF-β and IL-10. The CL extract attenuated oxidative stress induced early apoptosis, while the IHL extract attenuated late apoptosis. Our findings demonstrate significant physicochemical differences between Lentinan extracts, which produce differential in vitro immunomodulatory and pulmonary cytoprotective effects that may also have positive relevance to candidate COVID-19 therapeutics targeting cytokine storm.","tags":["#literature_note"],"author":[{"family":"Murphy","given":"Emma J.","literal":""},{"family":"Murphy","given":"Emma J.","literal":""},{"family":"Masterson","given":"Claire","literal":""},{"family":"Masterson","given":"Claire","literal":""},{"family":"Rezoagli","given":"Emanuele","literal":""},{"family":"Rezoagli","given":"Emanuele","literal":""},{"family":"O’Toole","given":"Daniel","literal":""},{"family":"O'Toole","given":"Daniel","literal":""},{"family":"Major","given":"Ian","literal":""},{"family":"Major","given":"Ian","literal":""},{"family":"Stack","given":"Gary","literal":""},{"family":"Stack","given":"Gary D.","literal":""},{"family":"Lynch","given":"Mark","literal":""},{"family":"Lynch","given":"Mark","literal":""},{"family":"Lynch","given":"Mark","literal":""},{"family":"Laffey","given":"John G.","literal":""},{"family":"Laffey","given":"John G.","literal":""},{"family":"Rowan","given":"Neil J.","literal":""},{"family":"Rowan","given":"Neil J.","literal":""}],"citation-key":"murphy_-glucan_2020","year":"2020","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Β-Glucan extracts from the same edible shiitake mushroom Lentinus edodes produce differential in-vitro immunomodulatory and pulmonary cytoprotective effects — Implications for coronavirus disease (COVID-19) immunotherapies"],"author-links":["[[Author/Emma J. Murphy]]","[[Author/Emma J. Murphy]]","[[Author/Claire Masterson]]","[[Author/Claire Masterson]]","[[Author/Emanuele Rezoagli]]","[[Author/Emanuele Rezoagli]]","[[Author/Daniel O’Toole]]","[[Author/Daniel O'Toole]]","[[Author/Ian Major]]","[[Author/Ian Major]]","[[Author/Gary Stack]]","[[Author/Gary D. Stack]]","[[Author/Mark Lynch]]","[[Author/Mark Lynch]]","[[Author/Mark Lynch]]","[[Author/John G. Laffey]]","[[Author/John G. Laffey]]","[[Author/Neil J. Rowan]]","[[Author/Neil J. Rowan]]"],"attachment":["[[biblib/murphy_-glucan_2020/murphy_-glucan_2020.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"1mf4lvl","at":1774951890066}},"smart_blocks:Research/@murphy_-glucan_2020.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.02653882,-0.03225331,0.02906911,-0.0280654,0.02911901,-0.00718048,0.04088858,0.02766583,-0.05678676,0.00556685,-0.03215578,-0.10945898,0.0296868,0.02844072,0.04034211,0.00596274,0.0292165,0.00885656,-0.12917992,0.01640837,0.02330045,-0.0624469,0.0411714,-0.02296247,0.03555685,0.08349671,-0.02352465,-0.00535362,-0.04130116,-0.2166919,-0.0421566,-0.03135287,0.00328392,0.01158773,-0.02790869,0.00467911,-0.01134912,0.05445115,-0.01427042,0.04387429,0.0183747,0.03460672,-0.00400621,0.05575995,0.04396649,-0.08028413,-0.10960895,-0.03424978,0.06818335,-0.01150956,0.0117088,-0.04464106,0.00501034,0.04014531,0.00615442,-0.02332162,-0.01527539,0.02574502,0.02701819,0.08145592,0.07632116,0.03066007,-0.18958889,0.09222116,0.05152438,0.01654671,-0.07518802,0.03287102,0.12307768,0.04151114,-0.07150114,0.0158448,0.04290958,0.05771096,0.04937899,0.01162623,-0.013