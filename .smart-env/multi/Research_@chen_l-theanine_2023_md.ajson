2,0.0309537,0.1917628,-0.01350907,-0.00462697,0.0376529,-0.02235034,0.00910817,-0.01790205,-0.01269207,-0.01209298,0.02300319,0.0933566,-0.02416685,0.0279236,0.05902723,-0.06015574,0.00571307,-0.04097614,0.03855438,0.00569868,0.05969505,0.01266454,-0.06854615,0.1044854,-0.07003946,-0.00527932,-0.0547115,-0.0030935,-0.00855223,-0.01916273,0.00978462,-0.03153447,-0.00082114,-0.03840126,-0.05367363,-0.00072963,-0.00626956,-0.01489422,-0.0030043,-0.04111639,-0.02556668,-0.06051734,0.15574551,0.03551794],"last_embed":{"hash":"1jjireg","tokens":482}}},"last_read":{"hash":"1jjireg","at":1774951895712},"class_name":"SmartSource","last_import":{"mtime":1774951828807,"size":2457,"at":1774951884830,"hash":"1jjireg"},"blocks":{"#---frontmatter---":[1,69],"#L-Theanine and Immunity: A Review":[71,75],"#L-Theanine and Immunity: A Review#{1}":[73,75]},"outlinks":[{"title":"Author/Shuna Chen","target":"Author/Shuna Chen","line":54},{"title":"Author/Jiaxin Kang","target":"Author/Jiaxin Kang","line":55},{"title":"Author/Huanqing Zhu","target":"Author/Huanqing Zhu","line":56},{"title":"Author/Kaixi Wang","target":"Author/Kaixi Wang","line":57},{"title":"Author/Ziyi Han","target":"Author/Ziyi Han","line":58},{"title":"Author/Le-yu Wang","target":"Author/Le-yu Wang","line":59},{"title":"Author/Junsheng Liu","target":"Author/Junsheng Liu","line":60},{"title":"Author/Yuanyuan Wu","target":"Author/Yuanyuan Wu","line":61},{"title":"Author/Puming He","target":"Author/Puming He","line":62},{"title":"Author/Youying Tu","target":"Author/Youying Tu","line":63},{"title":"Author/Bo Li","target":"Author/Bo Li","line":64},{"title":"PDF","target":"biblib/chen_l-theanine_2023/chen_l-theanine_2023.pdf","line":66}],"metadata":{"id":"chen_l-theanine_2023","type":"article-journal","title":"L-Theanine and Immunity: A Review","issued":{"date-parts":[[2023]]},"DOI":"10.3390/molecules28093846","container-title":"Molecules (Basel, Switzerland)","abstract":"L-theanine (N-ethyl-γ-glutamine) is the main amino acid in tea leaves. It not only contributes to tea flavor but also possesses several health benefits. Compared with its sedative and calming activities, the immunomodulatory effects of L-theanine have received less attention. Clinical and epidemiological studies have shown that L-theanine reduces immunosuppression caused by strenuous exercise and prevents colds and influenza by improving immunity. Numerous cell and animal studies have proven that theanine plays an immunoregulatory role in inflammation, nerve damage, the intestinal tract, and tumors by regulating γδT lymphocyte function, glutathione (GSH) synthesis, and the secretion of cytokines and neurotransmitters. In addition, theanine can be used as an immunomodulator in animal production. This article reviews the research progress of L-theanine on immunoregulation and related mechanisms, as well as its application in poultry and animal husbandry. It is hoped that this work will be beneficial to future related research.","tags":["#literature_note"],"author":[{"family":"Chen","given":"Shuna","literal":""},{"family":"Kang","given":"Jiaxin","literal":""},{"family":"Zhu","given":"Huanqing","literal":""},{"family":"Wang","given":"Kaixi","literal":""},{"family":"Han","given":"Ziyi","literal":""},{"family":"Wang","given":"Le-yu","literal":""},{"family":"Liu","given":"Junsheng","literal":""},{"family":"Wu","given":"Yuanyuan","literal":""},{"family":"He","given":"Puming","literal":""},{"family":"Tu","given":"Youying","literal":""},{"family":"Li","given":"Bo","literal":""}],"citation-key":"chen_l-theanine_2023","year":"2023","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["L-Theanine and Immunity: A Review"],"author-links":["[[Author/Shuna Chen]]","[[Author/Jiaxin Kang]]","[[Author/Huanqing Zhu]]","[[Author/Kaixi Wang]]","[[Author/Ziyi Han]]","[[Author/Le-yu Wang]]","[[Author/Junsheng Liu]]","[[Author/Yuanyuan Wu]]","[[Author/Puming He]]","[[Author/Youying Tu]]","[[Author/Bo Li]]"],"attachment":["[[biblib/ch