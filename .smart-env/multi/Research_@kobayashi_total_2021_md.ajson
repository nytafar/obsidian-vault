78261,0.02919908,0.19472232,-0.00952273,-0.0273722,0.04953029,-0.01356263,0.05086008,-0.01415927,0.07245126,-0.02228291,0.0466297,0.09484729,-0.09999834,0.05785894,0.07673905,-0.04734505,-0.01129498,0.02235642,0.02764786,0.03558911,0.03941139,-0.07912251,0.00500916,0.12951587,-0.06287095,-0.06127475,-0.03801028,-0.00264388,0.02101493,-0.01396231,0.0572382,0.02662378,0.0051761,-0.05208908,0.03190831,0.01597806,-0.01931497,-0.07058816,0.00502659,-0.01952033,0.00788305,-0.00681097,0.19236237,0.00702984],"last_embed":{"hash":"18wh3oa","tokens":491}}},"last_read":{"hash":"18wh3oa","at":1774951888556},"class_name":"SmartSource","last_import":{"mtime":1774951819004,"size":3287,"at":1774951884791,"hash":"18wh3oa"},"blocks":{"#---frontmatter---":[1,85],"#Total Synthesis, Structure Revision, and Neuroprotective Effect of Hericenones C–H and Their Derivatives":[87,91],"#Total Synthesis, Structure Revision, and Neuroprotective Effect of Hericenones C–H and Their Derivatives#{1}":[89,91]},"outlinks":[{"title":"Author/Shōji Kobayashi","target":"Author/Shōji Kobayashi","line":66},{"title":"Author/Shoji Kobayashi","target":"Author/Shoji Kobayashi","line":67},{"title":"Author/Takeshi Tamura","target":"Author/Takeshi Tamura","line":68},{"title":"Author/Tomoki Tamura","target":"Author/Tomoki Tamura","line":69},{"title":"Author/Mizuho Koshishiba","target":"Author/Mizuho Koshishiba","line":70},{"title":"Author/Mizuho Koshishiba","target":"Author/Mizuho Koshishiba","line":71},{"title":"Author/Takeshi Yasumoto","target":"Author/Takeshi Yasumoto","line":72},{"title":"Author/Takeshi Yasumoto","target":"Author/Takeshi Yasumoto","line":73},{"title":"Author/Takeshi Yasumoto","target":"Author/Takeshi Yasumoto","line":74},{"title":"Author/Satoshi Shimizu","target":"Author/Satoshi Shimizu","line":75},{"title":"Author/Satoshi Shimizu","target":"Author/Satoshi Shimizu","line":76},{"title":"Author/Tomoki Kintaka","target":"Author/Tomoki Kintaka","line":77},{"title":"Author/Tomoki Kintaka","target":"Author/Tomoki Kintaka","line":78},{"title":"Author/Kazuo Nagai","target":"Author/Kazuo Nagai","line":79},{"title":"Author/Kaoru Nagai","target":"Author/Kaoru Nagai","line":80},{"title":"PDF","target":"biblib/kobayashi_total_2021/kobayashi_total_2021.pdf","line":82}],"metadata":{"id":"kobayashi_total_2021","type":"article-journal","title":"Total Synthesis, Structure Revision, and Neuroprotective Effect of Hericenones C–H and Their Derivatives","issued":{"date-parts":[[2021]]},"DOI":"10.1021/acs.joc.0c02681","container-title":"Journal of Organic Chemistry","abstract":"The first total syntheses of hericenones C-H and \"putative 3-hydroxyhericenone F\" were achieved. Highlights of the synthesis include the straightforward construction of the resorcinol core and geranyl side chain, assembly of the natural product skeleton by sequential O-geranylation and a clay/zeolite-mediated O → C rearrangement reaction, and a biomimetic cyclization to form a variety of bicyclic natural hericenones and their congeners. The structure of the \"putative 3-hydroxyhericenone F\" was revised as the 5-exo cyclization product (named: hericenone Z) of epoxyhericenone C through in-depth analyses of the cyclization modes in addition to NMR spectroscopic studies. To gain insights into the biological functions of geranyl-resorcinols in Hericium erinaceus, potential neuroprotective effects against endoplasmic reticulum (ER) stress-dependent cell death were evaluated systematically to clarify a fundamental structure-activity relationship. Among the compounds assayed, the linoleate-containing hericenone analogue, i.e., the regioisomer of hericene D, was found to possess the most potent neuroprotective effect against tunicamycin and thapsigargin-induced ER stress-dependent cell death.","tags":["#literature_note"],"author":[{"family":"Kobayashi","given":"Shōji","literal":""},{"family":"Kobayashi","given":"Shoji","literal":""},{"family":"Tamura","given":"Takeshi","literal":""},{"family":"Tamura","given":"Tomoki","literal":""},{"family":"Koshishiba","given":"Mizuho","literal":""},{"family":"Koshishiba","given":"Mizuho","literal":""},{"family":"Yasumoto","given":"Takeshi","literal":""},{"family":"Yasumoto","given":"Takeshi","literal":""},{"family":"Yasumoto","given":"Takeshi","literal":""},{"family":"Shimizu","given":"Satoshi","literal":""},{"family":"Shimizu","given":"Satoshi","literal":""},{"family":"Kintaka","given":"Tomoki","literal":""},{"family":"Kintaka","given":"Tomoki","literal":""},{"family":"Nagai","given":"Kazuo","literal":""},{"family":"Nagai","given":"Kaoru","literal":""}],"citation-key":"kobayashi_total_2021","year":"2021","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Total Synthesis, Structure Revision, and Neuroprotective Effect of Hericenones C–H and Their Derivatives"],"author-links":["[[Author/Shōji Kobayashi]]","[[Author/Shoji Kobayashi]]","[[Author/Takeshi Tamura]]","[[Author/Tomoki Tamura]]","[[Author/Mizuho Koshishiba]]","[[Author/Mizuho Koshishiba]]","[[Author/Takeshi Yasumoto]]","[[Author/Takeshi Yasumoto]]","[[Author/Takeshi Yasumoto]]","[[Author/Satoshi Shimizu]]","[[Author/Satoshi Shimizu]]","[[Author/Tomoki Kintaka]]","[[Author/Tomoki Kintaka]]","[[Author/Kazuo Nagai]]","[[Author/Kaoru Nagai]]"],"attachment":["[[biblib/kobayashi_total_2021/kobayashi_total_2021.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"18wh3oa","at":1774951888545}},"smart_blocks:Research/@kobayashi_total_2021.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.10177179,-0.0342018,0.02413389,0.00739168,-0.01076814,0.02721355,-0.03543311,0.02326762,-0.02980128,0.01566516,-0.01719656,-0.04295336,0.04325998,-0.01568227,-0.02360887,0.00500888,-0.03480729,0.0519672,-0.06500545,0.0093149,-0.0259882,-0.05142018,0.02459503,0.03528918,0.05514972,0.0223112,-0.01477496,0.05879216,-0.08836406,-0.25647804,-0.01663744,0.02627935,0.01651749,-0.04932206,-0.03090419,0.01898733,0.0