","line":89},{"title":"Author/Nancy Y. Ip","target":"Author/Nancy Y. Ip","line":90},{"title":"Author/Wen-Cai Ye","target":"Author/Wen-Cai Ye","line":91},{"title":"Author/Wen-Cai Ye","target":"Author/Wen-Cai Ye","line":92},{"title":"PDF","target":"biblib/zhang_triterpenoids_2011/zhang_triterpenoids_2011.pdf","line":94}],"metadata":{"id":"zhang_triterpenoids_2011","type":"article-journal","title":"Triterpenoids with neurotrophic activity from Ganoderma lucidum","issued":{"date-parts":[[2011]]},"DOI":"10.1080/14786419.2010.496367","container-title":"Natural Product Research","abstract":"A new triterpenoid, 4,4,14α-trimethyl-5α-chol-7,9(11)-dien-3-oxo-24-oic acid (1), together with seven known triterpenoids, were isolated from the dried fruiting bodies of Ganoderma lucidum. Their structures were elucidated by extensive spectroscopic analyses. Bioassay results revealed that compounds 1 and methyl ganoderic acid B (5) had nerve growth factor-like neuronal survival-promoting effects, whereas compounds 1, and 4–7 showed brain-derived neurotrophic factor-like neuronal survival-promoting activities.","tags":["#literature_note"],"author":[{"family":"Zhang","given":"Xiaoqi","literal":""},{"family":"Zhang","given":"Xiao-Qi","literal":""},{"family":"Ip","given":"Fanny Chun Fun","literal":""},{"family":"Ip","given":"Fanny C. F.","literal":""},{"family":"Zhang","given":"Dongmei","literal":""},{"family":"Zhang","given":"Dong-Mei","literal":""},{"family":"Lixin","given":"Chen","literal":""},{"family":"Chen","given":"Li-Xin","literal":""},{"family":"Zhang","given":"Wei","literal":""},{"family":"Zhang","given":"Wei","literal":""},{"family":"Li","given":"Yao-Lan","literal":""},{"family":"Li","given":"Yao-Lan","literal":""},{"family":"Li","given":"Yao-Lan","literal":""},{"family":"Li","given":"Yao-Lan","literal":""},{"family":"Ip","given":"Nancy Y.","literal":""},{"family":"Ip","given":"Nancy Y.","literal":""},{"family":"Ye","given":"Wen-Cai","literal":""},{"family":"Ye","given":"Wen-Cai","literal":""}],"citation-key":"zhang_triterpenoids_2011","year":"2011","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Triterpenoids with neurotrophic activity from Ganoderma lucidum"],"author-links":["[[Author/Xiaoqi Zhang]]","[[Author/Xiao-Qi Zhang]]","[[Author/Fanny Chun Fun Ip]]","[[Author/Fanny C. F. Ip]]","[[Author/Dongmei Zhang]]","[[Author/Dong-Mei Zhang]]","[[Author/Chen Lixin]]","[[Author/Li-Xin Chen]]","[[Author/Wei Zhang]]","[[Author/Wei Zhang]]","[[Author/Yao-Lan Li]]","[[Author/Yao-Lan Li]]","[[Author/Yao-Lan Li]]","[[Author/Yao-Lan Li]]","[[Author/Nancy Y. Ip]]","[[Author/Nancy Y. Ip]]","[[Author/Wen-Cai Ye]]","[[Author/Wen-Cai Ye]]"],"attachment":["[[biblib/zhang_triterpenoids_2011/zhang_triterpenoids_2011.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"by4vsd","at":1774951891770}},"smart_blocks:Research/@zhang_triterpenoids_2011.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.03684692,-0.00944742,0.0031826,-0.04891549,0.04253636,0.03689371,0.01220289,0.05177787,-0.03835191,0.00325299,0.04390798,-0.01576325,0.09252514,0.02008273,-0.00366013,-0.01936106,-0.02090498,-0.01701209,-0.05405487,-0.01427262,0.05987744,-0.07902185,0.06905294,0.0159174,0.08725627,0.03640778,-0.00136501,-0.00213503,-0.03078842,-0.23734869,-0.03132121,0.11897023,-0.00985455,-0.02296611,0.01190147,0.02133312,-0.02216915,0.03343441,-0.06670456,-0.01775078,0.0703095,0.0229082,0.0125698,0.03651885,0.00896787,0.00991067,-0.05194486,-0.02676201,0.02178715,-0.05456893,-0.00824477,-0.02883513,0.05503146,0.01970286,0.00886113,-0.00471883,0.01818129,0.0039161,0.01069281,0.01790833,0.07149576,0.01593335,-0.16619423,0.06869408,0.0283439,0.01595093,-0.08491406,-0.03694655,0.07665345,0.05381359,-0.04776997,0.04930612,0.02001699,0.0499386,-0.00028886,0.02185906,0.0469049,-0.02335088,-0.04905955,-0.04476508,0.02585847,0.06015771,-0.01791347,0.01602348,-0.05937856,-0.01441986,-0.01836856,-