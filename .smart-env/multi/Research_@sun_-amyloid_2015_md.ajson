-0.01757823,-0.00392404,0.1485163,-0.01753507,-0.01476629,0.00634962,0.00781871,0.05996899,-0.00880696,-0.01770786,0.00310917,-0.03414705,0.10634165,0.01574037,0.06297214,0.1205913,-0.06772802,0.02392071,-0.01089355,-0.01216124,0.0354795,0.0150632,-0.04123758,0.04208627,0.07573559,-0.03369349,-0.05225239,-0.01337053,0.04568347,0.00412184,-0.01877243,-0.03095456,-0.010127,0.03923009,-0.01060724,0.01778186,0.00261428,-0.05018225,-0.00717168,0.02212573,0.01741026,0.02591076,-0.07141972,0.1106263,0.02848459],"last_embed":{"hash":"nu5ye7","tokens":420}}},"last_read":{"hash":"nu5ye7","at":1774951885512},"class_name":"SmartSource","last_import":{"mtime":1774951813974,"size":1956,"at":1774951884760,"hash":"nu5ye7"},"blocks":{"#---frontmatter---":[1,49],"#Β-Amyloid: the key peptide in the pathogenesis of Alzheimer's disease.":[51,55],"#Β-Amyloid: the key peptide in the pathogenesis of Alzheimer's disease.#{1}":[53,55]},"outlinks":[{"title":"Author/Xiaojuan Sun","target":"Author/Xiaojuan Sun","line":39},{"title":"Author/Xiaojuan Sun","target":"Author/Xiaojuan Sun","line":40},{"title":"Author/Weidong Chen","target":"Author/Weidong Chen","line":41},{"title":"Author/Wei-Dong Chen","target":"Author/Wei-Dong Chen","line":42},{"title":"Author/Yandong Wang","target":"Author/Yandong Wang","line":43},{"title":"Author/Yan-Dong Wang","target":"Author/Yan-Dong Wang","line":44},{"title":"PDF","target":"biblib/sun_-amyloid_2015/sun_-amyloid_2015.pdf","line":46}],"metadata":{"id":"sun_-amyloid_2015","type":"article-journal","title":"Β-Amyloid: the key peptide in the pathogenesis of Alzheimer's disease.","issued":{"date-parts":[[2015]]},"DOI":"10.3389/fphar.2015.00221","container-title":"Frontiers in Pharmacology","abstract":"The amyloid β peptide (Aβ) is a critical initiator that triggers the progression of Alzheimer’s Disease (AD) via accumulation and aggregation, of which the process may be caused by Aβ overproduction or perturbation clearance. Aβ is generated from amyloid precursor protein (APP) through sequential cleavage of β- and γ-secretases while Aβ removal is dependent on the proteolysis and lysosome degradation system. Here, we overviewed the biogenesis and toxicity of Aβ as well as the regulation of Aβ production and clearance. Moreover, we also summarized the animal models correlated with Aβ that are essential in AD research. In addition, we discussed current immunotherapeutic approaches targeting Aβ to give some clues for exploring the more potentially efficient drugs for treatment of AD.","tags":["#literature_note"],"author":[{"family":"Sun","given":"Xiaojuan","literal":""},{"family":"Sun","given":"Xiaojuan","literal":""},{"family":"Chen","given":"Weidong","literal":""},{"family":"Chen","given":"Wei-Dong","literal":""},{"family":"Wang","given":"Yandong","literal":""},{"family":"Wang","given":"Yan-Dong","literal":""}],"citation-key":"sun_-amyloid_2015","year":"2015","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Β-Amyloid: the key peptide in the pathogenesis of Alzheimer's disease."],"author-links":["[[Author/Xiaojuan Sun]]","[[Author/Xiaojuan Sun]]","[[Author/Weidong Chen]]","[[Author/Wei-Dong Chen]]","[[Author/Yandong Wang]]","[[Author/Yan-Dong Wang]]"],"attachment":["[[biblib/sun_-amyloid_2015/sun_-amyloid_2015.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"nu5ye7","at":1774951885503}},"smart_blocks:Research/@sun_-amyloid_2015.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.0497671,0.00921276,0.01321351,-0.03204601,-0.02557124,0.03241329,0.05878361,0.02556019,0.02918138,-0.04385951,0.0000639,-0.05922789,0.04479242,0.09831939,-0.00120974,0.01483677,-0.0654953,0.01569184,-0.04168623,0.00242961,0.08929034,-0.05664957,0.04288011,-0.03761291,0.0423799,0.06491882,-0.02056417,-0.03183183,-0.06819004,-0.24829648,-0.07282165,-0.0381114,0.02608775,-0.02591329,-0.04862782,0.00684325,-0.03403717,0.02511116,-0.02355619,-0.00358948,0.08715345,