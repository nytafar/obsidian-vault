,-0.03247538,0.16534334,-0.02237784,-0.02221345,-0.00632181,0.00879235,0.06745037,-0.08497399,0.01383444,0.01510798,0.06299858,0.11977305,-0.00187444,0.11896765,0.0834562,-0.00581798,-0.02150761,0.00765594,-0.0135703,-0.01626559,-0.03865153,-0.07187069,-0.00345411,0.08118343,-0.08484322,-0.03629256,-0.02433095,0.0129664,-0.00255059,-0.00198235,-0.02894306,-0.01043649,0.07765554,-0.03378781,-0.08196398,0.0106206,-0.05714644,-0.07020432,-0.01110531,-0.00667883,0.02799896,-0.09843541,0.06087596,0.00778533],"last_embed":{"hash":"1xg0cqo","tokens":389}}},"last_read":{"hash":"1xg0cqo","at":1774951885795},"class_name":"SmartSource","last_import":{"mtime":1774951814276,"size":3163,"at":1774951884765,"hash":"1xg0cqo"},"blocks":{"#---frontmatter---":[1,57],"#Medicinal mushrooms in prevention and control of diabetes mellitus":[59,63],"#Medicinal mushrooms in prevention and control of diabetes mellitus#{1}":[61,63]},"outlinks":[{"title":"Author/Dilani D. De Silva","target":"Author/Dilani D. De Silva","line":45},{"title":"Author/Dilani D. De Silva","target":"Author/Dilani D. De Silva","line":46},{"title":"Author/Sylvie Rapior","target":"Author/Sylvie Rapior","line":47},{"title":"Author/Sylvie Rapior","target":"Author/Sylvie Rapior","line":48},{"title":"Author/Kevin D. Hyde","target":"Author/Kevin D. Hyde","line":49},{"title":"Author/Kevin D. Hyde","target":"Author/Kevin D. Hyde","line":50},{"title":"Author/Ali H. Bahkali","target":"Author/Ali H. Bahkali","line":51},{"title":"Author/Ali H. Bahkali","target":"Author/Ali H. Bahkali","line":52},{"title":"PDF","target":"biblib/silva_medicinal_2012/silva_medicinal_2012.pdf","line":54}],"metadata":{"id":"silva_medicinal_2012","type":"article-journal","title":"Medicinal mushrooms in prevention and control of diabetes mellitus","issued":{"date-parts":[[2012]]},"DOI":"10.1007/s13225-012-0187-4","container-title":"Fungal Diversity","abstract":"Diabetes mellitus is a life-threatening chronic metabolic disease caused by lack of insulin and/or insulin dysfunction, characterized by high levels of glucose in the blood (hyperglycemia). Millions worldwide suffer from diabetes and its complications. Significantly, it has been recognized that type 2 diabetes is an important preventable disease and can be avoided or delayed by lifestyle intervention. Presently, there are many chemical and biochemical hypoglycemic agents (synthetic drugs), that are used in treating diabetes and are effective in controlling hyperglycemia. However, as they may have harmful side-effects and fail to significantly alter the course of diabetic complications, natural anti-diabetic drugs from medicinal plants have attracted a great deal of attention. Medicinal mushrooms have been valued as a traditional source of natural bioactive compounds over many centuries and have been targeted as potential hypoglycemic and anti-diabetic agents. Bioactive metabolites including polysaccharides, proteins, dietary fibres, and many other biomolecules isolated from medicinal mushrooms and their cultured mycelia have been shown to be successful in diabetes treatment as biological anti-hyperglycemic agents. In this review we discuss the biological nature of diabetes and, in particular, explore some promising mushrooms that have experimental anti-diabetic properties, preventing or reducing the development of diabetes mellitus. The importance of medicinal mushrooms as agents of medical nutrition therapy and how their metabolites can be used as supportive candidates for prevention and control of diabetes is explored. Future prospects for this field of study and the difficulties and constraints that might affect the development of rational drug products from medicinal mushrooms are discussed.","tags":["#literature_note"],"author":[{"family":"Silva","given":"Dilani D. De","literal":""},{"family":"Silva","given":"Dilani D. De","literal":""},{"family":"Rapior","given":"Sylvie","literal":""},{"family":"Rapior","given":"Sylvie","literal":""},{"family":"Hyde","given":"Kevin D.","literal":""},{"family":"Hyde","given":"Kevin D.","literal":""},{"family":"Bahkali","given":"Ali H.","literal":""},{"family":"Bahkali","given":"Ali H.","literal":""}],"citation-key":"silva_medicinal_2012","year":"2012","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Medicinal mushrooms in prevention and control of diabetes mellitus"],"author-links":["[[Author/Dilani D. De Silva]]","[[Author/Dilani D. De Silva]]","[[Author/Sylvie Rapior]]","[[Author/Sylvie Rapior]]","[[Author/Kevin D. Hyde]]","[[Author/Kevin D. Hyde]]","[[Author/Ali H. Bahkali]]","[[Author/Ali H. Bahkali]]"],"attachment":["[[biblib/silva_medicinal_2012/silva_medicinal_2012.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"1xg0cqo","at":1774951885787}},"smart_blocks:Research/@silva_medicinal_2012.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[0.01904982,0.00528867,0.02456443,-0.02200962,0.01424633,-0.0010365,-0.00219669,0.04613142,-0.05507847,0.00824371,-0.03031114,-0.04896488,-0.00176661,0.02592731,-0.01090809,0.03744406,0.00480062,0.00381512,-0.0809034,0.01251249,0.09444758,0.01303755,0.01933357,-0.00096291,0.02979194,0.02242897,-0.03046827,-0.02907676,-0.0731541,-0.17127669,-0.00658784,0.03695409,0.01990731,-0.01365272,-0.02935494,-0.01858605,-0.04834671,0.04068313,-0.03753259,0.00751966,0.08516898,0.00329765,0.00937968,0.03070481,0.00686381,-0.03247249,-0.03958648,-0.01935055,0.03448676,-0.00776662,-0.04408174,-0.01150415,0.02804929,0.04465427,0.03411852,-0.05327527,0.02330448,0.04740987,0.02518586,0.0673435,0.07243044,0.06696052,-0.16671145,0.0238797,0.02426917,0.00724502,-0.09296253,-0.01233911,0.12049686,-0.02883371,-0.02871503,0.01028523,0.06924202,0.02898679,0.05859477,-0.00955697,-0.00990358,-0.05843333,-0.02844177,0.06374638,0.02524186,0.05769246,0.0436441,-0.03902479,-0.05664643,-0.05594591,0.04708276,-0.05582365,0.04875137,0.01205865,-0.01018457,-0.05610814,-0.03106358,0.01