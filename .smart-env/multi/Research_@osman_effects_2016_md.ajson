3019,0.15023309,0.04312306,0.01485043,0.00415357,-0.03613115,-0.00425881,0.0180292,-0.02611178,-0.02416663,0.02951089,0.12289131,-0.05154918,0.07630057,0.08816776,-0.10269587,-0.0174851,-0.01567982,-0.01744991,0.02945916,0.01459298,-0.06874223,-0.03510634,0.11459357,-0.05348337,-0.0044114,-0.01043824,-0.03095564,-0.02404133,-0.04297856,0.00771882,0.0129632,0.01196519,0.0279583,-0.00816222,0.04382941,-0.05072469,0.01045468,-0.00559952,-0.02761194,-0.02257135,-0.04115728,0.13743466,-0.05066471],"last_embed":{"hash":"1i19pyr","tokens":481}}},"last_read":{"hash":"1i19pyr","at":1774951894790},"class_name":"SmartSource","last_import":{"mtime":1774951827471,"size":2849,"at":1774951884825,"hash":"1i19pyr"},"blocks":{"#---frontmatter---":[1,49],"#Effects of Ginko biloba leaf extract on the neurogenesis of the hippocampal dentate gyrus in the elderly mice.":[51,55],"#Effects of Ginko biloba leaf extract on the neurogenesis of the hippocampal dentate gyrus in the elderly mice.#{1}":[53,55]},"outlinks":[{"title":"Author/Noura M. S. Osman","target":"Author/Noura M. S. Osman","line":39},{"title":"Author/Noura Mohamed Saber Osman","target":"Author/Noura Mohamed Saber Osman","line":40},{"title":"Author/Ayman Amer","target":"Author/Ayman Amer","line":41},{"title":"Author/Ayman S. Amer","target":"Author/Ayman S. Amer","line":42},{"title":"Author/Soha Abdelkawi Abdelwahab","target":"Author/Soha Abdelkawi Abdelwahab","line":43},{"title":"Author/Soha Abdelwahab","target":"Author/Soha Abdelwahab","line":44},{"title":"PDF","target":"biblib/osman_effects_2016/osman_effects_2016.pdf","line":46}],"metadata":{"id":"osman_effects_2016","type":"article-journal","title":"Effects of Ginko biloba leaf extract on the neurogenesis of the hippocampal dentate gyrus in the elderly mice.","issued":{"date-parts":[[2016]]},"DOI":"10.1007/s12565-015-0297-7","container-title":"Anatomical Science International","abstract":"Aging is associated with reduced hippocampal neurogenesis, which may in turn contribute to cognitive impairment. We assessed the effect of Ginkgo biloba (Gb) on hippocampal neurogenesis in elderly male mice using immunohistochemistry. We used anti-caspase-3 as a marker of apoptosis, anti-GFAP as a marker of neural stem cells, anti-Ki-67 as a specific marker for cellular proliferation and anti-doublecortin (DCX) to detect newly born neurons in the hippocampal dentate gyrus (DG) of aged male mice. The 24-month-old male mice were divided into two groups: a control group treated with distilled water and a group fed with Gb at a dose of 100mg/kg once daily for 28days. A sharp decrease in apoptotic cells in Gb-treated compared to nontreated mice was observed by anti-csapase-3 immunostaining. A large number of GFAP+ve cells was found in the subgranular zone of the DG of Gb-treated mice, suggesting an increase in the pool of neural stem cells by Gb treatment. There was also an increase in Ki-67 immunoreactive cells, indicating increased cell proliferation in the DG in the Gb-treated compared to nontreated group. A significant increase in newborn DCX+ve neurons with well-developed tertiary dendrites was also found in the Gb-treated compared to nontreated group. Using Western blot analysis, the expression of DCX protein in the Gb group was also significantly increased compared to the control. The results support a beneficial role of Gb on hippocampal neurogenesis in the context of brain aging.","tags":["#literature_note"],"author":[{"family":"Osman","given":"Noura M. S.","literal":""},{"family":"Osman","given":"Noura Mohamed Saber","literal":""},{"family":"Amer","given":"Ayman","literal":""},{"family":"Amer","given":"Ayman S.","literal":""},{"family":"Abdelwahab","given":"Soha Abdelkawi","literal":""},{"family":"Abdelwahab","given":"Soha","literal":""}],"citation-key":"osman_effects_2016","year":"2016","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Effects of Ginko biloba leaf extract on the neurogenesis of the hippocampal dentate gyrus in the elderly mice."],"author-links":["[[Author/Noura M. S. Osman]]","[[Author/Noura Mohamed Saber Osman]]","[[Author/Ayman Amer]]","[[Author/Ayman S. Amer]]","[[Author/Soha Abdelkawi Abdelwahab]]","[[Author/Soha Abdelwahab]]"],"attachment":["[[biblib/osman_effects_2016/osman_effects_2016.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"1i19pyr","at":1774951894781}},"smart_blocks:Research/@osman_effects_2016.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.05480498,0.00544074,0.0909451,-0.01927972,-0.01337361,0.03284758,0.03515685,0.04088851,-0.05215995,-0.03169323,0.0437293,-0.06021286,0.03946813,0.03160974,-0.01781764,0.00615024,-0.05172798,0.00425793,-0.12316798,0.01247144,0.0262002,-0.03740806,0.05362408,0.01693804,0.02907819,-0.02672547,-0.04056995,0.01463089,-0.064093,-0.21789652,0.02520881,0.04188518,0.0403733,-0.0708252,-0.07934199,0.0293124,0.00636137,0.07209963,-0.05707831,0.00093969,0.06159642,0.03971524,-0.00872853,0.01125895,0.0015753,-0.05205071,-0.04129839,-0.08308874,0.01735039,0.01857901,0.04759795,-0.06855743,0.02494232,0.03311347,-0.01238027,0.02797159,0.02622576,0.0497369,0.05207789,0.03587623,0.01397439,0.01101998,-0.22083125,0.07730123,0.04838937,-0.00791604,-0.04387007,-0.03086674,0.10176075,-0.00388789,-0.09472442,0.01314577,0.04367565,0.01955677,0.01768783,-0.0056729,-0.03965181,-0.03421895,0.05605022,-0.00481026,0.05303053,0.06900632,-0.00237177,-0.02480527,-0.0055549,-0.03791135,-0.02357456,-0.10443658,-0.0107149,-0.0040847,0.03157449,0.00151554,0.0269027,-0.01462602,-0.0238496,-0.0073871,0.01406134,-0.01491594,-0.0571482,0.14542243,-0.04928176,0.0459974,-0.0013434,0.02165956,0.05500125,-0.03066207,-0.07366879,0.00093601,0.02224951,0.06854825,-0.00657411,-0.0204612,-0.01723538,0.05435934,-0.04763848,0.02519443,0.11327611,0.01356094,-0.01322387,0.01507878,-0.04718013,-0.01554717,0.07063464,-0.00738878,0.05950319,0.00286452,-0.04669556,0.07990636,0.04215874,-0