605868,0.01125988,-0.04466511,0.1646056,0.01202645,-0.04496401,-0.01303056,0.02188628,0.04797605,-0.01198358,0.035457,-0.00303304,0.05847353,0.11659061,-0.03120682,0.04316114,0.04243313,-0.04829108,-0.04413316,-0.01904076,0.05618884,0.07689463,0.01407944,-0.11310574,-0.04354183,0.11706648,-0.04239989,-0.02676236,-0.02371548,0.03277928,0.03636314,-0.02978149,-0.06130896,0.00432009,0.05475319,0.00071149,-0.01960037,-0.02961622,0.00200127,-0.03762879,0.01784714,0.03576742,0.01768188,-0.09306853,0.14290375,0.03930749],"last_embed":{"hash":"a458at","tokens":440}}},"last_read":{"hash":"a458at","at":1774951886978},"class_name":"SmartSource","last_import":{"mtime":1774951816108,"size":2173,"at":1774951884776,"hash":"a458at"},"blocks":{"#---frontmatter---":[1,49],"#Hypolipidemic Effect of an Exo-biopolymer Produced from a Submerged Mycelial Culture of Hericium erinaceus":[51,55],"#Hypolipidemic Effect of an Exo-biopolymer Produced from a Submerged Mycelial Culture of Hericium erinaceus#{1}":[53,55]},"outlinks":[{"title":"Author/Byung-Keun Yang","target":"Author/Byung-Keun Yang","line":39},{"title":"Author/Byung-Keun Yang","target":"Author/Byung-Keun Yang","line":40},{"title":"Author/Jun-Bo Park","target":"Author/Jun-Bo Park","line":41},{"title":"Author/Jun-Bo Park","target":"Author/Jun-Bo Park","line":42},{"title":"Author/Chulho Song","target":"Author/Chulho Song","line":43},{"title":"Author/Chi-Hyun Song","target":"Author/Chi-Hyun Song","line":44},{"title":"PDF","target":"biblib/yang_hypolipidemic_2003/yang_hypolipidemic_2003.pdf","line":46}],"metadata":{"id":"yang_hypolipidemic_2003","type":"article-journal","title":"Hypolipidemic Effect of an Exo-biopolymer Produced from a Submerged Mycelial Culture of Hericium erinaceus","issued":{"date-parts":[[2003]]},"DOI":"10.1271/bbb.67.1292","container-title":"Bioscience, Biotechnology, and Biochemistry","abstract":"The hypolipidemic effect of an exo-biopolymer produced from a submerged mycelial culture of Hericium erinaceus was investigated in dietary-induced hyperlipidemic rats. Hypolipidemic effects were proportionally increased with the increasing concentration of the exo-biopolymer for oral administration. The exo-biopolymer, at the dose of 200 mg/kg body weight, substantially reduced the plasma total cholesterol (32.9%), LDL cholesterol (45.4%), triglyceride (34.3%), phospholipid (18.9%), atherogenic index (58.7%), and hepatic HMG-CoA reductase activity (20.2%). It increased the plasma HDL cholesterol level (31.1%) as compared to the control group. The molecular mass of this exo-biopolymer measured by HPLC was under 40 kDa. Total sugar and protein contents were 91.2 and 8.8%, respectively. The sugar and amino acid compositions of the exo-biopolymer were analyzed in detail.","tags":["#literature_note"],"author":[{"family":"Yang","given":"Byung-Keun","literal":""},{"family":"Yang","given":"Byung-Keun","literal":""},{"family":"Park","given":"Jun-Bo","literal":""},{"family":"Park","given":"Jun-Bo","literal":""},{"family":"Song","given":"Chulho","literal":""},{"family":"Song","given":"Chi-Hyun","literal":""}],"citation-key":"yang_hypolipidemic_2003","year":"2003","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Hypolipidemic Effect of an Exo-biopolymer Produced from a Submerged Mycelial Culture of Hericium erinaceus"],"author-links":["[[Author/Byung-Keun Yang]]","[[Author/Byung-Keun Yang]]","[[Author/Jun-Bo Park]]","[[Author/Jun-Bo Park]]","[[Author/Chulho Song]]","[[Author/Chi-Hyun Song]]"],"attachment":["[[biblib/yang_hypolipidemic_2003/yang_hypolipidemic_2003.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"a458at","at":1774951886970}},"smart_blocks:Research/@yang_hypolipidemic_2003.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.03575825,0.07109668,0.04322036,-0.05838512,-0.01650009,-0.00331358,-0.00011385,0.05920327,-0.05350486,-0.02157238,0.01771503,-0.13354175,0.03647859,-0.01741853