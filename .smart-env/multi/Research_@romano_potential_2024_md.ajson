9984,0.00177979,0.1886685,0.01333888,-0.0043668,-0.02354124,-0.00161527,-0.00882946,-0.01615357,-0.01771868,-0.01409909,0.03139866,0.04002342,-0.02537952,0.05602261,0.00587784,0.00213476,-0.0093053,-0.01695758,-0.0240739,-0.01147234,0.01848909,-0.04244542,-0.0714136,0.08241554,-0.05444878,-0.05702406,-0.03053808,-0.03762949,0.00065684,0.02037929,0.02880284,-0.02472204,-0.02681179,0.07519471,0.01902873,-0.01188154,0.00467214,-0.00754656,-0.02232717,-0.02657853,-0.0555643,-0.04134998,0.09151754,0.02012728],"last_embed":{"hash":"1xx9sxy","tokens":454}}},"last_read":{"hash":"1xx9sxy","at":1774951894105},"class_name":"SmartSource","last_import":{"mtime":1774951826924,"size":2500,"at":1774951884823,"hash":"1xx9sxy"},"blocks":{"#---frontmatter---":[1,61],"#The potential therapeutic role of Hericium erinaceus extract in pathologic conditions involving the urogenital-gut axis: insights into the involved mechanisms and mediators.":[63,67],"#The potential therapeutic role of Hericium erinaceus extract in pathologic conditions involving the urogenital-gut axis: insights into the involved mechanisms and mediators.#{1}":[65,67]},"outlinks":[{"title":"Author/L. Romano","target":"Author/L. Romano","line":48},{"title":"Author/L. Napolitano","target":"Author/L. Napolitano","line":49},{"title":"Author/F. Crocetto","target":"Author/F. Crocetto","line":50},{"title":"Author/C. Sciorio","target":"Author/C. Sciorio","line":51},{"title":"Author/K. Priadko","target":"Author/K. Priadko","line":52},{"title":"Author/M. Fonticelli","target":"Author/M. Fonticelli","line":53},{"title":"Author/A. Federico","target":"Author/A. Federico","line":54},{"title":"Author/M. Romano","target":"Author/M. Romano","line":55},{"title":"Author/A. G. Gravina","target":"Author/A. G. Gravina","line":56},{"title":"PDF","target":"biblib/romano_potential_2024/romano_potential_2024.pdf","line":58}],"metadata":{"id":"romano_potential_2024","type":"article-journal","title":"The potential therapeutic role of Hericium erinaceus extract in pathologic conditions involving the urogenital-gut axis: insights into the involved mechanisms and mediators.","issued":{"date-parts":[[2024]]},"DOI":"10.26402/jpp.2024.1.01","container-title":"Journal of physiology and pharmacology : an official journal of the Polish Physiological Society","abstract":"In this review we focused on the putative therapeutic effect of Hericium erinaceus extract in the treatment of pathologic conditions of the lower urinary tract in which intestinal inflammation may play a role. To this aim we reviewed the available evidence on pelvic cross-organ sensitization as a possible mechanism through which intestinal inflammation and dysbiosis may affect the lower urinary tract. Also, we reviewed the clinical and experimental evidence supporting the role of Hericium erinaceus extract as an anti-inflammatory agent highlighting the role of a number of putative mediators and mechanisms which might make this nutraceutical suitable for the management of 'difficult to treat' lower urinary tract disorders.","tags":["#literature_note"],"author":[{"family":"Romano","given":"L.","literal":""},{"family":"Napolitano","given":"L.","literal":""},{"family":"Crocetto","given":"F.","literal":""},{"family":"Sciorio","given":"C.","literal":""},{"family":"Priadko","given":"K.","literal":""},{"family":"Fonticelli","given":"M.","literal":""},{"family":"Federico","given":"A.","literal":""},{"family":"Romano","given":"M.","literal":""},{"family":"Gravina","given":"A. G.","literal":""}],"citation-key":"romano_potential_2024","year":"2024","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["The potential therapeutic role of Hericium erinaceus extract in pathologic conditions involving the urogenital-gut axis: insights into the involved mechanisms and mediators."],"author-links":["[[Author/L. Romano]]","[[Author/L. Napolitano]]","[[Author/F. Crocetto]]","[[Author/C. Sciorio]]","[[Author/K. Priadko]]","[[Author/M. Fonticelli]]","[[Author/A. Fe