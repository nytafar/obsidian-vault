,0.00635212,0.00536198,0.19874738,0.04725166,-0.040027,0.00315274,-0.00096697,0.03383937,-0.02093867,0.02013791,-0.01657658,0.05049723,0.09972861,0.01239195,0.07691116,0.04632573,-0.04606383,-0.02895572,-0.01931121,0.01045647,-0.03072418,-0.01479109,-0.13371611,-0.03576522,0.10357451,-0.04606518,-0.04639785,-0.01596798,0.00438002,0.02399279,0.00051971,-0.00416072,0.02133068,0.02517138,-0.01130989,0.00259038,0.0140971,-0.03355622,-0.06878034,0.02027022,-0.01517697,-0.00147426,-0.07123624,0.05899826,0.08195499],"last_embed":{"hash":"btytnd","tokens":421}}},"last_read":{"hash":"btytnd","at":1774951888408},"class_name":"SmartSource","last_import":{"mtime":1774951818768,"size":2908,"at":1774951884789,"hash":"btytnd"},"blocks":{"#---frontmatter---":[1,64],"#Hericium erinaceus, an amazing medicinal mushroom":[66,70],"#Hericium erinaceus, an amazing medicinal mushroom#{1}":[68,70]},"outlinks":[{"title":"Author/Benjarong Thongbai","target":"Author/Benjarong Thongbai","line":51},{"title":"Author/Benjarong Thongbai","target":"Author/Benjarong Thongbai","line":52},{"title":"Author/Sylvie Rapior","target":"Author/Sylvie Rapior","line":53},{"title":"Author/Sylvie Rapior","target":"Author/Sylvie Rapior","line":54},{"title":"Author/Kevin D. Hyde","target":"Author/Kevin D. Hyde","line":55},{"title":"Author/Kevin D. Hyde","target":"Author/Kevin D. Hyde","line":56},{"title":"Author/Kathrin Wittstein","target":"Author/Kathrin Wittstein","line":57},{"title":"Author/Kathrin Wittstein","target":"Author/Kathrin Wittstein","line":58},{"title":"Author/Marc Stadler","target":"Author/Marc Stadler","line":59},{"title":"Author/Marc Stadler","target":"Author/Marc Stadler","line":60}],"metadata":{"id":"thongbai_hericium_2015","type":"article-journal","title":"Hericium erinaceus, an amazing medicinal mushroom","issued":{"date-parts":[[2015]]},"DOI":"10.1007/s11557-015-1105-4","container-title":"Mycological Progress","abstract":"Medicinal mushrooms have become a compelling topic because the bioactive compounds they contain promise a plethora of therapeutic properties. Hericium erinaceus commonly known as “Houtou” or “Shishigashira” in China and “Yamabushitake” in Japan, has commonly been prescribed in traditional Chinese medicine (TCM), because its consumption has been shown to be beneficial to human health. The species is found throughout the northern hemisphere in Europe, Asia, and North America. Hericium erinaceus has been firmly established as an important medicinal mushroom and its numerous bioactive compounds have been developed into food supplements and alternative medicines. However, the correspondence of the active components that cause the observed effects is often not clear. The mushroom as well as the fermented mycelia have been reported to produce several classes of bioactive molecules, including polysaccharides, proteins, lectins, phenols, and terpenoids. Most interestingly, two classes of terpenoid compounds, hericenones and erinacines, from fruiting bodies and cultured mycelia, respectively, have been found to stimulate nerve growth factor (NGF) synthesis. In this review we examine the scientific literature to explore and highlight the scientific facts concerning medicinal properties of H. erinaceus. We provide up-to-date information on this mushroom, including its taxonomy and a summary of bioactive compounds that appear related to the therapeutic potential of H. erinaceus.","tags":["#literature_note"],"author":[{"family":"Thongbai","given":"Benjarong","literal":""},{"family":"Thongbai","given":"Benjarong","literal":""},{"family":"Rapior","given":"Sylvie","literal":""},{"family":"Rapior","given":"Sylvie","literal":""},{"family":"Hyde","given":"Kevin D.","literal":""},{"family":"Hyde","given":"Kevin D.","literal":""},{"family":"Wittstein","given":"Kathrin","literal":""},{"family":"Wittstein","given":"Kathrin","literal":""},{"family":"Stadler","given":"Marc","literal":""},{"family":"Stadler","given":"Marc","literal":""}],"citation-key":"thongbai_hericium_2015","year":"2015","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Hericium erinaceus, an amazing medicinal mushroom"],"author-links":["[[Author/Benjarong Thongbai]]","[[Author/Benjarong Thongbai]]","[[Author/Sylvie Rapior]]","[[Author/Sylvie Rapior]]","[[Author/Kevin D. Hyde]]","[[Author/Kevin D. Hyde]]","[[Author/Kathrin Wittstein]]","[[Author/Kathrin Wittstein]]","[[Author/Marc Stadler]]","[[Author/Marc Stadler]]"],"attachment":[],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"btytnd","at":1774951888399}},"smart_blocks:Research/@thongbai_hericium_2015.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[0.00441956,-0.04633239,0.04674527,-0.04083692,0.05550772,0.00967625,0.02397996,0.04710133,-0.06313063,-0.00807925,0.01009653,-0.09509273,0.00279565,0.00008373,0.02440667,0.03304984,0.00621693,-0.02109715,-0.09060081,-0.02254128,0.03331556,0.00471136,-0.0052402,0.01235304,0.04241872,0.03434977,-0.03695576,0.02192592,-0.03295378,-0.20628187,-0.02217355,-0.01671475,-0.00031996,0.01035761,-0.0071325,-0.02579442,-0.02418018,0.00551621,-0.00791224,0.02174813,0.04357956,0.05031617,0.05862424,-0.00454891,0.01071056,-0.04036515,-0.02849333,-0.02430217,0.02314934,-0.03396393,-0.03478933,-0.032343,0.02783452,0.08346837,0.06807221,-0.03359529,-0.00521239,0.04887543,-0.00610525,0.05081764,0.05692304,0.07692292,-0.14769632,0.06710901,0.03301184,-0.01995397,-0.08466421,-0.04894647,0.08558111,0.01378948,-0.00433492,0.06675109,0.04066999,0.09216248,0.04289768,-0.06799078,0.01328213,-0.02662561,-0.05052058,0.01505592,0.01041702,0.08361349,0.03668711,-0.01220923,-0.01199611,-0.04044101,-0.00569309,-0.09704401,0.01264053,0.0597663,-0.01156512,-0.06196345,-0.03163051,0.03140952,-0.0589455,0.01415641,-0.03358515,-0.00581249,-0.05801444,0.11880362,-0.0767049,0.0044569,0.00340322,-0.06233857,0.00899898,-0.02607582,-0.03954182,-0.03122677,0.00989124,0.04041268,0.09107216,-0.01622289,-0.081502