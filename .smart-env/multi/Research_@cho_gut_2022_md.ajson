5,0.17558071,0.01541841,-0.00095233,-0.01946977,-0.00968784,0.03666376,0.0462694,-0.01362612,0.04329606,0.00225364,0.0993982,-0.04129083,0.03058694,0.0677965,-0.06101523,0.00596875,-0.02624721,0.03035367,0.03933804,-0.01579357,-0.04944698,-0.06508049,0.09231015,-0.02893389,-0.0185839,-0.01293725,0.02511215,0.00953052,-0.05756924,-0.04120269,-0.008657,0.04016165,0.02500437,0.01642879,0.00983492,-0.02539693,-0.0767316,-0.01559055,0.01807819,-0.03581783,-0.09183307,0.1142574,0.05186862],"last_embed":{"hash":"fthwae","tokens":489}}},"last_read":{"hash":"fthwae","at":1774951891403},"class_name":"SmartSource","last_import":{"mtime":1774951822445,"size":4140,"at":1774951884807,"hash":"fthwae"},"blocks":{"#---frontmatter---":[1,97],"#Gut microbiota profiling in aged dogs after feeding pet food contained Hericium erinaceus":[99,103],"#Gut microbiota profiling in aged dogs after feeding pet food contained Hericium erinaceus#{1}":[101,103]},"outlinks":[{"title":"Author/Hyun-Woo Cho","target":"Author/Hyun-Woo Cho","line":75},{"title":"Author/Hyun-Woo Cho","target":"Author/Hyun-Woo Cho","line":76},{"title":"Author/So-Young Choi","target":"Author/So-Young Choi","line":77},{"title":"Author/Soyoung Choi","target":"Author/Soyoung Choi","line":78},{"title":"Author/Kangmin Seo","target":"Author/Kangmin Seo","line":79},{"title":"Author/Kangmin Seo","target":"Author/Kangmin Seo","line":80},{"title":"Author/Ki Hyun Kim","target":"Author/Ki Hyun Kim","line":81},{"title":"Author/Ki Hyun Kim","target":"Author/Ki Hyun Kim","line":82},{"title":"Author/Jung Hwan Jeon","target":"Author/Jung Hwan Jeon","line":83},{"title":"Author/Jung-Hwan Jeon","target":"Author/Jung-Hwan Jeon","line":84},{"title":"Author/Chan-Ho Kim","target":"Author/Chan-Ho Kim","line":85},{"title":"Author/Chan Ho Kim","target":"Author/Chan Ho Kim","line":86},{"title":"Author/Sejin Lim","target":"Author/Sejin Lim","line":87},{"title":"Author/Sejin Lim","target":"Author/Sejin Lim","line":88},{"title":"Author/Sohee Jeong","target":"Author/Sohee Jeong","line":89},{"title":"Author/Sohee Jeong","target":"Author/Sohee Jeong","line":90},{"title":"Author/Ju Lan Chun","target":"Author/Ju Lan Chun","line":91},{"title":"Author/Ju Lan Chun","target":"Author/Ju Lan Chun","line":92},{"title":"PDF","target":"biblib/cho_gut_2022/cho_gut_2022.pdf","line":94}],"metadata":{"id":"cho_gut_2022","type":"article-journal","title":"Gut microbiota profiling in aged dogs after feeding pet food contained Hericium erinaceus","issued":{"date-parts":[[2022]]},"DOI":"10.5187/jast.2022.e66","container-title":"Journal of Animal Science and Technology","abstract":"Health concern of dogs is the most important issue for pet owners. People who have companied the dogs long-term provide the utmost cares for their well-being and healthy life. Recently, it was revealed that the population and types of gut microbiota affect the metabolism and immunity of the host. However, there is little information on the gut microbiome of dogs. Hericium erinaceus (H. erinaceus; HE) is one of the well-known medicinal mushrooms and has multiple bioactive components including polyphenol, β-glucan, polysaccharides, ergothioneine, hericerin, erinacines, etc. Here we tested a pet food that contained H. erinaceus for improvement in the gut microbiota environment of aged dogs. A total of 18 dogs, each 11 years old, were utilized. For sixteen weeks, the dogs were fed with 0.4 g of H. erinaceus (HE-L), or 0.8 g (HE-H), or without H. erinaceus (CON) per body weight (kg) with daily diets (n = 6 per group). Taxonomic analysis was performed using metagenomics to investigate the difference in the gut microbiome. Resulting from principal coordinates analysis (PCoA) to confirm the distance difference between the groups, there was a significant difference between HE-H and CON due to weighted Unique fraction metric (Unifrac) distance (p = 0.047), but HE-L did not have a statistical difference compared to that of CON. Additionally, the result of Linear discriminate analysis of effect size (LEfSe) showed that phylum Bacteroidetes in HE-H and its order Bacteroidales increased, compared to that of CON, Additionally, phylum Firmicutes in HE-H, and its genera (Streptococcus, Tyzzerella) were reduced. Furthermore, at the family level, Campylobacteraceae and its genus Campylobacter in HE-H was decreased compared to that of CON. Summarily, our data demonstrated that the intake of H. erinaceus can regulate the gut microbial community in aged dogs, and an adequate supply of HE on pet diets would possibly improve immunity and anti-obesity on gut-microbiota in dogs.","tags":["#literature_note"],"author":[{"family":"Cho","given":"Hyun-Woo","literal":""},{"family":"Cho","given":"Hyun-Woo","literal":""},{"family":"Choi","given":"So-Young","literal":""},{"family":"Choi","given":"Soyoung","literal":""},{"family":"Seo","given":"Kangmin","literal":""},{"family":"Seo","given":"Kangmin","literal":""},{"family":"Kim","given":"Ki Hyun","literal":""},{"family":"Kim","given":"Ki Hyun","literal":""},{"family":"Jeon","given":"Jung Hwan","literal":""},{"family":"Jeon","given":"Jung-Hwan","literal":""},{"family":"Kim","given":"Chan-Ho","literal":""},{"family":"Kim","given":"Chan Ho","literal":""},{"family":"Lim","given":"Sejin","literal":""},{"family":"Lim","given":"Sejin","literal":""},{"family":"Jeong","given":"Sohee","literal":""},{"family":"Jeong","given":"Sohee","literal":""},{"family":"Chun","given":"Ju Lan","literal":""},{"family":"Chun","given":"Ju Lan","literal":""}],"citation-key":"cho_gut_2022","year":"2022","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Gut microbiota profiling in aged dogs after feeding pet food contained Hericium erinaceus"],"author-links":["[[Author/Hyun-Woo Cho]]","[[Author/Hyun-Woo Cho]]","[[Author/So-Young Choi]]","[[Author/Soyoung Choi]]","[[Author/Kangmin Seo]]","[[Author/Kangmin Seo]]","[[Author/Ki Hyun Kim]]","[[Author/Ki Hyun Kim]]","[[Author/Jung Hwan Jeon]]","[[Author/Jung-Hwan Jeon]]","[[Aut