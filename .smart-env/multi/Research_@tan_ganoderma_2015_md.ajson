1968608,-0.00780986,0.18403167,0.03175164,-0.02952681,0.02856867,-0.02764777,-0.00518407,-0.02217379,0.01351501,0.01612619,0.04468721,0.10768198,0.00948419,0.0301078,0.0040168,-0.02776048,0.01496785,-0.03466535,-0.02738167,-0.02578858,-0.03149989,-0.17489737,-0.07730445,0.10193146,-0.07870407,-0.02232083,-0.03382001,-0.00494776,0.01421534,-0.01082804,-0.01188111,-0.0037013,0.04833045,-0.04628109,-0.05099137,-0.01391369,-0.03545595,-0.03789647,-0.01073952,0.00491564,0.02995079,-0.09157217,0.0583856,0.03038358],"last_embed":{"hash":"1xd8a7z","tokens":454}}},"last_read":{"hash":"1xd8a7z","at":1774951896254},"class_name":"SmartSource","last_import":{"mtime":1774951829480,"size":3478,"at":1774951884832,"hash":"1xd8a7z"},"blocks":{"#---frontmatter---":[1,81],"#Ganoderma neo-japonicum Imazeki revisited: Domestication study and antioxidant properties of its basidiocarps and mycelia":[83,87],"#Ganoderma neo-japonicum Imazeki revisited: Domestication study and antioxidant properties of its basidiocarps and mycelia#{1}":[85,87]},"outlinks":[{"title":"Author/Wee Cheat Tan","target":"Author/Wee Cheat Tan","line":63},{"title":"Author/Wee-Cheat Tan","target":"Author/Wee-Cheat Tan","line":64},{"title":"Author/Umah Rani Kuppusamy","target":"Author/Umah Rani Kuppusamy","line":65},{"title":"Author/Umah Rani Kuppusamy","target":"Author/Umah Rani Kuppusamy","line":66},{"title":"Author/Chia Wei Phan","target":"Author/Chia Wei Phan","line":67},{"title":"Author/Chia-Wei Phan","target":"Author/Chia-Wei Phan","line":68},{"title":"Author/Yanli Tan","target":"Author/Yanli Tan","line":69},{"title":"Author/Yee Shin Tan","target":"Author/Yee Shin Tan","line":70},{"title":"Author/Jegadeesh Raman","target":"Author/Jegadeesh Raman","line":71},{"title":"Author/Jegadeesh Raman","target":"Author/Jegadeesh Raman","line":72},{"title":"Author/Azliza Mad Anuar","target":"Author/Azliza Mad Anuar","line":73},{"title":"Author/Azliza Mad Anuar","target":"Author/Azliza Mad Anuar","line":74},{"title":"Author/Vikineswary Sabaratnam","target":"Author/Vikineswary Sabaratnam","line":75},{"title":"Author/Vikineswary Sabaratnam","target":"Author/Vikineswary Sabaratnam","line":76},{"title":"PDF","target":"biblib/tan_ganoderma_2015/tan_ganoderma_2015.pdf","line":78}],"metadata":{"id":"tan_ganoderma_2015","type":"article-journal","title":"Ganoderma neo-japonicum Imazeki revisited: Domestication study and antioxidant properties of its basidiocarps and mycelia","issued":{"date-parts":[[2015]]},"DOI":"10.1038/srep12515","container-title":"Scientific Reports","abstract":"Mushroom cultivation benefits humankind as it deliberately encourages wild mushrooms to be commercially propagated while recycling agricultural wastes. Ganoderma neo-japonicum is a rare polypore mushroom found growing on decaying Schizostachyum brachycladium (a tropical bamboo) clumps in Malaysia. The Malaysian indigenous tribes including the Temuans and Temiars use the basidiocarps of G. neo-japonicum to treat various ailments including diabetes. In this study, the domestication of G. neo-japonicum in artificial logs of different agricultural residues was investigated. Sawdust promoted the mycelia spawn colonisation in the shortest period of 38±0.5 days. However, only sawdust and bamboo dust supported the primodia formation. Complex medium supported mycelium growth in submerged cultures and 27.11±0.43g/L of mycelia was obtained after 2 weeks of cultivation at 28°C and 200rpm. Antioxidant potential in mushroom may be influenced by different cultivation and extraction methods. The different extracts from the wild and cultivated basidiocarps as well as mycelia were then tested for their antioxidant properties. Aqueous and ethanol extracts of mycelia and basidiocarps tested had varying levels of antioxidant activities. To conclude, domestication of wild G. neo-japonicum using agroresidues may ensure a continuous supply of G. neo-japonicum for its medicinal use while ensuring the conservation of this rare species.","tags":["#literature_note"],"author":[{"family":"Tan","given":"Wee Cheat","literal":""},{"family":"Tan","given":"Wee-Cheat","literal":""},{"family":"Kuppusamy","given":"Umah Rani","literal":""},{"family":"Kuppusamy","given":"Umah Rani","literal":""},{"family":"Phan","given":"Chia Wei","literal":""},{"family":"Phan","given":"Chia-Wei","literal":""},{"family":"Tan","given":"Yanli","literal":""},{"family":"Tan","given":"Yee Shin","literal":""},{"family":"Raman","given":"Jegadeesh","literal":""},{"family":"Raman","given":"Jegadeesh","literal":""},{"family":"Anuar","given":"Azliza Mad","literal":""},{"family":"Anuar","given":"Azliza Mad","literal":""},{"family":"Sabaratnam","given":"Vikineswary","literal":""},{"family":"Sabaratnam","given":"Vikineswary","literal":""}],"citation-key":"tan_ganoderma_2015","year":"2015","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Ganoderma neo-japonicum Imazeki revisited: Domestication study and antioxidant properties of its basidiocarps and mycelia"],"author-links":["[[Author/Wee Cheat Tan]]","[[Author/Wee-Cheat Tan]]","[[Author/Umah Rani Kuppusamy]]","[[Author/Umah Rani Kuppusamy]]","[[Author/Chia Wei Phan]]","[[Author/Chia-Wei Phan]]","[[Author/Yanli Tan]]","[[Author/Yee Shin Tan]]","[[Author/Jegadeesh Raman]]","[[Author/Jegadeesh Raman]]","[[Author/Azliza Mad Anuar]]","[[Author/Azliza Mad Anuar]]","[[Author/Vikineswary Sabaratnam]]","[[Author/Vikineswary Sabaratnam]]"],"attachment":["[[biblib/tan_ganoderma_2015/tan_ganoderma_2015.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"1xd8a7z","at":1774951896245}},"smart_blocks:Research/@tan_ganoderma_2015.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.0169808,0.01721004,0.05530681,-0.05280835,0.10440464,-0.04085749,0.00117476,0.00314521,-0.05321522,-0.01327496,-0.00216049,-0.06835195,0.02348031,0.04386264,0.0154515,0.01622218,-0.01265819,-0.00449414,-0.05779742,-0.02356254,0.05575158,-0.0313