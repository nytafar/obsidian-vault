79,0.1596884,0.00490156,0.01382736,0.05979775,0.01730371,0.00858865,-0.00588294,0.01811264,0.00249929,0.02872941,0.10323957,-0.05024108,0.01759531,0.05413462,-0.08354056,-0.01968036,0.02641706,0.05659362,0.03522855,-0.00328041,-0.02703822,-0.04072494,0.11353475,-0.05951308,-0.04000015,-0.07894886,-0.04237602,-0.05095909,0.02432631,0.02877488,0.0432561,0.0354259,-0.0101571,-0.01269635,-0.00169766,-0.04479407,0.03107353,-0.02525543,-0.01268769,-0.00438987,-0.03867548,0.09177786,-0.03622389],"last_embed":{"hash":"bdx10h","tokens":441}}},"last_read":{"hash":"bdx10h","at":1774951890389},"class_name":"SmartSource","last_import":{"mtime":1774951820940,"size":3607,"at":1774951884799,"hash":"bdx10h"},"blocks":{"#---frontmatter---":[1,73],"#An acute, double-blind, placebo-controlled cross-over study of 320 mg and 640 mg doses of Bacopa monnieri (CDRI 08) on multitasking stress reactivity and mood.":[75,79],"#An acute, double-blind, placebo-controlled cross-over study of 320 mg and 640 mg doses of Bacopa monnieri (CDRI 08) on multitasking stress reactivity and mood.#{1}":[77,79]},"outlinks":[{"title":"Author/Sarah Benson","target":"Author/Sarah Benson","line":57},{"title":"Author/Sarah Benson","target":"Author/Sarah Benson","line":58},{"title":"Author/Luke A. Downey","target":"Author/Luke A. Downey","line":59},{"title":"Author/Luke A. Downey","target":"Author/Luke A. Downey","line":60},{"title":"Author/Con Stough","target":"Author/Con Stough","line":61},{"title":"Author/Con Stough","target":"Author/Con Stough","line":62},{"title":"Author/Mark Wetherell","target":"Author/Mark Wetherell","line":63},{"title":"Author/Mark Wetherell","target":"Author/Mark Wetherell","line":64},{"title":"Author/A. Zangara","target":"Author/A. Zangara","line":65},{"title":"Author/Andrea Zangara","target":"Author/Andrea Zangara","line":66},{"title":"Author/Andrew Scholey","target":"Author/Andrew Scholey","line":67},{"title":"Author/Andrew Scholey","target":"Author/Andrew Scholey","line":68},{"title":"PDF","target":"biblib/benson_acute_2014/benson_acute_2014.pdf","line":70}],"metadata":{"id":"benson_acute_2014","type":"article-journal","title":"An acute, double-blind, placebo-controlled cross-over study of 320 mg and 640 mg doses of Bacopa monnieri (CDRI 08) on multitasking stress reactivity and mood.","issued":{"date-parts":[[2014]]},"DOI":"10.1002/ptr.5029","container-title":"Phytotherapy Research","abstract":"Little research exists in humans concerning the anxiolytic, antidepressant, sedative, and adaptogenic actions the traditional Ayurvedic medicine Bacopa monnieri (BM) possesses in addition to its documented cognitive-enhancing effects. Preclinical work has identified a number of acute anxiolytic, nootropic, and adaptogenic effects of BM that may also co-occur in humans. The current double-blind, placebo-controlled cross-over study assessed the acute effects of a specific extract of BM (KeenMind® - CDRI 08) in normal healthy participants during completion of a multitasking framework (MTF). Seventeen healthy volunteers completed the MTF, at baseline, then 1h and 2h after consuming a placebo, 320mg BM and 640mg of BM. Treatments were separated by a 7-day washout with order determined by Latin Square. Outcome measures included cognitive outcomes from the MTF, with mood and salivary cortisol measured before and after each completion of the MTF. Change from baseline scores indicated positive cognitive effects, notably at both 1h post and 2h post BM consumption on the Letter Search and Stroop tasks, suggesting an earlier nootropic effect of BM than previously investigated. There were also some positive mood effects and reduction in cortisol levels, pointing to a physiological mechanism for stress reduction associated with BM consumption. It was concluded that acute BM supplementation produced some adaptogenic and nootropic effects that need to be replicated in a larger sample and in isolation from stressful cognitive tests in order to quantify the magnitude of these effects. The study was registered with the Australian and New Zealand Clinical Trials Registry (ACTRN12612000834853).","tags":["#literature_note"],"author":[{"family":"Benson","given":"Sarah","literal":""},{"family":"Benson","given":"Sarah","literal":""},{"family":"Downey","given":"Luke A.","literal":""},{"family":"Downey","given":"Luke A.","literal":""},{"family":"Stough","given":"Con","literal":""},{"family":"Stough","given":"Con","literal":""},{"family":"Wetherell","given":"Mark","literal":""},{"family":"Wetherell","given":"Mark","literal":""},{"family":"Zangara","given":"A.","literal":""},{"family":"Zangara","given":"Andrea","literal":""},{"family":"Scholey","given":"Andrew","literal":""},{"family":"Scholey","given":"Andrew","literal":""}],"citation-key":"benson_acute_2014","year":"2014","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["An acute, double-blind, placebo-controlled cross-over study of 320 mg and 640 mg doses of Bacopa monnieri (CDRI 08) on multitasking stress reactivity and mood."],"author-links":["[[Author/Sarah Benson]]","[[Author/Sarah Benson]]","[[Author/Luke A. Downey]]","[[Author/Luke A. Downey]]","[[Author/Con Stough]]","[[Author/Con Stough]]","[[Author/Mark Wetherell]]","[[Author/Mark Wetherell]]","[[Author/A. Zangara]]","[[Author/Andrea Zangara]]","[[Author/Andrew Scholey]]","[[Author/Andrew Scholey]]"],"attachment":["[[biblib/benson_acute_2014/benson_acute_2014.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"bdx10h","at":1774951890380}},"smart_blocks:Research/@benson_acute_2014.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.0789343,6.9e-7,0.01707169,0.01776649,-0.01739132,0.00204331,0.0526099,0.0032319,-0.03090446,-0.04786842,0.01765223,-0.05504834,0.02201385,0.02600796,0.01057527,-0.00317245,0.06380796,-0.0023798,-0.06552212,-0.0175762,-0.01188006,-0.01547712,0.04176683,-0.01732161,0.03643591,0.03178266,-0.02131159,-0.01695617,-0.