7,-0.01856941,0.16310257,-0.01184626,-0.03884174,-0.01620815,-0.01496396,-0.01280538,0.0329007,0.03163791,0.06857312,0.01725023,0.15117204,0.00924065,0.01560451,0.06671358,-0.0448243,0.00861907,-0.03906531,0.04336272,0.04457442,-0.01983876,-0.09187085,-0.01498721,0.07577601,-0.08775966,0.0228539,-0.05359869,-0.05306965,0.00196974,-0.01952318,-0.00735364,0.01382132,0.05576616,0.01507403,0.00776034,0.02173526,0.00624483,-0.01503621,0.02021205,0.01869392,-0.0086846,-0.07606512,0.07740955,0.00050921],"last_embed":{"hash":"wmtje","tokens":459}}},"last_read":{"hash":"wmtje","at":1774951896129},"class_name":"SmartSource","last_import":{"mtime":1774951829263,"size":3819,"at":1774951884831,"hash":"wmtje"},"blocks":{"#---frontmatter---":[1,81],"#Effects of dietary fermentation concentrate of Hericium caput-medusae (Bull.:Fr.) Pers. on growth performance, digestibility, and intestinal microbiology and morphology in broiler chickens.":[83,87],"#Effects of dietary fermentation concentrate of Hericium caput-medusae (Bull.:Fr.) Pers. on growth performance, digestibility, and intestinal microbiology and morphology in broiler chickens.#{1}":[85,87]},"outlinks":[{"title":"Author/Hongmei Shang","target":"Author/Hongmei Shang","line":63},{"title":"Author/Hong Mei Shang","target":"Author/Hong Mei Shang","line":64},{"title":"Author/Hui Song","target":"Author/Hui Song","line":65},{"title":"Author/Hui Song","target":"Author/Hui Song","line":66},{"title":"Author/Ya Li Xing","target":"Author/Ya Li Xing","line":67},{"title":"Author/Ya Li Xing","target":"Author/Ya Li Xing","line":68},{"title":"Author/Shichao Niu","target":"Author/Shichao Niu","line":69},{"title":"Author/Shu Li Niu","target":"Author/Shu Li Niu","line":70},{"title":"Author/Guo Dong Ding","target":"Author/Guo Dong Ding","line":71},{"title":"Author/Guo Dong Ding","target":"Author/Guo Dong Ding","line":72},{"title":"Author/Yun Jiang","target":"Author/Yun Jiang","line":73},{"title":"Author/Yun Yao Jiang","target":"Author/Yun Yao Jiang","line":74},{"title":"Author/Liang Feng","target":"Author/Liang Feng","line":75},{"title":"Author/Feng Liang","target":"Author/Feng Liang","line":76},{"title":"PDF","target":"biblib/shang_effects_2016/shang_effects_2016.pdf","line":78}],"metadata":{"id":"shang_effects_2016","type":"article-journal","title":"Effects of dietary fermentation concentrate of Hericium caput-medusae (Bull.:Fr.) Pers. on growth performance, digestibility, and intestinal microbiology and morphology in broiler chickens.","issued":{"date-parts":[[2016]]},"DOI":"10.1002/jsfa.7084","container-title":"Journal of the Science of Food and Agriculture","abstract":"BACKGROUND The present study was undertaken to investigate the effects of fermentation concentrate of Hericium caput-medusae (Bull.:Fr.) Pers. (HFC) on growth performance, digestibility, intestinal microbiology, and intestinal morphology in broiler chickens. A total of 600 male Arbor Acres broilers were randomly divided into five dietary treatments (20 broilers per pen with six pens per treatment): CON (basal diet), ANT (basal diet supplemented with 5 mg kg−1 flavomycin) and HFC (basal diet supplemented with 6, 12, and 18 g kg−1 HFC). The experimental lasted for 42 days. RESULTS The results revealed that the average daily gain [linear (L), P < 0.01; quadratic (Q), P < 0.01] of broilers increased when the HFC levels increased during the starter (days 1–21), finisher (days 22–42), and the overall experiment period (days 1 to 42). In the small intestinal digesta and the caecum digesta, the Escherichia coli count (L, P < 0.05; Q, P < 0.001) decreased while the Lactobacilli count (L, P < 0.01; Q, P < 0.001) and Bifidobacteria count (L, P < 0.001; Q, P < 0.001) increased when the HFC levels increased. The crude protein digestibility of broilers (L, P < 0.01; Q, P < 0.001) increased when the HFC levels increased. In the duodenum, jejunum, and ileum of broilers, the villus height and villus height to crypt depth ratio (L, P < 0.001; Q, P < 0.001) increased when the HFC levels increased. CONCLUSION Dietary supplementation with HFC increased gut Lactobacilli and Bifidobacteria counts and inhibited E. coli growth, improved nutrient utilisation and intestine villus structure, and thus improved the growth of broilers. © 2015 Society of Chemical Industry","tags":["#literature_note"],"author":[{"family":"Shang","given":"Hongmei","literal":""},{"family":"Shang","given":"Hong Mei","literal":""},{"family":"Song","given":"Hui","literal":""},{"family":"Song","given":"Hui","literal":""},{"family":"Xing","given":"Ya Li","literal":""},{"family":"Xing","given":"Ya Li","literal":""},{"family":"Niu","given":"Shichao","literal":""},{"family":"Niu","given":"Shu Li","literal":""},{"family":"Ding","given":"Guo Dong","literal":""},{"family":"Ding","given":"Guo Dong","literal":""},{"family":"Jiang","given":"Yun","literal":""},{"family":"Jiang","given":"Yun Yao","literal":""},{"family":"Feng","given":"Liang","literal":""},{"family":"Liang","given":"Feng","literal":""}],"citation-key":"shang_effects_2016","year":"2016","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Effects of dietary fermentation concentrate of Hericium caput-medusae (Bull.:Fr.) Pers. on growth performance, digestibility, and intestinal microbiology and morphology in broiler chickens."],"author-links":["[[Author/Hongmei Shang]]","[[Author/Hong Mei Shang]]","[[Author/Hui Song]]","[[Author/Hui Song]]","[[Author/Ya Li Xing]]","[[Author/Ya Li Xing]]","[[Author/Shichao Niu]]","[[Author/Shu Li Niu]]","[[Author/Guo Dong Ding]]","[[Author/Guo Dong Ding]]","[[Author/Yun Jiang]]","[[Author/Yun Yao Jiang]]","[[Author/Liang Feng]]","[[Author/Feng Liang]]"],"attachment":["[[biblib/shang_effects_2016/shang_effects_2016.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"wmtje","at":1774951896107}},"smart_blocks:Research/@shang_effects_2016.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{