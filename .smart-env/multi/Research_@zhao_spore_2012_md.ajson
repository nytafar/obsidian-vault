-0.01383695,0.14410633,-0.07459167,-0.03162948,-0.02345852,0.01499533,0.01503697,-0.01697889,0.05054514,-0.00930133,0.03375461,0.02527245,0.01763163,0.01321675,0.0279599,-0.04130212,0.01476594,0.01763685,-0.00050817,0.07003673,-0.00061396,-0.03782198,-0.00379466,0.1039487,-0.1027405,-0.05221266,-0.0438943,0.00636166,-0.03503595,-0.02193542,-0.04151494,0.0071183,0.03397164,-0.07178396,-0.02087016,-0.00546165,-0.0662429,0.05358183,0.04449788,-0.00333781,0.03012848,-0.06012999,0.0860275,0.04813376],"last_embed":{"hash":"11k72i0","tokens":403}}},"last_read":{"hash":"11k72i0","at":1774951892554},"class_name":"SmartSource","last_import":{"mtime":1774951824442,"size":3462,"at":1774951884814,"hash":"11k72i0"},"blocks":{"#---frontmatter---":[1,85],"#Spore Powder of Ganoderma lucidum Improves Cancer-Related Fatigue in Breast Cancer Patients Undergoing Endocrine Therapy: A Pilot Clinical Trial":[87,91],"#Spore Powder of Ganoderma lucidum Improves Cancer-Related Fatigue in Breast Cancer Patients Undergoing Endocrine Therapy: A Pilot Clinical Trial#{1}":[89,91]},"outlinks":[{"title":"Author/Hong Zhao","target":"Author/Hong Zhao","line":66},{"title":"Author/Hong Zhao","target":"Author/Hong Zhao","line":67},{"title":"Author/Hong Zhao","target":"Author/Hong Zhao","line":68},{"title":"Author/Qingyuan Zhang","target":"Author/Qingyuan Zhang","line":69},{"title":"Author/Qingyuan Zhang","target":"Author/Qingyuan Zhang","line":70},{"title":"Author/Qingyuan Zhang","target":"Author/Qingyuan Zhang","line":71},{"title":"Author/Ling Zhao","target":"Author/Ling Zhao","line":72},{"title":"Author/Ling Zhao","target":"Author/Ling Zhao","line":73},{"title":"Author/Xu Huang","target":"Author/Xu Huang","line":74},{"title":"Author/Xu Huang","target":"Author/Xu Huang","line":75},{"title":"Author/Jincai Wang","target":"Author/Jincai Wang","line":76},{"title":"Author/Jincai Wang","target":"Author/Jincai Wang","line":77},{"title":"Author/Xinmei Kang","target":"Author/Xinmei Kang","line":78},{"title":"Author/Xinmei Kang","target":"Author/Xinmei Kang","line":79},{"title":"Author/Xinmei Kang","target":"Author/Xinmei Kang","line":80},{"title":"PDF","target":"biblib/zhao_spore_2012/zhao_spore_2012.pdf","line":82}],"metadata":{"id":"zhao_spore_2012","type":"article-journal","title":"Spore Powder of Ganoderma lucidum Improves Cancer-Related Fatigue in Breast Cancer Patients Undergoing Endocrine Therapy: A Pilot Clinical Trial","issued":{"date-parts":[[2012]]},"DOI":"10.1155/2012/809614","container-title":"Evidence-based Complementary and Alternative Medicine","abstract":"The fatigue prevalence in breast cancer survivors is high during the endocrine treatment. However, there are few evidence-based interventions to manage this symptom. The aim of this study was to investigate the effectiveness of spore powder of Ganoderma lucidum for cancer-related fatigue in breast cancer patients undergoing endocrine therapy. Spore powder of Ganoderma lucidum is a kind of Basidiomycete which is a widely used traditional medicine in China. 48 breast cancer patients with cancer-related fatigue undergoing endocrine therapy were randomized into the experimental or control group. FACT-F, HADS, and EORTC QLQ-C30 questionnaires data were collected at baseline and 4 weeks after treatment. The concentrations of TNF-α, IL-6, and liver-kidney functions were measured before and after intervention. The experimental group showed statistically significant improvements in the domains of physical well-being and fatigue subscale after intervention. These patients also reported less anxiety and depression and better quality of life. Immune markers of CRF were significantly lower and no serious adverse effects occurred during the study. This pilot study suggests that spore powder of Ganoderma lucidum may have beneficial effects on cancer-related fatigue and quality of life in breast cancer patients undergoing endocrine therapy without any significant adverse effect.","tags":["#literature_note"],"author":[{"family":"Zhao","given":"Hong","literal":""},{"family":"Zhao","given":"Hong","literal":""},{"family":"Zhao","given":"Hong","literal":""},{"family":"Zhang","given":"Qingyuan","literal":""},{"family":"Zhang","given":"Qingyuan","literal":""},{"family":"Zhang","given":"Qingyuan","literal":""},{"family":"Zhao","given":"Ling","literal":""},{"family":"Zhao","given":"Ling","literal":""},{"family":"Huang","given":"Xu","literal":""},{"family":"Huang","given":"Xu","literal":""},{"family":"Wang","given":"Jincai","literal":""},{"family":"Wang","given":"Jincai","literal":""},{"family":"Kang","given":"Xinmei","literal":""},{"family":"Kang","given":"Xinmei","literal":""},{"family":"Kang","given":"Xinmei","literal":""}],"citation-key":"zhao_spore_2012","year":"2012","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Spore Powder of Ganoderma lucidum Improves Cancer-Related Fatigue in Breast Cancer Patients Undergoing Endocrine Therapy: A Pilot Clinical Trial"],"author-links":["[[Author/Hong Zhao]]","[[Author/Hong Zhao]]","[[Author/Hong Zhao]]","[[Author/Qingyuan Zhang]]","[[Author/Qingyuan Zhang]]","[[Author/Qingyuan Zhang]]","[[Author/Ling Zhao]]","[[Author/Ling Zhao]]","[[Author/Xu Huang]]","[[Author/Xu Huang]]","[[Author/Jincai Wang]]","[[Author/Jincai Wang]]","[[Author/Xinmei Kang]]","[[Author/Xinmei Kang]]","[[Author/Xinmei Kang]]"],"attachment":["[[biblib/zhao_spore_2012/zhao_spore_2012.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"11k72i0","at":1774951892546}},"smart_blocks:Research/@zhao_spore_2012.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.00878879,-0.01656218,0.09556106,-0.0329997,0.0259675,0.04657168,0.01535112,0.04331511,-0.04287504,-0.02799371,0.06507105,-0.04111034,0.00742376,0.04708556,0.00412372,-0.00203948,0.04770863,0.03737125,-0.06469195,0.03900132,-0.02237668,-0.06309117,0.0582374,0.07686555,0.07861838,-0.03061227,-0.04705242,-0.01836121,-0.09972163,-0.1919