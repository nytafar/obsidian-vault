321668,0.04596148,0.01986314,0.17859381,-0.00944115,-0.02442022,0.04348638,-0.04189861,0.01035846,-0.00839368,0.03436667,0.02337711,-0.00134352,0.09113359,-0.04288041,0.08742478,0.09483934,-0.05100628,0.01491796,-0.04748886,-0.00222944,-0.00814291,-0.01840332,-0.03820234,-0.02256655,0.07345108,-0.08390491,0.00499022,-0.03373545,-0.00800754,-0.01237496,0.01866017,-0.00237402,0.03694399,0.05142401,-0.03402941,-0.06062263,0.03375122,-0.00707138,-0.04834275,0.02854424,0.05383512,0.01221362,-0.12003012,0.07865448,0.02050399],"last_embed":{"hash":"5gnl2e","tokens":453}}},"last_read":{"hash":"5gnl2e","at":1774951885387},"class_name":"SmartSource","last_import":{"mtime":1774951813862,"size":3437,"at":1774951884759,"hash":"5gnl2e"},"blocks":{"#---frontmatter---":[1,77],"#In vivo immunomodulatory effect of the lectin from edible mushroom Agaricus bisporus":[79,83],"#In vivo immunomodulatory effect of the lectin from edible mushroom Agaricus bisporus#{1}":[81,83]},"outlinks":[{"title":"Author/Yanina Ditamo","target":"Author/Yanina Ditamo","line":60},{"title":"Author/Yanina Ditamo","target":"Author/Yanina Ditamo","line":61},{"title":"Author/Lucía Lara Rupil","target":"Author/Lucía Lara Rupil","line":62},{"title":"Author/Lucia L. Rupil","target":"Author/Lucia L. Rupil","line":63},{"title":"Author/Víctor G. Sendra","target":"Author/Víctor G. Sendra","line":64},{"title":"Author/Victor G. Sendra","target":"Author/Victor G. Sendra","line":65},{"title":"Author/Gustavo A. Nores","target":"Author/Gustavo A. Nores","line":66},{"title":"Author/Gustavo A. Nores","target":"Author/Gustavo A. Nores","line":67},{"title":"Author/German A. Roth","target":"Author/German A. Roth","line":68},{"title":"Author/Gabriel Fabian Roth","target":"Author/Gabriel Fabian Roth","line":69},{"title":"Author/German A. Roth","target":"Author/German A. Roth","line":70},{"title":"Author/Fernando J. Irazoqui","target":"Author/Fernando J. Irazoqui","line":71},{"title":"Author/Fernando J. Irazoqui","target":"Author/Fernando J. Irazoqui","line":72},{"title":"PDF","target":"biblib/ditamo_vivo_2016/ditamo_vivo_2016.pdf","line":74}],"metadata":{"id":"ditamo_vivo_2016","type":"article-journal","title":"In vivo immunomodulatory effect of the lectin from edible mushroom Agaricus bisporus","issued":{"date-parts":[[2016]]},"DOI":"10.1039/c5fo00360a","container-title":"Food & Function","abstract":"Lectins are glycan-binding proteins that are resistant to digestion in the gastrointestinal tract and enter intact to blood circulation. The aim of this study was to evaluate the influence of edible mushroom Agaricus bisporus lectin (ABL) on innate and adaptive immune responses as well as its effect in two different experimental pathologies that involve the immune system. ABL inhibited in vitro nitric oxide (NO) production by mouse peritoneal macrophages in response to the pro-inflammatory stimuli lipopolysaccharides (LPS). However, it did not modify the activity of arginase, showing that while ABL downregulates M1 activation, it does not affect M2 activation. ABL also inhibited mononuclear cell proliferation in response to mitogen Con A, or in a mixed lymphocyte reaction. During the in vivo studies, oral administration of ABL to BALB/c mice induced a marked inhibition of NO production by peritoneal macrophages after LPS stimuli. The influence of ABL on tumor growth was studied in BALB/c mice receiving daily oral doses of ABL and implanted with CT26 tumor cells. ABL treatment induced significantly higher rate of tumor growth when compared with control mice. On the other hand, oral ABL administration in Wistar rats induced a marked diminution of the incidence of the disease and the severity of the clinical signs of experimental autoimmune encephalomyelitis. We can conclude that ABL has an in vivo immunomodulatory effect reducing the innate and adaptive responses. This food lectin shows potential therapeutic application on control of inflammatory autoimmune pathologies.","tags":["#literature_note"],"author":[{"family":"Ditamo","given":"Yanina","literal":""},{"family":"Ditamo","given":"Yanina","literal":""},{"family":"Rupil","given":"Lucía Lara","literal":""},{"family":"Rupil","given":"Lucia L.","literal":""},{"family":"Sendra","given":"Víctor G.","literal":""},{"family":"Sendra","given":"Victor G.","literal":""},{"family":"Nores","given":"Gustavo A.","literal":""},{"family":"Nores","given":"Gustavo A.","literal":""},{"family":"Roth","given":"German A.","literal":""},{"family":"Roth","given":"Gabriel Fabian","literal":""},{"family":"Roth","given":"German A.","literal":""},{"family":"Irazoqui","given":"Fernando J.","literal":""},{"family":"Irazoqui","given":"Fernando J.","literal":""}],"citation-key":"ditamo_vivo_2016","year":"2016","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["In vivo immunomodulatory effect of the lectin from edible mushroom Agaricus bisporus"],"author-links":["[[Author/Yanina Ditamo]]","[[Author/Yanina Ditamo]]","[[Author/Lucía Lara Rupil]]","[[Author/Lucia L. Rupil]]","[[Author/Víctor G. Sendra]]","[[Author/Victor G. Sendra]]","[[Author/Gustavo A. Nores]]","[[Author/Gustavo A. Nores]]","[[Author/German A. Roth]]","[[Author/Gabriel Fabian Roth]]","[[Author/German A. Roth]]","[[Author/Fernando J. Irazoqui]]","[[Author/Fernando J. Irazoqui]]"],"attachment":["[[biblib/ditamo_vivo_2016/ditamo_vivo_2016.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"5gnl2e","at":1774951885377}},"smart_blocks:Research/@ditamo_vivo_2016.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.0355702,-0.03820835,-0.01245554,-0.05542414,-0.0070346,-0.03429921,0.09511624,0.08250639,-0.05066541,-0.02950364,-0.00264412,-0.10192622,0.00249974,0.03439759,0.01825754,-0.03514133,0.017516,0.03160071,-0.13122453,-0.00677694,-0.00537631,-0.03162975,0.03139291,-0.00099744,0.03745457,-0.02787665,-0.00713436,0.00462259,-0.07682717,-0.2447568,0.00347132,-0.00158766,0.04448245,-0.0