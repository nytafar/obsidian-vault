00711268,0.18336751,0.07318521,-0.0221761,0.00340534,-0.03733592,0.05020192,-0.04354133,0.01700247,0.02045319,0.02599779,0.07667214,-0.06057734,0.06516276,0.0324284,-0.02810766,-0.03123949,-0.05673596,-0.02237339,-0.00136077,0.02159445,-0.12953527,-0.00693665,0.06478664,-0.03513558,-0.05941816,-0.03777267,0.00315681,0.01006241,-0.02131476,0.0146304,0.03902277,0.05672354,0.00044494,-0.01327902,-0.01153689,-0.04649423,-0.02390664,-0.00490285,-0.0130015,-0.00437925,-0.03976087,0.11318175,0.03434028],"last_embed":{"hash":"11apfde","tokens":498}}},"last_read":{"hash":"11apfde","at":1774951890839},"class_name":"SmartSource","last_import":{"mtime":1774951821802,"size":3882,"at":1774951884804,"hash":"11apfde"},"blocks":{"#---frontmatter---":[1,101],"#Polyoxygenated cyathane diterpenoids from the mushroom Cyathus africanus, and their neurotrophic and anti-neuroinflammatory activities.":[103,107],"#Polyoxygenated cyathane diterpenoids from the mushroom Cyathus africanus, and their neurotrophic and anti-neuroinflammatory activities.#{1}":[105,107]},"outlinks":[{"title":"Author/Jing Wei","target":"Author/Jing Wei","line":78},{"title":"Author/Jing Wei","target":"Author/Jing Wei","line":79},{"title":"Author/Wan-Hui Guo","target":"Author/Wan-Hui Guo","line":80},{"title":"Author/Wan-Hui Guo","target":"Author/Wan-Hui Guo","line":81},{"title":"Author/Chenyu Cao","target":"Author/Chenyu Cao","line":82},{"title":"Author/Chen-Yu Cao","target":"Author/Chen-Yu Cao","line":83},{"title":"Author/Chen-Yu Cao","target":"Author/Chen-Yu Cao","line":84},{"title":"Author/Rong-Wei Kou","target":"Author/Rong-Wei Kou","line":85},{"title":"Author/Rong-Wei Kou","target":"Author/Rong-Wei Kou","line":86},{"title":"Author/Yuanzhen Xu","target":"Author/Yuanzhen Xu","line":87},{"title":"Author/Yuan-Zhen Xu","target":"Author/Yuan-Zhen Xu","line":88},{"title":"Author/Marcin Górecki","target":"Author/Marcin Górecki","line":89},{"title":"Author/Marcin Górecki","target":"Author/Marcin Górecki","line":90},{"title":"Author/Lorenzo Di Bari","target":"Author/Lorenzo Di Bari","line":91},{"title":"Author/Lorenzo Di Bari","target":"Author/Lorenzo Di Bari","line":92},{"title":"Author/Gennaro Pescitelli","target":"Author/Gennaro Pescitelli","line":93},{"title":"Author/Gennaro Pescitelli","target":"Author/Gennaro Pescitelli","line":94},{"title":"Author/Jin-Ming Gao","target":"Author/Jin-Ming Gao","line":95},{"title":"Author/Jin-Ming Gao","target":"Author/Jin-Ming Gao","line":96},{"title":"PDF","target":"biblib/wei_polyoxygenated_2018/wei_polyoxygenated_2018.pdf","line":98}],"metadata":{"id":"wei_polyoxygenated_2018","type":"article-journal","title":"Polyoxygenated cyathane diterpenoids from the mushroom Cyathus africanus, and their neurotrophic and anti-neuroinflammatory activities.","issued":{"date-parts":[[2018]]},"DOI":"10.1038/s41598-018-20472-4","container-title":"Scientific Reports","abstract":"In a previous study, we reported ten new polyoxygenated cyathane diterpenoids, neocyathins A–J, and their anti-neuroinflammatory effects from the liquid culture of the medicinal Basidiomycete Cyathus africanus. In the present study, eight new highly polyoxygenated cyathane diterpenoids, named neocyathins K–R (1–8), were isolated from the solid culture of C. africanus cultivated on cooked rice, together with three known congeners (9–11). The structures and the absolute configurations of the new compounds were elucidated through comprehensive NMR and HRESIMS spectroscopic data, electronic circular dichroism (ECD) data, and chemical conversion. Compounds 1 and 2 represent the first reported naturally occurring compounds with 4,9-seco-cyathane carbon skeleton incorporating an unprecedented medium-sized 9/7 fused ring system, while the 3,4-seco-cyathane derivative (3) was isolated from Cyathus species for the first time. All compounds were evaluated for their neurotrophic and anti-neuroinflammatory activity. All the isolates at 1–25μM displayed differential nerve growth factor (NGF)-induced neurite outgrowth-promoting activity in PC-12 cells, while one of the compounds, allocyathin B2 (11), inhibited NO production in lipopolysaccharide (LPS)-stimulated microglia BV-2 cells. In addition, molecular docking studies showed that compound 11 generated interactions with the inducible nitric oxide synthase (iNOS) protein.","tags":["#literature_note"],"author":[{"family":"Wei","given":"Jing","literal":""},{"family":"Wei","given":"Jing","literal":""},{"family":"Guo","given":"Wan-Hui","literal":""},{"family":"Guo","given":"Wan-Hui","literal":""},{"family":"Cao","given":"Chenyu","literal":""},{"family":"Cao","given":"Chen-Yu","literal":""},{"family":"Cao","given":"Chen-Yu","literal":""},{"family":"Kou","given":"Rong-Wei","literal":""},{"family":"Kou","given":"Rong-Wei","literal":""},{"family":"Xu","given":"Yuanzhen","literal":""},{"family":"Xu","given":"Yuan-Zhen","literal":""},{"family":"Górecki","given":"Marcin","literal":""},{"family":"Górecki","given":"Marcin","literal":""},{"family":"Bari","given":"Lorenzo Di","literal":""},{"family":"Bari","given":"Lorenzo Di","literal":""},{"family":"Pescitelli","given":"Gennaro","literal":""},{"family":"Pescitelli","given":"Gennaro","literal":""},{"family":"Gao","given":"Jin-Ming","literal":""},{"family":"Gao","given":"Jin-Ming","literal":""}],"citation-key":"wei_polyoxygenated_2018","year":"2018","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Polyoxygenated cyathane diterpenoids from the mushroom Cyathus africanus, and their neurotrophic and anti-neuroinflammatory activities."],"author-links":["[[Author/Jing Wei]]","[[Author/Jing Wei]]","[[Author/Wan-Hui Guo]]","[[Author/Wan-Hui Guo]]","[[Author/Chenyu Cao]]","[[Author/Chen-Yu Cao]]","[[Author/Chen-Yu Cao]]","[[Author/Rong-Wei Kou]]","[[Author/Rong-Wei Kou]]","[[Author/Yuanzhen Xu]]","[[Author/Yuan-Zhen Xu]]","[[Author/Marcin Górecki]]","[[Author/Marcin Górecki]]","[[Author/Lorenzo Di Bari]]","[[Author/Lorenzo Di Bari]]","[[Author/Gennaro Pescitelli]]",