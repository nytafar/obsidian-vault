,-0.01833049,0.05757545,0.15132789,-0.02397114,0.02712601,0.01314022,-0.01671237,-0.00205991,0.02091429,0.0158792,-0.00902697,-0.00409625,0.06569026,-0.03264872,0.05810307,0.06396595,-0.07015133,-0.00921928,-0.02164141,0.0095739,0.01503022,-0.0138363,-0.08031206,-0.02945093,0.08389469,-0.06136162,-0.02858118,-0.05008068,-0.04936968,-0.00224674,-0.02811709,0.01994489,0.06258853,0.06545739,-0.01947959,-0.03316578,-0.00525994,-0.02021099,-0.02103633,-0.01272539,0.034648,-0.02382157,-0.04691995,0.15707627,0.05846944],"last_embed":{"hash":"187tkcl","tokens":466}}},"last_read":{"hash":"187tkcl","at":1774951893029},"class_name":"SmartSource","last_import":{"mtime":1774951825427,"size":5525,"at":1774951884817,"hash":"187tkcl"},"blocks":{"#---frontmatter---":[1,133],"#Redox modulation of cellular stress response and lipoxin A4 expression by Hericium Erinaceus in rat brain: relevance to Alzheimer's disease pathogenesis.":[135,139],"#Redox modulation of cellular stress response and lipoxin A4 expression by Hericium Erinaceus in rat brain: relevance to Alzheimer's disease pathogenesis.#{1}":[137,139]},"outlinks":[{"title":"Author/Angela Trovato Salinaro","target":"Author/Angela Trovato Salinaro","line":102},{"title":"Author/Angela Trovato","target":"Author/Angela Trovato","line":103},{"title":"Author/Angela Trovato","target":"Author/Angela Trovato","line":104},{"title":"Author/Rosalba Siracusa","target":"Author/Rosalba Siracusa","line":105},{"title":"Author/Rosalba Siracusa","target":"Author/Rosalba Siracusa","line":106},{"title":"Author/Rosanna Di Paola","target":"Author/Rosanna Di Paola","line":107},{"title":"Author/R. Di Paola","target":"Author/R. Di Paola","line":108},{"title":"Author/Maria Scuto","target":"Author/Maria Scuto","line":109},{"title":"Author/Maria Scuto","target":"Author/Maria Scuto","line":110},{"title":"Author/Maria Laura Ontario","target":"Author/Maria Laura Ontario","line":111},{"title":"Author/Maria Laura Ontario","target":"Author/Maria Laura Ontario","line":112},{"title":"Author/Rosaria Ornella Bua","target":"Author/Rosaria Ornella Bua","line":113},{"title":"Author/Ornella Bua","target":"Author/Ornella Bua","line":114},{"title":"Author/Paola Di Mauro","target":"Author/Paola Di Mauro","line":115},{"title":"Author/Paola Di Mauro","target":"Author/Paola Di Mauro","line":116},{"title":"Author/Maria Antonietta Toscano","target":"Author/Maria Antonietta Toscano","line":117},{"title":"Author/M. A. Toscano","target":"Author/M. A. Toscano","line":118},{"title":"Author/Cateno Concetto Petralia","target":"Author/Cateno Concetto Petralia","line":119},{"title":"Author/C. C. T. Petralia","target":"Author/C. C. T. Petralia","line":120},{"title":"Author/Luigi Maiolino","target":"Author/Luigi Maiolino","line":121},{"title":"Author/Luigi Maiolino","target":"Author/Luigi Maiolino","line":122},{"title":"Author/Agostino Serra","target":"Author/Agostino Serra","line":123},{"title":"Author/Agostino Serra","target":"Author/Agostino Serra","line":124},{"title":"Author/Salvatore Cuzzocrea","target":"Author/Salvatore Cuzzocrea","line":125},{"title":"Author/Salvatore Cuzzocrea","target":"Author/Salvatore Cuzzocrea","line":126},{"title":"Author/Vittorio Calabrese","target":"Author/Vittorio Calabrese","line":127},{"title":"Author/Vittorio Calabrese","target":"Author/Vittorio Calabrese","line":128},{"title":"PDF","target":"biblib/salinaro_redox_2016-1/salinaro_redox_2016-1.pdf","line":130}],"metadata":{"id":"salinaro_redox_2016-1","type":"article-journal","title":"Redox modulation of cellular stress response and lipoxin A4 expression by Hericium Erinaceus in rat brain: relevance to Alzheimer's disease pathogenesis.","issued":{"date-parts":[[2016]]},"DOI":"10.1186/s12979-016-0078-8","container-title":"Immunity & Ageing","abstract":"There has been a recent upsurge of interest in complementary medicine, especially dietary supplements and foods functional in delaying the onset of age-associated neurodegenerative diseases. Mushrooms have long been used in traditional medicine for thousands of years, being now increasingly recognized as antitumor, antioxidant, antiviral, antibacterial and hepatoprotective agent also capable to stimulate host immune responses. Here we provide evidence of neuroprotective action of Hericium Herinaceus when administered orally to rat. Expression of Lipoxin A4 (LXA4) was measured in different brain regions after oral administration of a biomass Hericium preparation, given for 3month. LXA4 up-regulation was associated with an increased content of redox sensitive proteins involved in cellular stress response, such as Hsp72, Heme oxygenase −1 and Thioredoxin. In the brain of rats receiving Hericium, maximum induction of LXA4 was observed in cortex, and hippocampus followed by substantia Nigra, striatum and cerebellum. Increasing evidence supports the notion that oxidative stress-driven neuroinflammation is a fundamental cause in neurodegenerative diseases. As prominent intracellular redox system involved in neuroprotection, the vitagene system is emerging as a neurohormetic potential target for novel cytoprotective interventions. Vitagenes encode for cytoprotective heat shock proteins 70, heme oxygenase-1, thioredoxin and Lipoxin A4. Emerging interest is now focussing on molecules capable of activating the vitagene system as novel therapeutic target to minimize deleterious consequences associated with free radical-induced cell damage, such as in neurodegeneration. LXA4 is an emerging endogenous eicosanoid able to promote resolution of inflammation, acting as an endogenous “braking signal” in the inflammatory process. In addition, Hsp system is emerging as key pathway for modulation to prevent neuronal dysfunction, caused by protein misfolding. Conceivably, activation of LXA4 signaling and modulation of stress responsive vitagene proteins could serve as a potential therapeutic target for AD-related inflammation and neurodegenerative damage.","tags":["#literature_note"],"author":[{"family":"Salinaro","given":"Angela Trovato","literal":""},{"family":"Trovato","given":"Angela","literal":""},{"family":"Trovato","given":"Angela","literal":""},{"family":"Siracusa","given":"Rosalba","literal":""},{"family":"Siracusa","given":"Rosalba","literal":""},{"family":"Paola","given":"Rosanna Di","literal":""},{"family":"Paola","given":"R. Di","literal":""},{"family":"Scuto","given":"Maria","literal":""},{"family":"Scuto","given":"Maria","literal":""},{"family":"Ontario","given":"Maria Laura","literal":""},{"family":"Ontario","given":"Maria Laura","literal":""},{"family":"Bua","given":"Rosaria Ornella","literal":""},{"family":"Bua","given":"Ornella","literal":""},{"family":"Mauro","given":"Paola Di","literal":""},{"family":"Mauro","given":"Paola Di","literal":""},{"family":"Toscano","given":"Maria Antonietta","literal":""},{"family":"Toscano","given":"M. A.","literal":""},{"family":"Petralia","given":"Cateno Concetto","literal":""},{"family":"Petralia","given":"C. C. T.","literal":""},{"family":"Maiolino","given":"Luigi","literal":""},{"family":"Maiolino","given":"Luigi","literal":""},{"family":"Serra","given":"Agostino","literal":""},{"family":"Serra","given":"Agostino","literal":""},{"family":"Cuzzocrea","given":"Salvatore","literal":""},{"family":"Cuzzocrea","given":"Salvatore","literal":""},{"family":"Calabrese","given":"Vittorio","literal":""},{"family":"Calabrese","given":"Vittorio","literal":""}],"citation-key":"salinaro_redox_2016-1","year":"2016","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Redox modulation of cellular stress response and lipoxin A4 expression by Hericium Erinaceus in rat brain: relevance to Alzheimer's disease pathogenesis."],"author-links":["[[Author/Angela Trovato Salinaro]]","[[Author/Angela Trovato]]","[[Author/Angela Trovato]]","[[Author/Rosalba Siracusa]]","[[Author/Rosalba Siracusa]]","[[Author/Rosanna Di Paola]]","[[Author/R. Di Paola]]","[[Author/Maria Scuto]]","[[Author/Maria Scuto]]","[[Author/Maria Laura O