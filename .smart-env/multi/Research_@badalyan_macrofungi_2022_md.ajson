 anticollagenase, antielastase, antihyaluronidase, antipigmentation, anti-inflammatory, antioxidant, and antityrosinase) to design formulations. Edible medicinal mushrooms are an unlimited source of nutraceuticals and pharmaceuticals. They can be used as a source of ingredients to develop organic cosmeceuticals, nutriceuticals, and nutracosmetics for topical and oral administration.","tags":["#literature_note"],"author":[{"family":"Badalyan","given":"Susanna","literal":""},{"family":"Badalyan","given":"Susanna M.","literal":""},{"family":"Barkhudaryan","given":"Anush","literal":""},{"family":"Barkhudaryan","given":"Anush","literal":""}],"citation-key":"badalyan_macrofungi_2022","year":"2022","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Macrofungi as Cosmeceuticals: a Review"],"author-links":["[[Author/Susanna Badalyan]]","[[Author/Susanna M. Badalyan]]","[[Author/Anush Barkhudaryan]]","[[Author/Anush Barkhudaryan]]"],"attachment":["[[biblib/badalyan_macrofungi_2022/badalyan_macrofungi_2022.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"73kgpb","at":1774951885936}},"smart_blocks:Research/@badalyan_macrofungi_2022.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.00630433,-0.02007198,0.03742225,-0.01505663,0.02646357,-0.01472536,0.01729999,-0.02069614,-0.05022376,-0.00801767,-0.02645996,-0.06714653,0.01730672,-0.00089372,0.03600333,0.0136462,0.06969269,-0.02841623,-0.07733233,0.0261335,0.11609233,-0.0142377,0.03726159,-0.02565053,0.0087614,0.01643075,-0.011492,-0.02611721,-0.04889223,-0.2138173,-0.00323054,-0.00574745,0.03534934,-0.05118445,-0.00268859,-0.03152885,0.00566328,0.10975317,-0.00026685,0.03601975,0.04151188,0.04734093,0.00659978,0.05317314,0.04462903,0.00653091,-0.05269492,0.02720597,-0.0295513,-0.0648931,-0.04698409,-0.04725273,0.02464031,0.0233271,-0.00585384,0.01508824,0.00826413,0.02879311,0.04881242,0.07084682,0.0590457,0.01489087,-0.20532368,0.