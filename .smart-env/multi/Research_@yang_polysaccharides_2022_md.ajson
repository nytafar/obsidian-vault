44593,-0.00046421,-0.03533933,0.17128322,-0.00678519,-0.03425423,0.02370375,0.01621845,-0.00268736,-0.01000515,0.02818586,0.00172615,-0.00600713,0.11385969,-0.04605206,0.00599422,0.05922892,0.00920087,-0.02888562,0.03604695,0.03115943,0.00596618,0.01950069,-0.08975368,-0.04571288,0.09506228,-0.05214457,-0.05352943,-0.04451144,0.05757207,0.01451121,-0.01029685,-0.01169465,-0.00665185,-0.04377056,0.0059205,-0.02888866,-0.0115756,-0.02468121,-0.05681589,0.02264301,0.01195469,0.00539894,-0.09409479,0.09797848,0.0291977],"last_embed":{"hash":"1fua3e2","tokens":465}}},"last_read":{"hash":"1fua3e2","at":1774951893487},"class_name":"SmartSource","last_import":{"mtime":1774951826210,"size":2939,"at":1774951884820,"hash":"1fua3e2"},"blocks":{"#---frontmatter---":[1,77],"#Polysaccharides from Hericium erinaceus Fruiting Bodies: Structural Characterization, Immunomodulatory Activity and Mechanism":[79,83],"#Polysaccharides from Hericium erinaceus Fruiting Bodies: Structural Characterization, Immunomodulatory Activity and Mechanism#{1}":[81,83]},"outlinks":[{"title":"Author/Yang Yang","target":"Author/Yang Yang","line":60},{"title":"Author/Yang Yang","target":"Author/Yang Yang","line":61},{"title":"Author/Jihong Li","target":"Author/Jihong Li","line":62},{"title":"Author/Jihong Li","target":"Author/Jihong Li","line":63},{"title":"Author/Qing Hong","target":"Author/Qing Hong","line":64},{"title":"Author/Qing Hong","target":"Author/Qing Hong","line":65},{"title":"Author/Xuehong Zhang","target":"Author/Xuehong Zhang","line":66},{"title":"Author/Xuehong Zhang","target":"Author/Xuehong Zhang","line":67},{"title":"Author/Zhenmin Liu","target":"Author/Zhenmin Liu","line":68},{"title":"Author/Zhenmin Liu","target":"Author/Zhenmin Liu","line":69},{"title":"Author/Zhenmin Liu","target":"Author/Zhenmin Liu","line":70},{"title":"Author/Tiehua Zhang","target":"Author/Tiehua Zhang","line":71},{"title":"Author/Tiehua Zhang","target":"Author/Tiehua Zhang","line":72},{"title":"PDF","target":"biblib/yang_polysaccharides_2022/yang_polysaccharides_2022.pdf","line":74}],"metadata":{"id":"yang_polysaccharides_2022","type":"article-journal","title":"Polysaccharides from Hericium erinaceus Fruiting Bodies: Structural Characterization, Immunomodulatory Activity and Mechanism","issued":{"date-parts":[[2022]]},"DOI":"10.3390/nu14183721","container-title":"Nutrients","abstract":"Five fractions from crude Hericium erinaceus polysaccharides (HEPs), including HEP-1, HEP-2, HEP-3, HEP-4 and HEP-5, were obtained through column chromatography with a DEAE Cellulose-52 column and Sephadex G-100 column. The contents of total carbohydrates and uronic acid in HEPs were 53.36% and 32.56%, respectively. HEPs were mainly composed of Fuc, Gal and Glu in a molar ratio of 7.9:68.4:23.7. Its chemical structure was characterized by sugar and methylation analysis, along with 1H and 13C NMR spectroscopy. HEP-1 contains the backbone composed of (1→6)-linked-galactose with branches attached to O-2 of some glucose. The immunological activity assay indicated that HEP-1 significantly promoted the production of nitric oxide, interleukin-6, interleukin-10, interferon-γ and tumor necrosis factor-α and the phosphorylation of signaling molecules. Collectively, these results suggested that HEP-1 could improve immunity via NF-κB, MAPK and PI3K/Akt pathways. Hericium erinaceus polysaccharides might be explored as an immunomodulatory agent for use in dietary supplements.","tags":["#literature_note"],"author":[{"family":"Yang","given":"Yang","literal":""},{"family":"Yang","given":"Yang","literal":""},{"family":"Li","given":"Jihong","literal":""},{"family":"Li","given":"Jihong","literal":""},{"family":"Hong","given":"Qing","literal":""},{"family":"Hong","given":"Qing","literal":""},{"family":"Zhang","given":"Xuehong","literal":""},{"family":"Zhang","given":"Xuehong","literal":""},{"family":"Liu","given":"Zhenmin","literal":""},{"family":"Liu","given":"Zhenmin","literal":""},{"family":"Liu","given":"Zhenmin","literal":""},{"family":"Zhang","given":"Tiehua","literal":""},{"family":"Zhang","given":"Tiehua","literal":""}],"citation-key":"yang_polysaccharides_2022","year":"2022","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Polysaccharides from Hericium erinaceus Fruiting Bodies: Structural Characterization, Immunomodulatory Activity and Mechanism"],"author-links":["[[Author/Yang Yang]]","[[Author/Yang Yang]]","[[Author/Jihong Li]]","[[Author/Jihong Li]]","[[Author/Qing Hong]]","[[Author/Qing Hong]]","[[Author/Xuehong Zhang]]","[[Author/Xuehong Zhang]]","[[Author/Zhenmin Liu]]","[[Author/Zhenmin Liu]]","[[Author/Zhenmin Liu]]","[[Author/Tiehua Zhang]]","[[Author/Tiehua Zhang]]"],"attachment":["[[biblib/yang_polysaccharides_2022/yang_polysaccharides_2022.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"1fua3e2","at":1774951893475}},"smart_blocks:Research/@yang_polysaccharides_2022.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.05197823,-0.07176626,0.07802584,-0.06243182,0.01973351,-0.00494914,0.02574234,0.03224537,-0.06737079,-0.03791971,0.05349537,-0.10552665,0.01982689,-0.00497377,0.03830907,0.00421616,-0.01544906,-0.00776333,-0.09487862,0.01223799,0.08716575,-0.07650583,-0.01704246,-0.03041106,0.06693187,0.06259762,0.00503731,-0.04574256,-0.03081539,-0.20754087,-0.00600773,-0.04697827,0.05655901,-0.00948096,-0.02583927,0.00542815,-0.03141998,0.05683899,-0.02445726,0.00610652,0.07728416,0.01666074,0.02901827,-0.00460651,0.02570638,-0.0826423,-0.05600576,-0.05099111,0.01562538,0.00042241,-0.01473523,-0.03271101,0.02732346,0.04590474,0.04854087,0.00862966,0.01271182,-0.01232583,0.04927519,0.01836395,0.05402803,0.04656231,-0.1869548,0.07531403,0.0808727,-0.00774311,-0.05644796,0.00574162,0.06108302,0.03302743,-0.07365672,0.10557707,0.01361937,0.04591664,0.00203675,-0.00543224,0.0381994,-0.04001338,-0.02977997,0.01879395,-0.01104367,0.09508337,0.02686997,-0.00140711