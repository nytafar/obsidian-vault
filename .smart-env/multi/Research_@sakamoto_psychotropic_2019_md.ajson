544155,0.00933922,0.04964764,0.16974966,0.01275195,-0.01435458,0.04039057,-0.05731502,0.01786078,-0.05264796,-0.01169716,-0.02933077,0.06864477,0.10413842,-0.05337864,0.03331607,0.0411067,-0.08769169,-0.04047912,-0.00485236,0.02226932,0.01953043,0.05591496,-0.00109575,-0.03777459,0.09102767,-0.09431732,-0.03963737,-0.03702955,-0.04788961,0.00460358,0.03752569,0.00429645,-0.00460261,0.02451585,-0.01286188,-0.0094879,0.00646438,-0.02297576,-0.00483414,-0.05174189,-0.03598774,0.00570234,-0.03082138,0.13952725,0.04215891],"last_embed":{"hash":"7p041e","tokens":403}}},"last_read":{"hash":"7p041e","at":1774951895729},"class_name":"SmartSource","last_import":{"mtime":1774951828841,"size":3132,"at":1774951884830,"hash":"7p041e"},"blocks":{"#---frontmatter---":[1,57],"#Psychotropic effects of L-theanine and its clinical properties: From the management of anxiety and stress to a potential use in schizophrenia.":[59,63],"#Psychotropic effects of L-theanine and its clinical properties: From the management of anxiety and stress to a potential use in schizophrenia.#{1}":[61,63]},"outlinks":[{"title":"Author/Filipe Lopes Sakamoto","target":"Author/Filipe Lopes Sakamoto","line":45},{"title":"Author/Filipe Lopes Sakamoto","target":"Author/Filipe Lopes Sakamoto","line":46},{"title":"Author/Rodrigo Metzker Pereira Ribeiro","target":"Author/Rodrigo Metzker Pereira Ribeiro","line":47},{"title":"Author/Rodrigo Metzker Pereira Ribeiro","target":"Author/Rodrigo Metzker Pereira Ribeiro","line":48},{"title":"Author/Allain Amador Bueno","target":"Author/Allain Amador Bueno","line":49},{"title":"Author/Allain A. Bueno","target":"Author/Allain A. Bueno","line":50},{"title":"Author/Heitor O. Santos","target":"Author/Heitor O. Santos","line":51},{"title":"Author/Heitor O. Santos","target":"Author/Heitor O. Santos","line":52},{"title":"PDF","target":"biblib/sakamoto_psychotropic_2019/sakamoto_psychotropic_2019.pdf","line":54}],"metadata":{"id":"sakamoto_psychotropic_2019","type":"article-journal","title":"Psychotropic effects of L-theanine and its clinical properties: From the management of anxiety and stress to a potential use in schizophrenia.","issued":{"date-parts":[[2019]]},"DOI":"10.1016/j.phrs.2019.104395","container-title":"Pharmacological Research","abstract":"Abstract Anxiety disorders are highly prevalent in modern societies, and are ranked the sixth most important contributor of non-fatal negative health outcomes. L-theanine is an amino acid naturally found in green tea (Camellia sinensis) and some other plant extracts, and recent clinical studies have proposed promising adjuvant effects of L-theanine for the negative impact of anxiety and psychological stress on health. In this integrative narrative review, we aimed to appraise and further discuss the effects of L-theanine administration on anxiety disorders and psychological stress. Published data suggests that L-theanine administered at daily doses ranging from 200 to 400mg for up to 8 weeks are safe and induce anxiolytic and anti-stress effects in acute and chronic conditions. L-theanine at doses lower and higher than these may also show promising therapeutic potential; however, a more thorough investigation through randomized double-blind placebo-controlled crossover clinical trials are necessary to elucidate its effects for longer periods, providing further insights for meta-analyses and the development of recommendation guidelines. Additionally, animal studies investigating a higher dosage, its combination with other pharmacological compounds and associated metabolic comorbidities are recommended, as cases of hepatotoxicity associated with the consumption of green tea extract have been reported.","tags":["#literature_note"],"author":[{"family":"Sakamoto","given":"Filipe Lopes","literal":""},{"family":"Sakamoto","given":"Filipe Lopes","literal":""},{"family":"Ribeiro","given":"Rodrigo Metzker Pereira","literal":""},{"family":"Ribeiro","given":"Rodrigo Metzker Pereira","literal":""},{"family":"Bueno","given":"Allain Amador","literal":""},{"family":"Bueno","given":"Allain A.","literal":""},{"family":"Santos","given":"Heitor O.","literal":""},{"family":"Santos","given":"Heitor O.","literal":""}],"citation-key":"sakamoto_psychotropic_2019","year":"2019","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Psychotropic effects of L-theanine and its clinical properties: From the management of anxiety and stress to a potential use in schizophrenia."],"author-links":["[[Author/Filipe Lopes Sakamoto]]","[[Author/Filipe Lopes Sakamoto]]","[[Author/Rodrigo Metzker Pereira Ribeiro]]","[[Author/Rodrigo Metzker Pereira Ribeiro]]","[[Author/Allain Amador Bueno]]","[[Author/Allain A. Bueno]]","[[Author/Heitor O. Santos]]","[[Author/Heitor O. Santos]]"],"attachment":["[[biblib/sakamoto_psychotropic_2019/sakamoto_psychotropic_2019.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"7p041e","at":1774951895720}},"smart_blocks:Research/@sakamoto_psychotropic_2019.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.01132738,-0.01850223,0.00875062,0.03189099,0.02453627,0.0342785,0.0900405,0.01344477,-0.03000582,-0.01075768,0.04426469,-0.01677728,0.05592537,0.07623669,0.02806863,-0.0022739,0.01085434,-0.02347024,-0.08198483,-0.02480146,-0.02684321,-0.01500641,0.10200325,-0.01572354,0.00531281,-0.01633449,-0.04645833,0.02671717,-0.08950798,-0.20928127,0.01041053,0.01636671,0.05230081,-0.0344037,-0.04418513,0.01561462,-0.04263689,0.07158972,0.00060683,0.0615356,0.05508021,0.04995666,0.01262701,-0.03269218,-0.03775717,-0.04800076,-0.00477576,-0.01205709,0.02224139,-0.03547415,-0.01958482,-0.04269632,0.07036377,0.01877021,-0.00454702,0.00597265,0.03465424,0.03135187,-0.02429619,0.07665832,-0.0058637,-0.00717623,-0.20455123,0.06218491,0.01781097,-0.02632171,-0.10368495,0.00950926,0.06271102,0.00236508,-0.10207848,-0.01041726,0.00039952,0.04684251,0.06176696,-0.00313166,-0.02697225,-0.0537