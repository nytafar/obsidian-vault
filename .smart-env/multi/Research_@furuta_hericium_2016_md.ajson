18830764,-0.03387419,-0.01955376,0.02035233,0.00518204,0.01563427,0.07163768,0.05721198,-0.00272403,0.03419361,0.10717405,0.05784887,0.05189409,-0.02800636,-0.10648892,-0.04560699,-0.01307302,-0.04058233,-0.02850349,0.01258312,-0.06427921,-0.0793383,0.11313594,-0.04379802,-0.05315144,-0.03498435,-0.00611251,-0.00608858,-0.01346093,-0.04685709,0.00938272,0.06390823,-0.04393058,0.03082998,0.00576203,-0.01828825,-0.03897489,0.01042903,0.01249657,-0.03023337,-0.04555461,0.0661827,0.05175333],"last_embed":{"hash":"1k337w7","tokens":452}}},"last_read":{"hash":"1k337w7","at":1774951893506},"class_name":"SmartSource","last_import":{"mtime":1774951826243,"size":2683,"at":1774951884820,"hash":"1k337w7"},"blocks":{"#---frontmatter---":[1,77],"#Hericium erinaceus extracts alter behavioral rhythm in mice.":[79,83],"#Hericium erinaceus extracts alter behavioral rhythm in mice.#{1}":[81,83]},"outlinks":[{"title":"Author/Shu Furuta","target":"Author/Shu Furuta","line":60},{"title":"Author/Shoko Furuta","target":"Author/Shoko Furuta","line":61},{"title":"Author/Rika Kuwahara","target":"Author/Rika Kuwahara","line":62},{"title":"Author/Rika Kuwahara","target":"Author/Rika Kuwahara","line":63},{"title":"Author/Eri Hiraki","target":"Author/Eri Hiraki","line":64},{"title":"Author/Eri Hiraki","target":"Author/Eri Hiraki","line":65},{"title":"Author/Koichiro Ohnuki","target":"Author/Koichiro Ohnuki","line":66},{"title":"Author/Koichiro Ohnuki","target":"Author/Koichiro Ohnuki","line":67},{"title":"Author/Koichiro Ohnuki","target":"Author/Koichiro Ohnuki","line":68},{"title":"Author/Shinobu Yasuo","target":"Author/Shinobu Yasuo","line":69},{"title":"Author/Shinobu Yasuo","target":"Author/Shinobu Yasuo","line":70},{"title":"Author/Kuniyoshi Shimizu","target":"Author/Kuniyoshi Shimizu","line":71},{"title":"Author/Kuniyoshi Shimizu","target":"Author/Kuniyoshi Shimizu","line":72},{"title":"PDF","target":"biblib/furuta_hericium_2016/furuta_hericium_2016.pdf","line":74}],"metadata":{"id":"furuta_hericium_2016","type":"article-journal","title":"Hericium erinaceus extracts alter behavioral rhythm in mice.","issued":{"date-parts":[[2016]]},"DOI":"10.2220/biomedres.37.227","container-title":"Biomedical Research-tokyo","abstract":"Hericium erinaceus (HE), an edible mushroom, has been used as a herbal medicine in several Asian countries since ancient times. HE has potential as a medicine for the treatment and prevention of dementia, a disorder closely linked with circadian rhythm. This study investigated the effects of the intake of HE extracts on behavioral rhythm, photosensitivity of the circadian clock, and clock gene mRNA expression in the suprachiasmatic nucleus (SCN), a central clock, in mice. Although the HE ethanol extract only affected the offset time of activity, the HE water extract advanced the sleep-wake cycle without affecting the free-running period, photosensitivity, or the clock gene mRNA expression in SCN. In addition, both extracts decreased wakefulness around end of active phase. The findings of the present study suggest that HE may serve as a functional food in the prevention and treatment of Alzheimer's disease and delayed sleep phase syndrome.","tags":["#literature_note"],"author":[{"family":"Furuta","given":"Shu","literal":""},{"family":"Furuta","given":"Shoko","literal":""},{"family":"Kuwahara","given":"Rika","literal":""},{"family":"Kuwahara","given":"Rika","literal":""},{"family":"Hiraki","given":"Eri","literal":""},{"family":"Hiraki","given":"Eri","literal":""},{"family":"Ohnuki","given":"Koichiro","literal":""},{"family":"Ohnuki","given":"Koichiro","literal":""},{"family":"Ohnuki","given":"Koichiro","literal":""},{"family":"Yasuo","given":"Shinobu","literal":""},{"family":"Yasuo","given":"Shinobu","literal":""},{"family":"Shimizu","given":"Kuniyoshi","literal":""},{"family":"Shimizu","given":"Kuniyoshi","literal":""}],"citation-key":"furuta_hericium_2016","year":"2016","dateCreated":"2026-03-31","reading-status":"to-read","aliases":[