5047,0.01244823,0.17554997,0.00167177,-0.01760815,0.03441316,-0.00195048,0.05388235,-0.09171069,0.01088511,0.04122829,-0.01981985,0.06562744,-0.05208751,0.04810141,0.07373743,0.06209217,-0.036378,-0.01006522,-0.01665189,-0.02918985,-0.00785577,-0.10907361,-0.00765027,0.08503475,-0.01118886,-0.05626684,-0.09245813,0.004982,0.04694105,-0.104285,0.06265008,0.01517025,0.01906017,-0.07142105,-0.00813313,-0.07008703,-0.03922575,-0.05429521,0.01144418,-0.05783782,-0.00528495,0.00558227,0.08809821,-0.00564672],"last_embed":{"hash":"1j7q1e8","tokens":466}}},"last_read":{"hash":"1j7q1e8","at":1774951892629},"class_name":"SmartSource","last_import":{"mtime":1774951824573,"size":2483,"at":1774951884815,"hash":"1j7q1e8"},"blocks":{"#---frontmatter---":[1,65],"#Cyathin, a new antibiotic complex produced by Cyathus helenae":[67,71],"#Cyathin, a new antibiotic complex produced by Cyathus helenae#{1}":[69,71]},"outlinks":[{"title":"Author/A. D. Allbutt","target":"Author/A. D. Allbutt","line":51},{"title":"Author/A. D. Allbutt","target":"Author/A. D. Allbutt","line":52},{"title":"Author/William A. Ayer","target":"Author/William A. Ayer","line":53},{"title":"Author/W. A. Ayer","target":"Author/W. A. Ayer","line":54},{"title":"Author/Harold J. Brodie","target":"Author/Harold J. Brodie","line":55},{"title":"Author/H. J. Brodie","target":"Author/H. J. Brodie","line":56},{"title":"Author/B. N. Johri","target":"Author/B. N. Johri","line":57},{"title":"Author/Bhavdish N. Johri","target":"Author/Bhavdish N. Johri","line":58},{"title":"Author/H. Taube","target":"Author/H. Taube","line":59},{"title":"Author/H. Taube","target":"Author/H. Taube","line":60},{"title":"PDF","target":"biblib/allbutt_cyathin_1971/allbutt_cyathin_1971.pdf","line":62}],"metadata":{"id":"allbutt_cyathin_1971","type":"article-journal","title":"Cyathin, a new antibiotic complex produced by Cyathus helenae","issued":{"date-parts":[[1971]]},"DOI":"10.1139/m71-223","container-title":"Canadian Journal of Microbiology","abstract":"The fungus Cyathus helenae Brodie (Gasteromycetes) produces a complex of antibiotic substances collectively called cyathin. Highest yields were obtained when the fungus was grown at room temperature for 25 days on a chemically defined liquid medium in static culture. The action spectrum of cyathin (and its components) was determined by placing cyathin-bearing paper discs on agar plates seeded with the microorganisms being tested. The cyathin complex is active against actinomycetes, bacteria (gram-positive as well as gram-negative), and some fungi, including dermatophytes. Weaker antimicrobial activity is also shown by C. striatus (Huds.) Willd. ex Pers., C. poeppigii L., and C. limbatus L. Seven different compounds have been isolated from the cyathin complex: 2,4,5-trihydroxybenzaldehyde (C7H6O4),cyathin A3(C20H30O3), cyathin A4(C20H30O4),allocyathinA4(C20H30O4),cyathin B3(C20H28O3), cyathin B4(C20H28O4), and cyathin C5(C20H26O5). Aside from 2,4,5-trihydroxybenzaldehyde, these compounds appear not to have...","tags":["#literature_note"],"author":[{"family":"Allbutt","given":"A. D.","literal":""},{"family":"Allbutt","given":"A. D.","literal":""},{"family":"Ayer","given":"William A.","literal":""},{"family":"Ayer","given":"W. A.","literal":""},{"family":"Brodie","given":"Harold J.","literal":""},{"family":"Brodie","given":"H. J.","literal":""},{"family":"Johri","given":"B. N.","literal":""},{"family":"Johri","given":"Bhavdish N.","literal":""},{"family":"Taube","given":"H.","literal":""},{"family":"Taube","given":"H.","literal":""}],"citation-key":"allbutt_cyathin_1971","year":"1971","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Cyathin, a new antibiotic complex produced by Cyathus helenae"],"author-links":["[[Author/A. D. Allbutt]]","[[Author/A. D. Allbutt]]","[[Author/William A. Ayer]]","[[Author/W. A. Ayer]]","[[Author/Harold J. Brodie]]","[[Author/H. J. Brodie]]","[[Author/B. N. Johri]]","[[Author/Bhavdish N. Johri]]","[[Author/H. Taube]]"