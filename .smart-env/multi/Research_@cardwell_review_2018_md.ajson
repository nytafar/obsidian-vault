335,0.19378656,-0.01735568,-0.0368722,-0.03495836,-0.03253827,0.06024565,-0.00626171,0.07218307,0.04625476,0.08968032,0.10944571,0.01062212,0.02544287,0.06617963,-0.03043158,-0.04853971,-0.01864819,-0.03832357,0.03483993,-0.09713221,-0.07468776,-0.03658449,0.1224563,-0.07144258,-0.0355275,-0.06523664,0.03096446,-0.04784914,-0.00629053,-0.00835243,-0.00044558,0.06975023,-0.03131538,-0.02822895,0.00248142,0.00964748,-0.00024898,-0.00201221,0.02050343,0.00084209,-0.05386735,0.10804743,0.04654064],"last_embed":{"hash":"3k0uzy","tokens":419}}},"last_read":{"hash":"3k0uzy","at":1774951889420},"class_name":"SmartSource","last_import":{"mtime":1774951820490,"size":2536,"at":1774951884798,"hash":"3k0uzy"},"blocks":{"#---frontmatter---":[1,57],"#A Review of Mushrooms as a Potential Source of Dietary Vitamin D":[59,63],"#A Review of Mushrooms as a Potential Source of Dietary Vitamin D#{1}":[61,63]},"outlinks":[{"title":"Author/Glenn Cardwell","target":"Author/Glenn Cardwell","line":45},{"title":"Author/Glenn Cardwell","target":"Author/Glenn Cardwell","line":46},{"title":"Author/Janet F. Bornman","target":"Author/Janet F. Bornman","line":47},{"title":"Author/Janet F. Bornman","target":"Author/Janet F. Bornman","line":48},{"title":"Author/Anthony P. James","target":"Author/Anthony P. James","line":49},{"title":"Author/Anthony P. James","target":"Author/Anthony P. James","line":50},{"title":"Author/Lucinda J. Black","target":"Author/Lucinda J. Black","line":51},{"title":"Author/Lucinda J. Black","target":"Author/Lucinda J. Black","line":52},{"title":"PDF","target":"biblib/cardwell_review_2018/cardwell_review_2018.pdf","line":54}],"metadata":{"id":"cardwell_review_2018","type":"article-journal","title":"A Review of Mushrooms as a Potential Source of Dietary Vitamin D","issued":{"date-parts":[[2018]]},"DOI":"10.3390/nu10101498","container-title":"Nutrients","abstract":"When commonly consumed mushroom species are exposed to a source of ultraviolet (UV) radiation, such as sunlight or a UV lamp, they can generate nutritionally relevant amounts of vitamin D. The most common form of vitamin D in mushrooms is D2, with lesser amounts of vitamins D3 and D4, while vitamin D3 is the most common form in animal foods. Although the levels of vitamin D2 in UV-exposed mushrooms may decrease with storage and cooking, if they are consumed before the ‘best-before’ date, vitamin D2 level is likely to remain above 10 μg/100 g fresh weight, which is higher than the level in most vitamin D-containing foods and similar to the daily requirement of vitamin D recommended internationally. Worldwide mushroom consumption has increased markedly in the past four decades, and mushrooms have the potential to be the only non-animal, unfortified food source of vitamin D that can provide a substantial amount of vitamin D2 in a single serve. This review examines the current information on the role of UV radiation in enhancing the concentration of vitamin D2 in mushrooms, the effects of storage and cooking on vitamin D2 content, and the bioavailability of vitamin D2 from mushrooms.","tags":["#literature_note"],"author":[{"family":"Cardwell","given":"Glenn","literal":""},{"family":"Cardwell","given":"Glenn","literal":""},{"family":"Bornman","given":"Janet F.","literal":""},{"family":"Bornman","given":"Janet F.","literal":""},{"family":"James","given":"Anthony P.","literal":""},{"family":"James","given":"Anthony P.","literal":""},{"family":"Black","given":"Lucinda J.","literal":""},{"family":"Black","given":"Lucinda J.","literal":""}],"citation-key":"cardwell_review_2018","year":"2018","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["A Review of Mushrooms as a Potential Source of Dietary Vitamin D"],"author-links":["[[Author/Glenn Cardwell]]","[[Author/Glenn Cardwell]]","[[Author/Janet F. Bornman]]","[[Author/Janet F. Bornman]]","[[Author/Anthony P. James]]","[[Author/Anthony P. James]]","[[Author/Lucinda J. Black]]","[[Author/Lucinda J. Black]]"],"attachment":["[[biblib/cardwell_review_2018/cardwell_review_2018.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"3k0uzy","at":1774951889410}},"smart_blocks:Research/@cardwell_review_2018.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.00801197,-0.03288158,0.01689356,-0.02973736,0.05263343,-0.00966496,0.01714306,0.01855171,-0.06356156,0.04460308,0.03803021,-0.06691567,0.05621447,0.00677608,0.06784978,0.00458481,0.01931297,-0.01482783,-0.11325146,0.03426293,0.05957581,0.00902402,0.01663682,-0.00695287,0.06586534,0.06007447,-0.02154728,-0.01627187,-0.04701125,-0.22460844,0.02180192,0.02842763,0.00163402,-0.04438957,-0.05205875,-0.05947967,0.06090402,-0.01769375,-0.00801872,0.01686861,0.06985021,-0.0169258,0.01064222,0.01697527,-0.04922809,0.00474414,-0.05777368,0.01377013,0.05715533,-0.0429447,-0.0148267,-0.01480246,-0.02609225,-0.0274001,0.00471595,-0.01196632,0.06093334,0.02840483,0.01918738,0.08451559,0.04131201,0.04085444,-0.13808946,0.04467996,0.06584906,0.02654208,-0.07265232,0.01146254,0.03431338,-0.05025715,-0.07512198,0.0031055,0.0310516,0.04089952,0.09859163,-0.04061816,0.0027144,-0.08633751,-0.04335745,-0.01542532,-0.02504756,0.11911082,-0.01181945,0.02328534,-0.00447187,-0.047132,-0.01075015,-0.034309,0.01045275,0.04829019,-0.00801891,-0.03821088,0.00616295,0.05006156,-0.06967446,-0.02937483,0.00962527,-0.01547372,-0.01681583,0.1245187,-0.083257,0.02322931,0.03435304,0.02436118,-0.01234636,-0.03946065,0.00009723,-0.02329812,0.04928199,0.00738878,0.0121146,-0.0047757,-0.02703252,-0.00338833,0.03602295,0.07785342,0.11140709,0.00870052,-0.03616707,-0.01287365,-0.01996406,0.0528178,0.06921549,-0.01352048,0.04068721,-0.01114595,0.01755781,0.00235264,0.02276721,0.03890656,0.07634328,-0.00881254,-0.07625448,-0.04003596,-0.06289586,-0.0126549,0.06063138,-0.04592271,0.00964424,0.01713082,-0.03981591,-0.0599701,-0.04606982,-0.09714951,-0.00363494,0.11172731,0.07097268,0.05940025,-0.02070772,-0.04