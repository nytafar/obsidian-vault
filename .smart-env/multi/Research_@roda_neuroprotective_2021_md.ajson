095465,-0.08869941,0.01989674,-0.00632045,0.14589275,0.02780651,-0.00859483,-0.00115838,0.01701771,0.03569341,0.03373364,-0.02894942,-0.0674829,0.00486282,0.10250685,-0.02323938,0.04307479,0.04665251,-0.08520894,-0.00645459,0.00258637,-0.03102769,0.02956404,0.02814587,-0.03109646,-0.06200877,0.08097329,-0.05674307,-0.0602193,-0.03894491,-0.03927669,-0.00194889,0.00667577,-0.0162134,0.02037171,-0.01259497,-0.00289663,-0.02786789,0.03310766,-0.02688835,-0.03023856,-0.04027665,-0.02756126,0.00188058,-0.06888287,0.16350424,0.02517932],"last_embed":{"hash":"10x7cen","tokens":449}}},"last_read":{"hash":"10x7cen","at":1774951893523},"class_name":"SmartSource","last_import":{"mtime":1774951826257,"size":4190,"at":1774951884821,"hash":"10x7cen"},"blocks":{"#---frontmatter---":[1,120],"#Neuroprotective Metabolites of Hericium erinaceus Promote Neuro-Healthy Aging.":[122,126],"#Neuroprotective Metabolites of Hericium erinaceus Promote Neuro-Healthy Aging.#{1}":[124,126]},"outlinks":[{"title":"Author/Elisa Roda","target":"Author/Elisa Roda","line":93},{"title":"Author/Elisa Roda","target":"Author/Elisa Roda","line":94},{"title":"Author/Erica Cecilia Priori","target":"Author/Erica Cecilia Priori","line":95},{"title":"Author/Erica Cecilia Priori","target":"Author/Erica Cecilia Priori","line":96},{"title":"Author/Daniela Ratto","target":"Author/Daniela Ratto","line":97},{"title":"Author/Daniela Ratto","target":"Author/Daniela Ratto","line":98},{"title":"Author/Fabrizio De Luca","target":"Author/Fabrizio De Luca","line":99},{"title":"Author/Fabrizio De Luca","target":"Author/Fabrizio De Luca","line":100},{"title":"Author/Carmine Di Iorio","target":"Author/Carmine Di Iorio","line":101},{"title":"Author/Carmine Di Iorio","target":"Author/Carmine Di Iorio","line":102},{"title":"Author/Paola Angelone","target":"Author/Paola Angelone","line":103},{"title":"Author/Paola Angelone","target":"Author/Paola Angelone","line":104},{"title":"Author/Carlo Locatelli","target":"Author/Carlo Locatelli","line":105},{"title":"Author/Carlo Locatelli","target":"Author/Carlo Locatelli","line":106},{"title":"Author/Anthea Desiderio","target":"Author/Anthea Desiderio","line":107},{"title":"Author/Anthea Desiderio","target":"Author/Anthea Desiderio","line":108},{"title":"Author/Lorenzo Goppa","target":"Author/Lorenzo Goppa","line":109},{"title":"Author/Lorenzo Goppa","target":"Author/Lorenzo Goppa","line":110},{"title":"Author/Elena Savino","target":"Author/Elena Savino","line":111},{"title":"Author/Elena Savino","target":"Author/Elena Savino","line":112},{"title":"Author/Maria Grazia Bottone","target":"Author/Maria Grazia Bottone","line":113},{"title":"Author/Maria Grazia Bottone","target":"Author/Maria Grazia Bottone","line":114},{"title":"Author/Paola Rossi","target":"Author/Paola Rossi","line":115},{"title":"Author/Paola Rossi","target":"Author/Paola Rossi","line":116}],"metadata":{"id":"roda_neuroprotective_2021","type":"article-journal","title":"Neuroprotective Metabolites of Hericium erinaceus Promote Neuro-Healthy Aging.","issued":{"date-parts":[[2021]]},"DOI":"10.3390/ijms22126379","container-title":"International Journal of Molecular Sciences","abstract":"Frailty is a geriatric syndrome associated with both locomotor and cognitive decline, typically linked to chronic systemic inflammation, i.e., inflammaging. In the current study, we investigated the effect of a two-month oral supplementation with standardized extracts of H. erinaceus, containing a known amount of Erinacine A, Hericenone C, Hericenone D, and L-ergothioneine, on locomotor frailty and cerebellum of aged mice. Locomotor performances were monitored comparing healthy aging and frail mice. Cerebellar volume and cytoarchitecture, together with inflammatory and oxidative stress pathways, were assessed focusing on senescent frail animals. H. erinaceus partially recovered the aged-related decline of locomotor performances. Histopathological analyses paralleled by immunocytochemical evaluation of specific molecules strengthened the neuroprotective role of H. erinaceus able to ameliorate cerebellar alterations, i.e., milder volume reduction, slighter molecular layer thickness decrease and minor percentage of shrunken Purkinje neurons, also diminishing inflammation and oxidative stress in frail mice while increasing a key longevity regulator and a neuroprotective molecule. Thus, our present findings demonstrated the efficacy of a non-pharmacological approach, based on the dietary supplementation using H. erinaceus extract, which represent a promising adjuvant therapy to be associated with conventional geriatric treatments.","tags":["#literature_note"],"author":[{"family":"Roda","given":"Elisa","literal":""},{"family":"Roda","given":"Elisa","literal":""},{"family":"Priori","given":"Erica Cecilia","literal":""},{"family":"Priori","given":"Erica Cecilia","literal":""},{"family":"Ratto","given":"Daniela","literal":""},{"family":"Ratto","given":"Daniela","literal":""},{"family":"Luca","given":"Fabrizio De","literal":""},{"family":"Luca","given":"Fabrizio De","literal":""},{"family":"Iorio","given":"Carmine Di","literal":""},{"family":"Iorio","given":"Carmine Di","literal":""},{"family":"Angelone","given":"Paola","literal":""},{"family":"Angelone","given":"Paola","literal":""},{"family":"Locatelli","given":"Carlo","literal":""},{"family":"Locatelli","given":"Carlo","literal":""},{"family":"Desiderio","given":"Anthea","literal":""},{"family":"Desiderio","given":"Anthea","literal":""},{"family":"Goppa","given":"Lorenzo","literal":""},{"family":"Goppa","given":"Lorenzo","literal":""},{"family":"Savino","given":"Elena","literal":""},{"family":"Savino","given":"Elena","literal":""},{"family":"Bottone","given":"Maria Grazia","literal":""},{"family":"Bottone","given":"Maria Grazia","literal":""},{"family":"Rossi","given":"Paola","literal":""},{"family":"Rossi","given":"Paola","literal":""}],"citation-key":"roda_neuroprotective_2021","year":"2021","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Neuroprotective Metabolites of Hericium erinaceus Promote Neuro-Healthy Aging."],"author-links":["[[Author/Elisa Roda]]","[[Author/Elisa Roda]]","[[Author/Erica Cecilia Priori]]","[[Author/Erica Cecilia Priori]]","[[Author/Daniela Ratto]]","[[Author/Daniela Ratto]]","[[Author/Fabrizio De Luca]]","[[Author/Fabrizio De Luca]]","[[Author/Carmine Di Iorio]]","[[Author/Carmine Di Iorio]]","[[Author/Paola Angelone]]","[[Author/Paola Angelone]]","[[Author/Carlo Locatelli]]","[[Author/Carlo Locatelli]]","[[Author/Anthea Desiderio]]","[[Author/Anthea Desiderio]]","[[Author/Lorenzo Goppa]]","[[Author/Lorenzo Goppa]]","[[Author/Elena Savino]]","[[Author/Elena Savino]]","[[Author/Maria Grazia Bottone]]","[[Author/Maria Grazia Bottone]]","[[Author/Paola Rossi]]","[[Author/Paola Rossi]]"],"attachment":[],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"10x7cen","at":1774951893514}},"smart_blocks:Research/@roda_neuroprotective_2021.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.05678698,0.00737636,-0.0203127,-0.00733539,-0.04097923,0.07941184,-0.0210362,0.05877611,-0.05387254,-0.01066827,-0.00505925,-0.06379043,0.03605228,0.03962209,0.01062396,0.0167775,0.00791099,0.04125156,-0.06079978,-0.00937974,-0.02358649,-0.05952081,0.03909795,0.06750848,0.00630324,0.06940957,-0.04654617,0.00324509,-0.07785907,-0.19539811,-0.00827088,-0.05641899,-0.00068886,-0.01511091,-0.06042005,0.03752558,-0.04156721,0.03246099,0.00540614,0.01886524,0.07006931,0.02638423,-0.00387466,-0.01515439,0.01320231,-0.03611711,-0.01645263,-0.06529387,0.04212575,0.0239662,-0.01506774,-0.01899953,0.07464744,0.07076222,0.03987474,0.02138014,-0.00993989,0.04164454,0.00371425,0.09919364,0.00435425,0.01814237,-0.20062536,0.06711704,0.04503549,-0.0318826,-0.06350302,-0.01349362,0.06982052,-0.01014875,-0.07147486,0.00462613,0.00789422,0.05923292,0.02515956,0.01140668,-0.00467692,-0.0553775,0.05072913,0.01806942,0.