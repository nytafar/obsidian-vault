.09059347,0.00619766,0.02672324,0.15277998,0.02738029,0.01197079,-0.04790483,0.02804861,0.00719584,0.01743897,-0.02414861,0.00469418,0.01717774,0.08549561,-0.01751081,0.07328185,0.06962173,-0.07670487,0.01355173,0.00640502,-0.0314323,0.03050515,0.0560034,-0.00747079,-0.00349703,0.07376716,-0.0191796,0.0306542,-0.01206751,-0.03929019,-0.01099785,-0.01870103,-0.02318478,0.06251918,0.01307118,0.01208008,0.0187548,0.02476389,-0.03293833,0.02815771,0.00310862,0.03621932,0.0599825,-0.0079814,0.09116313,-0.0337929],"last_embed":{"hash":"16xbl0u","tokens":414}}},"last_read":{"hash":"16xbl0u","at":1774951894299},"class_name":"SmartSource","last_import":{"mtime":1774951827285,"size":2664,"at":1774951884824,"hash":"16xbl0u"},"blocks":{"#---frontmatter---":[1,61],"#Ventromedial prefrontal cortex stimulation enhances memory and hippocampal neurogenesis in the middle-aged rats":[63,67],"#Ventromedial prefrontal cortex stimulation enhances memory and hippocampal neurogenesis in the middle-aged rats#{1}":[65,67]},"outlinks":[{"title":"Author/Albert Liu","target":"Author/Albert Liu","line":48},{"title":"Author/Albert Liu","target":"Author/Albert Liu","line":49},{"title":"Author/Neeraj Jain","target":"Author/Neeraj Jain","line":50},{"title":"Author/Neeraj Jain","target":"Author/Neeraj Jain","line":51},{"title":"Author/Ajai Vyas","target":"Author/Ajai Vyas","line":52},{"title":"Author/Ajai Vyas","target":"Author/Ajai Vyas","line":53},{"title":"Author/Lee Yong Lim","target":"Author/Lee Yong Lim","line":54},{"title":"Author/Lee Wei Lim","target":"Author/Lee Wei Lim","line":55},{"title":"Author/Lee Wei Lim","target":"Author/Lee Wei Lim","line":56},{"title":"PDF","target":"biblib/liu_ventromedial_2015/liu_ventromedial_2015.pdf","line":58}],"metadata":{"id":"liu_ventromedial_2015","type":"article-journal","title":"Ventromedial prefrontal cortex stimulation enhances memory and hippocampal neurogenesis in the middle-aged rats","issued":{"date-parts":[[2015]]},"DOI":"10.7554/elife.04803","container-title":"eLife","abstract":"Memory dysfunction is a key symptom of age-related dementia. Although recent studies have suggested positive effects of electrical stimulation for memory enhancement, its potential targets remain largely unknown. In this study, we hypothesized that spatially targeted deep brain stimulation of ventromedial prefrontal cortex enhanced memory functions in a middle-aged rat model. Our results show that acute stimulation enhanced the short-, but not the long-term memory in the novel-object recognition task. Interestingly, after chronic high-frequency stimulation, both the short- and long-term memories were robustly improved in the novel-object recognition test and Morris water-maze spatial task compared to sham. Our results also demonstrated that chronic ventromedial prefrontal cortex high-frequency stimulation upregulated neurogenesis-associated genes along with enhanced hippocampal cell proliferation. Importantly, these memory behaviors were strongly correlated with the hippocampal neurogenesis. Overall, these findings suggest that chronic ventromedial prefrontal cortex high-frequency stimulation may serve as a novel effective therapeutic target for dementia-related disorders.","tags":["#literature_note"],"author":[{"family":"Liu","given":"Albert","literal":""},{"family":"Liu","given":"Albert","literal":""},{"family":"Jain","given":"Neeraj","literal":""},{"family":"Jain","given":"Neeraj","literal":""},{"family":"Vyas","given":"Ajai","literal":""},{"family":"Vyas","given":"Ajai","literal":""},{"family":"Lim","given":"Lee Yong","literal":""},{"family":"Lim","given":"Lee Wei","literal":""},{"family":"Lim","given":"Lee Wei","literal":""}],"citation-key":"liu_ventromedial_2015","year":"2015","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Ventromedial prefrontal cortex stimulation enhances memory and hippocampal neurogenesis in the middle-aged rats"],"author-links":["[[Author/Albert Liu]]","[[Author/Albert Liu]]","[[Author/Neeraj Jain]]","[[Author/Neeraj Jain]]","[[Author/Ajai Vyas]]","[[Author/Ajai Vyas]]","[[Author/Lee Yong Lim]]","[[Author/Lee Wei Lim]]","[[Author/Lee Wei Lim]]"],"attachment":["[[biblib/liu_ventromedial_2015/liu_ventromedial_2015.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"16xbl0u","at":1774951894289}},"smart_blocks:Research/@liu_ventromedial_2015.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.04168372,0.04197718,0.08183432,-0.00947458,-0.04060048,0.07947087,-0.01271469,0.02570863,0.0283413,-0.02985695,-0.04509687,-0.05196091,0.02843287,0.0755935,0.03476746,0.03860876,-0.02418329,0.03237752,-0.00602368,0.00959489,-0.00573756,-0.11949785,0.06163315,-0.00035395,-0.00851445,0.0147686,-0.0111803,-0.00168812,-0.07611728,-0.24454695,0.04278003,0.03357327,0.03427938,-0.02896961,-0.07319623,-0.01857413,-0.0143587,0.04287979,-0.02191876,0.02466799,0.0513306,0.04258767,0.00507824,-0.01563624,-0.02266835,-0.03816092,-0.01800226,-0.09991292,-0.01269153,-0.01913146,0.02951692,0.00861913,0.03913744,0.05746062,-0.01781608,0.05650211,0.02316798,0.07176407,0.07374685,0.06017968,0.0087275,0.04197287,-0.19964582,0.03209513,0.07532907,-0.02563532,-0.03678899,-0.02933432,0.00600196,-0.00604531,-0.08791697,0.02626943,0.06538727,0.01698105,0.06969976,-0.00736328,-0.05226137,-0.02648617,0.05087406,-0.05637389,0.07311474,0.06292457,-0.01414405,-0.06941348,-0.01526307,-0.01148025,0.00630906,-0.08189177,-0.04853225,-0.01918337,-0.00952486,0.00240353,-0.04427204,0.01018577,-0.02567091,0.0038805,0.06873567,-0.00057544,-0.09286324,0.0990232,-0.05168437,0.05916661,-0.02161101,0.0108774,0.03046719,-0.02964968,0.01361845,-0.00455198,-0.05683274,0.03897467,-0.02912829,-0.07041621,-0.01072527,0.00787024,0.02281687,0.02938993,0.13052489,0.01945413,0.02568224,0.02113445,-0.06367856,0.02776415,0.04572613,-0.04041254,-0.03080498,-0.03846683,-0.0697869,0.11098719,0.01516342,-0.0642552,0.06744354,0.03772659,-0.024