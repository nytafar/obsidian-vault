2676201,0.03988737,0.12762623,-0.01342175,0.02185237,-0.0116015,0.0405804,0.01247765,0.03441323,-0.03117319,-0.00582888,0.00460502,0.1001259,-0.01359454,0.07127649,0.0728905,-0.07585076,-0.05113792,0.01237908,-0.02220102,0.02753341,0.00936134,-0.08296325,-0.04088072,0.09924386,-0.03013101,-0.01455451,-0.03691879,-0.06681249,-0.02172223,-0.00744051,-0.03872132,0.01964939,-0.02332904,-0.01596544,-0.00972347,0.04716476,-0.03887559,-0.02223278,0.00613983,-0.04164818,0.04260365,-0.02950991,0.13495503,0.00760985],"last_embed":{"hash":"8fhjvs","tokens":459}}},"last_read":{"hash":"8fhjvs","at":1774951894025},"class_name":"SmartSource","last_import":{"mtime":1774951826806,"size":2878,"at":1774951884823,"hash":"8fhjvs"},"blocks":{"#---frontmatter---":[1,53],"#Cognitive Healthy Aging in Mice: Boosting Memory by an Ergothioneine-Rich Hericium erinaceus Primordium Extract":[55,59],"#Cognitive Healthy Aging in Mice: Boosting Memory by an Ergothioneine-Rich Hericium erinaceus Primordium Extract#{1}":[57,59]},"outlinks":[{"title":"Author/Elisa Roda","target":"Author/Elisa Roda","line":42},{"title":"Author/Fabrizio De Luca","target":"Author/Fabrizio De Luca","line":43},{"title":"Author/Daniela Ratto","target":"Author/Daniela Ratto","line":44},{"title":"Author/Erica Cecilia Priori","target":"Author/Erica Cecilia Priori","line":45},{"title":"Author/Elena Savino","target":"Author/Elena Savino","line":46},{"title":"Author/Maria Grazia Bottone","target":"Author/Maria Grazia Bottone","line":47},{"title":"Author/Paola Rossi","target":"Author/Paola Rossi","line":48},{"title":"PDF","target":"biblib/roda_cognitive_2023/roda_cognitive_2023.pdf","line":50}],"metadata":{"id":"roda_cognitive_2023","type":"article-journal","title":"Cognitive Healthy Aging in Mice: Boosting Memory by an Ergothioneine-Rich Hericium erinaceus Primordium Extract","issued":{"date-parts":[[2023]]},"DOI":"10.3390/biology12020196","container-title":"Biology","abstract":"Brain aging is a crucial risk factor for several neurodegenerative disorders and dementia. The most affected cognitive function is memory, worsening early during aging. Inflammation and oxidative stress are known to have a role in pathogenesis of cognitive impairments, and a link exists between aging/frailty and immunosenescence/inflammaging. Based on anti-aging properties, medicinal mushrooms represent a source to develop medicines and functional foods. In particular, Hericium erinaceus (He) displays several actions ranging from boosting the immune system to fighting senescence, due to its active ingredients/metabolites. Among these, Ergothioneine (ERGO) is known as the longevity vitamin. Currently, we demonstrated the efficacy of an ERGO-rich He primordium extract (He2) in preventing cognitive decline in a murine model of aging. We focused on recognition memory deterioration during aging, monitored through spontaneous behavioral tests assessing both memory components and frailty index. A parallel significant decrease in key markers of inflammation and oxidative stress, i.e., IL6, TGFβ1, GFAP, Nrf2, SOD1, COX2, NOS2, was revealed in the hippocampus by immunohistochemistry, accompanied by an enhancement of NMDAR1and mGluR2, crucially involved in glutamatergic neurotransmission. In summary, we disclosed a selective, preventive and neuroprotective effect of He2 on aged hippocampus, both on recognition memory as well on inflammation/oxidative stress/glutamate receptors expression.","tags":["#literature_note"],"author":[{"family":"Roda","given":"Elisa","literal":""},{"family":"Luca","given":"Fabrizio De","literal":""},{"family":"Ratto","given":"Daniela","literal":""},{"family":"Priori","given":"Erica Cecilia","literal":""},{"family":"Savino","given":"Elena","literal":""},{"family":"Bottone","given":"Maria Grazia","literal":""},{"family":"Rossi","given":"Paola","literal":""}],"citation-key":"roda_cognitive_2023","year":"2023","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Cognitive Healthy Aging in Mice: Boosting Memory by an Ergothioneine-Rich Hericium erinaceus Primordium Extract"],"author-links":["[[Author/Elisa Roda]]","[[Author/Fabrizio De Luca]]","[[Author/Daniela Ratto]]","[[Author/Erica Cecilia Priori]]","[[Author/Elena Savino]]","[[Author/Maria Grazia Bottone]]","[[Author/Paola Rossi]]"],"attachment":["[[biblib/roda_cognitive_2023/roda_cognitive_2023.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"8fhjvs","at":1774951894016}},"smart_blocks:Research/@roda_cognitive_2023.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.02497565,0.01286673,-0.00011415,-0.00572139,-0.01839059,0.0890274,0.02912511,0.04504499,-0.03514734,-0.00515389,-0.00959633,-0.03785172,0.05360419,0.06855222,-0.00276362,0.04065221,-0.03350757,0.0660748,-0.06810495,0.00189074,0.00362243,-0.03100116,0.03747367,0.02978534,0.00029954,0.06256561,-0.07093634,0.01249648,-0.07507402,-0.20620966,-0.01167122,-0.03398799,0.00720107,-0.04292661,-0.0564458,0.02565955,0.00529405,0.04705143,-0.03323509,0.02674488,0.07917257,0.03499756,-0.01428882,0.01071778,-0.02532397,-0.02802484,-0.04540918,-0.04403199,0.01171541,-0.03346039,-0.03825384,0.01871947,0.01449476,0.05194517,0.01194797,0.05260715,-0.01912021,0.05512917,0.01370708,0.07331875,0.03093706,0.0293674,-0.1775514,0.06790749,0.04948467,-0.03815372,-0.05463883,-0.0114922,0.01989338,-0.00816548,-0.07854432,0.03785697,0.04067884,0.01362104,0.02867543,0.02414466,-0.02880171,-0.06459481,0.06154606,-0.01370162,0.06498223,0.09146959,-0.00812745,-0.00326074,0.01988953,-0.0639637,-0.07925273,-0.0720948,-0.00412424,-0.00631328,0.01692041,0.03774536,0.00168213,0.03900527,-0.02133047,-0.01581932,0.02766998,0.00644708,-0.09923862,0.14903815,-0.07274256,0.04538338,0.00035037,-0.02616862,0.01251855,-0.06903277,-0.0114528,0.00845133,-0.01569667,0.02680008,0.00376616,-0.03235838,-0.02532655,0.0327871,0.08893818,0.04329628,0.09075049,0.0559258,0.01099668,-0.01628541,-0.00014686,-0.014