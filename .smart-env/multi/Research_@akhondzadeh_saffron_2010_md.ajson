8,-0.08742815,-0.01698253,0.05663716,0.13469523,-0.01217909,-0.01028137,0.02768296,0.01561195,0.01692445,-0.02720871,0.03790561,0.02812058,-0.0079298,0.10548601,0.00269908,0.06441665,0.01600047,-0.07357552,-0.03946598,0.00466826,-0.0178451,0.06752504,0.02159413,-0.04471248,0.03111656,0.10217962,-0.05108275,-0.01490136,-0.07004435,-0.03503137,-0.04571607,-0.01315316,-0.07634363,0.04599423,0.01725563,0.03480236,0.01902345,-0.00718325,-0.06276993,0.00788656,-0.02630498,0.00402055,-0.029466,-0.02223467,0.08491834,-0.00333917],"last_embed":{"hash":"ats2o4","tokens":481}}},"last_read":{"hash":"ats2o4","at":1774951886154},"class_name":"SmartSource","last_import":{"mtime":1774951814755,"size":4639,"at":1774951884768,"hash":"ats2o4"},"blocks":{"#---frontmatter---":[1,125],"#Saffron in the treatment of patients with mild to moderate Alzheimer’s disease: a 16‐week, randomized and placebo‐controlled trial":[127,131],"#Saffron in the treatment of patients with mild to moderate Alzheimer’s disease: a 16‐week, randomized and placebo‐controlled trial#{1}":[129,131]},"outlinks":[{"title":"Author/Shahin Akhondzadeh","target":"Author/Shahin Akhondzadeh","line":96},{"title":"Author/Shahin Akhondzadeh","target":"Author/Shahin Akhondzadeh","line":97},{"title":"Author/Mohammad Sabet","target":"Author/Mohammad Sabet","line":98},{"title":"Author/M. Shafiee Sabet","target":"Author/M. Shafiee Sabet","line":99},{"title":"Author/Mohammad-Hossein Harirchian","target":"Author/Mohammad-Hossein Harirchian","line":100},{"title":"Author/Mohammad Hossein Harirchian","target":"Author/Mohammad Hossein Harirchian","line":101},{"title":"Author/Mansoureh Togha","target":"Author/Mansoureh Togha","line":102},{"title":"Author/Mansoureh Togha","target":"Author/Mansoureh Togha","line":103},{"title":"Author/Hamed Cheraghmakani","target":"Author/Hamed Cheraghmakani","line":104},{"title":"Author/Hamed Cheraghmakani","target":"Author/Hamed Cheraghmakani","line":105},{"title":"Author/Soodeh Razeghi","target":"Author/Soodeh Razeghi","line":106},{"title":"Author/Soodeh Razeghi","target":"Author/Soodeh Razeghi","line":107},{"title":"Author/Seyyed Amir Hejazi","target":"Author/Seyyed Amir Hejazi","line":108},{"title":"Author/Sh Hejazi","target":"Author/Sh Hejazi","line":109},{"title":"Author/Mohammad Hosein Yousefi","target":"Author/Mohammad Hosein Yousefi","line":110},{"title":"Author/M. H. Yousefi","target":"Author/M. H. Yousefi","line":111},{"title":"Author/Roozbeh Alimardani","target":"Author/Roozbeh Alimardani","line":112},{"title":"Author/Roozbeh Alimardani","target":"Author/Roozbeh Alimardani","line":113},{"title":"Author/A. H. Jamshidi","target":"Author/A. H. Jamshidi","line":114},{"title":"Author/A. H. Jamshidi","target":"Author/A. H. Jamshidi","line":115},{"title":"Author/Fateme Zare","target":"Author/Fateme Zare","line":116},{"title":"Author/F. Zare","target":"Author/F. Zare","line":117},{"title":"Author/Ali Mashinchian Moradi","target":"Author/Ali Mashinchian Moradi","line":118},{"title":"Author/Ali Moradi","target":"Author/Ali Moradi","line":119},{"title":"Author/Alireza Moradi","target":"Author/Alireza Moradi","line":120},{"title":"PDF","target":"biblib/akhondzadeh_saffron_2010/akhondzadeh_saffron_2010.pdf","line":122}],"metadata":{"id":"akhondzadeh_saffron_2010","type":"article-journal","title":"Saffron in the treatment of patients with mild to moderate Alzheimer’s disease: a 16‐week, randomized and placebo‐controlled trial","issued":{"date-parts":[[2010]]},"DOI":"10.1111/j.1365-2710.2009.01133.x","container-title":"Journal of Clinical Pharmacy and Therapeutics","abstract":"What is known: Herbal medicines have been used in the treatment of behavioural and psychological symptoms of dementia but with variable response. Crocus sativus (saffron) may inhibit the aggregation and deposition of amyloid β in the human brain and may therefore be useful in Alzheimer’s disease (AD). Objective: The goal of this study was to assess the efficacy of saffron in the treatment of mild to moderate AD. Methods: Forty-six patients with probable AD were screened for a 16-week, double-blind study of parallel groups of patients with mild to moderate AD. The psychometric measures, which included AD assessment scale-cognitive subscale (ADAS-cog), and clinical dementia rating scale-sums of boxes, were performed to monitor the global cognitive and clinical profiles of the patients. Patients were randomly assigned to receive capsule saffron 30mg/day (15mg twice per day) (Group A) or capsule placebo (two capsules per day) for a 16-week study. Results: After 16weeks, saffron produced a significantly better outcome on cognitive function than placebo (ADAS-cog: F=4·12, d.f.=1, P=0·04; CDR: F=4·12, d.f.=1, P=0·04). There were no significant differences in the two groups in terms of observed adverse events. What is new and conclusion: This double-blind, placebo-controlled study suggests that at least in the short-term, saffron is both safe and effective in mild to moderate AD. Larger confirmatory randomized controlled trials are called for.","tags":["#literature_note"],"author":[{"family":"Akhondzadeh","given":"Shahin","literal":""},{"family":"Akhondzadeh","given":"Shahin","literal":""},{"family":"Sabet","given":"Mohammad","literal":""},{"family":"Sabet","given":"M. Shafiee","literal":""},{"family":"Harirchian","given":"Mohammad-Hossein","literal":""},{"family":"Harirchian","given":"Mohammad Hossein","literal":""},{"family":"Togha","given":"Mansoureh","literal":""},{"family":"Togha","given":"Mansoureh","literal":""},{"family":"Cheraghmakani","given":"Hamed","literal":""},{"family":"Cheraghmakani","given":"Hamed","literal":""},{"family":"Razeghi","given":"Soodeh","literal":""},{"family":"Razeghi","given":"Soodeh","literal":""},{"family":"Hejazi","given":"Seyyed Amir","literal":""},{"family":"Hejazi","given":"Sh","literal":""},{"family":"Yousefi","given":"Mohammad Hosein","literal":""},{"family":"Yousefi","given":"M. H.","literal":""},{"family":"Alimardani","given":"Roozbeh","literal":""},{"family":"Alimardani","given":"Roozbeh","literal":""},{"family":"Jamshidi","given":"A. H.","literal":""},{"family":"Jamshidi","given":"A. H.","literal":""},{"family":"Zare","given":"Fateme","literal":""},{"family":"Zare","given":"F.","literal":""},{"family":"Moradi","given":"Ali Mashinchian","literal":""},{"family":"Moradi","given":"Ali","literal":""},{"family":"Moradi","given":"Alireza","literal":""}],"citation-key":"akhondzadeh_saffron_2010","year":"2010","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Saffron in the treatment of patients with mild to moderate Alzheimer’s disease: a 16‐week, randomized and placebo‐controlled trial"],"author-links":["[[Author/Shahin Akhondzadeh]]","[[Author/Shahin Akhondzadeh]]","[[Author/Mohammad Sabet]]","[[Author/M. Shafiee Sabet]]","[[Author/Mohammad-Hossein Harirchian]]","[[Author/Mohammad Hossein Harirchian]]","[[Author/Mansoureh Togha]]","[[Author/Mansoureh Togha]]","[[Author/Hamed Cheraghmakani]]","[[Author/Hamed Cheraghmakani]]","[[Author/Soodeh Razeghi]]","[[Author/Soodeh Razeghi]]","[[Author/Seyyed Amir Hejazi]]","[[Author/Sh Hejazi]]","[[Author/Mohammad Hosein Yousefi]]","[[Author/M. H. Yousefi]]","[[Author/Roozbeh Alimardani]]","[[Author/Roozbeh Alimardani]]","[[Author/A. H. Jamshidi]]","[[Author/A. H. Jamshidi]]","[[Author/Fateme Zare]]","[[Author/F. Zare]]","[[Author/Ali Mashinchian Moradi]]","[[Author/Ali Moradi]]","[[Author/Alireza Moradi]]"],"attachment":["[[biblib/akhondzadeh_saffron_2010/akhondzadeh_saffron_2010.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"ats2o4","at":1774951886142}},"smart_blocks:Research/@akhondzadeh_saffron_2010.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.02379325,-0.03375885,0.01363928,0.02366809,-0.00226707,0.03038298,0.02665702,0.02110192,-0.03857354,-0.05075649,0.05095127,-0.00731927,0.0776628,0.09523305,-0.00013134,-0.02972131,0.00673718,-0.02567639