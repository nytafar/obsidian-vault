42,0.02469939,0.19295204,-0.01229309,-0.00487389,0.01884254,-0.07373589,0.05589609,-0.01614136,-0.02628511,0.01578837,0.03458131,0.08697501,-0.04460709,0.05286222,0.0399295,-0.01466606,-0.01635968,0.00697649,0.00105691,0.01781359,-0.00506744,-0.07692497,-0.0186654,0.09801873,-0.03667433,-0.04773998,-0.01320908,-0.00037296,0.00989481,-0.04734752,0.00859544,0.04418695,0.06667588,-0.08065278,-0.00182706,-0.00308132,-0.02973528,-0.01552133,-0.02741738,0.0390394,-0.01298792,-0.02032891,0.10657676,0.03196048],"last_embed":{"hash":"9t5tua","tokens":461}}},"last_read":{"hash":"9t5tua","at":1774951886285},"class_name":"SmartSource","last_import":{"mtime":1774951814940,"size":4360,"at":1774951884770,"hash":"9t5tua"},"blocks":{"#---frontmatter---":[1,152],"#A New Fungal Diterpene Induces VDAC1-dependent Apoptosis in Bax/Bak-deficient Cells":[154,158],"#A New Fungal Diterpene Induces VDAC1-dependent Apoptosis in Bax/Bak-deficient Cells#{1}":[156,158]},"outlinks":[{"title":"Author/Li Huang","target":"Author/Li Huang","line":117},{"title":"Author/Li Huang","target":"Author/Li Huang","line":118},{"title":"Author/Junjie Han","target":"Author/Junjie Han","line":119},{"title":"Author/Junjie Han","target":"Author/Junjie Han","line":120},{"title":"Author/Junjie Han","target":"Author/Junjie Han","line":121},{"title":"Author/Danya Ben-Hail","target":"Author/Danya Ben-Hail","line":122},{"title":"Author/Danya Ben-Hail","target":"Author/Danya Ben-Hail","line":123},{"title":"Author/Liming He","target":"Author/Liming He","line":124},{"title":"Author/Luwei He","target":"Author/Luwei He","line":125},{"title":"Author/Baowei Li","target":"Author/Baowei Li","line":126},{"title":"Author/Baowei Li","target":"Author/Baowei Li","line":127},{"title":"Author/Ziheng Chen","target":"Author/Ziheng Chen","line":128},{"title":"Author/Ziheng Chen","target":"Author/Ziheng Chen","line":129},{"title":"Author/Yueying Wang","target":"Author/Yueying Wang","line":130},{"title":"Author/Yueying Wang","target":"Author/Yueying Wang","line":131},{"title":"Author/Yanlei Yang","target":"Author/Yanlei Yang","line":132},{"title":"Author/Yan-lei Yang","target":"Author/Yan-lei Yang","line":133},{"title":"Author/Lei Liu","target":"Author/Lei Liu","line":134},{"title":"Author/Lei Liu","target":"Author/Lei Liu","line":135},{"title":"Author/Lei Liu","target":"Author/Lei Liu","line":136},{"title":"Author/Lei Liu","target":"Author/Lei Liu","line":137},{"title":"Author/Yushan Zhu","target":"Author/Yushan Zhu","line":138},{"title":"Author/Yushan Zhu","target":"Author/Yushan Zhu","line":139},{"title":"Author/Varda Shoshan‐Barmatz","target":"Author/Varda Shoshan‐Barmatz","line":140},{"title":"Author/Varda Shoshan-Barmatz","target":"Author/Varda Shoshan-Barmatz","line":141},{"title":"Author/Hongwei Liu","target":"Author/Hongwei Liu","line":142},{"title":"Author/Hongwei Liu","target":"Author/Hongwei Liu","line":143},{"title":"Author/Hongwei Liu","target":"Author/Hongwei Liu","line":144},{"title":"Author/Quan Chen","target":"Author/Quan Chen","line":145},{"title":"Author/Quan Chen","target":"Author/Quan Chen","line":146},{"title":"Author/Quan Chen","target":"Author/Quan Chen","line":147},{"title":"Author/Quan Chen","target":"Author/Quan Chen","line":148}],"metadata":{"id":"huang_new_2015","type":"article-journal","title":"A New Fungal Diterpene Induces VDAC1-dependent Apoptosis in Bax/Bak-deficient Cells","issued":{"date-parts":[[2015]]},"DOI":"10.1074/jbc.m115.648774","container-title":"Journal of Biological Chemistry","abstract":"The pro-apoptotic Bax and Bak proteins are considered central to apoptosis, yet apoptosis occurs in their absence. Here, we asked whether the mitochondrial protein VDAC1 mediates apoptosis independently of Bax/Bak. Upon screening a fungal secondary metabolite library for compounds inducing apoptosis in Bax/Bak-deficient mouse embryonic fibroblasts, we identified cyathin-R, a new cyathane diterpenoid compound able to activate apoptosis in the absence of Bax/Bak via promotion of the VDAC1 oligomerization that mediates cytochrome c release. Diphenylamine-2-carboxilic acid, an inhibitor of VDAC1 conductance and oligomerization, inhibited cyathin-R-induced VDAC1 oligomerization and apoptosis. Similarly, Bcl-2 overexpression conferred resistance to cyathin-R-induced apoptosis and VDAC1 oligomerization. Silencing of VDAC1 expression prevented cyathin-R-induced apoptosis. Finally, cyathin-R effectively attenuated tumor growth and induced apoptosis in Bax/Bak-deficient cells implanted into a xenograft mouse model. Hence, this study identified a new compound promoting VDAC1-dependent apoptosis as a potential therapeutic option for cancerous cells lacking or presenting inactivated Bax/Bak.","tags":["#literature_note"],"author":[{"family":"Huang","given":"Li","literal":""},{"family":"Huang","given":"Li","literal":""},{"family":"Han","given":"Junjie","literal":""},{"family":"Han","given":"Junjie","literal":""},{"family":"Han","given":"Junjie","literal":""},{"family":"Ben-Hail","given":"Danya","literal":""},{"family":"Ben-Hail","given":"Danya","literal":""},{"family":"He","given":"Liming","literal":""},{"family":"He","given":"Luwei","literal":""},{"family":"Li","given":"Baowei","literal":""},{"family":"Li","given":"Baowei","literal":""},{"family":"Chen","given":"Ziheng","literal":""},{"family":"Chen","given":"Ziheng","literal":""},{"family":"Wang","given":"Yueying","literal":""},{"family":"Wang","given":"Yueying","literal":""},{"family":"Yang","given":"Yanlei","literal":""},{"family":"Yang","given":"Yan-lei","literal":""},{"family":"Liu","given":"Lei","literal":""},{"family":"Liu","given":"Lei","literal":""},{"family":"Liu","given":"Lei","literal":""},{"family":"Liu","given":"Lei","literal":""},{"family":"Zhu","given":"Yushan","literal":""},{"family":"Zhu","given":"Yushan","literal":""},{"family":"Shoshan‐Barmatz","given":"Varda","literal":""},{"family":"Shoshan-Barmatz","given":"Varda","literal":""},{"family":"Liu","given":"Hongwei","literal":""},{"family":"Liu","given":"Hongwei","literal":""},{"family":"Liu","given":"Hongwei","literal":""},{"family":"Chen","given":"Quan","literal":""},{"family":"Chen","given":"Quan","literal":""},{"family":"Chen","given":"Quan","literal":""},{"family":"Chen","given":"Quan","literal":""}],"citation-key":"huang_new_2015","year":"2015","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["A New Fungal Diterpene Induces VDAC1-dependent Apoptosis in Bax/Bak-deficient Cells"],"author-links":["[[Author/Li Huang]]","[[Author/Li Huang]]","[[Author/Junjie Han]]","[[Author/Junjie Han]]","[[Author/Junjie Han]]","[[Author/Danya Ben-Hail]]","[[Author/Danya Ben-Hail]]","[[Author/Liming He]]","[[Author/Luwei He]]","[[Author/Baowei Li]]","[[Author/Baowei Li]]","[[Author/Ziheng Chen]]","[[Author/Ziheng Chen]]","[[Author/Yueying Wang]]","[[Author/Yueying Wang]]","[[Author/Yanlei Yang]]","[[Author/Yan-lei Yang]]","[[Author/Lei Liu]]","[[Author/Lei Liu]]","[[Author/Lei Liu]]","[[Author/Lei Liu]]","[[Author/Yushan Zhu]]","[[Author/Yushan Zhu]]","[[Author/Varda Shoshan‐Barmatz]]","[[Author/Varda Shoshan-Barmatz]]","[[Author/Hongwei Liu]]","[[Author/Hongwei Liu]]","[[Author/Hongwei Liu]]","[[Author/Quan Chen]]","[[Author/Quan Chen]]","[[Author/Quan Chen]]","[[Author/Quan Chen]]"],"attachment":[],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"9t5tua","at":1774951886275}},"smart_blocks:Research/@huang_new_2015.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.09940969,-0.03676101,0.0236759,-0.04603722,0.00241173,0.01686366,-0.00693287,0.1042008,-0.01629221,-0.02384134,0.01607311,-0.04656564,0.02957671,0.00395323,0.02547377,0.03885035,-0.02157189,0.02087507,-0.04638729,0.00688818,0.02893993,-0.04554667,0.03896318,-0.05773162,0.0523282,0.03042514,0.03070078,0.00304622,-0.03051202,-0.24575764,0.02686951,-0.00055685,0.02235038,0.00284598,-0.01465079,-0.03489115,0.00020875,0.05859333,-0.05056278,-0.00860358,0.0412481,