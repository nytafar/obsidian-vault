,-0.01277927,0.16154236,0.04794124,-0.03281162,-0.01277879,0.00857872,0.02637656,-0.04588935,-0.02548508,0.06186201,0.01165971,0.06673332,-0.03267885,0.09105432,0.01297082,-0.07916898,0.04596802,0.01502061,-0.04455474,-0.01315267,-0.05559972,-0.07739198,-0.01243953,0.08780974,-0.04056188,-0.03777857,-0.03775964,-0.03057173,0.02780522,0.0141371,0.02694444,0.06327815,0.02135779,0.01205132,-0.01286085,-0.01042448,-0.01160548,-0.03514984,0.01689546,0.01328317,0.03805849,-0.0476955,0.09526516,0.06555243],"last_embed":{"hash":"185pqj1","tokens":412}}},"last_read":{"hash":"185pqj1","at":1774951887219},"class_name":"SmartSource","last_import":{"mtime":1774951816563,"size":3810,"at":1774951884779,"hash":"185pqj1"},"blocks":{"#---frontmatter---":[1,81],"#Peripheral Nerve Regeneration Following Crush Injury to Rat Peroneal Nerve by Aqueous Extract of Medicinal Mushroom Hericium erinaceus (Bull.: Fr) Pers. (Aphyllophoromycetideae)":[83,87],"#Peripheral Nerve Regeneration Following Crush Injury to Rat Peroneal Nerve by Aqueous Extract of Medicinal Mushroom Hericium erinaceus (Bull.: Fr) Pers. (Aphyllophoromycetideae)#{1}":[85,87]},"outlinks":[{"title":"Author/Kah-Hui Wong","target":"Author/Kah-Hui Wong","line":63},{"title":"Author/Kah-Hui Wong","target":"Author/Kah-Hui Wong","line":64},{"title":"Author/Murali Naidu","target":"Author/Murali Naidu","line":65},{"title":"Author/Murali Naidu","target":"Author/Murali Naidu","line":66},{"title":"Author/Pamela David","target":"Author/Pamela David","line":67},{"title":"Author/Pamela David","target":"Author/Pamela David","line":68},{"title":"Author/Mahmood Ameen Abdulla","target":"Author/Mahmood Ameen Abdulla","line":69},{"title":"Author/Mahmood Ameen Abdulla","target":"Author/Mahmood Ameen Abdulla","line":70},{"title":"Author/Noorlidah Abdullah","target":"Author/Noorlidah Abdullah","line":71},{"title":"Author/Noorlidah Abdullah","target":"Author/Noorlidah Abdullah","line":72},{"title":"Author/Umah Rani Kuppusamy","target":"Author/Umah Rani Kuppusamy","line":73},{"title":"Author/Umah Rani Kuppusamy","target":"Author/Umah Rani Kuppusamy","line":74},{"title":"Author/Vikineswary Sabaratnam","target":"Author/Vikineswary Sabaratnam","line":75},{"title":"Author/Vikineswary Sabaratnam","target":"Author/Vikineswary Sabaratnam","line":76},{"title":"PDF","target":"biblib/wong_peripheral_2011/wong_peripheral_2011.pdf","line":78}],"metadata":{"id":"wong_peripheral_2011","type":"article-journal","title":"Peripheral Nerve Regeneration Following Crush Injury to Rat Peroneal Nerve by Aqueous Extract of Medicinal Mushroom Hericium erinaceus (Bull.: Fr) Pers. (Aphyllophoromycetideae)","issued":{"date-parts":[[2011]]},"DOI":"10.1093/ecam/neq062","container-title":"Evidence-based Complementary and Alternative Medicine","abstract":"Nerve crush injury is a well-established axonotmetic model in experimental regeneration studies to investigate the impact of various pharmacological treatments. Hericium erinaceus is a temperate mushroom but is now being cultivated in tropical Malaysia. In this study, we investigated the activity of aqueous extract of H. erinaceus fresh fruiting bodies in promoting functional recovery following an axonotmetic peroneal nerve injury in adult female Sprague-Dawley rats by daily oral administration. The aim was to investigate the possible use of this mushroom in the treatment of injured nerve. Functional recovery was assessed in behavioral experiment by walking track analysis. Peroneal functional index (PFI) was determined before surgery and after surgery as rats showed signs of recovery. Histological examinations were performed on peroneal nerve by immunofluorescence staining and neuromuscular junction by combined silver-cholinesterase stain. Analysis of PFI indicated that return of hind limb function occurred earlier in rats of aqueous extract or mecobalamin (positive control) group compared to negative control group. Regeneration of axons and reinnervation of motor endplates in extensor digitorum longus muscle in rats of aqueous extract or mecobalamin group developed better than in negative control group. These data suggest that daily oral administration of aqueous extract of H. erinaceus fresh fruiting bodies could promote the regeneration of injured rat peroneal nerve in the early stage of recovery.","tags":["#literature_note"],"author":[{"family":"Wong","given":"Kah-Hui","literal":""},{"family":"Wong","given":"Kah-Hui","literal":""},{"family":"Naidu","given":"Murali","literal":""},{"family":"Naidu","given":"Murali","literal":""},{"family":"David","given":"Pamela","literal":""},{"family":"David","given":"Pamela","literal":""},{"family":"Abdulla","given":"Mahmood Ameen","literal":""},{"family":"Abdulla","given":"Mahmood Ameen","literal":""},{"family":"Abdullah","given":"Noorlidah","literal":""},{"family":"Abdullah","given":"Noorlidah","literal":""},{"family":"Kuppusamy","given":"Umah Rani","literal":""},{"family":"Kuppusamy","given":"Umah Rani","literal":""},{"family":"Sabaratnam","given":"Vikineswary","literal":""},{"family":"Sabaratnam","given":"Vikineswary","literal":""}],"citation-key":"wong_peripheral_2011","year":"2011","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Peripheral Nerve Regeneration Following Crush Injury to Rat Peroneal Nerve by Aqueous Extract of Medicinal Mushroom Hericium erinaceus (Bull.: Fr) Pers. (Aphyllophoromycetideae)"],"author-links":["[[Author/Kah-Hui Wong]]","[[Author/Kah-Hui Wong]]","[[Author/Murali Naidu]]","[[Author/Murali Naidu]]","[[Author/Pamela David]]","[[Author/Pamela David]]","[[Author/Mahmood Ameen Abdulla]]","[[Author/Mahmood Ameen Abdulla]]","[[Author/Noorlidah Abdullah]]","[[Author/Noorlidah Abdullah]]","[[Author/Umah Rani Kuppusamy]]","[[Author/Umah Rani Kuppusamy]]","[[Author/Vikineswary Sabaratnam]]","[[Author/Vikineswary Sabaratnam]]"],"attachment":["[[biblib/wong_peripheral_2011/wong_peripheral_2011.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_emb