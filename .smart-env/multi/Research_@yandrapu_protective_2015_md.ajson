22,0.00780681,-0.02229839,-0.00639227,0.18371926,-0.03069326,0.03362352,0.00019946,0.03014382,0.05171122,0.03698045,0.02599438,0.00824058,0.01546106,0.07441268,-0.04435459,-0.02027189,0.07465146,0.0011786,-0.03846889,-0.00325109,-0.02044266,0.04739984,-0.00303149,-0.0342474,-0.02478248,0.0941154,-0.16773127,0.03865807,-0.03952033,0.04451916,-0.04768254,-0.03275621,-0.01808015,0.02277119,0.03245958,0.02513502,-0.02896987,0.03407291,0.00508209,-0.01080526,0.05019539,0.02054604,0.01256849,-0.01968752,0.08906692,0.0382105],"last_embed":{"hash":"1s6doyq","tokens":477}}},"last_read":{"hash":"1s6doyq","at":1774951891156},"class_name":"SmartSource","last_import":{"mtime":1774951822017,"size":2297,"at":1774951884805,"hash":"1s6doyq"},"blocks":{"#---frontmatter---":[1,41],"#Protective Factors of the Gastric and Duodenal Mucosa: An Overview.":[43,47],"#Protective Factors of the Gastric and Duodenal Mucosa: An Overview.#{1}":[45,47]},"outlinks":[{"title":"Author/Harathi Yandrapu","target":"Author/Harathi Yandrapu","line":33},{"title":"Author/Harathi Yandrapu","target":"Author/Harathi Yandrapu","line":34},{"title":"Author/Jerzy Sarosiek","target":"Author/Jerzy Sarosiek","line":35},{"title":"Author/Jerzy Sarosiek","target":"Author/Jerzy Sarosiek","line":36},{"title":"PDF","target":"biblib/yandrapu_protective_2015/yandrapu_protective_2015.pdf","line":38}],"metadata":{"id":"yandrapu_protective_2015","type":"article-journal","title":"Protective Factors of the Gastric and Duodenal Mucosa: An Overview.","issued":{"date-parts":[[2015]]},"DOI":"10.1007/s11894-015-0452-2","container-title":"Current Gastroenterology Reports","abstract":"The structural and functional integrity of the gastric and duodenal mucosa represents equilibrium between aggressive factors and protective mechanisms. Mucus-buffers-phospholipid layer as pre-epithelial barrier, enhanced by prostaglandins and epidermal growth factor, remains a vanguard of mucosal protection. It maintains a neutral pH at the surface epithelial luminal interface, facing luminal pH dropping to 1.0, i.e., hydrogen ion concentration gradient equal 1,000,000. The surface epithelial cells, elaborating mucins, buffers, phospholipids, prostaglandins, trefoil peptides, peptide growth factor and their receptors, heat shock proteins, cathelicidins, and β-defensins form the second line of defense. Endothelium exerts mucosal protection through production of potent vasodilators like nitric oxide and prostacyclins and through release of angiogenic growth factors, securing adequate blood flow and representing the third and an ultimate line of mucosal protection. This microcirculation is instrumental for supply of oxygen, nitric oxide, hydrogen sulfide and removal of ad hoc generated toxic substances as well as for continuous mucosal cell renewal from progenitor cells, secured by growth factors accompanied by survivin preventing early apoptosis.","tags":["#literature_note"],"author":[{"family":"Yandrapu","given":"Harathi","literal":""},{"family":"Yandrapu","given":"Harathi","literal":""},{"family":"Sarosiek","given":"Jerzy","literal":""},{"family":"Sarosiek","given":"Jerzy","literal":""}],"citation-key":"yandrapu_protective_2015","year":"2015","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Protective Factors of the Gastric and Duodenal Mucosa: An Overview."],"author-links":["[[Author/Harathi Yandrapu]]","[[Author/Harathi Yandrapu]]","[[Author/Jerzy Sarosiek]]","[[Author/Jerzy Sarosiek]]"],"attachment":["[[biblib/yandrapu_protective_2015/yandrapu_protective_2015.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"1s6doyq","at":1774951891147}},"smart_blocks:Research/@yandrapu_protective_2015.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.08372375,-0.01178991,0.06918397,0.00074406,0.00242026,-0.00751161,0.06242144,0.05973286,-0.02455509,-0.03968036,-0.04273388,-0.15116933,0.03869763,0.04654262,0.05597433,0.01837546,-0.