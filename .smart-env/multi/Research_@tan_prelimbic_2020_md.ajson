7672,0.01567867,0.1380235,0.02655617,0.0465675,0.00973387,0.0157014,0.00833486,0.05374341,0.00077329,0.00662209,0.05560219,0.08460634,-0.04828509,0.06188975,0.09530502,-0.1097204,-0.0072025,0.00391617,-0.0067577,0.01952215,0.02760813,-0.00162445,-0.01860729,0.12841579,-0.02416069,0.03491992,-0.03623514,-0.0167667,-0.02019565,-0.0522156,0.00342845,0.03717818,-0.00019247,0.01173164,0.03418721,0.03774332,-0.05737191,0.02003571,-0.03251059,0.0178491,-0.00023284,-0.05642727,0.12228297,-0.04006935],"last_embed":{"hash":"1hde942","tokens":440}}},"last_read":{"hash":"1hde942","at":1774951889203},"class_name":"SmartSource","last_import":{"mtime":1774951820060,"size":2881,"at":1774951884797,"hash":"1hde942"},"blocks":{"#---frontmatter---":[1,65],"#Prelimbic Cortical Stimulation Improves Spatial Memory Through Distinct Patterns of Hippocampal Gene Expression in Aged Rats.":[67,71],"#Prelimbic Cortical Stimulation Improves Spatial Memory Through Distinct Patterns of Hippocampal Gene Expression in Aged Rats.#{1}":[69,71]},"outlinks":[{"title":"Author/Shawn Zheng Kai Tan","target":"Author/Shawn Zheng Kai Tan","line":51},{"title":"Author/Shawn Tan","target":"Author/Shawn Tan","line":52},{"title":"Author/J. Neoh","target":"Author/J. Neoh","line":53},{"title":"Author/Joveen Neoh","target":"Author/Joveen Neoh","line":54},{"title":"Author/Andrew J. Lawrence","target":"Author/Andrew J. Lawrence","line":55},{"title":"Author/Andrew J. Lawrence","target":"Author/Andrew J. Lawrence","line":56},{"title":"Author/Ed X. Wu","target":"Author/Ed X. Wu","line":57},{"title":"Author/Ed X. Wu","target":"Author/Ed X. Wu","line":58},{"title":"Author/Lee Wei Lim","target":"Author/Lee Wei Lim","line":59},{"title":"Author/Lee Wei Lim","target":"Author/Lee Wei Lim","line":60},{"title":"PDF","target":"biblib/tan_prelimbic_2020/tan_prelimbic_2020.pdf","line":62}],"metadata":{"id":"tan_prelimbic_2020","type":"article-journal","title":"Prelimbic Cortical Stimulation Improves Spatial Memory Through Distinct Patterns of Hippocampal Gene Expression in Aged Rats.","issued":{"date-parts":[[2020]]},"DOI":"10.1007/s13311-020-00913-7","container-title":"Neurotherapeutics","abstract":"Dementia poses major health challenges worldwide, yet current treatments are faced with issues of efficacy and toxicity. Deep brain stimulation (DBS) is a promising non-pharmacological treatment for dementia, but most DBS studies use young healthy animals, which may not be aetiologically relevant. In this study, we used an aged rat model in which cognitive decline occurs through a natural ageing process. We used a Morris water maze (MWM) to determine the effects of prelimbic cortex (PrL) DBS on memory in aged rats. To investigate the underlying mechanisms of the effects of DBS, we carried out microarray, quantitative PCR analysis, and mass spectrometry to detect gene expression and neurotransmitter changes in the hippocampus. We showed PrL DBS improved the performance in MWM, with related distinct patterns of gene expression involving G protein-coupled receptor pathways. We further found neurotransmitter changes in the dorsal hippocampus, which corroborated and extended the microarray findings. Our results suggest that non-neurogenesis pathways play roles in the effects of DBS. Further studies are needed to investigate the effects of DBS on memory beyond neurogenesis and to consider the highlighted pathways suggested by our data.","tags":["#literature_note"],"author":[{"family":"Tan","given":"Shawn Zheng Kai","literal":""},{"family":"Tan","given":"Shawn","literal":""},{"family":"Neoh","given":"J.","literal":""},{"family":"Neoh","given":"Joveen","literal":""},{"family":"Lawrence","given":"Andrew J.","literal":""},{"family":"Lawrence","given":"Andrew J.","literal":""},{"family":"Wu","given":"Ed X.","literal":""},{"family":"Wu","given":"Ed X.","literal":""},{"family":"Lim","given":"Lee Wei","literal":""},{"family":"Lim","given":"Lee Wei","literal":""}],"citation-key":"tan_prelimbic_2020","year":"2020","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Prelimbic Cortical Stimulation Improves Spatial Memory Through Distinct Patterns of Hippocampal Gene Expression in Aged Rats."],"author-links":["[[Author/Shawn Zheng Kai Tan]]","[[Author/Shawn Tan]]","[[Author/J. Neoh]]","[[Author/Joveen Neoh]]","[[Author/Andrew J. Lawrence]]","[[Author/Andrew J. Lawrence]]","[[Author/Ed X. Wu]]","[[Author/Ed X. Wu]]","[[Author/Lee Wei Lim]]","[[Author/Lee Wei Lim]]"],"attachment":["[[biblib/tan_prelimbic_2020/tan_prelimbic_2020.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"1hde942","at":1774951889194}},"smart_blocks:Research/@tan_prelimbic_2020.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.02199226,0.00587917,0.02983451,-0.00201642,-0.00412082,0.07290787,-0.01476238,-0.00808168,0.0600194,-0.05806249,-0.02022995,-0.02626611,0.02710195,0.11373864,0.01149076,0.01739134,0.00225981,0.02993941,-0.00705141,-0.00044361,-0.02185737,-0.08669666,0.03038806,0.01132627,-0.02930399,0.00170403,-0.02624599,-0.02218054,-0.06181055,-0.24247667,0.04404685,0.01527315,-0.01775604,-0.06573479,-0.06356022,0.00997215,0.02142134,0.03280409,-0.01477403,0.01632156,0.01908,0.02689535,-0.01304339,0.01621997,-0.02086593,-0.0393947,-0.03959502,-0.08537013,-0.00107389,-0.07922399,-0.01788235,-0.03832982,0.03143632,0.06731158,0.00628,0.0064091,0.01111471,0.08277366,0.04226046,0.04241122,0.04750317,0.02348876,-0.23055704,0.03299377,0.08112554,0.03045707,-0.02995341,-0.01998554,0.0335495,0.02668943,-0.103283,0.01547156,0.03298405,0.03864746,0.05032216,-0.00861144,-0.01829116,-0.04424528,0.05772226,-0.04261212,0.04993665,0.05238166,-0.0109334,-0.05541159,-0.00805281,-0.02037344,-0.04468733,-0.09974783,-0.05616054,-0.01573282,-0.00456567,0.00012467,-0.00859042,0.00624957,-0.04875902,0.00512905,0.04305859,-0.04202468,-0.05530892,0.10678387,-0.0536016,0.08711158,-0.04905862,-0.01125254,0.02960764,-0.04694259,0.003