0.02317702,0.17826378,-0.00549177,-0.00822744,0.01186754,0.02721271,0.04679245,-0.01168529,0.00542534,0.00237673,-0.02953528,0.11182726,0.01320284,0.02351393,0.03712145,0.03398613,0.00933907,-0.02102816,0.04502937,-0.00143584,0.02071306,-0.06322165,-0.03735322,0.07140166,-0.07338555,-0.07388344,-0.05973861,0.01024934,0.04601196,-0.06731315,0.01559416,0.01368488,-0.01637518,-0.01983671,-0.01692531,-0.01079443,-0.02702179,-0.06199814,0.02138629,-0.0126677,-0.02428295,-0.11611618,0.09894488,0.04666355],"last_embed":{"hash":"11zk8p5","tokens":459}}},"last_read":{"hash":"11zk8p5","at":1774951887351},"class_name":"SmartSource","last_import":{"mtime":1774951816820,"size":3162,"at":1774951884780,"hash":"11zk8p5"},"blocks":{"#---frontmatter---":[1,85],"#Immunomodulatory Activities of a Fungal Protein Extracted from Hericium erinaceus through Regulating the Gut Microbiota":[87,91],"#Immunomodulatory Activities of a Fungal Protein Extracted from Hericium erinaceus through Regulating the Gut Microbiota#{1}":[89,91]},"outlinks":[{"title":"Author/Diling Chen","target":"Author/Diling Chen","line":66},{"title":"Author/Diling Chen","target":"Author/Diling Chen","line":67},{"title":"Author/Chen Diling","target":"Author/Chen Diling","line":68},{"title":"Author/Zheng Chaoqun","target":"Author/Zheng Chaoqun","line":69},{"title":"Author/Zheng Chaoqun","target":"Author/Zheng Chaoqun","line":70},{"title":"Author/Jian Yang","target":"Author/Jian Yang","line":71},{"title":"Author/Yang Jian","target":"Author/Yang Jian","line":72},{"title":"Author/Jian Li","target":"Author/Jian Li","line":73},{"title":"Author/Li Jian","target":"Author/Li Jian","line":74},{"title":"Author/Juanjuan Su","target":"Author/Juanjuan Su","line":75},{"title":"Author/Su Jiyan","target":"Author/Su Jiyan","line":76},{"title":"Author/Yizhen Xie","target":"Author/Yizhen Xie","line":77},{"title":"Author/Xie Yizhen","target":"Author/Xie Yizhen","line":78},{"title":"Author/Guoxiao Lai","target":"Author/Guoxiao Lai","line":79},{"title":"Author/Lai Guoxiao","target":"Author/Lai Guoxiao","line":80},{"title":"PDF","target":"biblib/chen_immunomodulatory_2017/chen_immunomodulatory_2017.pdf","line":82}],"metadata":{"id":"chen_immunomodulatory_2017","type":"article-journal","title":"Immunomodulatory Activities of a Fungal Protein Extracted from Hericium erinaceus through Regulating the Gut Microbiota","issued":{"date-parts":[[2017]]},"DOI":"10.3389/fimmu.2017.00666","container-title":"Frontiers in Immunology","abstract":"A single-band protein (HEP3) was isolated from Hericium erinaceus using a chemical separation combined with pharmacodynamic evaluation methods. This protein exhibited immunomodulatory activity in lipopolysaccharide-activated RAW 264.7 macrophages by decreasing the overproduction of tumor necrosis factor-α, interleukin (IL)-1β, and IL-6, and downregulating the expression of inducible nitric oxide synthase and nuclear factor-κB p65. Further researches revealed that HEP3 could improve the immune system via regulating the composition and metabolism of gut microbiota to activate the proliferation and differentiation of T cells, stimulate the intestinal antigen-presenting cells in high-dose cyclophosphamide-induced immunotoxicity in mice, and play a prebiotic role in the case of excessive antibiotics in inflammatory bowel disease model mice. Aided experiments also showed that HEP3 could be used as an antitumor immune inhibitor in tumor-burdened mice. The results of the present study suggested that fungal protein from H. erinaceus could be used as a drug or functional food ingredient for immunotherapy because of its immunomodulatory activities.","tags":["#literature_note"],"author":[{"family":"Chen","given":"Diling","literal":""},{"family":"Chen","given":"Diling","literal":""},{"family":"Diling","given":"Chen","literal":""},{"family":"Chaoqun","given":"Zheng","literal":""},{"family":"Chaoqun","given":"Zheng","literal":""},{"family":"Yang","given":"Jian","literal":""},{"family":"Jian","given":"Yang","literal":""},{"family":"Li","given":"Jian","literal":""},{"family":"Jian","given":"Li","literal":""},{"family":"Su","given":"Juanjuan","literal":""},{"family":"Jiyan","given":"Su","literal":""},{"family":"Xie","given":"Yizhen","literal":""},{"family":"Yizhen","given":"Xie","literal":""},{"family":"Lai","given":"Guoxiao","literal":""},{"family":"Guoxiao","given":"Lai","literal":""}],"citation-key":"chen_immunomodulatory_2017","year":"2017","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Immunomodulatory Activities of a Fungal Protein Extracted from Hericium erinaceus through Regulating the Gut Microbiota"],"author-links":["[[Author/Diling Chen]]","[[Author/Diling Chen]]","[[Author/Chen Diling]]","[[Author/Zheng Chaoqun]]","[[Author/Zheng Chaoqun]]","[[Author/Jian Yang]]","[[Author/Yang Jian]]","[[Author/Jian Li]]","[[Author/Li Jian]]","[[Author/Juanjuan Su]]","[[Author/Su Jiyan]]","[[Author/Yizhen Xie]]","[[Author/Xie Yizhen]]","[[Author/Guoxiao Lai]]","[[Author/Lai Guoxiao]]"],"attachment":["[[biblib/chen_immunomodulatory_2017/chen_immunomodulatory_2017.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"11zk8p5","at":1774951887340}},"smart_blocks:Research/@chen_immunomodulatory_2017.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.0302784,-0.05265697,0.04749956,-0.0417919,-0.05200482,-0.06502453,0.05008295,0.07193424,-0.06476033,-0.00679688,0.0219719,-0.09726672,0.01499693,-0.05188283,0.01046409,-0.01767192,0.0135337,0.0511472,-0.11378619,-0.01311379,0.04725163,-0.05753892,0.00038684,0.01140191,0.06958865,0.05762175,-0.00412396,-0.01319905,-0.03396051,-0.21755171,0.00990902,-0.04069131,0.03866729,-0.03822257,-0.03806062,-0.02933482,-0.05473737,0.02196003,-0.01499492,0.02433022,0.064763,0.065021,0.00171928,0.01056162,0.00781873,-0.08351057,-0.03482534,-0.075754,0.04519333,-0.00585335,0.00345887,-0.03163057,0.03336563,0.10296599,0.04474558,0.01932958,0.