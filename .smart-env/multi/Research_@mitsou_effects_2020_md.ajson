8356,0.0055784,0.16918379,0.0213554,-0.01667299,0.00543301,-0.0269856,0.03643065,0.02129852,0.04817327,0.02128617,0.01510744,0.11816816,-0.04726266,0.05909281,0.06125183,-0.0413925,-0.08900715,-0.05676854,0.01109051,0.0205123,-0.04373699,-0.10714857,-0.04652731,0.1006908,-0.0821095,-0.01265512,-0.04658786,-0.02169978,-0.01936489,-0.03942962,0.00622458,-0.00369233,0.02023653,-0.02332488,-0.01898186,-0.02848198,0.0429721,-0.09914417,-0.00942469,-0.00606424,0.03586467,-0.09854667,0.10592598,-0.03222714],"last_embed":{"hash":"uzq41w","tokens":498}}},"last_read":{"hash":"uzq41w","at":1774951888646},"class_name":"SmartSource","last_import":{"mtime":1774951819175,"size":4338,"at":1774951884793,"hash":"uzq41w"},"blocks":{"#---frontmatter---":[1,117],"#Effects of Rich in Β-Glucans Edible Mushrooms on Aging Gut Microbiota Characteristics: An In Vitro Study":[119,123],"#Effects of Rich in Β-Glucans Edible Mushrooms on Aging Gut Microbiota Characteristics: An In Vitro Study#{1}":[121,123]},"outlinks":[{"title":"Author/Evdokia K. Mitsou","target":"Author/Evdokia K. Mitsou","line":90},{"title":"Author/Evdokia K. Mitsou","target":"Author/Evdokia K. Mitsou","line":91},{"title":"Author/Georgia Saxami","target":"Author/Georgia Saxami","line":92},{"title":"Author/Georgia Saxami","target":"Author/Georgia Saxami","line":93},{"title":"Author/Emmanuela Stamoulou","target":"Author/Emmanuela Stamoulou","line":94},{"title":"Author/Emmanuela Stamoulou","target":"Author/Emmanuela Stamoulou","line":95},{"title":"Author/Evangelia N. Kerezoudi","target":"Author/Evangelia N. Kerezoudi","line":96},{"title":"Author/Evangelia N. Kerezoudi","target":"Author/Evangelia N. Kerezoudi","line":97},{"title":"Author/Eirini Terzi","target":"Author/Eirini Terzi","line":98},{"title":"Author/Eirini Terzi","target":"Author/Eirini Terzi","line":99},{"title":"Author/Georgios Koutrotsios","target":"Author/Georgios Koutrotsios","line":100},{"title":"Author/Georgios Koutrotsios","target":"Author/Georgios Koutrotsios","line":101},{"title":"Author/Georgios Bekiaris","target":"Author/Georgios Bekiaris","line":102},{"title":"Author/Georgios Bekiaris","target":"Author/Georgios Bekiaris","line":103},{"title":"Author/George-John E. Nychas","target":"Author/George-John E. Nychas","line":104},{"title":"Author/Georgios I. Zervakis","target":"Author/Georgios I. Zervakis","line":105},{"title":"Author/Georgios I. Zervakis","target":"Author/Georgios I. Zervakis","line":106},{"title":"Author/Konstantinos C. Mountzouris","target":"Author/Konstantinos C. Mountzouris","line":107},{"title":"Author/Konstantinos C. Mountzouris","target":"Author/Konstantinos C. Mountzouris","line":108},{"title":"Author/Vasiliki Pletsa","target":"Author/Vasiliki Pletsa","line":109},{"title":"Author/Vasiliki Pletsa","target":"Author/Vasiliki Pletsa","line":110},{"title":"Author/Adamantini Kyriacou","target":"Author/Adamantini Kyriacou","line":111},{"title":"Author/Adamantini Kyriacou","target":"Author/Adamantini Kyriacou","line":112},{"title":"PDF","target":"biblib/mitsou_effects_2020/mitsou_effects_2020.pdf","line":114}],"metadata":{"id":"mitsou_effects_2020","type":"article-journal","title":"Effects of Rich in Β-Glucans Edible Mushrooms on Aging Gut Microbiota Characteristics: An In Vitro Study","issued":{"date-parts":[[2020]]},"DOI":"10.3390/molecules25122806","container-title":"Molecules","abstract":"Alterations of gut microbiota are evident during the aging process. Prebiotics may restore the gut microbial balance, with β-glucans emerging as prebiotic candidates. This study aimed to investigate the impact of edible mushrooms rich in β-glucans on the gut microbiota composition and metabolites by using in vitro static batch culture fermentations and fecal inocula from elderly donors (n = 8). Pleurotus ostreatus, P. eryngii, Hericium erinaceus and Cyclocybe cylindracea mushrooms derived from various substrates were examined. Gut microbiota composition (quantitative PCR (qPCR)) and short-chain fatty acids (SCFAs; gas chromatography (GC)) were determined during the 24-h fermentation. P. eryngii induced a strong lactogenic effect, while P. ostreatus and C. cylindracea induced a significant bifidogenic effect (p for all <0.05). Furthermore, P. eryngii produced on wheat straw and the prebiotic inulin had comparable Prebiotic Indexes, while P. eryngii produced on wheat straw/grape marc significantly increased the levels of tested butyrate producers. P. ostreatus, P. eryngii and C. cylindracea had similar trends in SCFA profile; H. erinaceus mushrooms were more diverse, especially in the production of propionate, butyrate and branched SCFAs. In conclusion, mushrooms rich in β-glucans may exert beneficial in vitro effects in gut microbiota and/or SCFAs production in elderly subjects.","tags":["#literature_note"],"author":[{"family":"Mitsou","given":"Evdokia K.","literal":""},{"family":"Mitsou","given":"Evdokia K.","literal":""},{"family":"Saxami","given":"Georgia","literal":""},{"family":"Saxami","given":"Georgia","literal":""},{"family":"Stamoulou","given":"Emmanuela","literal":""},{"family":"Stamoulou","given":"Emmanuela","literal":""},{"family":"Kerezoudi","given":"Evangelia N.","literal":""},{"family":"Kerezoudi","given":"Evangelia N.","literal":""},{"family":"Terzi","given":"Eirini","literal":""},{"family":"Terzi","given":"Eirini","literal":""},{"family":"Koutrotsios","given":"Georgios","literal":""},{"family":"Koutrotsios","given":"Georgios","literal":""},{"family":"Bekiaris","given":"Georgios","literal":""},{"family":"Bekiaris","given":"Georgios","literal":""},{"family":"Nychas","given":"George-John E.","literal":""},{"family":"Zervakis","given":"Georgios I.","literal":""},{"family":"Zervakis","given":"Georgios I.","literal":""},{"family":"Mountzouris","given":"Konstantinos C.","literal":""},{"family":"Mountzouris","given":"Konstantinos C.","literal":""},{"family":"Pletsa","given":"Vasiliki","literal":""},{"family":"Pletsa","given":"Vasiliki","literal":""},{"family":"Kyriacou","given":"Adamantini","literal":""},{"family":"Kyriacou","given":"Adamantini","literal":""}],"citation-key":"mitsou_effects_2020","year":"2020","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Effects of Rich in Β-Glucans Edible Mushrooms on Aging Gut Microbiota Characteristics: An In Vitro Study"],"author-links":["[[Author/Evdokia K. Mitsou]]","[[Author/Evdokia K. Mitsou]]","[[Author/Georgia Saxami]]","[[Author/Georgia Saxami]]","[[Author/Emmanuela Stamoulou]]","[[Author/Emmanuela Stamoulou]]","[[Author/Evangelia N. Kerezoudi]]","[[Author/Evangelia N. Kerezoudi]]","[[Author/Eirini Terzi]]","[[Author/Eirini Terzi]]","[[Author/Georgios Koutrotsios]]","[[Author/Georgios Koutrotsios]]","[[Author/Georgios Bekiaris]]","[[Author/Georgios Bekiaris]]","[[Author/George-John E. Nychas]]","[[Author/Georgios I. Zervakis]]","[[Author/Georgios I. Zervakis]]","[[Author/Konstantinos C. Mountzouris]]","[[Author/Konstantinos C. Mountzouris]]","[[Author/Vasiliki Pletsa]]","[[Author/Vasiliki Pletsa]]","[[Author/Adamantini Kyriacou]]","[[Author/Adamantini Kyriacou]]"],"attachment":["[[biblib/mitsou_effects_2020/mitsou_effects_2020.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"uzq41w","at":1774951888636}},"smart_blocks:Research/@mitsou_effects_2020.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.02415015,-0.02598258,0.01236276,-0.02502177,0.03641553,0.01841783,-0.07320761,0.01006644,-0.086013,-0.01897442,-0.00511954,-0.08452114,-0.00444162,-0.00234967,-0.01304854,-0.00687239,0.03168543,0.02586734,-0.13350479,0.00171203,0.07528054,-0.01902949,0.01264434,0.01411952,0.03831973,0.0287991,-0.03173311,-0.01175638,-0.0819492,-0.23934028,0.00545312,0.01171457,0.05738268,-0.03602094,-0.03794619,-0.00314382,-0.03767663,-0.04144128,-0.05470395,0.02336421,0.08693331,0.04024151,-0.00602854,0.04542391,-0.03254268,-0.07703672,-0.05527235,-0.03003134,0.02808408,-0.02975609,-0.03728575,-0.09745707,0.00