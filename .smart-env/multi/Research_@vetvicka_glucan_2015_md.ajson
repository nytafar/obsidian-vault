
"smart_sources:Research/@vetvicka_glucan_2015.md": {"path":"Research/@vetvicka_glucan_2015.md","last_embed":{"hash":null},"embeddings":{},"last_read":{"hash":"tghjlj","at":1774951884832},"class_name":"SmartSource","last_import":{"mtime":1774951829343,"size":1832,"at":1774951884832,"hash":"tghjlj"},"blocks":{"#---frontmatter---":[1,41],"#Glucan supplementation enhances the immune response against an influenza challenge in mice.":[43,47],"#Glucan supplementation enhances the immune response against an influenza challenge in mice.#{1}":[45,47]},"outlinks":[{"title":"Author/Václav Větvička","target":"Author/Václav Větvička","line":33},{"title":"Author/Vaclav Vetvicka","target":"Author/Vaclav Vetvicka","line":34},{"title":"Author/Jana Větvičková","target":"Author/Jana Větvičková","line":35},{"title":"Author/Jana Vetvickova","target":"Author/Jana Vetvickova","line":36},{"title":"PDF","target":"biblib/vetvicka_glucan_2015/vetvicka_glucan_2015.pdf","line":38}],"metadata":{"id":"vetvicka_glucan_2015","type":"article-journal","title":"Glucan supplementation enhances the immune response against an influenza challenge in mice.","issued":{"date-parts":[[2015]]},"DOI":"10.3978/j.issn.2305-5839.2015.01.08","container-title":"Annals of Translational Medicine","abstract":"Background: The strong immunostimulating potential of β-glucans has been well established in numerous diseases. However, the effects on viral infection were less studied. Methods: In our study, we focused on possible effects of a special combined glucan formulation on immunosuppression caused by influenza infection. Results: We found that a 2-week oral feeding with glucan mixture significantly reduced the effects of influenza infection in total mortality. Our study was focused on phagocytosis, cytokine levels, antibody response and cytotoxicity assay. Conclusions: Based on our data, we concluded that these effects are caused by stimulation of both cellular and humoral immune reaction resulting in lower viral load.","tags":["#literature_note"],"author":[{"family":"Větvička","given":"Václav","literal":""},{"family":"Vetvicka","given":"Vaclav","literal":""},{"family":"Větvičková","given":"Jana","literal":""},{"family":"Vetvickova","given":"Jana","literal":""}],"citation-key":"vetvicka_glucan_2015","year":"2015","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Glucan supplementation enhances the immune response against an influenza challenge in mice."],"author-links":["[[Author/Václav Větvička]]","[[Author/Vaclav Vetvicka]]","[[Author/Jana Větvičková]]","[[Author/Jana Vetvickova]]"],"attachment":["[[biblib/vetvicka_glucan_2015/vetvicka_glucan_2015.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[]},
