0.09014783,-0.12626089,0.01919435,0.01832276,0.16116594,0.05281078,0.00494589,0.00592721,-0.02886014,0.03760686,0.02888999,-0.00995435,-0.02600267,0.03182815,0.11879984,-0.05106925,0.08196881,0.06668053,-0.03156346,0.0075364,0.00473962,-0.02789226,0.04161637,-0.00438989,-0.09562584,-0.00267115,0.09688517,-0.0548139,-0.02669225,0.02535368,-0.03558435,0.02147538,-0.0050443,0.01418822,0.04693254,0.00931156,0.0053848,0.00001285,0.01462029,-0.03463534,-0.04944196,0.01554638,0.00274481,-0.03878079,-0.0245793,0.12305425,0.0385208],"last_embed":{"hash":"17wrw60","tokens":447}}},"last_read":{"hash":"17wrw60","at":1774951887844},"class_name":"SmartSource","last_import":{"mtime":1774951817825,"size":4373,"at":1774951884784,"hash":"17wrw60"},"blocks":{"#---frontmatter---":[1,117],"#Hericerin derivatives from Hericium erinaceus exert BDNF-like neurotrophic activity in central hippocampal neurons and enhance memory":[119,123],"#Hericerin derivatives from Hericium erinaceus exert BDNF-like neurotrophic activity in central hippocampal neurons and enhance memory#{1}":[121,123]},"outlinks":[{"title":"Author/Ramón Martínez-Mármol","target":"Author/Ramón Martínez-Mármol","line":90},{"title":"Author/Ramón Martínez-Mármol","target":"Author/Ramón Martínez-Mármol","line":91},{"title":"Author/YeJin Chai","target":"Author/YeJin Chai","line":92},{"title":"Author/YeJin Chai","target":"Author/YeJin Chai","line":93},{"title":"Author/Zahra Khan","target":"Author/Zahra Khan","line":94},{"title":"Author/Zahra Khan","target":"Author/Zahra Khan","line":95},{"title":"Author/Seon Beom Kim","target":"Author/Seon Beom Kim","line":96},{"title":"Author/Seon Beom Kim","target":"Author/Seon Beom Kim","line":97},{"title":"Author/Seong Min Hong","target":"Author/Seong Min Hong","line":98},{"title":"Author/Seong Min Hong","target":"Author/Seong Min Hong","line":99},{"title":"Author/Seong Min Hong","target":"Author/Seong Min Hong","line":100},{"title":"Author/Rachel S. Gormal","target":"Author/Rachel S. Gormal","line":101},{"title":"Author/Rachel S. Gormal","target":"Author/Rachel S. Gormal","line":102},{"title":"Author/Dong Hoon Lee","target":"Author/Dong Hoon Lee","line":103},{"title":"Author/DaeHee Lee","target":"Author/DaeHee Lee","line":104},{"title":"Author/Jae Kang Lee","target":"Author/Jae Kang Lee","line":105},{"title":"Author/Jae Kang Lee","target":"Author/Jae Kang Lee","line":106},{"title":"Author/Mi Kyeong Lee","target":"Author/Mi Kyeong Lee","line":107},{"title":"Author/Mi Kyeong Lee","target":"Author/Mi Kyeong Lee","line":108},{"title":"Author/Sun Yeou Kim","target":"Author/Sun Yeou Kim","line":109},{"title":"Author/Sun Yeou Kim","target":"Author/Sun Yeou Kim","line":110},{"title":"Author/Frédéric A. Meunier","target":"Author/Frédéric A. Meunier","line":111},{"title":"Author/Frederic A. Meunier","target":"Author/Frederic A. Meunier","line":112},{"title":"PDF","target":"biblib/martinez-marmol_hericerin_2020/martinez-marmol_hericerin_2020.pdf","line":114}],"metadata":{"id":"martinez-marmol_hericerin_2020","type":"article-journal","title":"Hericerin derivatives from Hericium erinaceus exert BDNF-like neurotrophic activity in central hippocampal neurons and enhance memory","issued":{"date-parts":[[2020]]},"DOI":"10.1101/2020.08.28.271676","container-title":"bioRxiv","abstract":"The traditional medicinal mushroom Hericium erinaceus has long been known for enhancing the peripheral nerve regeneration through targeting nerve growth factor (NGF) neurotrophic activity. It was also reported to protect against ageing-dependent cognitive decline in wildtype and in Alzheimer9s disease mouse models suggesting a yet to be defined action on neurons of the central nervous system. Here, we purified and identified biologically active compounds from H. erinaceus, based on their ability to promote neurite outgrowth in hippocampal neurons. N-de phenylethyl isohericerin (NDPIH), an isoindoline compound from this mushroom together with its hydrophobic derivative hericene A, were highly potent in inducing extensive axon outgrowth and neurite branching in the absence of serum demonstrating high neurotropic activity. NDPIH also induced enlarged growth cones suggestive of a brain-derived neurotrophic factor (BDNF)-like activity. Pharmacological inhibition of tropomyosin receptor kinase B (TrkB) by ANA12 prevented NDPIH-induced neurotrophic activity providing evidence that NDPIH acts via TrkB receptors to mediate its neurotrophic effect in central neurons. Finally, in vivo treatment with H. erinaceus crude extract and hericene A significantly increased BDNF and downstream pathway and enhanced learning and memory in the novel object recognition memory test. Our results suggest that hericene A can promote BDNF-like activity in neurons in vitro and in vivo thereby enhancing recognition memory.","tags":["#literature_note"],"author":[{"family":"Martínez-Mármol","given":"Ramón","literal":""},{"family":"Martínez-Mármol","given":"Ramón","literal":""},{"family":"Chai","given":"YeJin","literal":""},{"family":"Chai","given":"YeJin","literal":""},{"family":"Khan","given":"Zahra","literal":""},{"family":"Khan","given":"Zahra","literal":""},{"family":"Kim","given":"Seon Beom","literal":""},{"family":"Kim","given":"Seon Beom","literal":""},{"family":"Hong","given":"Seong Min","literal":""},{"family":"Hong","given":"Seong Min","literal":""},{"family":"Hong","given":"Seong Min","literal":""},{"family":"Gormal","given":"Rachel S.","literal":""},{"family":"Gormal","given":"Rachel S.","literal":""},{"family":"Lee","given":"Dong Hoon","literal":""},{"family":"Lee","given":"DaeHee","literal":""},{"family":"Lee","given":"Jae Kang","literal":""},{"family":"Lee","given":"Jae Kang","literal":""},{"family":"Lee","given":"Mi Kyeong","literal":""},{"family":"Lee","given":"Mi Kyeong","literal":""},{"family":"Kim","given":"Sun Yeou","literal":""},{"family":"Kim","given":"Sun Yeou","literal":""},{"family":"Meunier","given":"Frédéric A.","literal":""},{"family":"Meunier","given":"Frederic A.","literal":""}],"citation-key":"martinez-marmol_hericerin_2020","year":"2020","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Hericerin derivatives from Hericium erinaceus exert BDNF-like neurotrophic activity in central hippocampal neurons and enhance memory"],"author-links":["[[Author/Ramón Martínez-Mármol]]","[[Author/Ramón Martínez-Mármol]]","[[Author/YeJin Chai]]","[[Author/YeJin Chai]]","[[Author/Zahra Khan]]","[[Author/Zahra Khan]]","[[Author/Seon Beom Kim]]","[[Author/Seon Beom Kim]]","[[Author/Seong Min Hong]]","[[Author/Seong Min Hong]]","[[Author/Seong Min Hong]]","[[Author/Rachel S. Gormal]]","[[Author/Rachel S. Gormal]]","[[Author/Dong Hoon Lee]]","[[Author/DaeHee Lee]]","[[Author/Jae Kang Lee]]","[[Author/Jae Kang Lee]]","[[Author/Mi Kyeong Lee]]","[[Author/Mi Kyeong Lee]]","[[Author/Sun Yeou Kim]]","[[Author/Sun Yeou Kim]]","[[Author/Frédéric A. Meunier]]","[[Author/Frederic A. Meunier]]"],"attachment":["[[biblib/martinez-marmol_hericerin_2020/martinez-marmol_hericerin_2020.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"17wrw60","at":1774951887835}},"smart_blocks:Research/@martinez-marmol_hericerin_2020.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.03112939,-0.0567737,0.02106952,-0.03312517,-0.01054659,0.0162675,0.02135413,0.03700851,-0.07078548,0.00342972,0.01385204,-0.04562322,0.05530813,0.02678508,0.02070351,0.02757903,-0.05142716,0.04744029,-0.07555438,-0.00048706,0.00834802,-0.07250176,0.04343444,0.02310338,0.00866596,0.01025086,-0.0333497,-0.01281295,-0.04249307,-0.22453561,-0.00945875,0.00449856,0.00928269,-0.04988963,-0.02390878,0.0094547,-0.01578688,0.01070468,-0.02191049,-0.01198293,0.03495149,0.03232868,0.01018671,0.00627127,-0.0085699,-0.08021477,-0.03171553,-0.02781412,0.02870514,-0.02725078,-0.00935463,-0.04918154,0.02904975,0.04351813,0.0596687,-0.02628765,-0.0270598,0.02146768,0.02975958,0.00715917,0.0767974,0.0696114