19622,-0.06465369,0.02301063,-0.06213474,0.15696552,0.00434334,-0.04373651,0.00329181,-0.02704471,0.0234143,-0.01452499,0.04824395,-0.01816977,0.06012392,0.09651704,-0.02189221,0.06215831,0.09655777,-0.0420993,-0.02408855,-0.0309051,-0.03219261,0.02487307,-0.01975086,-0.15935701,-0.05399432,0.08216008,-0.07443715,-0.03715931,-0.01869188,0.02458928,0.00186935,0.00298307,-0.00599912,-0.03999683,0.01904687,-0.08471288,-0.0114813,-0.00761906,0.00644988,-0.05479134,-0.03485406,0.03851801,0.02996741,-0.03306195,0.11404982,0.03791276],"last_embed":{"hash":"1pevy7u","tokens":503}}},"last_read":{"hash":"1pevy7u","at":1774951887938},"class_name":"SmartSource","last_import":{"mtime":1774951818013,"size":3383,"at":1774951884785,"hash":"1pevy7u"},"blocks":{"#---frontmatter---":[1,73],"#Antioxidant activity and cytotoxicity of exopolysaccharide from mushroom Hericium coralloides in submerged fermentation":[75,79],"#Antioxidant activity and cytotoxicity of exopolysaccharide from mushroom Hericium coralloides in submerged fermentation#{1}":[77,79]},"outlinks":[{"title":"Author/Firouzeh Tabibzadeh","target":"Author/Firouzeh Tabibzadeh","line":57},{"title":"Author/Firouzeh Tabibzadeh","target":"Author/Firouzeh Tabibzadeh","line":58},{"title":"Author/Hale Alvandi","target":"Author/Hale Alvandi","line":59},{"title":"Author/Hale Alvandi","target":"Author/Hale Alvandi","line":60},{"title":"Author/Ashrafalsadat Hatamian-Zarmi","target":"Author/Ashrafalsadat Hatamian-Zarmi","line":61},{"title":"Author/Ashrafalsadat Hatamian-Zarmi","target":"Author/Ashrafalsadat Hatamian-Zarmi","line":62},{"title":"Author/Liudmila Kalitukha","target":"Author/Liudmila Kalitukha","line":63},{"title":"Author/Liudmila Kalitukha","target":"Author/Liudmila Kalitukha","line":64},{"title":"Author/Hamed Aghajani","target":"Author/Hamed Aghajani","line":65},{"title":"Author/Hamed Aghajani","target":"Author/Hamed Aghajani","line":66},{"title":"Author/Bahman Ebrahimi-Hosseinzadeh","target":"Author/Bahman Ebrahimi-Hosseinzadeh","line":67},{"title":"Author/Bahman Ebrahimi-Hosseinzadeh","target":"Author/Bahman Ebrahimi-Hosseinzadeh","line":68},{"title":"PDF","target":"biblib/tabibzadeh_antioxidant_2022/tabibzadeh_antioxidant_2022.pdf","line":70}],"metadata":{"id":"tabibzadeh_antioxidant_2022","type":"article-journal","title":"Antioxidant activity and cytotoxicity of exopolysaccharide from mushroom Hericium coralloides in submerged fermentation","issued":{"date-parts":[[2022]]},"DOI":"10.1007/s13399-022-03386-0","container-title":"Biomass Conversion and Biorefinery","abstract":"Mushrooms of the genus Hericium spp. represent a series of delicious edible mushrooms with medicinal value. Here, for the first time, the species native to Iran, the mushroom Hericium coralloides, was collected in Mazandaran province, identified, and registered with the NCBI under accession number MW136052. The production of exopolysaccharides (EPS) in submerged culture was optimized using the response surface method. Among the physicochemical and culture medium conditions tested, rotation speed and concentration of maltose and peptone of soybean significantly affected the production of EPS. The proposed model predicts maximum EPS production (0.13 g/L) at 50 g/L maltose, 3 g/L soy peptone, and 1 g/L yeast extract, pH = 6.5, 200 rpm, inoculum at 5% v/v, and 22 °C. The molecular weight of the EPS chains was 413 and 1578 Da. EPS has antioxidant action (EC50 = 6.59 mg/mL) and cytotoxic activity against cancer cells. The viability of AGS and MKN-45 cancer cell lines declined to 20 and 30% after 48 h of the EPS treatment. H. coralloides EPS could be considered a natural dietary anti-cancer supplement. Further studies are necessary to understand the mechanism of the H. coralloides EPS activity on the cell cycle of cancer cells and to prove its action in vivo.The online version contains supplementary material available at 10.1007/s13399-022-03386-0.","tags":["#literature_note"],"author":[{"family":"Tabibzadeh","given":"Firouzeh","literal":""},{"family":"Tabibzadeh","given":"Firouzeh","literal":""},{"family":"Alvandi","given":"Hale","literal":""},{"family":"Alvandi","given":"Hale","literal":""},{"family":"Hatamian-Zarmi","given":"Ashrafalsadat","literal":""},{"family":"Hatamian-Zarmi","given":"Ashrafalsadat","literal":""},{"family":"Kalitukha","given":"Liudmila","literal":""},{"family":"Kalitukha","given":"Liudmila","literal":""},{"family":"Aghajani","given":"Hamed","literal":""},{"family":"Aghajani","given":"Hamed","literal":""},{"family":"Ebrahimi-Hosseinzadeh","given":"Bahman","literal":""},{"family":"Ebrahimi-Hosseinzadeh","given":"Bahman","literal":""}],"citation-key":"tabibzadeh_antioxidant_2022","year":"2022","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Antioxidant activity and cytotoxicity of exopolysaccharide from mushroom Hericium coralloides in submerged fermentation"],"author-links":["[[Author/Firouzeh Tabibzadeh]]","[[Author/Firouzeh Tabibzadeh]]","[[Author/Hale Alvandi]]","[[Author/Hale Alvandi]]","[[Author/Ashrafalsadat Hatamian-Zarmi]]","[[Author/Ashrafalsadat Hatamian-Zarmi]]","[[Author/Liudmila Kalitukha]]","[[Author/Liudmila Kalitukha]]","[[Author/Hamed Aghajani]]","[[Author/Hamed Aghajani]]","[[Author/Bahman Ebrahimi-Hosseinzadeh]]","[[Author/Bahman Ebrahimi-Hosseinzadeh]]"],"attachment":["[[biblib/tabibzadeh_antioxidant_2022/tabibzadeh_antioxidant_2022.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"1pevy7u","at":1774951887927}},"smart_blocks:Research/@tabibzadeh_antioxidant_2022.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[0.01588572,-0.01796683,0.01291828,-0.02214583,0.02589209,-0.01398223,-0.01025204,0.05343642,-0.03706516,0.01229081,-0.00803369,-0.09467768,-0.00782522,0.001846,-0.00200565,0.01080186,0.00661253,-0.00862407,-0.06543879,0.00590822,0.0633285,-0.00891911,-0.00546733,-0.00393644,0.05648653,0.01733585,-0.03688214,0.01359727,-0.10130452,-0