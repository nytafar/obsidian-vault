04381611,-0.08156995,0.01805035,-0.03895291,0.20140013,-0.05206657,-0.00450296,0.04962973,-0.01279248,0.04128968,0.01606417,0.00040357,0.01249503,0.00631174,0.07522076,0.03463023,0.03193935,0.04730912,-0.01591145,0.00289567,-0.02676654,-0.00969882,0.03776984,-0.01882205,-0.07012473,0.01225221,0.04648652,-0.07798148,-0.0210856,-0.00325016,0.03588594,-0.01742863,-0.01046593,0.04414639,0.06934822,0.06995649,0.00584644,-0.04331079,0.03564584,-0.07217629,0.01302128,0.02957324,-0.0388845,-0.00495671,-0.09179778,0.06712038,0.01884704],"last_embed":{"hash":"1j3lu5b","tokens":440}}},"last_read":{"hash":"1j3lu5b","at":1774951885190},"class_name":"SmartSource","last_import":{"mtime":1774951813764,"size":3767,"at":1774951884756,"hash":"1j3lu5b"},"blocks":{"#---frontmatter---":[1,56],"#UV-spectrophotometric and spectroscopic observed Vachellia nilotica and Nigella sativa formulations regularized the histopathological and biochemical parameters during wound contraction.":[58,62],"#UV-spectrophotometric and spectroscopic observed Vachellia nilotica and Nigella sativa formulations regularized the histopathological and biochemical parameters during wound contraction.#{1}":[60,62]},"outlinks":[{"title":"Author/H Shahzad","target":"Author/H Shahzad","line":45},{"title":"Author/S Ali","target":"Author/S Ali","line":46},{"title":"Author/MA Farooq","target":"Author/MA Farooq","line":47},{"title":"Author/M Summer","target":"Author/M Summer","line":48},{"title":"Author/A Hassan","target":"Author/A Hassan","line":49},{"title":"Author/R Sulayman","target":"Author/R Sulayman","line":50},{"title":"Author/L Kanwal","target":"Author/L Kanwal","line":51},{"title":"Author/UA Awan","target":"Author/UA Awan","line":52}],"metadata":{"id":"h_shahzad_uv-spectrophotometric_2025","type":"article-journal","title":"UV-spectrophotometric and spectroscopic observed Vachellia nilotica and Nigella sativa formulations regularized the histopathological and biochemical parameters during wound contraction.","issued":{"date-parts":[[2025]]},"DOI":"10.1002/jemt.24673","container-title":"Microscopy research and technique","abstract":"Diabetes mellitus causes impaired diabetic wounds which is linked to a number of pathological alterations that impede the healing of wounds. In the current research, Swiss albino mice were given alloxan monohydrate to induce diabetes and excision wounds of approximately 6 mm using biopsy punch. The diabetic wounds were treated with various biomaterials including Vachellia nilotica extract (VN), Nigella sativa extract (NS), V. nilotica nanoparticles (VNNPs) and N. sativa nanoparticles (NSNPs). Their effects were determined by evaluating the percent wound contraction, healing time, and histopathological analysis. The serum level of various biochemical parameters that is, pro-inflammatory cytokines, Matrix metalloproteinases (MMPs) and tissue inhibitor matrix metalloproteinases (TIMPs) were also determined. VNNPs group provided the best outcomes, with wound contraction 100% on 12th day. According to histopathological examination, VNNPs group reduced inflammation and encouraged the formation of blood vessels, fibroblasts, and keratinocytes. VNNPs group significantly alleviated the serum level of pro-inflammatory cytokines that are, TNF-α (19.4 ± 1.5 pg/mL), IL-6 (13.8 ± 0.6 pg/mL), and IL-8 (24.8 ± 1.2 pg/mL) as compared with the diabetic mice. The serum level of MMP2 (248.2 ± 7.9 pg/mL), MMP7 (316 ± 5.2 pg/mL), and MMP9 (167.8 ± 12.1 pg/mL) in the same group VNNPs were also observed much less than the diabetic mice. The serum level of TIMPs (176.8 ± 2.9 pg/mL) in the VNNPs group was increased maximally with respect to diabetic mice. It is concluded that nanoparticles and biomaterials possess healing properties and have the ability to repair the chronic/diabetic wound. RESEARCH HIGHLIGHTS: UV-spectrophotometric and Fourier transform infrared spectroscopy observation for functional group analysis and possible linkage between conjugates Optimization of the histopathological and biochemical markers after application of the formulations Microscopic analysis of epithelial tissues for evaluation of healing mechanisms Speedy contraction of wounds as the alleviation of the inflammatory and necrotic factors.© 2024 Wiley Periodicals LLC.","tags":["#literature_note"],"author":[{"family":"H Shahzad","given":"","literal":""},{"family":"S Ali","given":"","literal":""},{"family":"MA Farooq","given":"","literal":""},{"family":"M Summer","given":"","literal":""},{"family":"A Hassan","given":"","literal":""},{"family":"R Sulayman","given":"","literal":""},{"family":"L Kanwal","given":"","literal":""},{"family":"UA Awan","given":"","literal":""}],"citation-key":"h_shahzad_uv-spectrophotometric_2025","year":"2025","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["UV-spectrophotometric and spectroscopic observed Vachellia nilotica and Nigella sativa formulations regularized the histopathological and biochemical parameters during wound contraction."],"author-links":["[[Author/H Shahzad]]","[[Author/S Ali]]","[[Author/MA Farooq]]","[[Author/M Summer]]","[[Author/A Hassan]]","[[Author/R Sulayman]]","[[Author/L Kanwal]]","[[Author/UA Awan]]"],"attachment":[],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"1j3lu5b","at":1774951885172}},"smart_blocks:Research/@h_shahzad_uv-spectrophotometric_2025.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.04659604,0.01262002,0.04283803,-0.037517,0.01434237,0.04586865,0.04835837,0.05957533,-0.06110121,0.04636647,0.01210173,-0.05184724,-0.00553234,0.06407096,-0.0280605,-0.05427418,0.01490328,0.01795511,-0.14307915,-0.02057934,0.04416172,-0.03621899,0.04196856,0.00289843,0.06618779,0.01150485,0.01085742,0.04234948,-0.06894527,-0.21538863,-0.04348028,-0.01794985,-0.03190076,-0.0158499,-0.02930203,0.00105511,-0.03008264,0.07508557,-0.0262591,-0.04813021,0.07188045,0.01996784,-0.04974657,0.01623738,0.04933717,-0.0541