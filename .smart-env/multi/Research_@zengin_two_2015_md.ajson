0256413,-0.02203159,0.17417343,-0.04597339,-0.05628443,-0.00890362,-0.02108436,-0.0373284,-0.05378282,0.05668173,0.00946216,0.01253472,0.12953644,-0.00497566,0.05608671,0.14309151,-0.08508524,-0.01340563,-0.0069,-0.02190847,0.02208637,-0.01119336,-0.15685198,-0.01392012,0.09300199,-0.13345055,-0.00768633,-0.03591443,0.01149563,0.0162174,-0.01677955,-0.0511659,0.00972499,0.06527622,0.00311261,-0.04810562,-0.00284413,-0.04388743,0.00651811,0.01844526,-0.00557442,-0.01233977,-0.04698958,0.10247392,0.0487982],"last_embed":{"hash":"gppy05","tokens":466}}},"last_read":{"hash":"gppy05","at":1774951892583},"class_name":"SmartSource","last_import":{"mtime":1774951824478,"size":4178,"at":1774951884814,"hash":"gppy05"},"blocks":{"#---frontmatter---":[1,89],"#Two Ganoderma species: profiling of phenolic compounds by HPLC-DAD, antioxidant, antimicrobial and inhibitory activities on key enzymes linked to diabetes mellitus, Alzheimer's disease and skin disorders.":[91,95],"#Two Ganoderma species: profiling of phenolic compounds by HPLC-DAD, antioxidant, antimicrobial and inhibitory activities on key enzymes linked to diabetes mellitus, Alzheimer's disease and skin disorders.#{1}":[93,95]},"outlinks":[{"title":"Author/Gökhan Zengin","target":"Author/Gökhan Zengin","line":69},{"title":"Author/Gokhan Zengin","target":"Author/Gokhan Zengin","line":70},{"title":"Author/Cengiz Sarıkürkçü","target":"Author/Cengiz Sarıkürkçü","line":71},{"title":"Author/Cengiz Sarikurkcu","target":"Author/Cengiz Sarikurkcu","line":72},{"title":"Author/Erdoğan Güneş","target":"Author/Erdoğan Güneş","line":73},{"title":"Author/Erdogan Gunes","target":"Author/Erdogan Gunes","line":74},{"title":"Author/Ahmet Uysal","target":"Author/Ahmet Uysal","line":75},{"title":"Author/Ahmet Uysal","target":"Author/Ahmet Uysal","line":76},{"title":"Author/Ramazan Ceylan","target":"Author/Ramazan Ceylan","line":77},{"title":"Author/Ramazan Ceylan","target":"Author/Ramazan Ceylan","line":78},{"title":"Author/Şengül Uysal","target":"Author/Şengül Uysal","line":79},{"title":"Author/Sengul Uysal","target":"Author/Sengul Uysal","line":80},{"title":"Author/Halil Güngör","target":"Author/Halil Güngör","line":81},{"title":"Author/Halil Gungor","target":"Author/Halil Gungor","line":82},{"title":"Author/Abdurrahman Aktümsek","target":"Author/Abdurrahman Aktümsek","line":83},{"title":"Author/Abdurrahman Aktumsek","target":"Author/Abdurrahman Aktumsek","line":84},{"title":"PDF","target":"biblib/zengin_two_2015/zengin_two_2015.pdf","line":86}],"metadata":{"id":"zengin_two_2015","type":"article-journal","title":"Two Ganoderma species: profiling of phenolic compounds by HPLC-DAD, antioxidant, antimicrobial and inhibitory activities on key enzymes linked to diabetes mellitus, Alzheimer's disease and skin disorders.","issued":{"date-parts":[[2015]]},"DOI":"10.1039/c5fo00665a","container-title":"Food & Function","abstract":"This work reports the antioxidant, antimicrobial, and inhibitory effects of methanol and water extracts from Ganoderma applanatum (GAM: methanol extract and GAW: water extract) and G. resinaceum (GRM: methanol extract and GRW: water extract) against cholinesterase, tyrosinase, α-amylase and α-glucosidase. The total phenolics, flavonoids contents, and HPLC profile of phenolic components present in the extracts, were also determined. Antioxidant activities were investigated by using different assays, including DPPH, ABTS, FRAP, CUPRAC, phosphomolybdenum and metal chelating assays. Antimicrobial activity of the tested Ganoderma extracts was also studied by the broth microdilution method. Generally, the highest antioxidant (59.24 mg TEs per g extract for DPPH, 41.32 mg TEs per g extract for ABTS, 41.35 mg TEs per g extract for CUPRAC, 49.68 mg TEs per g extract for FRAP, 130.57 mg AAEs per g extract for phosphomolybdenum and 26.92 mg EDTAEs per g extract) and enzyme inhibitory effects (1.47 mg GALAEs per g extract for AChE, 1.51 mg GALAEs per g extract for BChE, 13.40 mg KAEs per g extract for tyrosinase, 1.13 mmol ACEs per g extract for α-amylase and 2.20 mmol ACEs per g extract for α-glucosidase) were observed in GRM, which had the highest concentrations of phenolics (37.32 mg GAEs g−1 extract). Again, Ganoderma extracts possess weak antibacterial and antifungal activities. Apigenin and protocatechuic acid were determined as the main components in GRM (1761 μg per g extract) and GAM (165 μg per g extract), respectively. The results suggest that the Ganoderma species may be considered as a candidate for preparing new food supplements and can represent a good model for the development of new drug formulations.","tags":["#literature_note"],"author":[{"family":"Zengin","given":"Gökhan","literal":""},{"family":"Zengin","given":"Gokhan","literal":""},{"family":"Sarıkürkçü","given":"Cengiz","literal":""},{"family":"Sarikurkcu","given":"Cengiz","literal":""},{"family":"Güneş","given":"Erdoğan","literal":""},{"family":"Gunes","given":"Erdogan","literal":""},{"family":"Uysal","given":"Ahmet","literal":""},{"family":"Uysal","given":"Ahmet","literal":""},{"family":"Ceylan","given":"Ramazan","literal":""},{"family":"Ceylan","given":"Ramazan","literal":""},{"family":"Uysal","given":"Şengül","literal":""},{"family":"Uysal","given":"Sengul","literal":""},{"family":"Güngör","given":"Halil","literal":""},{"family":"Gungor","given":"Halil","literal":""},{"family":"Aktümsek","given":"Abdurrahman","literal":""},{"family":"Aktumsek","given":"Abdurrahman","literal":""}],"citation-key":"zengin_two_2015","year":"2015","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Two Ganoderma species: profiling of phenolic compounds by HPLC-DAD, antioxidant, antimicrobial and inhibitory activities on key enzymes linked to diabetes mellitus, Alzheimer's disease and skin disorders."],"author-links":["[[Author/Gökhan Zengin]]","[[Author/Gokhan Zengin]]","[[Author/Cengiz Sarıkürkçü]]","[[Author/Cengiz Sarikurkcu]]","[[Author/Erdoğan Güneş]]","[[Author/Erdogan Gunes]]","[[Author/Ahmet Uysal]]","[[Author/Ahmet Uysal]]","[[Author/Ramazan Ceylan]]","[[Author/Ramazan Ceylan]]","[[Author/Şengül Uysal]]","[[Author/Sengul Uysal]]","[[Author/Halil Güngör]]","[[Author/Halil Gungor]]","[[Author/Abdurrahman Aktümsek]]","[[Author/Abdurrahman Aktumsek]]"],"attachment":["[[biblib/zengin_two_2015/zengin_two_2015.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"gppy05","at":1774951892563}},"smart_blocks:Research/@zengin_two_2015.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.04480128,0.02327899,0.0127286,-0.05767855,0.04707424,-0.0264683,0.04689461,0.05793374,-0.0605046,-0.07009451,-0.0353926,-0.05640839,-0.02810578,0.01680621,0.00210269,-0.03693385,0.02820963,0.00063135,-0.12398251,0.01674875,0.02649322,-0.04314569,0.01938434,-0.00143723,0.07798583,0.04741971,-0.02270329,0.02428892,-0.01125799,-0.21019055,-0.0117456,0.01910243,-0.00260602,0.00247332,-0.02466086,-0.03518834,-0.03716023,0.05427386,-0.00246342,-0.03653492,0.07422867,0.03936533,-0.03257164,0.0252385,0.04403873,-0.04514712,-0.08623845,-0.02135323,0.01863018,-0.06864928,-0.0160834,-0.0019441,0.02600227,0.0332193,0.03085481,0.00363407,0.05397551,0.00311537,-0.03660249,0.07979274,0.03462147,0.00075129,-0.17721602,0.07026383,0.00086574,-0.02103916,-0.02637785,-0.01633012,0.08318476,-0.01249784,-0.07334056,0.00452106,0.01101657,0.02243361,-0.03734415,-0.00013079,-0.05408191,-0.02385972,-0.00257868,-0.00933355,0.02162261,0.04234347,0.00166625,-0.00586593,-0.02446218,0.02165077,0.00885239,-0.03563474,0.05653377,0.01179769,0.03703946,-0.05689662,0.03428124,0.01682191,-0.0421853,0.04221197,0.01942494,-0.00833955,0.00227208,0.14018229,-0.0816746,-0.0184272,-0.0340323,-0.05728812,0.01434572,-0.03633215,-0.03680791,-0.07349616,0.02068841,0.01032136,0.08272673,-0.01439683,-0.01672867,-0.01597178,-0.01453196,0.03811683,0.09479079,-0.00072585,0.00773563,0.00332031,-0.00829975,-0.05380386,0.11513375,-0.01435298,-0