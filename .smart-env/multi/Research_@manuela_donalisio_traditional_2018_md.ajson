0.03903618,-0.03726204,-0.00617856,-0.05288109,0.14260451,-0.04503106,-0.02094997,0.01774714,-0.08904795,-0.00830291,0.00800326,0.00933486,-0.03922781,-0.03186363,0.15644927,-0.00468135,0.03834926,0.02028461,-0.05101752,-0.01463086,-0.04094885,-0.05799074,-0.01127482,0.07574693,-0.07947866,-0.03985889,0.03938592,-0.08425698,-0.02752449,-0.01371185,0.04396606,0.020282,0.01367867,-0.04188038,0.04099628,0.08045651,0.05922595,-0.00342269,0.03995606,-0.02470704,-0.01329376,-0.00821809,-0.01162277,-0.03451358,-0.03157708,0.09176994,0.04944786],"last_embed":{"hash":"1vyqnk7","tokens":487}}},"last_read":{"hash":"1vyqnk7","at":1774951885204},"class_name":"SmartSource","last_import":{"mtime":1774951813767,"size":4331,"at":1774951884757,"hash":"1vyqnk7"},"blocks":{"#---frontmatter---":[1,91],"#The traditional use of Vachellia nilotica for sexually transmitted diseases is substantiated by the antiviral activity of its bark extract against sexually transmitted viruses.":[93,97],"#The traditional use of Vachellia nilotica for sexually transmitted diseases is substantiated by the antiviral activity of its bark extract against sexually transmitted viruses.#{1}":[95,97]},"outlinks":[{"title":"Author/Manuela Donalisio","target":"Author/Manuela Donalisio","line":72},{"title":"Author/Manuela Donalisio","target":"Author/Manuela Donalisio","line":73},{"title":"Author/Valeria Cagno","target":"Author/Valeria Cagno","line":74},{"title":"Author/Valeria Cagno","target":"Author/Valeria Cagno","line":75},{"title":"Author/Andrea Civra","target":"Author/Andrea Civra","line":76},{"title":"Author/Andrea Civra","target":"Author/Andrea Civra","line":77},{"title":"Author/Davide Gibellini","target":"Author/Davide Gibellini","line":78},{"title":"Author/Davide Gibellini","target":"Author/Davide Gibellini","line":79},{"title":"Author/Giuseppina Musumeci","target":"Author/Giuseppina Musumeci","line":80},{"title":"Author/Giuseppina Musumeci","target":"Author/Giuseppina Musumeci","line":81},{"title":"Author/Massimo Rittà","target":"Author/Massimo Rittà","line":82},{"title":"Author/Massimo Rittà","target":"Author/Massimo Rittà","line":83},{"title":"Author/Manik Ghosh","target":"Author/Manik Ghosh","line":84},{"title":"Author/Manik Ghosh","target":"Author/Manik Ghosh","line":85},{"title":"Author/David Lembo","target":"Author/David Lembo","line":86},{"title":"Author/David Lembo","target":"Author/David Lembo","line":87}],"metadata":{"id":"manuela_donalisio_traditional_2018","type":"article-journal","title":"The traditional use of Vachellia nilotica for sexually transmitted diseases is substantiated by the antiviral activity of its bark extract against sexually transmitted viruses.","issued":{"date-parts":[[2018,3]]},"page":"403-408","DOI":"10.1016/j.jep.2017.11.039","container-title":"Journal of Ethnopharmacology","volume":213,"abstract":"Abstract Ethnopharmacological relevance Vachellia (Acacia) nilotica and other plants of this genus have been used in traditional medicine of Asian and African countries to treat many disorders, including sexually transmitted diseases, but few studies were performed to validate their anti-microbial and anti-viral activity against sexually transmitted infections. Aim of the study The present study was undertaken to explore whether the ethnomedical use of V.nilotica to treat genital lesions is substantiated by its antiviral activity against the human immunodeficiency virus (HIV), the herpes simplex virus (HSV) and the human papillomavirus (HPV). Materials and methods The antiviral activity of V.nilotica was tested in vitro by virus-specific inhibition assays using HSV-2 strains, sensible or resistant to acyclovir, HIV-1IIIb strain and HPV-16 pseudovirion (PsV). The potential mode of action of extract against HSV-2 and HPV-16 was further investigated by virus inactivation and time-of-addition assays on cell cultures. Results V.nilotica chloroform, methanolic and water bark extracts exerted antiviral activity against HSV-2 and HPV-16 PsV infections; among these, methanolic extract showed the best EC50s with values of 4.71 and 1.80µg/ml against HSV-2 and HPV-16, respectively, and it was also active against an acyclovir-resistant HSV-2 strain with an EC50 of 6.71µg/ml. By contrast, no suppression of HIV infection was observed. Investigation of the mechanism of action revealed that the methanolic extract directly inactivated the infectivity of the HPV-16 particles, whereas a partial virus inactivation and interference with virus attachment (EC50 of 2.74µg/ml) were both found to contribute to the anti-HSV-2 activity. Conclusions These results support the traditional use of V.nilotica applied externally for the treatment of genital lesions. Further work remains to be done in order to identify the bioactive components.","tags":["#literature_note"],"author":[{"family":"Manuela Donalisio","given":"","literal":""},{"family":"Donalisio","given":"Manuela","literal":""},{"family":"Valeria Cagno","given":"","literal":""},{"family":"Cagno","given":"Valeria","literal":""},{"family":"Andrea Civra","given":"","literal":""},{"family":"Civra","given":"Andrea","literal":""},{"family":"Davide Gibellini","given":"","literal":""},{"family":"Gibellini","given":"Davide","literal":""},{"family":"Giuseppina Musumeci","given":"","literal":""},{"family":"Musumeci","given":"Giuseppina","literal":""},{"family":"Massimo Rittà","given":"","literal":""},{"family":"Rittà","given":"Massimo","literal":""},{"family":"Manik Ghosh","given":"","literal":""},{"family":"Ghosh","given":"Manik","literal":""},{"family":"David Lembo","given":"","literal":""},{"family":"Lembo","given":"David","literal":""}],"citation-key":"manuela_donalisio_traditional_2018","year":"2018","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["The traditional use of Vachellia nilotica for sexually transmitted diseases is substantiated by the antiviral activity of its bark extract against sexually transmitted viruses."],"author-links":["[[Author/Manuela Donalisio]]","[[Author/Manuela Donalisio]]","[[Author/Valeria Cagno]]","[[Author/Valeria Cagno]]","[[Author/Andrea Civra]]","[[Author/Andrea Civra]]","[[Author/Davide Gibellini]]","[[Author/Davide Gibellini]]","[[Author/Giuseppina Musumeci]]","[[Author/Giuseppina Musumeci]]","[[Author/Massimo Rittà]]","[[Author/Massimo Rittà]]","[[Author/Manik Ghosh]]","[[Author/Manik Ghosh]]","[[Author/David Lembo]]","[[Author/David Lembo]]"],"attachment":[],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"1vyqnk7","at":1774951885195}},"smart_blocks:Research/@manuela_donalisio_traditional_2018.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[0.0397258,0.00121282,0.02097642,-0.01654773,0.04946056,-0.01724302,0.03925808,0.04191866,-0.02192138,0.03648573,-0.01085998,-0.07705565,0.02541038,0.00377525,-0.02608159,-0.03270514,-0.0278449,-0.0103537,-0.0597186,0.028965,0.0088908,-0.04369286,-0.05579695,0.00127536,0.01941373,0.00683565,-0.00961479,-0.03099052,-0.015309,-0.20114467,0.00054818,0.02124394,-0.04953506,0.04055894,-0.03925369,-0.00715588,-0.05505965,0.03438665,-0.04617652,0.0359543,0.05047252,0.05258549,0.00489037,0.01456454,0.00654048,-0.05034388,-0.08516095,0.0043789,0.03609039,-0.04075239,0.05604364,-0.05985567,0.0022969,0.0378665,-0.01273196,-0.03010453,0.05296402,0.04332164,-0.05998391,0.08378915,0.03769536,0.04415967,-0.23609048,0.08572848,-0.04061684,-0.03689741,-0.05278697,0.00055732,0.09204423,0.00224336,-0.06248549,0.04095493,-0.02753487,0.05510126,0.05819866,0.01512396,-0.00246862,-0.07160597,-0.01011554,-0.03242509,-0.02470765,0.11424563,0.02881122,-0.00287107,-0.00757927,0.0238446,-0.02936465,-0.03698146,0.06115252,-0.04889253,-0.02118316,0.01580853,0.00982926,-0.00920316,-0.0493353,0.00659449,0.01864071,-0.00661849,0.01945113,0.13534741,-0.06093114,-0.00897296,-0.03540766,-0.07951923,0.03575233,0.01954601,-0.02854765,-0.10764427,0.04755027,0.08308279,0.03921457,0.0130628,-0.0169331,-0.03776539,-0.0364