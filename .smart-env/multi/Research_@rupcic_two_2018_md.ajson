590385,0.06671386,-0.05712374,-0.0033634,-0.03017431,0.0344838,0.0028194,0.01920962,-0.00779037,0.02219553,0.08982634,-0.045999,0.06601265,0.02246944,-0.03651455,-0.01586721,-0.02622219,-0.02586985,-0.0179262,-0.01773921,-0.1200011,-0.02722034,0.096097,-0.0851051,-0.05584196,0.01062952,0.01016962,0.01561159,-0.02443866,0.02752186,0.02152272,0.06340259,-0.01529274,-0.03918378,0.0064645,-0.01727606,-0.03324668,0.02849661,-0.01835892,0.01217188,-0.02985597,0.09361002,0.06224227],"last_embed":{"hash":"16lxdx6","tokens":464}}},"last_read":{"hash":"16lxdx6","at":1774951887404},"class_name":"SmartSource","last_import":{"mtime":1774951816908,"size":3148,"at":1774951884780,"hash":"16lxdx6"},"blocks":{"#---frontmatter---":[1,72],"#Two New Cyathane Diterpenoids from Mycelial Cultures of the Medicinal Mushroom Hericium erinaceus and the Rare Species, Hericium flagellum":[74,78],"#Two New Cyathane Diterpenoids from Mycelial Cultures of the Medicinal Mushroom Hericium erinaceus and the Rare Species, Hericium flagellum#{1}":[76,78]},"outlinks":[{"title":"Author/Zeljka Rupcic","target":"Author/Zeljka Rupcic","line":57},{"title":"Author/Zeljka Rupcic","target":"Author/Zeljka Rupcic","line":58},{"title":"Author/Monique Rascher","target":"Author/Monique Rascher","line":59},{"title":"Author/Monique Rascher","target":"Author/Monique Rascher","line":60},{"title":"Author/Sae Kanaki","target":"Author/Sae Kanaki","line":61},{"title":"Author/Sae Kanaki","target":"Author/Sae Kanaki","line":62},{"title":"Author/Reinhard W. Köster","target":"Author/Reinhard W. Köster","line":63},{"title":"Author/Reinhard W. Köster","target":"Author/Reinhard W. Köster","line":64},{"title":"Author/Marc Stadler","target":"Author/Marc Stadler","line":65},{"title":"Author/Marc Stadler","target":"Author/Marc Stadler","line":66},{"title":"Author/Kathrin Wittstein","target":"Author/Kathrin Wittstein","line":67},{"title":"Author/Kathrin Wittstein","target":"Author/Kathrin Wittstein","line":68}],"metadata":{"id":"rupcic_two_2018","type":"article-journal","title":"Two New Cyathane Diterpenoids from Mycelial Cultures of the Medicinal Mushroom Hericium erinaceus and the Rare Species, Hericium flagellum","issued":{"date-parts":[[2018]]},"DOI":"10.3390/ijms19030740","container-title":"International Journal of Molecular Sciences","abstract":"Basidiomycetes of the genus Hericium are among the most praised medicinal and edible mushrooms, which are known to produce secondary metabolites with the potential to treat neurodegenerative diseases. This activity has been attributed to the discovery of various terpenoids that can stimulate the production of nerve growth factor (NGF) or (as established more recently) brain-derived neurotrophic factor (BDNF) in cell-based bioassays. The present study reports on the metabolite profiles of a Lion’s Mane mushroom (Hericium erinaceus) strain and a strain of the rare species, Hericium flagellum (synonym H. alpestre). While we observed highly similar metabolite profiles between the two strains that were examined, we isolated two previously undescribed metabolites, given the trivial names erinacines Z1 and Z2. Their chemical structures were elucidated by means of nuclear magnetic resonance (NMR) spectroscopy and high resolution mass spectrometry. Along with six further, previously identified cyathane diterpenes, the novel erinacines were tested for neurotrophin inducing effects. We found that erinacines act on BDNF, which is a neurotrophic factor that has been reported recently by us to be induced by the corallocins, but as well on NGF expression, which is consistent with the literature.","tags":["#literature_note"],"author":[{"family":"Rupcic","given":"Zeljka","literal":""},{"family":"Rupcic","given":"Zeljka","literal":""},{"family":"Rascher","given":"Monique","literal":""},{"family":"Rascher","given":"Monique","literal":""},{"family":"Kanaki","given":"Sae","literal":""},{"family":"Kanaki","given":"Sae","literal":""},{"family":"Köster","given":"Reinhard W.","literal":""},{"family":"Köster","given":"Reinhard W.","literal":""},{"family":"Stadler","given":"Marc","literal":""},{"family":"Stadler","given":"Marc","literal":""},{"family":"Wittstein","given":"Kathrin","literal":""},{"family":"Wittstein","given":"Kathrin","literal":""}],"citation-key":"rupcic_two_2018","year":"2018","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Two New Cyathane Diterpenoids from Mycelial Cultures of the Medicinal Mushroom Hericium erinaceus and the Rare Species, Hericium flagellum"],"author-links":["[[Author/Zeljka Rupcic]]","[[Author/Zeljka Rupcic]]","[[Author/Monique Rascher]]","[[Author/Monique Rascher]]","[[Author/Sae Kanaki]]","[[Author/Sae Kanaki]]","[[Author/Reinhard W. Köster]]","[[Author/Reinhard W. Köster]]","[[Author/Marc Stadler]]","[[Author/Marc Stadler]]","[[Author/Kathrin Wittstein]]","[[Author/Kathrin Wittstein]]"],"attachment":[],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"16lxdx6","at":1774951887396}},"smart_blocks:Research/@rupcic_two_2018.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.02014622,-0.05613954,-0.01575854,-0.07716021,0.0298981,0.01060715,-0.01834756,0.03033325,-0.06607768,-0.00681892,0.03700139,-0.06991246,0.0436403,-0.01574014,0.02628811,0.01381962,-0.03156681,-0.01351334,-0.08666949,0.04166535,0.02701048,-0.00960809,0.03212506,-0.02709817,0.02312238,0.04641359,-0.02520121,0.01297775,-0.08043055,-0.21716841,0.01073474,0.03539097,-0.00036595,-0.03988292,0.01518888,-0.01197611,-0.02624139,0.00228205,-0.03098007,-0.00290805,0.07016018,0.0201935,0.03979295,0.01943614,-0.02145438,-0.04317417,-0.07492741,-0.03648903,0.04673926,-0.06992101,-0.02283928,-0.06702988,0.01778769,0.03478713,0.02587077,-0.0294721,-0.01718435,0.03859526,0.02171495,0.07500677,0.05007793,0.04935177,-0.16386196,0.04108357,0.03449671,0.00174958,-0.13313366,-0.06201937,0.05529376,0.01300471,0.00754484,0.00223533,0.04639111,0.0695366,0.02679467,-0.