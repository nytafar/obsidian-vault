0.02402497,-0.01337922,0.18166846,-0.00250705,-0.04290533,0.01915842,0.01062521,0.03327081,-0.01419563,0.00639822,0.00187829,0.01944589,0.10030962,-0.01045908,0.08168242,0.04039073,-0.07807881,-0.02956923,-0.00732056,-0.041804,0.01170007,-0.01715937,-0.06162301,-0.01944077,0.08656524,-0.03842578,-0.03647414,-0.01549745,-0.02945501,0.01819113,-0.02881463,-0.00284674,0.01287203,-0.01215925,-0.00184009,-0.01705164,0.02180247,-0.04205795,-0.02122698,-0.01350072,-0.02168129,0.00641732,-0.07840353,0.1080438,0.03910727],"last_embed":{"hash":"1tx2etz","tokens":425}}},"last_read":{"hash":"1tx2etz","at":1774951893542},"class_name":"SmartSource","last_import":{"mtime":1774951826300,"size":3164,"at":1774951884821,"hash":"1tx2etz"},"blocks":{"#---frontmatter---":[1,69],"#Hericium erinaceus in Neurodegenerative Diseases: From Bench to Bedside and Beyond, How Far from the Shoreline?":[71,75],"#Hericium erinaceus in Neurodegenerative Diseases: From Bench to Bedside and Beyond, How Far from the Shoreline?#{1}":[73,75]},"outlinks":[{"title":"Author/Federico Brandalise","target":"Author/Federico Brandalise","line":54},{"title":"Author/Elisa Roda","target":"Author/Elisa Roda","line":55},{"title":"Author/Daniela Ratto","target":"Author/Daniela Ratto","line":56},{"title":"Author/Lorenzo Goppa","target":"Author/Lorenzo Goppa","line":57},{"title":"Author/Maria Letizia Gargano","target":"Author/Maria Letizia Gargano","line":58},{"title":"Author/Fortunato Cirlincione","target":"Author/Fortunato Cirlincione","line":59},{"title":"Author/Erica Cecilia Priori","target":"Author/Erica Cecilia Priori","line":60},{"title":"Author/Maria Teresa Venuti","target":"Author/Maria Teresa Venuti","line":61},{"title":"Author/Emanuela Pastorelli","target":"Author/Emanuela Pastorelli","line":62},{"title":"Author/Elena Savino","target":"Author/Elena Savino","line":63},{"title":"Author/Paola Rossi","target":"Author/Paola Rossi","line":64},{"title":"PDF","target":"biblib/brandalise_hericium_2023/brandalise_hericium_2023.pdf","line":66}],"metadata":{"id":"brandalise_hericium_2023","type":"article-journal","title":"Hericium erinaceus in Neurodegenerative Diseases: From Bench to Bedside and Beyond, How Far from the Shoreline?","issued":{"date-parts":[[2023]]},"DOI":"10.3390/jof9050551","container-title":"Journal of fungi (Basel, Switzerland)","abstract":"A growing number of studies is focusing on the pharmacology and feasibility of bioactive compounds as a novel valuable approach to target a variety of human diseases related to neurological degeneration. Among the group of the so-called medicinal mushrooms (MMs), Hericium erinaceus has become one of the most promising candidates. In fact, some of the bioactive compounds extracted from H. erinaceus have been shown to recover, or at least ameliorate, a wide range of pathological brain conditions such as Alzheimer’s disease, depression, Parkinson’s disease, and spinal cord injury. In a large body of in vitro and in vivo preclinical studies on the central nervous system (CNS), the effects of erinacines have been correlated with a significant increase in the production of neurotrophic factors. Despite the promising outcome of preclinical investigations, only a limited number of clinical trials have been carried out so far in different neurological conditions. In this survey, we summarized the current state of knowledge on H. erinaceus dietary supplementation and its therapeutic potential in clinical settings. The bulk collected evidence underlies the urgent need to carry out further/wider clinical trials to prove the safety and efficacy of H. erinaceus supplementation, offering significant neuroprotective applications in brain pathologies.","tags":["#literature_note"],"author":[{"family":"Brandalise","given":"Federico","literal":""},{"family":"Roda","given":"Elisa","literal":""},{"family":"Ratto","given":"Daniela","literal":""},{"family":"Goppa","given":"Lorenzo","literal":""},{"family":"Gargano","given":"Maria Letizia","literal":""},{"family":"Cirlincione","given":"Fortunato","literal":""},{"family":"Priori","given":"Erica Cecilia","literal":""},{"family":"Venuti","given":"Maria Teresa","literal":""},{"family":"Pastorelli","given":"Emanuela","literal":""},{"family":"Savino","given":"Elena","literal":""},{"family":"Rossi","given":"Paola","literal":""}],"citation-key":"brandalise_hericium_2023","year":"2023","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Hericium erinaceus in Neurodegenerative Diseases: From Bench to Bedside and Beyond, How Far from the Shoreline?"],"author-links":["[[Author/Federico Brandalise]]","[[Author/Elisa Roda]]","[[Author/Daniela Ratto]]","[[Author/Lorenzo Goppa]]","[[Author/Maria Letizia Gargano]]","[[Author/Fortunato Cirlincione]]","[[Author/Erica Cecilia Priori]]","[[Author/Maria Teresa Venuti]]","[[Author/Emanuela Pastorelli]]","[[Author/Elena Savino]]","[[Author/Paola Rossi]]"],"attachment":["[[biblib/brandalise_hericium_2023/brandalise_hericium_2023.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"1tx2etz","at":1774951893532}},"smart_blocks:Research/@brandalise_hericium_2023.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[0.00767995,-0.02026529,0.0059527,-0.03538041,-0.02753839,0.04510362,-0.03380153,0.04594666,-0.00870385,-0.01658274,0.00798089,-0.06635777,0.00482632,-0.01248574,0.01085471,-0.00267478,-0.001972,0.00974717,-0.06374075,0.02311439,0.00734201,-0.02385598,0.02546909,0.024848,0.00041532,0.00726395,-0.02560118,-0.00161582,-0.0514327,-0.21260142,-0.01389606,-0.02707328,0.01577831,-0.04161178,-0.02037717,-0.00139638,0.00495974,0.037506,0.01102459,0.0200139,0.07152786,0.05318497,0.03185008,0.0059754,-0.03405447,-0.05155486,-0.02849718,-0.03894603,0.03566252,-0.00747273,-0.07299332,-0.03907127,0.04040429,0.04982347,0.04672621,-0.00071599,-0.02564257,0.01160664,0.00735451,0.10437664,0.06845452,0.03602175,-0.19003864,0.05080736,0.0012266,-0.02472211,-0.0935