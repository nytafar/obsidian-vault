01018847,0.17275554,-0.02533507,-0.03381082,0.00607377,0.06617083,0.00976542,-0.00362634,0.01170459,-0.02068918,0.03573322,0.07453777,0.03631776,0.02473468,0.06200619,-0.06510184,-0.02575632,0.00292512,-0.05097452,0.05557556,0.03746035,0.00226619,-0.02216657,0.07606655,-0.04541809,-0.0161763,0.00296276,0.03233756,0.00425216,0.00003309,-0.00430593,0.05443026,0.03113882,0.02561663,-0.06833378,-0.04562934,-0.01787473,0.00576976,-0.01391851,-0.02661711,-0.02493425,-0.11190277,0.08386637,0.04011113],"last_embed":{"hash":"nv4wuq","tokens":438}}},"last_read":{"hash":"nv4wuq","at":1774951888519},"class_name":"SmartSource","last_import":{"mtime":1774951818933,"size":4463,"at":1774951884790,"hash":"nv4wuq"},"blocks":{"#---frontmatter---":[1,117],"#Hericium erinaceus Improves Mood and Sleep Disorders in Patients Affected by Overweight or Obesity: Could Circulating Pro-BDNF and BDNF Be Potential Biomarkers?":[119,123],"#Hericium erinaceus Improves Mood and Sleep Disorders in Patients Affected by Overweight or Obesity: Could Circulating Pro-BDNF and BDNF Be Potential Biomarkers?#{1}":[121,123]},"outlinks":[{"title":"Author/Luisella Vigna","target":"Author/Luisella Vigna","line":90},{"title":"Author/Luisella Vigna","target":"Author/Luisella Vigna","line":91},{"title":"Author/Federica Morelli","target":"Author/Federica Morelli","line":92},{"title":"Author/Federica Morelli","target":"Author/Federica Morelli","line":93},{"title":"Author/G. Agnelli","target":"Author/G. Agnelli","line":94},{"title":"Author/Gianna M. Agnelli","target":"Author/Gianna M. Agnelli","line":95},{"title":"Author/Filomena Napolitano","target":"Author/Filomena Napolitano","line":96},{"title":"Author/Filomena Napolitano","target":"Author/Filomena Napolitano","line":97},{"title":"Author/Daniela Ratto","target":"Author/Daniela Ratto","line":98},{"title":"Author/Daniela Ratto","target":"Author/Daniela Ratto","line":99},{"title":"Author/Alessandra Occhinegro","target":"Author/Alessandra Occhinegro","line":100},{"title":"Author/A. Occhinegro","target":"Author/A. Occhinegro","line":101},{"title":"Author/Carmine Di Iorio","target":"Author/Carmine Di Iorio","line":102},{"title":"Author/Carmine Di Iorio","target":"Author/Carmine Di Iorio","line":103},{"title":"Author/Elena Savino","target":"Author/Elena Savino","line":104},{"title":"Author/Elena Savino","target":"Author/Elena Savino","line":105},{"title":"Author/Carolina Elena Girometta","target":"Author/Carolina Elena Girometta","line":106},{"title":"Author/Carolina Girometta","target":"Author/Carolina Girometta","line":107},{"title":"Author/Federico Brandalise","target":"Author/Federico Brandalise","line":108},{"title":"Author/Federico Brandalise","target":"Author/Federico Brandalise","line":109},{"title":"Author/Federico Brandalise","target":"Author/Federico Brandalise","line":110},{"title":"Author/Paola Rossi","target":"Author/Paola Rossi","line":111},{"title":"Author/Paola Rossi","target":"Author/Paola Rossi","line":112},{"title":"PDF","target":"biblib/vigna_hericium_2019/vigna_hericium_2019.pdf","line":114}],"metadata":{"id":"vigna_hericium_2019","type":"article-journal","title":"Hericium erinaceus Improves Mood and Sleep Disorders in Patients Affected by Overweight or Obesity: Could Circulating Pro-BDNF and BDNF Be Potential Biomarkers?","issued":{"date-parts":[[2019]]},"DOI":"10.1155/2019/7861297","container-title":"Evidence-based Complementary and Alternative Medicine","abstract":"Epidemiological data indicate that subjects affected by obesity have an increased risk of developing mood disorders. The relationship between obesity and mood disorders is bidirectional. We assessed whether a Hericium erinaceus treatment improved depression, anxiety, sleep, and binge eating disorders after 8 weeks of supplementation in subjects affected by overweight or obesity under a low calorie diet regimen. Looking for a possible clinical biomarker, we assessed the serum balance between brain-derived neurotrophic factor (BDNF) and its precursor pro-BDNF before and after H. erinaceus supplementation. Seventy-seven volunteers affected by overweight or obesity were recruited at the offices of the Department of Preventive Medicine, Luigi Devoto Clinic of Work, Obesity Centre, at the IRCCS Foundation Policlinico Hospital of Milan (Italy). Patients were recruited only if they had a mood and/or sleep disorder and/or were binge eating as evaluated through self-assessment questionnaires. We used two different enzyme-linked immunosorbent assays kits to discriminate circulating levels of pro-BDNF and BDNF. Eight weeks of oral H. erinaceus supplementation decreased depression, anxiety, and sleep disorders. H. erinaceus supplementation improved mood disorders of a depressive-anxious nature and the quality of the nocturnal rest. H. erinaceus increased circulating pro-BDNF levels without any significant change in BDNF circulating levels.","tags":["#literature_note"],"author":[{"family":"Vigna","given":"Luisella","literal":""},{"family":"Vigna","given":"Luisella","literal":""},{"family":"Morelli","given":"Federica","literal":""},{"family":"Morelli","given":"Federica","literal":""},{"family":"Agnelli","given":"G.","literal":""},{"family":"Agnelli","given":"Gianna M.","literal":""},{"family":"Napolitano","given":"Filomena","literal":""},{"family":"Napolitano","given":"Filomena","literal":""},{"family":"Ratto","given":"Daniela","literal":""},{"family":"Ratto","given":"Daniela","literal":""},{"family":"Occhinegro","given":"Alessandra","literal":""},{"family":"Occhinegro","given":"A.","literal":""},{"family":"Iorio","given":"Carmine Di","literal":""},{"family":"Iorio","given":"Carmine Di","literal":""},{"family":"Savino","given":"Elena","literal":""},{"family":"Savino","given":"Elena","literal":""},{"family":"Girometta","given":"Carolina Elena","literal":""},{"family":"Girometta","given":"Carolina","literal":""},{"family":"Brandalise","given":"Federico","literal":""},{"family":"Brandalise","given":"Federico","literal":""},{"family":"Brandalise","given":"Federico","literal":""},{"family":"Rossi","given":"Paola","literal":""},{"family":"Rossi","given":"Paola","literal":""}],"citation-key":"vigna_hericium_2019","year":"2019","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Hericium erinaceus Improves Mood and Sleep Disorders in Patients Affected by Overweight or Obesity: Could Circulating Pro-BDNF and BDNF Be Potential Biomarkers?"],"author-links":["[[Author/Luisella Vigna]]","[[Author/Luisella Vigna]]","[[Author/Federica Morelli]]","[[Author/Federica Morelli]]","[[Author/G. Agnelli]]","[[Author/Gianna M. Agnelli]]","[[Author/Filomena Napolitano]]","[[Author/Filomena Napolitano]]","[[Author/Daniela Ratto]]","[[Author/Daniela Ratto]]","[[Author/Alessandra Occhinegro]]","[[Author/A. Occhinegro]]","[[Author/Carmine Di Iorio]]","[[Author/Carmine Di Iorio]]","[[Author/Elena Savino]]","[[Author/Elena Savino]]","[[Author/Carolina Elena Girometta]]","[[Author/Carolina Girometta]]","[[Author/Federico Brandalise]]","[[Author/Federico Brandalise]]","[[Author/Federico Brandalise]]","[[Author/Paola Rossi]]","[[Author/Paola Rossi]]"],"attachment":["[[biblib/vigna_hericium_2019/vigna_hericium_2019.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"nv4wuq","at":1774951888509}},"smart_blocks:Research/@vigna_hericium_2019.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.00751849,0.02056406,0.03534111,0.00338464,-0.02588588,0.05622363,-0.03870947,0.03445469,-0.0084384,-0.03902437,0.03371411,-0.10777276,0.02821337,0.01374751,0.03527841,-0.01669729,0.02350025,-0.01016106,-0.07509322,0.0211602,0.01065789,-0.03890639,0.07807311,0.00571299,0.01312479,0.01448136,-0.0360182,0.00882664,-0.06144994,-0.17958495,0.01370495,-0.06678793,0.06424527,-0.01153434,-0.02908002,-0.01828201,-0.05069462,0.04411972,0.01724976,-0.01120801,0.06480309,0.05148968,0.00258354,-0.02634092,-0.02307029,-0.05966946,-0.01549843,-0.03695641,