
"smart_sources:Research/@wang_effects_2011.md": {"path":"Research/@wang_effects_2011.md","last_embed":{"hash":null},"embeddings":{},"last_read":{"hash":"m0fpjn","at":1774951884832},"class_name":"SmartSource","last_import":{"mtime":1774951829370,"size":3901,"at":1774951884832,"hash":"m0fpjn"},"blocks":{"#---frontmatter---":[1,148],"#Effects of curcumin on hippocampal Bax and Bcl-2 expression and cognitive function of a rat model of Alzheimer's disease":[150,154],"#Effects of curcumin on hippocampal Bax and Bcl-2 expression and cognitive function of a rat model of Alzheimer's disease#{1}":[152,154]},"outlinks":[{"title":"Author/Yunliang Wang","target":"Author/Yunliang Wang","line":114},{"title":"Author/Yunliang Wang","target":"Author/Yunliang Wang","line":115},{"title":"Author/Yunliang","target":"Author/Yunliang","line":116},{"title":"Author/Huaizhi Yin","target":"Author/Huaizhi Yin","line":117},{"title":"Author/Wang","target":"Author/Wang","line":118},{"title":"Author/Honglei Yin","target":"Author/Honglei Yin","line":119},{"title":"Author/Jian-Shu Lou","target":"Author/Jian-Shu Lou","line":120},{"title":"Author/Honglei","target":"Author/Honglei","line":121},{"title":"Author/Jiyu Lou","target":"Author/Jiyu Lou","line":122},{"title":"Author/Bing Han","target":"Author/Bing Han","line":123},{"title":"Author/Yin","target":"Author/Yin","line":124},{"title":"Author/Bing Han","target":"Author/Bing Han","line":125},{"title":"Author/Xinyue Qin","target":"Author/Xinyue Qin","line":126},{"title":"Author/Jiyu","target":"Author/Jiyu","line":127},{"title":"Author/Xinyue Qin","target":"Author/Xinyue Qin","line":128},{"title":"Author/Fanchao Meng","target":"Author/Fanchao Meng","line":129},{"title":"Author/Lou","target":"Author/Lou","line":130},{"title":"Author/Fanchao Meng","target":"Author/Fanchao Meng","line":131},{"title":"Author/Shuang Geng","target":"Author/Shuang Geng","line":132},{"title":"Author/Shuang Geng","target":"Author/Shuang Geng","line":133},{"title":"Author/Yajun Liu","target":"Author/Yajun Liu","line":134},{"title":"Author/Han","target":"Author/Han","line":135},{"title":"Author/Yajun Liu","target":"Author/Yajun Liu","line":136},{"title":"Author/Xinyue","target":"Author/Xinyue","line":137},{"title":"Author/Qin","target":"Author/Qin","line":138},{"title":"Author/Fanchao","target":"Author/Fanchao","line":139},{"title":"Author/Meng","target":"Author/Meng","line":140},{"title":"Author/Shuang","target":"Author/Shuang","line":141},{"title":"Author/Geng","target":"Author/Geng","line":142},{"title":"Author/Yajun","target":"Author/Yajun","line":143},{"title":"Author/Liu","target":"Author/Liu","line":144}],"metadata":{"id":"wang_effects_2011","type":"article-journal","title":"Effects of curcumin on hippocampal Bax and Bcl-2 expression and cognitive function of a rat model of Alzheimer's disease","issued":{"date-parts":[[2011]]},"DOI":"null","container-title":"Neural Regeneration Research","abstract":"We tested the effects of curcumin treatment on a rat model of Alzheimer's disease induced by beta-amlyoid (Aβ 1-40 ) expression. We investigated alterations in the expression of the apoptosis-related genes Bax and Bcl-2 in the hippocampus, as well as changes in the spatial memory and cognitive function of the rats. Reverse transcription-polymerase chain reaction and immunohistochemistry results showed that Bax expression was remarkably decreased and Bcl-2 expression was increased in the rat Alzheimer's disease model after curcumin treatment. Morris water maze results showed that the average time of escape latency was shortened in the curcumin treated model rats. Our study shows that curcumin can significantly improve spatial learning and memory functions in rats with Aβ 1-40 -induced Alzheimer's disease by modulating Bax and Bcl-2 expression.","tags":["#literature_note"],"author":[{"family":"Wang","given":"Yunliang","literal":""},{"family":"Wang","given":"Yunliang","literal":""},{"family":"Yunliang","given":"","literal":""},{"family":"Yin","given":"Huaizhi","literal":""},{"family":"Wang","given":"","literal":""},{"family":"Yin","given":"Honglei","literal":""},{"family":"Lou","given":"Jian-Shu","literal":""},{"family":"Honglei","given":"","literal":""},{"family":"Lou","given":"Jiyu","literal":""},{"family":"Han","given":"Bing","literal":""},{"family":"Yin","given":"","literal":""},{"family":"Han","given":"Bing","literal":""},{"family":"Qin","given":"Xinyue","literal":""},{"family":"Jiyu","given":"","literal":""},{"family":"Qin","given":"Xinyue","literal":""},{"family":"Meng","given":"Fanchao","literal":""},{"family":"Lou","given":"","literal":""},{"family":"Meng","given":"Fanchao","literal":""},{"family":"Geng","given":"Shuang","literal":""},{"family":"Geng","given":"Shuang","literal":""},{"family":"Liu","given":"Yajun","literal":""},{"family":"Han","given":"","literal":""},{"family":"Liu","given":"Yajun","literal":""},{"family":"Xinyue","given":"","literal":""},{"family":"Qin","given":"","literal":""},{"family":"Fanchao","given":"","literal":""},{"family":"Meng","given":"","literal":""},{"family":"Shuang","given":"","literal":""},{"family":"Geng","given":"","literal":""},{"family":"Yajun","given":"","literal":""},{"family":"Liu","given":"","literal":""}],"citation-key":"wang_effects_2011","year":"2011","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Effects of curcumin on hippocampal Bax and Bcl-2 expression and cognitive function of a rat model of Alzheimer's disease"],"author-links":["[[Author/Yunliang Wang]]","[[Author/Yunliang Wang]]","[[Author/Yunliang]]","[[Author/Huaizhi Yin]]","[[Author/Wang]]","[[Author/Honglei Yin]]","[[Author/Jian-Shu Lou]]","[[Author/Honglei]]","[[Author/Jiyu Lou]]","[[Author/Bing Han]]","[[Author/Yin]]","[[Author/Bing Han]]","[[Author/Xinyue Qin]]","[[Author/Jiyu]]","[[Author/Xinyue Qin]]","[[Author/Fanchao Meng]]","[[Author/Lou]]","[[Author/Fanchao Meng]]","[[Author/Shuang Geng]]","[[Author/Shuang Geng]]","[[Author/Yajun Liu]]","[[Author/Han]]","[[Auth