,-0.05818842,0.04906107,-0.00642949,0.1814281,0.0356165,-0.02794802,0.00001466,-0.02972103,0.03119038,-0.01981451,0.06328016,0.03436221,0.00862451,0.11940268,0.00609379,0.07770147,0.03925504,-0.00237771,-0.04282765,-0.02830061,0.00429464,0.00721626,-0.02910849,-0.10506051,-0.03258956,0.0954031,-0.07786067,0.00730222,-0.08716124,-0.00010461,-0.0416893,-0.02017025,0.02229261,0.01809252,0.01437355,-0.04872502,-0.02602986,-0.00423307,0.02872775,-0.06743744,-0.01505909,0.02716717,0.03016379,-0.08645616,0.09344849,0.02230513],"last_embed":{"hash":"1f2ik4q","tokens":437}}},"last_read":{"hash":"1f2ik4q","at":1774951885927},"class_name":"SmartSource","last_import":{"mtime":1774951814467,"size":2526,"at":1774951884766,"hash":"1f2ik4q"},"blocks":{"#---frontmatter---":[1,53],"#A Critical Review on Health Promoting Benefits of Edible Mushrooms through Gut Microbiota":[55,59],"#A Critical Review on Health Promoting Benefits of Edible Mushrooms through Gut Microbiota#{1}":[57,59]},"outlinks":[{"title":"Author/Muthukumaran Jayachandran","target":"Author/Muthukumaran Jayachandran","line":42},{"title":"Author/Muthukumaran Jayachandran","target":"Author/Muthukumaran Jayachandran","line":43},{"title":"Author/Satyajit D. Sarker","target":"Author/Satyajit D. Sarker","line":44},{"title":"Author/Jianbo Xiao","target":"Author/Jianbo Xiao","line":45},{"title":"Author/Jianbo Xiao","target":"Author/Jianbo Xiao","line":46},{"title":"Author/Baojun Xu","target":"Author/Baojun Xu","line":47},{"title":"Author/Baojun Xu","target":"Author/Baojun Xu","line":48},{"title":"PDF","target":"biblib/jayachandran_critical_2017/jayachandran_critical_2017.pdf","line":50}],"metadata":{"id":"jayachandran_critical_2017","type":"article-journal","title":"A Critical Review on Health Promoting Benefits of Edible Mushrooms through Gut Microbiota","issued":{"date-parts":[[2017]]},"DOI":"10.3390/ijms18091934","container-title":"International Journal of Molecular Sciences","abstract":"Mushrooms have long been used for medicinal and food purposes for over a thousand years, but a complete elucidation of the health-promoting properties of mushrooms through regulating gut microbiota has not yet been fully exploited. Mushrooms comprise a vast, and yet largely untapped, source of powerful new pharmaceutical substances. Mushrooms have been used in health care for treating simple and common diseases, like skin diseases and pandemic diseases like AIDS. This review is aimed at accumulating the health-promoting benefits of edible mushrooms through gut microbiota. Mushrooms are proven to possess anti-allergic, anti-cholesterol, anti-tumor, and anti-cancer properties. Mushrooms are rich in carbohydrates, like chitin, hemicellulose, β and α-glucans, mannans, xylans, and galactans, which make them the right choice for prebiotics. Mushrooms act as a prebiotics to stimulate the growth of gut microbiota, conferring health benefits to the host. In the present review, we have summarized the beneficial activities of various mushrooms on gut microbiota via the inhibition of exogenous pathogens and, thus, improving the host health.","tags":["#literature_note"],"author":[{"family":"Jayachandran","given":"Muthukumaran","literal":""},{"family":"Jayachandran","given":"Muthukumaran","literal":""},{"family":"Sarker","given":"Satyajit D.","literal":""},{"family":"Xiao","given":"Jianbo","literal":""},{"family":"Xiao","given":"Jianbo","literal":""},{"family":"Xu","given":"Baojun","literal":""},{"family":"Xu","given":"Baojun","literal":""}],"citation-key":"jayachandran_critical_2017","year":"2017","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["A Critical Review on Health Promoting Benefits of Edible Mushrooms through Gut Microbiota"],"author-links":["[[Author/Muthukumaran Jayachandran]]","[[Author/Muthukumaran Jayachandran]]","[[Author/Satyajit D. Sarker]]","[[Author/Jianbo Xiao]]","[[Author/Jianbo Xiao]]","[[Author/Baojun Xu]]","[[Author/Baojun Xu]]"],"attachment":["[[biblib/jayachandran_critical_2017/jayachandran_critical_2017.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"1f2ik4q","at":1774951885918}},"smart_blocks:Research/@jayachandran_critical_2017.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.01079781,-0.0224176,0.04123792,0.00148606,0.03161037,-0.00172096,-0.01220789,0.02871774,-0.07627827,0.02643873,-0.00313926,-0.08372811,0.01304619,0.00481629,0.01953753,0.02217919,0.0294551,0.00595715,-0.11870839,0.01025807,0.07031137,0.00222155,0.04478343,-0.02520337,0.0672273,0.02494832,-0.00081658,-0.03228948,-0.06103437,-0.19643384,-0.00439031,-0.00241799,0.06446283,-0.00463427,-0.06186052,-0.03891402,-0.02074749,0.00543236,-0.02502435,0.02060549,0.07144111,0.04354857,0.00003688,0.03949149,-0.00829479,-0.05802697,-0.03509744,-0.05016076,0.01521917,-0.07781748,-0.00411333,-0.02677555,-0.02319607,0.04022128,0.02705907,-0.01741686,-0.0242525,-0.00522103,0.00444104,0.05520225,0.09449311,0.03259362,-0.16015835,0.08902223,0.01759419,-0.01825395,-0.06238628,0.03209088,0.05119935,-0.00438145,-0.01958271,0.00883776,0.08201256,0.09500437,0.04611518,-0.03116681,0.0317459,-0.05654628,-0.05042873,0.01042476,0.02494054,0.086341,0.04728198,0.01106958,-0.05609048,-0.06178408,-0.02338863,-0.1079956,0.01722161,0.01957277,0.01483567,-0.05378142,-0.01198253,-0.0074676,-0.0800398,-0.01165354,-0.03478978,-0.03942804,-0.0408188,0.13462727,-0.08329669,-0.00485345,0.01952162,-0.02412208,-0.00238046,-0.01109436,0.00960938,-0.02550886,0.06710721,0.04485355,0.04498549,0.01102064,-0.01351516,0.01858963,-0.00942051,0.06155749,0.12445839,0.02272796,0.00043568,-0.02155405,-0.05381906,0.03037872,0.08246104,0.01978558,0.01185221,0.00535474,-0.01271364,0.06946843,0.02171294,-0.02439112,0.06483124,0.02717482,-0.01879715,-0.0374558,-0.05432268,-0.0188412,-0.00814626,0.02316221,0.02467535,0.00677722,-0.01416497,-0.0338072,-0.01528965,-0.1413722,-0.08048812,0.04145651,0.09476659,0.04105212,-0.05384628,-0.02