4903444,-0.0054263,0.19879176,0.0479331,-0.06354446,-0.0038986,-0.0061073,0.02753901,0.00138934,0.0196563,0.0045717,0.04450511,0.07681482,0.03271204,0.06165956,0.06206521,-0.03250467,-0.01141048,-0.05199782,0.02826539,-0.00713206,-0.01568569,-0.05857297,-0.04870331,0.10444421,-0.07365385,-0.04251685,-0.06361399,-0.03667597,0.00235814,-0.00688687,0.03680363,-0.02844574,-0.01353518,-0.02532759,-0.01276223,-0.00782259,-0.01135205,-0.06481836,0.02374975,0.02328231,0.04855783,-0.05096269,0.09587869,0.0342139],"last_embed":{"hash":"1rxkfa0","tokens":476}}},"last_read":{"hash":"1rxkfa0","at":1774951892705},"class_name":"SmartSource","last_import":{"mtime":1774951824720,"size":2648,"at":1774951884815,"hash":"1rxkfa0"},"blocks":{"#---frontmatter---":[1,65],"#Composition and mechanism of antitumor effects of Hericium erinaceus mushroom extracts in tumor-bearing mice.":[67,71],"#Composition and mechanism of antitumor effects of Hericium erinaceus mushroom extracts in tumor-bearing mice.#{1}":[69,71]},"outlinks":[{"title":"Author/Sung Phil Kim","target":"Author/Sung Phil Kim","line":51},{"title":"Author/Sung Phil Kim","target":"Author/Sung Phil Kim","line":52},{"title":"Author/Mi Young Kang","target":"Author/Mi Young Kang","line":53},{"title":"Author/Mi Young Kang","target":"Author/Mi Young Kang","line":54},{"title":"Author/Jae Ho Kim","target":"Author/Jae Ho Kim","line":55},{"title":"Author/Jae Ho Kim","target":"Author/Jae Ho Kim","line":56},{"title":"Author/Sung Min Nam","target":"Author/Sung Min Nam","line":57},{"title":"Author/Seok Hyun Nam","target":"Author/Seok Hyun Nam","line":58},{"title":"Author/Mendel Friedman","target":"Author/Mendel Friedman","line":59},{"title":"Author/Mendel Friedman","target":"Author/Mendel Friedman","line":60},{"title":"PDF","target":"biblib/kim_composition_2011/kim_composition_2011.pdf","line":62}],"metadata":{"id":"kim_composition_2011","type":"article-journal","title":"Composition and mechanism of antitumor effects of Hericium erinaceus mushroom extracts in tumor-bearing mice.","issued":{"date-parts":[[2011]]},"DOI":"10.1021/jf201944n","container-title":"Journal of Agricultural and Food Chemistry","abstract":"We investigated antitumor effects of the following four extracts of freeze-dried Hericium erinaceus mushrooms in Balb/c mice intracutaneously transplanted on the backs with CT-26 colon cancer cells: HWE, hot water extraction by boiling in water for 3 h; MWE, microwaving in 50% ethanol/water at 60 W for 3 min; and ACE and AKE, boiling in 1% HCl or 3% NaOH for 2 h. HWE and MWE with a higher content of β-glucans, determined by an assay kit, than ACE and MKE were active in all bioassays. Gas chromatography/mass spectrometry analyses showed the presence of 40, 27, 16, and 13 compounds, respectively, in the four extracts. Daily intraperitoneal (ip) injections of HWE and MWE for 2 weeks significantly reduced tumor weights by 38 and 41%. Tumor regressions were associated with changes in the following cancer biomarkers as compared to phosphate buffer (PBS)-treated control mice: 2.7- and 2.4-fold increases in cytolytic activity of splenic natural killer (NK) cells; restored nitric oxide production and phagocytosis ...","tags":["#literature_note"],"author":[{"family":"Kim","given":"Sung Phil","literal":""},{"family":"Kim","given":"Sung Phil","literal":""},{"family":"Kang","given":"Mi Young","literal":""},{"family":"Kang","given":"Mi Young","literal":""},{"family":"Kim","given":"Jae Ho","literal":""},{"family":"Kim","given":"Jae Ho","literal":""},{"family":"Nam","given":"Sung Min","literal":""},{"family":"Nam","given":"Seok Hyun","literal":""},{"family":"Friedman","given":"Mendel","literal":""},{"family":"Friedman","given":"Mendel","literal":""}],"citation-key":"kim_composition_2011","year":"2011","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Composition and mechanism of antitumor effects of Hericium erinaceus mushroom extracts in tumor-bearing mice."],"author-links":["[[Author/Sung Phil Kim]]","[[Author/Sung Phil Kim]]","[[Author/Mi Young Kang]]","[[Author/Mi Young Kang]]","[[Author/Jae Ho Kim]]","[[Author/Jae Ho Kim]]","[[Author/Sung Min Nam]]","[[Author/Seok Hyun Nam]]","[[Author/Mendel Friedman]]","[[Author/Mendel Friedman]]"],"attachment":["[[biblib/kim_composition_2011/kim_composition_2011.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"1rxkfa0","at":1774951892696}},"smart_blocks:Research/@kim_composition_2011.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.02479998,-0.02756512,0.0336293,-0.02856008,0.04480582,0.00714118,0.04704065,0.02298888,-0.08152968,-0.04557418,0.02134577,-0.05172142,0.05799652,-0.00447985,0.0401496,0.0237007,0.03532724,0.01745777,-0.10318264,-0.00231464,-0.02042282,-0.06877223,0.00180507,0.0147536,0.07513515,0.01714132,-0.00666114,0.00698777,-0.05815485,-0.2418773,0.00554748,-0.01879367,0.03392275,-0.00979175,-0.02508165,0.01499573,0.00600811,0.02445952,-0.03784377,-0.02413689,0.05054729,0.01808778,0.03443229,0.04403728,0.02025181,-0.07224356,-0.01623612,-0.06437002,0.0420824,-0.02584243,-0.04075385,-0.10958515,0.00622295,0.06595221,0.05103271,0.02820779,-0.02097793,0.03927749,0.07272322,0.07392544,0.00448543,0.06990523,-0.18321751,0.09558885,0.03342445,0.00358751,-0.12323861,-0.04557917,0.07703215,0.01771768,-0.01630363,0.05656472,0.07505991,0.07377006,0.00584017,-0.04904876,0.0184051,-0.0282464,-0.05397655,0.03835523,0.04774118,0.03847419,0.0630247,0.02722971,-0.01671313,-0.00867216,-0.04964787,-0.07813337,0.00672159,0.03891641,-0.00561252,-0.0518287,0.02137217,0.01466822,-0.0642107,0.01054716,-0.00195957,-0.02825348,-0.00385473,0.13290562,-0.0761082,0.00330895,-0.04176906,-0.04709529,0.02668903,-0.0530589,-0.01368983,-0.04273273,0.05338549,0.01689131,0.06059976,-0.0042149,-0.05913231,-0.02328471,-0.01237663,0.00904502,0.13517113,0.03685655,-0.01123328,0.00104649,0.02739612,-0.01415262,0.00790498,0.03040296,0.05064648,-0.02772487,0.02