6,0.00675594,0.18010662,0.00256748,-0.03877469,0.04567899,0.00312389,0.03448834,-0.02635674,0.05721919,0.01302162,0.00444563,0.0995281,-0.02172044,0.06187019,0.0397542,0.01526207,-0.02006142,-0.00612674,0.01687559,0.01317208,0.00390861,-0.06626552,-0.05818272,0.09193729,-0.04519439,-0.03688983,-0.04545267,-0.02475175,0.01639144,-0.03078245,0.03405154,-0.02670866,-0.00892175,-0.0138622,-0.03860611,-0.02409298,-0.02170561,-0.05383717,-0.00457592,0.01051995,-0.03612094,-0.12803389,0.09829544,0.04244113],"last_embed":{"hash":"1th57kq","tokens":509}}},"last_read":{"hash":"1th57kq","at":1774951896597},"class_name":"SmartSource","last_import":{"mtime":1774951829987,"size":4124,"at":1774951884834,"hash":"1th57kq"},"blocks":{"#---frontmatter---":[1,101],"#Auxiliary antitumor effects of fungal proteins from Hericium erinaceus by target on the gut microbiota":[103,107],"#Auxiliary antitumor effects of fungal proteins from Hericium erinaceus by target on the gut microbiota#{1}":[105,107]},"outlinks":[{"title":"Author/Dongdong Wang","target":"Author/Dongdong Wang","line":78},{"title":"Author/Wang Dongdong","target":"Author/Wang Dongdong","line":79},{"title":"Author/Xiangxiang Zhu","target":"Author/Xiangxiang Zhu","line":80},{"title":"Author/Xiangxiang Zhu","target":"Author/Xiangxiang Zhu","line":81},{"title":"Author/Xiangxiang Zhu","target":"Author/Xiangxiang Zhu","line":82},{"title":"Author/Xiaocui Tang","target":"Author/Xiaocui Tang","line":83},{"title":"Author/Tang Xiaocui","target":"Author/Tang Xiaocui","line":84},{"title":"Author/Xiaocui Tang","target":"Author/Xiaocui Tang","line":85},{"title":"Author/Hong-Ye Li","target":"Author/Hong-Ye Li","line":86},{"title":"Author/Hongye Li","target":"Author/Hongye Li","line":87},{"title":"Author/Hongye Li","target":"Author/Hongye Li","line":88},{"title":"Author/Yizhen Xie","target":"Author/Yizhen Xie","line":89},{"title":"Author/Xie Yizhen","target":"Author/Xie Yizhen","line":90},{"title":"Author/Xie Yizhen","target":"Author/Xie Yizhen","line":91},{"title":"Author/Diling Chen","target":"Author/Diling Chen","line":92},{"title":"Author/Diling Chen","target":"Author/Diling Chen","line":93},{"title":"Author/Diling Chen","target":"Author/Diling Chen","line":94},{"title":"Author/Chen Diling","target":"Author/Chen Diling","line":95},{"title":"Author/Diling Chen","target":"Author/Diling Chen","line":96},{"title":"PDF","target":"biblib/wang_auxiliary_2020/wang_auxiliary_2020.pdf","line":98}],"metadata":{"id":"wang_auxiliary_2020","type":"article-journal","title":"Auxiliary antitumor effects of fungal proteins from Hericium erinaceus by target on the gut microbiota","issued":{"date-parts":[[2020]]},"DOI":"10.1111/1750-3841.15134","container-title":"Journal of Food Science","abstract":"Cancer represents a major disease burden worldwide. Despite continuous advances obtained in medical therapies recently, resistance to standard drugs and adverse effects still represent important causes of therapeutic failure. There is growing evidence that the gut microbiota can affect the response to chemo- and immunotherapeutic drugs by modulating efficacy and/or toxicity, and diet is the most important factor affecting the gut microbiota. In this study, we assessed the auxiliary antitumor effects of immunomodulatory fungal proteins from Hericium erinaceus (HEP) administered with the chemotherapy drug 5-Fluorouracil (5-Fu), and we attempted to identify new potential prebiotic bacteria for auxiliary antitumor treatment. There were 1,455 proteins identified from H. erinaceus. In a xenografted mouse model of cancer, HEP with 5-Fu significantly suppressed tumor growth, inhibited inflammatory markers such as interferon (IFN)-γ, interleukin (IL)-1β, IL-2, IL-6, tumor necrosis factor (TNF)-α, and lipopolysaccharide (LPS), and regulated the expression of Akt, CCDN1, CKD4, FOXM1, MMP7, MYC, PPAR-α, and PPAR-γ. 16S rRNA sequencing showed that HEP ameliorated the dysbacteriosis induced by 5-Fu, as it inhibited certain aerobic and microaerobic bacteria including Parabacteroides, Flavobacteriaceae, Christensenellaceae, Anoxybacillus, Aggregatibacter, Comamonadaceae, Planococcaceae, Desulfovibrionaceae, Sporosarcina, Staphylococcus, Aerococcaceae, and Bilophila in the xenografted mice, and increase some probiotic bacteria such as Bifidobacterium, Gemellales, Blautia, Sutterella, Anaerostipes, Roseburia, Lachnobacterium, Lactobacillus, and Desulfovibrio. This demonstrates that HEP could promote the antitumor efficacy of 5-Fu by improving the microbiota composition, the immune inflammatory response, and homeostasis.","tags":["#literature_note"],"author":[{"family":"Wang","given":"Dongdong","literal":""},{"family":"Dongdong","given":"Wang","literal":""},{"family":"Zhu","given":"Xiangxiang","literal":""},{"family":"Zhu","given":"Xiangxiang","literal":""},{"family":"Zhu","given":"Xiangxiang","literal":""},{"family":"Tang","given":"Xiaocui","literal":""},{"family":"Xiaocui","given":"Tang","literal":""},{"family":"Tang","given":"Xiaocui","literal":""},{"family":"Li","given":"Hong-Ye","literal":""},{"family":"Li","given":"Hongye","literal":""},{"family":"Li","given":"Hongye","literal":""},{"family":"Xie","given":"Yizhen","literal":""},{"family":"Yizhen","given":"Xie","literal":""},{"family":"Yizhen","given":"Xie","literal":""},{"family":"Chen","given":"Diling","literal":""},{"family":"Chen","given":"Diling","literal":""},{"family":"Chen","given":"Diling","literal":""},{"family":"Diling","given":"Chen","literal":""},{"family":"Chen","given":"Diling","literal":""}],"citation-key":"wang_auxiliary_2020","year":"2020","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Auxiliary antitumor effects of fungal proteins from Hericium erinaceus by target on the gut microbiota"],"author-links":["[[Author/Dongdong Wang]]","[[Author/Wang Dongdong]]","[[Author/Xiangxiang Zhu]]","[[Author/Xiangxiang Zhu]]","[[Author/Xiangxiang Zhu]]","[[Author/Xiaocui Tang]]","[[Author/Tang Xiaocui]]","[[Author/Xiaocui Tang