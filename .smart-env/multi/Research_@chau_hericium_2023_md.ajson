63,-0.02790477,0.17372489,0.01887541,0.01496498,-0.0100124,-0.00972898,0.04329065,0.02334513,-0.01539605,-0.01541864,0.02479133,0.10038783,0.00388341,0.03769847,0.02078185,-0.11648567,-0.0160198,-0.01802264,-0.01480384,0.03761942,0.05802755,-0.0104499,-0.02906123,0.06648676,-0.02636983,-0.04201907,0.01154057,-0.01901395,0.03356094,-0.00747141,-0.02113614,-0.01268343,0.02931757,-0.00710376,-0.01601936,-0.02010279,-0.02790534,-0.05168065,-0.02772114,-0.01300689,0.00247263,-0.07019717,0.15423119,0.07808957],"last_embed":{"hash":"70ntwm","tokens":482}}},"last_read":{"hash":"70ntwm","at":1774951893424},"class_name":"SmartSource","last_import":{"mtime":1774951826100,"size":3280,"at":1774951884820,"hash":"70ntwm"},"blocks":{"#---frontmatter---":[1,73],"#Hericium erinaceus Promotes Anti-Inflammatory Effects and Regulation of Metabolites in an Animal Model of Cerebellar Ataxia":[75,79],"#Hericium erinaceus Promotes Anti-Inflammatory Effects and Regulation of Metabolites in an Animal Model of Cerebellar Ataxia#{1}":[77,79]},"outlinks":[{"title":"Author/Sze Chun Chau","target":"Author/Sze Chun Chau","line":57},{"title":"Author/Pit Shan Chong","target":"Author/Pit Shan Chong","line":58},{"title":"Author/Hongkai Jin","target":"Author/Hongkai Jin","line":59},{"title":"Author/Ka Chun Tsui","target":"Author/Ka Chun Tsui","line":60},{"title":"Author/Sharafuddin Khairuddin","target":"Author/Sharafuddin Khairuddin","line":61},{"title":"Author/Alex Wing Cheung Tse","target":"Author/Alex Wing Cheung Tse","line":62},{"title":"Author/Sze Yuen Lew","target":"Author/Sze Yuen Lew","line":63},{"title":"Author/George L. Tipoe","target":"Author/George L. Tipoe","line":64},{"title":"Author/Chi Wai Lee","target":"Author/Chi Wai Lee","line":65},{"title":"Author/Man-Lung Fung","target":"Author/Man-Lung Fung","line":66},{"title":"Author/Kah-Hui Wong","target":"Author/Kah-Hui Wong","line":67},{"title":"Author/Lee Wei Lim","target":"Author/Lee Wei Lim","line":68},{"title":"PDF","target":"biblib/chau_hericium_2023/chau_hericium_2023.pdf","line":70}],"metadata":{"id":"chau_hericium_2023","type":"article-journal","title":"Hericium erinaceus Promotes Anti-Inflammatory Effects and Regulation of Metabolites in an Animal Model of Cerebellar Ataxia","issued":{"date-parts":[[2023]]},"DOI":"10.3390/ijms24076089","container-title":"International journal of molecular sciences","abstract":"Cerebellar ataxia is a neurodegenerative disorder with no definitive treatment. Although previous study demonstrated the neuroprotective effects of Hericium erinaceus (H.E.), the mechanisms of H.E. treatment on the neuroinflammatory response, neurotransmission, and related metabolites remain largely unknown. We demonstrated that 3-AP rats treated with 25 mg/kg H.E. extracts had improved motor coordination and balance in the accelerated rotarod and rod tests. We showed that the H.E. treatment upregulated the expression of Tgfb1, Tgfb2, and Smad3 genes to levels comparable to those in the non-3-AP control group. Interestingly, we also observed a significant correlation between Tgfb2 gene expression and rod test performance in the 3-AP saline group, but not in the non-3-AP control or H.E.+3-AP groups, indicating a relationship between Tgfb2 gene expression and motor balance in the 3-AP rat model. Additionally, we also found that the H.E. treatment increased mitochondrial COX-IV protein expression and normalized dopamine-serotonin neurotransmission and metabolite levels in the cerebellum of the H.E.+3-AP group compared to the 3-AP saline group. In conclusion, our findings suggest that the H.E. treatment improved motor function in the 3-AP rat model, which was potentially mediated through neuroprotective mechanisms involving TGFB2-Smad3 signaling via normalization of neurotransmission and metabolic pathways.","tags":["#literature_note"],"author":[{"family":"Chau","given":"Sze Chun","literal":""},{"family":"Chong","given":"Pit Shan","literal":""},{"family":"Jin","given":"Hongkai","literal":""},{"family":"Tsui","given":"Ka Chun","literal":""},{"family":"Khairuddin","given":"Sharafuddin","literal":""},{"family":"Tse","given":"Alex Wing Cheung","literal":""},{"family":"Lew","given":"Sze Yuen","literal":""},{"family":"Tipoe","given":"George L.","literal":""},{"family":"Lee","given":"Chi Wai","literal":""},{"family":"Fung","given":"Man-Lung","literal":""},{"family":"Wong","given":"Kah-Hui","literal":""},{"family":"Lim","given":"Lee Wei","literal":""}],"citation-key":"chau_hericium_2023","year":"2023","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Hericium erinaceus Promotes Anti-Inflammatory Effects and Regulation of Metabolites in an Animal Model of Cerebellar Ataxia"],"author-links":["[[Author/Sze Chun Chau]]","[[Author/Pit Shan Chong]]","[[Author/Hongkai Jin]]","[[Author/Ka Chun Tsui]]","[[Author/Sharafuddin Khairuddin]]","[[Author/Alex Wing Cheung Tse]]","[[Author/Sze Yuen Lew]]","[[Author/George L. Tipoe]]","[[Author/Chi Wai Lee]]","[[Author/Man-Lung Fung]]","[[Author/Kah-Hui Wong]]","[[Author/Lee Wei Lim]]"],"attachment":["[[biblib/chau_hericium_2023/chau_hericium_2023.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"70ntwm","at":1774951893414}},"smart_blocks:Research/@chau_hericium_2023.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.01420442,-0.0384832,0.00910906,0.01463514,-0.0389227,0.04806433,-0.00332096,0.05540803,-0.03255602,-0.03925376,0.01503872,-0.08208598,0.02790988,0.00732392,0.01292123,0.03122545,-0.03797972,0.02291521,-0.06837435,-0.03505497,-0.03452439,-0.0320482,0.03791606,0.04452646,-0.0241941,0.02688576,-0.02164639,0.02643298,-0.09368111,-0.2317401,-0.00385202,-0.04131369,0.03322351,-0.0285032,-0.04777169,0.01688185,-0.02891173,0.05069617,-0.03596957,-0.01714113,0.06812416,0.06873413,0.03556437,-0.02282492,0.03460817,-0.01115636,-0.0037912,-0.07319008,0.04180961,-0.00018096,0.01150255,-0.02297612,0.0511489,0.05769498,0.04508513,0.018