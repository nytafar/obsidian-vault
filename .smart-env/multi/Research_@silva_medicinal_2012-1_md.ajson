0.01626693,0.18243828,-0.02666908,-0.00170741,-0.00045926,-0.03947066,0.01124979,-0.0798248,0.00966211,0.03600015,0.03375453,0.08509208,-0.01607505,0.08237112,0.06484784,0.00750535,-0.00741567,-0.03281158,0.00290543,-0.00790129,-0.01479965,-0.08550317,-0.01755933,0.12225104,-0.12150904,-0.03451093,-0.07869092,-0.01933116,0.00436622,-0.0538883,0.01701436,-0.00105168,0.05347384,-0.04491082,-0.01790744,0.03425799,-0.03726133,-0.03631204,0.00396056,0.0140627,0.04734764,-0.07730897,0.1098346,0.01490752],"last_embed":{"hash":"1y4ah74","tokens":364}}},"last_read":{"hash":"1y4ah74","at":1774951885826},"class_name":"SmartSource","last_import":{"mtime":1774951814313,"size":3457,"at":1774951884765,"hash":"1y4ah74"},"blocks":{"#---frontmatter---":[1,65],"#Medicinal mushrooms in supportive cancer therapies: an approach to anti-cancer effects and putative mechanisms of action":[67,71],"#Medicinal mushrooms in supportive cancer therapies: an approach to anti-cancer effects and putative mechanisms of action#{1}":[69,71]},"outlinks":[{"title":"Author/Dilani D. De Silva","target":"Author/Dilani D. De Silva","line":51},{"title":"Author/Dilani D. De Silva","target":"Author/Dilani D. De Silva","line":52},{"title":"Author/Sylvie Rapior","target":"Author/Sylvie Rapior","line":53},{"title":"Author/Sylvie Rapior","target":"Author/Sylvie Rapior","line":54},{"title":"Author/Françoise Fons","target":"Author/Françoise Fons","line":55},{"title":"Author/Françoise Fons","target":"Author/Françoise Fons","line":56},{"title":"Author/Ali H. Bahkali","target":"Author/Ali H. Bahkali","line":57},{"title":"Author/Ali H. Bahkali","target":"Author/Ali H. Bahkali","line":58},{"title":"Author/Kevin D. Hyde","target":"Author/Kevin D. Hyde","line":59},{"title":"Author/Kevin D. Hyde","target":"Author/Kevin D. Hyde","line":60},{"title":"PDF","target":"biblib/silva_medicinal_2012-1/silva_medicinal_2012-1.pdf","line":62}],"metadata":{"id":"silva_medicinal_2012-1","type":"article-journal","title":"Medicinal mushrooms in supportive cancer therapies: an approach to anti-cancer effects and putative mechanisms of action","issued":{"date-parts":[[2012]]},"DOI":"10.1007/s13225-012-0151-3","container-title":"Fungal Diversity","abstract":"Medicinal mushrooms have been valued as natural sources of bioactive compounds since times immemorial and have been recognized as potential immunomodulating and anti-cancer agents. Their consumption has consistently been shown to have beneficial effects on human health. Cancer is a generic term for several types of diseases that can be chronic and are responsible for a large number of deaths worldwide. Although there has been considerable progress in modern cancer therapy research, difficulties in understanding the molecular behavior of various types of cancers and the numerous side effects experienced by patients from treatments means that this whole subject area is still problematic. Thus, biological immunotherapy using natural bioactive compounds as supportive treatments in conventional cancer therapies has become in vogue. Bioactive metabolites isolated from medicinal mushrooms have shown potential successes in cancer treatment as biological immunotherapeutic agents that stimulate the immune system against cancer cells. They also act as an effective source of anti-cancer agents, capable of interfering with cellular signal transduction pathways linked to cancer development and progression. In this review we compile available data on the characteristics of medicinal mushrooms that appear to be particularly effective as biological immunotherapeutic agents. Major consideration is given to biological constituents and the putative mechanisms of action by which bioactive compounds act on the human body. Consideration is also given to the benefits that have been claimed for the use of mushrooms in treating cancer and the future prospects of using medicinal mushrooms as potent supportive candidate bioagents for treatment of cancers is discussed.","tags":["#literature_note"],"author":[{"family":"Silva","given":"Dilani D. De","literal":""},{"family":"Silva","given":"Dilani D. De","literal":""},{"family":"Rapior","given":"Sylvie","literal":""},{"family":"Rapior","given":"Sylvie","literal":""},{"family":"Fons","given":"Françoise","literal":""},{"family":"Fons","given":"Françoise","literal":""},{"family":"Bahkali","given":"Ali H.","literal":""},{"family":"Bahkali","given":"Ali H.","literal":""},{"family":"Hyde","given":"Kevin D.","literal":""},{"family":"Hyde","given":"Kevin D.","literal":""}],"citation-key":"silva_medicinal_2012-1","year":"2012","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Medicinal mushrooms in supportive cancer therapies: an approach to anti-cancer effects and putative mechanisms of action"],"author-links":["[[Author/Dilani D. De Silva]]","[[Author/Dilani D. De Silva]]","[[Author/Sylvie Rapior]]","[[Author/Sylvie Rapior]]","[[Author/Françoise Fons]]","[[Author/Françoise Fons]]","[[Author/Ali H. Bahkali]]","[[Author/Ali H. Bahkali]]","[[Author/Kevin D. Hyde]]","[[Author/Kevin D. Hyde]]"],"attachment":["[[biblib/silva_medicinal_2012-1/silva_medicinal_2012-1.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"1y4ah74","at":1774951885819}},"smart_blocks:Research/@silva_medicinal_2012-1.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.01859065,-0.06348448,0.01928699,-0.03402318,-0.00759811,0.00726422,0.03437667,0.02501896,-0.03859868,0.00358915,0.02307292,-0.02794142,-0.0033736,-0.00540346,0.0232898,0.02034429,0.04951794,0.02450823,-0.08147021,0.00787864,-0.01939201,-0.0080415,-0.00019119,0.02848814,0.02220559,0.00111573,-0.00568849,-0.04619329,-0.05612813,-0.1676223,0.00070079,0.00561581,0.01879127,-0.0026763,-0.04098528,-0.01117275,-0.02261902,0.00803186,-0.0430545,0.02519274,0.03563793,0.04336742,0.01382478,0.07648052,-0.01066508,-0.01554045,-0.09079753,-0.07618939,-0.00115032,-0.04390617,-0.04177112,