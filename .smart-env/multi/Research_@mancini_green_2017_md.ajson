06448337,0.1786311,0.00879359,-0.02753645,-0.00577686,-0.02884334,-0.0265443,-0.00469185,0.00031914,0.00316549,0.04369714,0.1041552,-0.035049,0.04520437,0.06411289,-0.09596801,-0.04600157,0.03683742,-0.0172607,0.08086175,0.04521381,-0.08597257,-0.06910306,0.09426987,-0.05250166,0.00433929,-0.07769863,-0.03255276,-0.00008645,-0.00531113,0.00097673,-0.0105068,0.03166357,-0.01502803,-0.03282181,-0.0096469,-0.03487681,-0.00762637,-0.02266534,-0.03512479,-0.01714749,-0.02946286,0.13631381,-0.00406991],"last_embed":{"hash":"92x6gs","tokens":420}}},"last_read":{"hash":"92x6gs","at":1774951895690},"class_name":"SmartSource","last_import":{"mtime":1774951828774,"size":3697,"at":1774951884830,"hash":"92x6gs"},"blocks":{"#---frontmatter---":[1,73],"#Green tea effects on cognition, mood and human brain function: A systematic review":[75,79],"#Green tea effects on cognition, mood and human brain function: A systematic review#{1}":[77,79]},"outlinks":[{"title":"Author/Edele Mancini","target":"Author/Edele Mancini","line":57},{"title":"Author/Edele Mancini","target":"Author/Edele Mancini","line":58},{"title":"Author/Christoph Beglinger","target":"Author/Christoph Beglinger","line":59},{"title":"Author/Christoph Beglinger","target":"Author/Christoph Beglinger","line":60},{"title":"Author/Jürgen Drewe","target":"Author/Jürgen Drewe","line":61},{"title":"Author/Jürgen Drewe","target":"Author/Jürgen Drewe","line":62},{"title":"Author/Davide Zanchi","target":"Author/Davide Zanchi","line":63},{"title":"Author/Davide Zanchi","target":"Author/Davide Zanchi","line":64},{"title":"Author/Undine E. Lang","target":"Author/Undine E. Lang","line":65},{"title":"Author/Undine E. Lang","target":"Author/Undine E. Lang","line":66},{"title":"Author/Stefan Borgwardt","target":"Author/Stefan Borgwardt","line":67},{"title":"Author/Stefan Borgwardt","target":"Author/Stefan Borgwardt","line":68},{"title":"PDF","target":"biblib/mancini_green_2017/mancini_green_2017.pdf","line":70}],"metadata":{"id":"mancini_green_2017","type":"article-journal","title":"Green tea effects on cognition, mood and human brain function: A systematic review","issued":{"date-parts":[[2017]]},"DOI":"10.1016/j.phymed.2017.07.008","container-title":"Phytomedicine","abstract":"Abstract Background Green tea (Camellia sinensis) is a beverage consumed for thousands of years. Numerous claims about the benefits of its consumption were stated and investigated. As green tea is experiencing a surge in popularity in Western culture and as millions of people all over the world drink it every day, it is relevant to understand its effects on the human brain. Purpose To assess the current state of knowledge in the literature regarding the effects of green tea or green tea extracts, l -theanine and epigallocatechin gallate both components of green tea—on general neuropsychology, on the sub-category cognition and on brain functions in humans. Methods We systematically searched on PubMed database and selected studies by predefined eligibility criteria. We then assessed their quality and extracted data. We structured our effort according to the PRISMA statement. Outcome We reviewed and assessed 21 studies, 4 of which were randomised controlled trials, 12 cross-over studies (both assessed with an adapted version of the DELPHI-list), 4 were cross-sectional studies and one was a cohort study (both assessed with an adapted version of the Newcastle–Ottawa assessment scale). The average study quality as appraised by means of the DELPHI-list was good (8.06/9); the studies evaluated with the Newcastle–Ottawa-scale were also good (6.7/9). Conclusions The reviewed studies presented evidence that green tea influences psychopathological symptoms (e.g. reduction of anxiety), cognition (e.g. benefits in memory and attention) and brain function (e.g. activation of working memory seen in functional MRI). The effects of green tea cannot be attributed to a single constituent of the beverage. This is exemplified in the finding that beneficial green tea effects on cognition are observed under the combined influence of both caffeine and l -theanine, whereas separate administration of either substance was found to have a lesser impact.","tags":["#literature_note"],"author":[{"family":"Mancini","given":"Edele","literal":""},{"family":"Mancini","given":"Edele","literal":""},{"family":"Beglinger","given":"Christoph","literal":""},{"family":"Beglinger","given":"Christoph","literal":""},{"family":"Drewe","given":"Jürgen","literal":""},{"family":"Drewe","given":"Jürgen","literal":""},{"family":"Zanchi","given":"Davide","literal":""},{"family":"Zanchi","given":"Davide","literal":""},{"family":"Lang","given":"Undine E.","literal":""},{"family":"Lang","given":"Undine E.","literal":""},{"family":"Borgwardt","given":"Stefan","literal":""},{"family":"Borgwardt","given":"Stefan","literal":""}],"citation-key":"mancini_green_2017","year":"2017","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Green tea effects on cognition, mood and human brain function: A systematic review"],"author-links":["[[Author/Edele Mancini]]","[[Author/Edele Mancini]]","[[Author/Christoph Beglinger]]","[[Author/Christoph Beglinger]]","[[Author/Jürgen Drewe]]","[[Author/Jürgen Drewe]]","[[Author/Davide Zanchi]]","[[Author/Davide Zanchi]]","[[Author/Undine E. Lang]]","[[Author/Undine E. Lang]]","[[Author/Stefan Borgwardt]]","[[Author/Stefan Borgwardt]]"],"attachment":["[[biblib/mancini_green_2017/mancini_green_2017.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"92x6gs","at":1774951895683}},"smart_blocks:Research/@mancini_green_2017.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[0.02052638,-0.03748363,0.05895995,-0.00006227,0.01301296,0.0623558,0.09328397,0.01321553,-0.01322273,0.00781174,-0.00651494,-0.05915394,0.02975313,0.07711461,0.01581226,-0.02935006,-0.05262353,-0.03939018,-0.08675507,-0.01505608,-0.03255222,-0.06105302,0.032680