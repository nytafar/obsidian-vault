0.08944891,0.05442238,0.0054429,0.17094824,0.00856014,0.02294788,-0.02619704,0.00263132,0.03418763,0.01844075,-0.0188388,-0.02776238,-0.01168291,0.08753247,-0.02268587,0.05711396,0.03345967,-0.10983261,0.0035846,0.00187503,-0.0169462,0.05691186,0.05248774,-0.00327727,-0.03573956,0.07847697,0.03103772,-0.06057708,-0.01687389,-0.00920423,0.0157112,0.001825,-0.05528039,-0.00731275,0.0014936,0.0280795,-0.00261048,-0.01430915,-0.01454002,-0.05545966,-0.03949927,0.0210695,-0.0003695,-0.03148068,0.1852379,0.08338747],"last_embed":{"hash":"nnpfjz","tokens":495}}},"last_read":{"hash":"nnpfjz","at":1774951888500},"class_name":"SmartSource","last_import":{"mtime":1774951818909,"size":3893,"at":1774951884790,"hash":"nnpfjz"},"blocks":{"#---frontmatter---":[1,100],"#Hericium erinaceus potentially rescues behavioural motor deficits through ERK-CREB-PSD95 neuroprotective mechanisms in rat model of 3-acetylpyridine-induced cerebellar ataxia.":[102,106],"#Hericium erinaceus potentially rescues behavioural motor deficits through ERK-CREB-PSD95 neuroprotective mechanisms in rat model of 3-acetylpyridine-induced cerebellar ataxia.#{1}":[104,106]},"outlinks":[{"title":"Author/Pit Shan Chong","target":"Author/Pit Shan Chong","line":78},{"title":"Author/Pit Shan Chong","target":"Author/Pit Shan Chong","line":79},{"title":"Author/Sharafuddin Khairuddin","target":"Author/Sharafuddin Khairuddin","line":80},{"title":"Author/Alex Wing Cheung Tse","target":"Author/Alex Wing Cheung Tse","line":81},{"title":"Author/Sharafuddin Khairuddin","target":"Author/Sharafuddin Khairuddin","line":82},{"title":"Author/Anna Chung Kwan Tse","target":"Author/Anna Chung Kwan Tse","line":83},{"title":"Author/Anna Chung-Kwan Tse","target":"Author/Anna Chung-Kwan Tse","line":84},{"title":"Author/Lih Fhung Hiew","target":"Author/Lih Fhung Hiew","line":85},{"title":"Author/Lih Fhung Hiew","target":"Author/Lih Fhung Hiew","line":86},{"title":"Author/Chun Lok Lau","target":"Author/Chun Lok Lau","line":87},{"title":"Author/George L. Tipoe","target":"Author/George L. Tipoe","line":88},{"title":"Author/Chun Lok Lau","target":"Author/Chun Lok Lau","line":89},{"title":"Author/George L. Tipoe","target":"Author/George L. Tipoe","line":90},{"title":"Author/Man-Lung Fung","target":"Author/Man-Lung Fung","line":91},{"title":"Author/Man-Lung Fung","target":"Author/Man-Lung Fung","line":92},{"title":"Author/Kah-Hui Wong","target":"Author/Kah-Hui Wong","line":93},{"title":"Author/Kah-Hui Wong","target":"Author/Kah-Hui Wong","line":94},{"title":"Author/Lee Wei Lim","target":"Author/Lee Wei Lim","line":95},{"title":"Author/Lee Wei Lim","target":"Author/Lee Wei Lim","line":96}],"metadata":{"id":"chong_hericium_2020","type":"article-journal","title":"Hericium erinaceus potentially rescues behavioural motor deficits through ERK-CREB-PSD95 neuroprotective mechanisms in rat model of 3-acetylpyridine-induced cerebellar ataxia.","issued":{"date-parts":[[2020]]},"DOI":"10.1038/s41598-020-71966-z","container-title":"Scientific Reports","abstract":"Cerebellar ataxia is a neurodegenerative disorder with no definitive treatment. Although several studies have demonstrated the neuroprotective effects of Hericium erinaceus (H.E.), its mechanisms in cerebellar ataxia remain largely unknown. Here, we investigated the neuroprotective effects of H.E. treatment in an animal model of 3-acetylpyridine (3-AP)-induced cerebellar ataxia. Animals administered 3-AP injection exhibited remarkable impairments in motor coordination and balance. There were no significant effects of 25mg/kg H.E. on the 3-AP treatment group compared to the 3-AP saline group. Interestingly, there was also no significant difference in the 3-AP treatment group compared to the non-3-AP control, indicating a potential rescue of motor deficits. Our results revealed that 25mg/kg H.E. normalised the neuroplasticity-related gene expression to the level of non-3-AP control. These findings were further supported by increased protein expressions of pERK1/2-pCREB-PSD95 as well as neuroprotective effects on cerebellar Purkinje cells in the 3-AP treatment group compared to the 3-AP saline group. In conclusion, our findings suggest that H.E. potentially rescued behavioural motor deficits through the neuroprotective mechanisms of ERK-CREB-PSD95 in an animal model of 3-AP-induced cerebellar ataxia.","tags":["#literature_note"],"author":[{"family":"Chong","given":"Pit Shan","literal":""},{"family":"Chong","given":"Pit Shan","literal":""},{"family":"Khairuddin","given":"Sharafuddin","literal":""},{"family":"Tse","given":"Alex Wing Cheung","literal":""},{"family":"Khairuddin","given":"Sharafuddin","literal":""},{"family":"Tse","given":"Anna Chung Kwan","literal":""},{"family":"Tse","given":"Anna Chung-Kwan","literal":""},{"family":"Hiew","given":"Lih Fhung","literal":""},{"family":"Hiew","given":"Lih Fhung","literal":""},{"family":"Lau","given":"Chun Lok","literal":""},{"family":"Tipoe","given":"George L.","literal":""},{"family":"Lau","given":"Chun Lok","literal":""},{"family":"Tipoe","given":"George L.","literal":""},{"family":"Fung","given":"Man-Lung","literal":""},{"family":"Fung","given":"Man-Lung","literal":""},{"family":"Wong","given":"Kah-Hui","literal":""},{"family":"Wong","given":"Kah-Hui","literal":""},{"family":"Lim","given":"Lee Wei","literal":""},{"family":"Lim","given":"Lee Wei","literal":""}],"citation-key":"chong_hericium_2020","year":"2020","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Hericium erinaceus potentially rescues behavioural motor deficits through ERK-CREB-PSD95 neuroprotective mechanisms in rat model of 3-acetylpyridine-induced cerebellar ataxia."],"author-links":["[[Author/Pit Shan Chong]]","[[Author/Pit Shan Chong]]","[[Author/Sharafuddin Khairuddin]]","[[Author/Alex Wing Cheung Tse]]","[[Author/Sharafuddin Khairuddin]]","[[Author/Anna Chung Kwan Tse]]","[[Author/Anna Chung-Kwan Tse]]","[[Author/Lih Fhung Hiew]]","[[Author/Lih Fhung Hiew]]","[[Author/Chun Lok Lau]]","[[Auth