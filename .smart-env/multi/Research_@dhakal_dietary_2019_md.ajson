02106649,0.17287426,-0.0168413,0.01860399,0.03589126,0.01989243,0.00348563,0.01187308,0.055706,-0.01569798,-0.00779152,0.12769349,-0.04734868,0.06539594,0.08669689,-0.04507297,-0.02729899,-0.01613383,0.02672119,0.03220364,0.01338216,-0.05055526,-0.02962921,0.09814864,-0.0060006,-0.02388568,-0.01684787,-0.07870506,-0.03046537,-0.05311659,-0.04754844,-0.02545319,0.03150667,-0.02011707,0.01421034,0.01926104,-0.06304675,-0.00316642,0.00980897,0.00827916,0.00100042,-0.04174449,0.162728,-0.02285271],"last_embed":{"hash":"xn4apz","tokens":411}}},"last_read":{"hash":"xn4apz","at":1774951886045},"class_name":"SmartSource","last_import":{"mtime":1774951814615,"size":3046,"at":1774951884767,"hash":"xn4apz"},"blocks":{"#---frontmatter---":[1,73],"#Dietary Polyphenols: A Multifactorial Strategy to Target Alzheimer's Disease.":[75,79],"#Dietary Polyphenols: A Multifactorial Strategy to Target Alzheimer's Disease.#{1}":[77,79]},"outlinks":[{"title":"Author/Sudip Dhakal","target":"Author/Sudip Dhakal","line":57},{"title":"Author/Sudip Dhakal","target":"Author/Sudip Dhakal","line":58},{"title":"Author/Naufal Kushairi","target":"Author/Naufal Kushairi","line":59},{"title":"Author/Naufal Kushairi","target":"Author/Naufal Kushairi","line":60},{"title":"Author/Chia Wei Phan","target":"Author/Chia Wei Phan","line":61},{"title":"Author/Chia-Wei Phan","target":"Author/Chia-Wei Phan","line":62},{"title":"Author/Benu Adhikari","target":"Author/Benu Adhikari","line":63},{"title":"Author/Benu Adhikari","target":"Author/Benu Adhikari","line":64},{"title":"Author/Vikineswary Sabaratnam","target":"Author/Vikineswary Sabaratnam","line":65},{"title":"Author/Vikineswary Sabaratnam","target":"Author/Vikineswary Sabaratnam","line":66},{"title":"Author/Ian Macreadie","target":"Author/Ian Macreadie","line":67},{"title":"Author/Ian G. Macreadie","target":"Author/Ian G. Macreadie","line":68},{"title":"PDF","target":"biblib/dhakal_dietary_2019/dhakal_dietary_2019.pdf","line":70}],"metadata":{"id":"dhakal_dietary_2019","type":"article-journal","title":"Dietary Polyphenols: A Multifactorial Strategy to Target Alzheimer's Disease.","issued":{"date-parts":[[2019]]},"DOI":"10.3390/ijms20205090","container-title":"International Journal of Molecular Sciences","abstract":"Ageing is an inevitable fundamental process for people and is their greatest risk factor for neurodegenerative disease. The ageing processes bring changes in cells that can drive the organisms to experience loss of nutrient sensing, disrupted cellular functions, increased oxidative stress, loss of cellular homeostasis, genomic instability, accumulation of misfolded protein, impaired cellular defenses and telomere shortening. Perturbation of these vital cellular processes in neuronal cells can lead to life threatening neurological disorders like Alzheimer’s Disease, Parkinson’s Disease, Huntington’s Disease, Lewy body dementia, etc. Alzheimer’s Disease is the most frequent cause of deaths in the elderly population. Various therapeutic molecules have been designed to overcome the social, economic and health care burden caused by Alzheimer’s Disease. Almost all the chemical compounds in clinical practice have been found to treat symptoms only limiting them to palliative care. The reason behind such imperfect drugs may result from the inefficiencies of the current drugs to target the cause of the disease. Here, we review the potential role of antioxidant polyphenolic compounds that could possibly be the most effective preventative strategy against Alzheimer’s Disease.","tags":["#literature_note"],"author":[{"family":"Dhakal","given":"Sudip","literal":""},{"family":"Dhakal","given":"Sudip","literal":""},{"family":"Kushairi","given":"Naufal","literal":""},{"family":"Kushairi","given":"Naufal","literal":""},{"family":"Phan","given":"Chia Wei","literal":""},{"family":"Phan","given":"Chia-Wei","literal":""},{"family":"Adhikari","given":"Benu","literal":""},{"family":"Adhikari","given":"Benu","literal":""},{"family":"Sabaratnam","given":"Vikineswary","literal":""},{"family":"Sabaratnam","given":"Vikineswary","literal":""},{"family":"Macreadie","given":"Ian","literal":""},{"family":"Macreadie","given":"Ian G.","literal":""}],"citation-key":"dhakal_dietary_2019","year":"2019","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Dietary Polyphenols: A Multifactorial Strategy to Target Alzheimer's Disease."],"author-links":["[[Author/Sudip Dhakal]]","[[Author/Sudip Dhakal]]","[[Author/Naufal Kushairi]]","[[Author/Naufal Kushairi]]","[[Author/Chia Wei Phan]]","[[Author/Chia-Wei Phan]]","[[Author/Benu Adhikari]]","[[Author/Benu Adhikari]]","[[Author/Vikineswary Sabaratnam]]","[[Author/Vikineswary Sabaratnam]]","[[Author/Ian Macreadie]]","[[Author/Ian G. Macreadie]]"],"attachment":["[[biblib/dhakal_dietary_2019/dhakal_dietary_2019.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"xn4apz","at":1774951886036}},"smart_blocks:Research/@dhakal_dietary_2019.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.01665168,0.00152239,0.03765208,-0.02639022,-0.01986683,0.05363003,0.0309277,0.03900714,-0.02241926,-0.05559838,0.02835066,-0.08530839,0.01992422,0.05898622,-0.01025805,0.01375139,-0.00375729,0.03654046,-0.04288454,0.02565401,0.03099124,-0.01719438,0.02663301,-0.02594185,0.0368554,0.05658517,-0.02956419,-0.02750442,-0.07359257,-0.19176446,0.01113969,0.00589548,-0.02710187,-0.05120702,-0.04808854,0.03343307,0.01971602,0.04762004,-0.01431892,-0.03637908,0.03846182,0.05131079,0.00747302,-0.0431318,0.00675833,-0.01099333,-0.07870533,-0.04026015,-0.01563391,-0.0647219,-0.04378304,0.02080459,-0.00079784,0.0300689,0.03133017,0.01255359,-0.03742986,0.09531136,0.02649609,0.05781199,0.04490092,0.00408868,-0.18358126,0.08302972,0.04765638,0.00224741,-0.00421686,0.07183958,0.04433669,0.01997259,-0.09478559,-0.01296268,0.00747651,0.02685701,0.03630482,-0.00772738,-0.02423294,-0.07558708,-0.0214797,0.0120859