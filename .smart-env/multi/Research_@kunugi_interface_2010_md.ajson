.0374354,0.00868291,0.06055445,0.14204037,-0.04040929,0.04242695,-0.0170338,0.0586292,0.04524981,-0.00797657,-0.02564142,-0.01767841,0.0086156,0.08678598,-0.02345907,0.00323424,0.0485865,-0.04532291,-0.00478732,0.07756674,0.01319327,0.01727848,0.02235445,-0.03019811,-0.01263398,0.09737757,-0.07131706,-0.04032857,-0.01120046,-0.00709395,0.00986254,0.04285761,0.01415853,0.10629136,0.00923231,-0.02780275,-0.00318532,0.05831669,-0.02839032,-0.00567735,-0.02620486,-0.00461555,-0.05359084,-0.07992851,0.11493522,-0.01002123],"last_embed":{"hash":"1wag78h","tokens":441}}},"last_read":{"hash":"1wag78h","at":1774951890338},"class_name":"SmartSource","last_import":{"mtime":1774951820849,"size":3097,"at":1774951884799,"hash":"1wag78h"},"blocks":{"#---frontmatter---":[1,57],"#Interface between hypothalamic-pituitary-adrenal axis and brain-derived neurotrophic factor in depression":[59,63],"#Interface between hypothalamic-pituitary-adrenal axis and brain-derived neurotrophic factor in depression#{1}":[61,63]},"outlinks":[{"title":"Author/Hiroshi Kunugi","target":"Author/Hiroshi Kunugi","line":45},{"title":"Author/Hiroshi Kunugi","target":"Author/Hiroshi Kunugi","line":46},{"title":"Author/Hiroaki Hori","target":"Author/Hiroaki Hori","line":47},{"title":"Author/Hiroaki Hori","target":"Author/Hiroaki Hori","line":48},{"title":"Author/Naoki Adachi","target":"Author/Naoki Adachi","line":49},{"title":"Author/Naoki Adachi","target":"Author/Naoki Adachi","line":50},{"title":"Author/Tadahiro Numakawa","target":"Author/Tadahiro Numakawa","line":51},{"title":"Author/Tadahiro Numakawa","target":"Author/Tadahiro Numakawa","line":52},{"title":"PDF","target":"biblib/kunugi_interface_2010/kunugi_interface_2010.pdf","line":54}],"metadata":{"id":"kunugi_interface_2010","type":"article-journal","title":"Interface between hypothalamic-pituitary-adrenal axis and brain-derived neurotrophic factor in depression","issued":{"date-parts":[[2010]]},"DOI":"10.1111/j.1440-1819.2010.02135.x","container-title":"Psychiatry and Clinical Neurosciences","abstract":"Although the pathophysiology of depressive disorder remains elusive, two hypothetical frameworks seem to be promising: the involvement of hypothalamic pituitary-adrenal (HPA) axis abnormalities and brain-derived neurotrophic factor (BDNF) in the pathogenesis and in the mechanism of action of antidepressant treatments. In this review, we focused on research based on these two frameworks in relation to depression and related conditions and tried to formulate an integrated theory of the disorder. Hormonal challenge tests, such as the dexamethasone/corticotropin-releasing hormone test, have revealed elevated HPA activity (hypercortisolism) in at least a portion of patients with depression, although growing evidence has suggested that abnormally low HPA axis (hypocortisolism) has also been implicated in a variety of stress-related conditions. Several lines of evidence from postmortem studies, animal studies, blood levels, and genetic studies have suggested that BDNF is involved in the pathogenesis of depression and in the mechanism of action of biological treatments for depression. Considerable evidence has suggested that stress reduces the expression of BDNF and that antidepressant treatments increase it. Moreover, the glucocorticoid receptor interacts with the specific receptor of BDNF, TrkB, and excessive glucocorticoid interferes with BDNF signaling. Altered BDNF function is involved in the structural changes and possibly impaired neurogenesis in the brain of depressed patients. Based on these findings, an integrated schema of the pathological and recovery processes of depression is illustrated.","tags":["#literature_note"],"author":[{"family":"Kunugi","given":"Hiroshi","literal":""},{"family":"Kunugi","given":"Hiroshi","literal":""},{"family":"Hori","given":"Hiroaki","literal":""},{"family":"Hori","given":"Hiroaki","literal":""},{"family":"Adachi","given":"Naoki","literal":""},{"family":"Adachi","given":"Naoki","literal":""},{"family":"Numakawa","given":"Tadahiro","literal":""},{"family":"Numakawa","given":"Tadahiro","literal":""}],"citation-key":"kunugi_interface_2010","year":"2010","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Interface between hypothalamic-pituitary-adrenal axis and brain-derived neurotrophic factor in depression"],"author-links":["[[Author/Hiroshi Kunugi]]","[[Author/Hiroshi Kunugi]]","[[Author/Hiroaki Hori]]","[[Author/Hiroaki Hori]]","[[Author/Naoki Adachi]]","[[Author/Naoki Adachi]]","[[Author/Tadahiro Numakawa]]","[[Author/Tadahiro Numakawa]]"],"attachment":["[[biblib/kunugi_interface_2010/kunugi_interface_2010.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"1wag78h","at":1774951890327}},"smart_blocks:Research/@kunugi_interface_2010.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.06071873,0.02210643,0.0268931,-0.00273817,-0.00891923,0.01989621,0.00208221,0.00562928,-0.01656717,-0.07084976,-0.02304631,-0.03063613,0.10933612,0.06984516,0.00422834,-0.00452515,0.0080317,0.05134113,-0.03437215,-0.0067609,0.0177045,-0.01856362,0.03290669,0.01066055,-0.00369229,0.03190605,-0.02502696,0.00471929,-0.07573862,-0.19637971,0.04390698,0.04547865,0.06680167,-0.03607281,-0.03304146,-0.00403074,-0.0310677,0.0378933,0.03402172,0.07953724,0.06301307,0.00818177,-0.00224209,0.01214414,-0.00009043,-0.00860916,-0.03464782,0.01012509,-0.01018738,0.00976092,0.00888281,-0.04981881,0.01145689,0.07162227,0.02227804,0.02703856,0.05571122,0.04803046,-0.01217738,0.102783,0.01595843,0.06510433,-0.20629331,0.05321303,0.14439934,0.01871751,-0.06000287,-0.05195058,0.09238432,0.01798769,-0.06998992,0.03339558,0.09233635,0.03094566,-0.04065083,-0.03209922,-0.01416254,-0.03622059,0.03665611,-0.05102894,0.06402232,0.11654904,0.01873312,-0.00615375,-0.02096529,-0.05356535,-0.01324208,-0.08095255,-0.00636705,-0.01754877,-0.06846666,-0.07107157,-0.03247923,0.03078707,-0.0581715,-0.02