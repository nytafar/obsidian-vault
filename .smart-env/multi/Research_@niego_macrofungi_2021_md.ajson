59719,-0.00426259,0.00319895,0.19838271,0.01347374,-0.04080532,-0.0119878,-0.05433229,0.00944824,-0.05662399,0.02285678,-0.00850167,0.04194494,0.13880503,-0.0373796,0.03772592,0.07658289,-0.00908022,-0.06853607,-0.06483502,-0.0055171,0.01687309,-0.00836961,-0.12710974,-0.03031515,0.07699057,-0.08327966,-0.0436505,-0.05715863,0.00464175,-0.01254877,-0.01706685,0.00106885,0.01887383,0.02077621,-0.02156212,-0.05967191,0.01363621,-0.02376294,-0.01954287,0.04378473,0.01316113,0.03286811,-0.11390587,0.10413196,0.01694993],"last_embed":{"hash":"15f10ez","tokens":414}}},"last_read":{"hash":"15f10ez","at":1774951886421},"class_name":"SmartSource","last_import":{"mtime":1774951815144,"size":3950,"at":1774951884772,"hash":"15f10ez"},"blocks":{"#---frontmatter---":[1,89],"#Macrofungi as a Nutraceutical Source: Promising Bioactive Compounds and Market Value.":[91,95],"#Macrofungi as a Nutraceutical Source: Promising Bioactive Compounds and Market Value.#{1}":[93,95]},"outlinks":[{"title":"Author/Allen Grace T. Niego","target":"Author/Allen Grace T. Niego","line":69},{"title":"Author/Allen Grace T. Niego","target":"Author/Allen Grace T. Niego","line":70},{"title":"Author/Sylvie Rapior","target":"Author/Sylvie Rapior","line":71},{"title":"Author/Sylvie Rapior","target":"Author/Sylvie Rapior","line":72},{"title":"Author/Naritsada Thongklang","target":"Author/Naritsada Thongklang","line":73},{"title":"Author/Naritsada Thongklang","target":"Author/Naritsada Thongklang","line":74},{"title":"Author/Olivier Raspé","target":"Author/Olivier Raspé","line":75},{"title":"Author/Olivier Raspé","target":"Author/Olivier Raspé","line":76},{"title":"Author/Olivier Raspé","target":"Author/Olivier Raspé","line":77},{"title":"Author/Wuttichai Jaidee","target":"Author/Wuttichai Jaidee","line":78},{"title":"Author/Wuttichai Jaidee","target":"Author/Wuttichai Jaidee","line":79},{"title":"Author/Wuttichai Jaidee","target":"Author/Wuttichai Jaidee","line":80},{"title":"Author/Saisamorn Lumyong","target":"Author/Saisamorn Lumyong","line":81},{"title":"Author/Saisamorn Lumyong","target":"Author/Saisamorn Lumyong","line":82},{"title":"Author/Kevin D. Hyde","target":"Author/Kevin D. Hyde","line":83},{"title":"Author/Kevin D. Hyde","target":"Author/Kevin D. Hyde","line":84},{"title":"PDF","target":"biblib/niego_macrofungi_2021/niego_macrofungi_2021.pdf","line":86}],"metadata":{"id":"niego_macrofungi_2021","type":"article-journal","title":"Macrofungi as a Nutraceutical Source: Promising Bioactive Compounds and Market Value.","issued":{"date-parts":[[2021]]},"DOI":"10.3390/jof7050397","container-title":"Journal of Fungi","abstract":"Macrofungi production and economic value have been increasing globally. The demand for macrofungi has expanded rapidly owing to their popularity among consumers, pleasant taste, and unique flavors. The presence of high quality proteins, polysaccharides, unsaturated fatty acids, minerals, triterpene sterols, and secondary metabolites makes macrofungi an important commodity. Macrofungi are well known for their ability to protect from or cure various health problems, such as immunodeficiency, cancer, inflammation, hypertension, hyperlipidemia, hypercholesterolemia, and obesity. Many studies have demonstrated their medicinal properties, supported by both in vivo and in vitro experimental studies, as well as clinical trials. Numerous bioactive compounds isolated from mushrooms, such as polysaccharides, proteins, fats, phenolic compounds, and vitamins, possess strong bioactivities. Consequently, they can be considered as an important source of nutraceuticals. Numerous edible mushrooms have been studied for their bioactivities, but only a few species have made it to the market. Many species remain to be explored. The converging trends and popularity of eastern herbal medicines, natural/organic food product preference, gut-healthy products, and positive outlook towards sports nutrition are supporting the growth in the medicinal mushroom market. The consumption of medicinal mushrooms as functional food or dietary supplement is expected to markedly increase in the future. The global medicinal mushroom market size is projected to increase by USD 13.88 billion from 2018 to 2022. The global market values of promising bioactive compounds, such as lentinan and lovastatin, are also expected to rise. With such a market growth, mushroom nutraceuticals hold to be very promising in the years to come.","tags":["#literature_note"],"author":[{"family":"Niego","given":"Allen Grace T.","literal":""},{"family":"Niego","given":"Allen Grace T.","literal":""},{"family":"Rapior","given":"Sylvie","literal":""},{"family":"Rapior","given":"Sylvie","literal":""},{"family":"Thongklang","given":"Naritsada","literal":""},{"family":"Thongklang","given":"Naritsada","literal":""},{"family":"Raspé","given":"Olivier","literal":""},{"family":"Raspé","given":"Olivier","literal":""},{"family":"Raspé","given":"Olivier","literal":""},{"family":"Jaidee","given":"Wuttichai","literal":""},{"family":"Jaidee","given":"Wuttichai","literal":""},{"family":"Jaidee","given":"Wuttichai","literal":""},{"family":"Lumyong","given":"Saisamorn","literal":""},{"family":"Lumyong","given":"Saisamorn","literal":""},{"family":"Hyde","given":"Kevin D.","literal":""},{"family":"Hyde","given":"Kevin D.","literal":""}],"citation-key":"niego_macrofungi_2021","year":"2021","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Macrofungi as a Nutraceutical Source: Promising Bioactive Compounds and Market Value."],"author-links":["[[Author/Allen Grace T. Niego]]","[[Author/Allen Grace T. Niego]]","[[Author/Sylvie Rapior]]","[[Author/Sylvie Rapior]]","[[Author/Naritsada Thongklang]]","[[Author/Naritsada Thongklang]]","[[Author/Olivier Raspé]]","[[Author/Olivier Raspé]]","[[Author/Olivier Raspé]]","[[Author/Wuttichai Jaidee]]","[[Author/Wuttichai Jaidee]]","[[Author/Wuttichai Jaidee]]","[[Author/Saisamorn Lumyong]]","[[Author/Saisamorn Lumyong]]","[[Author/Kevin D. Hyd