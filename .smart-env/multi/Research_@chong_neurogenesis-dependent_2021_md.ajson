3865118,0.05979431,-0.09381033,0.02083261,-0.00635382,0.15735704,0.01256735,0.04187754,0.00851107,-0.0208024,0.03536255,-0.01169869,-0.01593425,-0.01152726,0.06033875,0.10918906,-0.03557182,0.05148001,0.04146224,-0.11811997,0.02406029,0.00903964,-0.02899775,0.01325838,0.02267672,-0.00216934,0.00687331,0.11116788,-0.04738554,-0.01985987,-0.00031635,-0.0328207,0.05332603,-0.00763127,0.06583997,0.03843961,0.03689267,0.01906139,0.01294819,0.00393923,-0.01380307,-0.01297609,-0.02075404,-0.01778775,-0.04893345,-0.06726146,0.1317897,0.05792453],"last_embed":{"hash":"1hvfefi","tokens":451}}},"last_read":{"hash":"1hvfefi","at":1774951887862},"class_name":"SmartSource","last_import":{"mtime":1774951817863,"size":4545,"at":1774951884785,"hash":"1hvfefi"},"blocks":{"#---frontmatter---":[1,113],"#Neurogenesis-dependent antidepressant-like activity of Hericium erinaceus in an animal model of depression.":[115,119],"#Neurogenesis-dependent antidepressant-like activity of Hericium erinaceus in an animal model of depression.#{1}":[117,119]},"outlinks":[{"title":"Author/Pit Shan Chong","target":"Author/Pit Shan Chong","line":87},{"title":"Author/Pit Shan Chong","target":"Author/Pit Shan Chong","line":88},{"title":"Author/Chi Him Poon","target":"Author/Chi Him Poon","line":89},{"title":"Author/Chi Him Poon","target":"Author/Chi Him Poon","line":90},{"title":"Author/Jaydeep Roy","target":"Author/Jaydeep Roy","line":91},{"title":"Author/Jaydeep Roy","target":"Author/Jaydeep Roy","line":92},{"title":"Author/Ka Chun Tsui","target":"Author/Ka Chun Tsui","line":93},{"title":"Author/Ka Chun Tsui","target":"Author/Ka Chun Tsui","line":94},{"title":"Author/Sze-Yuen Lew","target":"Author/Sze-Yuen Lew","line":95},{"title":"Author/Sze Yuen Lew","target":"Author/Sze Yuen Lew","line":96},{"title":"Author/Michael Weng Lok Phang","target":"Author/Michael Weng Lok Phang","line":97},{"title":"Author/Michael Weng Lok Phang","target":"Author/Michael Weng Lok Phang","line":98},{"title":"Author/Rachael Julia Yuenyinn Tan","target":"Author/Rachael Julia Yuenyinn Tan","line":99},{"title":"Author/Rachael Julia Yuenyinn Tan","target":"Author/Rachael Julia Yuenyinn Tan","line":100},{"title":"Author/Poh Guat Cheng","target":"Author/Poh Guat Cheng","line":101},{"title":"Author/Poh Guat Cheng","target":"Author/Poh Guat Cheng","line":102},{"title":"Author/Man-Lung Fung","target":"Author/Man-Lung Fung","line":103},{"title":"Author/Man-Lung Fung","target":"Author/Man-Lung Fung","line":104},{"title":"Author/Kah-Hui Wong","target":"Author/Kah-Hui Wong","line":105},{"title":"Author/Kah-Hui Wong","target":"Author/Kah-Hui Wong","line":106},{"title":"Author/Lee Wei Lim","target":"Author/Lee Wei Lim","line":107},{"title":"Author/Lee Wei Lim","target":"Author/Lee Wei Lim","line":108},{"title":"PDF","target":"biblib/chong_neurogenesis-dependent_2021/chong_neurogenesis-dependent_2021.pdf","line":110}],"metadata":{"id":"chong_neurogenesis-dependent_2021","type":"article-journal","title":"Neurogenesis-dependent antidepressant-like activity of Hericium erinaceus in an animal model of depression.","issued":{"date-parts":[[2021]]},"DOI":"10.1186/s13020-021-00546-8","container-title":"Chinese Medicine","abstract":"Depression is a severe neuropsychiatric disorder that affects more than 264 million people worldwide. The efficacy of conventional antidepressants are barely adequate and many have side effects. Hericium erinaceus (HE) is a medicinal mushroom that has been reported to have therapeutic potential for treating depression.Animals subjected to chronic restraint stress were given 4weeks HE treatment. Animals were then screened for anxiety and depressive-like behaviours. Gene and protein assays, as well as histological analysis were performed to probe the role of neurogenesis in mediating the therapeutic effect of HE. Temozolomide was administered to validate the neurogenesis-dependent mechanism of HE.The results showed that 4weeks of HE treatment ameliorated depressive-like behaviours in mice subjected to 14days of restraint stress. Further molecular assays demonstrated the 4-week HE treatment elevated the expression of several neurogenesis-related genes and proteins, including doublecortin, nestin, synaptophysin, brain-derived neurotrophic factor (BDNF), tropomyosin receptor kinase B (TrkB), phosphorylated extracellular signal-regulated kinase, and phosphorylated cAMP response element-binding protein (pCREB). Increased bromodeoxyuridine-positive cells were also observed in the dentate gyrus of the hippocampus, indicating enhanced neurogenesis. Neurogenesis blocker temozolomide completely abolished the antidepressant-like effects of HE, confirming a neurogenesis-dependent mechanism. Moreover, HE induced anti-neuroinflammatory effects through reducing astrocyte activation in the hippocampus, which was also abolished with temozolomide administration.HE exerts antidepressant effects by promoting neurogenesis and reducing neuroinflammation through enhancing the BDNF-TrkB-CREB signalling pathway.","tags":["#literature_note"],"author":[{"family":"Chong","given":"Pit Shan","literal":""},{"family":"Chong","given":"Pit Shan","literal":""},{"family":"Poon","given":"Chi Him","literal":""},{"family":"Poon","given":"Chi Him","literal":""},{"family":"Roy","given":"Jaydeep","literal":""},{"family":"Roy","given":"Jaydeep","literal":""},{"family":"Tsui","given":"Ka Chun","literal":""},{"family":"Tsui","given":"Ka Chun","literal":""},{"family":"Lew","given":"Sze-Yuen","literal":""},{"family":"Lew","given":"Sze Yuen","literal":""},{"family":"Phang","given":"Michael Weng Lok","literal":""},{"family":"Phang","given":"Michael Weng Lok","literal":""},{"family":"Tan","given":"Rachael Julia Yuenyinn","literal":""},{"family":"Tan","given":"Rachael Julia Yuenyinn","literal":""},{"family":"Cheng","given":"Poh Guat","literal":""},{"family":"Cheng","given":"Poh Guat","literal":""},{"family":"Fung","given":"Man-Lung","literal":""},{"family":"Fung","given":"Man-Lung","literal":""},{"family":"Wong","given":"Kah-Hui","literal":""},{"family":"Wong","given":"Kah-Hui","literal":""},{"family":"Lim","given":"Lee Wei","literal":""},{"family":"Lim","given":"Lee Wei","literal":""}],"citation-key":"chong_neurogenesis-dependent_2021","year":"2021","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Neurogenesis-dependent antidepressant-like activity of Hericium erinaceus in an animal model of depression."],"author-links":["[[Author/Pit Shan Chong]]","[[Author/Pit Shan Chong]]","[[Author/Chi Him Poon]]","[[Author/Chi Him Poon]]","[[Author/Jaydeep Roy]]","[[Author/Jaydeep Roy]]","[[Author/Ka Chun Tsui]]","[[Author/Ka Chun Tsui]]","[[Author/Sze-Yuen Lew]]","[[Author/Sze Yuen Lew]]","[[Author/Michael Weng Lok Phang]]","[[Author/Michael Weng Lok Phang]]","[[Author/Rachael Julia Yuenyinn Tan]]","[[Author/Rachael Julia Yuenyinn Tan]]","[[Author/Poh Guat Cheng]]","[[Author/Poh Guat Cheng]]","[[Author/Man-Lung Fung]]","[[Author/Man-Lung Fung]]","[[Author/Kah-Hui Wong]]","[[Author/Kah-Hui Wong]]","[[Author/Lee Wei Lim]]","[[Author/Lee Wei Lim]]"],"attachment":["[[biblib/chong_neurogenesis-dependent_2021/chong_neurogenesis-dependent_2021.pdf|PDF]]"],"related":[[]]},"task_lines":[],"tasks":{},"codeblock_ranges":[],"last_embed":{"hash":"1hvfefi","at":1774951887853}},"smart_blocks:Research/@chong_neurogenesis-dependent_2021.md#---frontmatter---": {"path":null,"embeddings":{"TaylorAI/bge-micro-v2":{"vec":[-0.01371564,0.00854042,0.06560992,-0.01703852,-0.02898022,0.07775404,0.02319244,0.03926049,-0.02156474,-0.01934703,0.01159415,-0.03984312,0.04101121,0.05541704,-0.00549869,0.01168821,-0.0084426,-0.01758716,-0.08818338,-0.03379988,0.03583473,-0.05532925,0.03459648,-0.04242598,0.00252632,0.00269214,-0.05874374,0.05643815,-0.0276226,-0.17570274,-0.00721165,-0.00385082,0.02469574,-0.01778622,0.00346481,-0.0007247,-0.04697791,0.01964136,-0.03658199,0.02562283,0.03614896,0.05130219,0.04684926,-0.00937179,0.02571409,-0.06402794,-0.01072051,-0.06765147,0.0508637