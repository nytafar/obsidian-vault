54,0.06669831,0.18236619,0.015499,-0.01637453,0.04557922,0.03178937,0.02434065,0.00268662,0.00655784,-0.00326942,0.01084083,0.12107392,-0.01699932,0.08011912,0.02461812,-0.0864032,-0.07263061,0.07325128,0.01058447,0.00948794,0.00388162,-0.03059058,-0.0498001,0.14611459,-0.08608527,-0.07630222,-0.08367488,0.00239322,-0.02181649,0.00762491,0.0448567,-0.00356188,0.08955403,-0.01482577,0.05129042,-0.05609412,-0.01325978,-0.01778623,-0.02833764,-0.03507906,0.04997643,-0.03872528,0.06320456,0.01692947],"last_embed":{"hash":"14o6nu7","tokens":402}}},"last_read":{"hash":"14o6nu7","at":1774951890878},"class_name":"SmartSource","last_import":{"mtime":1774951821863,"size":4017,"at":1774951884804,"hash":"14o6nu7"},"blocks":{"#---frontmatter---":[1,105],"#Adults who microdose psychedelics report health related motivations and lower levels of anxiety and depression compared to non-microdosers.":[107,111],"#Adults who microdose psychedelics report health related motivations and lower levels of anxiety and depression compared to non-microdosers.#{1}":[109,111]},"outlinks":[{"title":"Author/Joseph M. Rootman","target":"Author/Joseph M. Rootman","line":81},{"title":"Author/Joseph M. Rootman","target":"Author/Joseph M. Rootman","line":82},{"title":"Author/Pamela Kryskow","target":"Author/Pamela Kryskow","line":83},{"title":"Author/Pamela Kryskow","target":"Author/Pamela Kryskow","line":84},{"title":"Author/Kalin Harvey","target":"Author/Kalin Harvey","line":85},{"title":"Author/Kalin Harvey","target":"Author/Kalin Harvey","line":86},{"title":"Author/Paul Stamets","target":"Author/Paul Stamets","line":87},{"title":"Author/Paul E. Stamets","target":"Author/Paul E. Stamets","line":88},{"title":"Author/Paul E. Stamets","target":"Author/Paul E. Stamets","line":89},{"title":"Author/Eesmyal Santos-Brault","target":"Author/Eesmyal Santos-Brault","line":90},{"title":"Author/Eesmyal Santos-Brault","target":"Author/Eesmyal Santos-Brault","line":91},{"title":"Author/Kim P. C. Kuypers","target":"Author/Kim P. C. Kuypers","line":92},{"title":"Author/Kim P. C. Kuypers","target":"Author/Kim P. C. Kuypers","line":93},{"title":"Author/Vince Polito","target":"Author/Vince Polito","line":94},{"title":"Author/Vince Polito","target":"Author/Vince Polito","line":95},{"title":"Author/Vince Polito","target":"Author/Vince Polito","line":96},{"title":"Author/Francoise Bourzat","target":"Author/Francoise Bourzat","line":97},{"title":"Author/Francoise Bourzat","target":"Author/Francoise Bourzat","line":98},{"title":"Author/Zach Walsh","target":"Author/Zach Walsh","line":99},{"title":"Author/Zach Walsh","target":"Author/Zach Walsh","line":100},{"title":"PDF","target":"biblib/rootman_adults_2021/rootman_adults_2021.pdf","line":102}],"metadata":{"id":"rootman_adults_2021","type":"article-journal","title":"Adults who microdose psychedelics report health related motivations and lower levels of anxiety and depression compared to non-microdosers.","issued":{"date-parts":[[2021]]},"DOI":"10.1038/s41598-021-01811-4","container-title":"Scientific Reports","abstract":"The use of psychedelic substances at sub-sensorium ‘microdoses’, has gained popular academic interest for reported positive effects on wellness and cognition. The present study describes microdosing practices, motivations and mental health among a sample of self-selected microdosers (n=4050) and non-microdosers (n=4653) via a mobile application. Psilocybin was the most commonly used microdose substances in our sample (85%) and we identified diverse microdose practices with regard to dosage, frequency, and the practice of stacking which involves combining psilocybin with non-psychedelic substances such as Lion’s Mane mushrooms, chocolate, and niacin. Microdosers were generally similar to non-microdosing controls with regard to demographics, but were more likely to report a history of mental health concerns. Among individuals reporting mental health concerns, microdosers exhibited lower levels of depression, anxiety, and stress across gender. Health and wellness-related motives were the most prominent motives across microdosers in general, and were more prominent among females and among individuals who reported mental health concerns. Our results indicate health and wellness motives and perceived mental health benefits among microdosers, and highlight the need for further research into the mental health consequences of microdosing including studies with rigorous longitudinal designs.","tags":["#literature_note"],"author":[{"family":"Rootman","given":"Joseph M.","literal":""},{"family":"Rootman","given":"Joseph M.","literal":""},{"family":"Kryskow","given":"Pamela","literal":""},{"family":"Kryskow","given":"Pamela","literal":""},{"family":"Harvey","given":"Kalin","literal":""},{"family":"Harvey","given":"Kalin","literal":""},{"family":"Stamets","given":"Paul","literal":""},{"family":"Stamets","given":"Paul E.","literal":""},{"family":"Stamets","given":"Paul E.","literal":""},{"family":"Santos-Brault","given":"Eesmyal","literal":""},{"family":"Santos-Brault","given":"Eesmyal","literal":""},{"family":"Kuypers","given":"Kim P. C.","literal":""},{"family":"Kuypers","given":"Kim P. C.","literal":""},{"family":"Polito","given":"Vince","literal":""},{"family":"Polito","given":"Vince","literal":""},{"family":"Polito","given":"Vince","literal":""},{"family":"Bourzat","given":"Francoise","literal":""},{"family":"Bourzat","given":"Francoise","literal":""},{"family":"Walsh","given":"Zach","literal":""},{"family":"Walsh","given":"Zach","literal":""}],"citation-key":"rootman_adults_2021","year":"2021","dateCreated":"2026-03-31","reading-status":"to-read","aliases":["Adults who microdose psychedelics report health related motivations and lower levels of anxiety and depression compared to non-microdosers."],"author-links":["[[Author/Joseph M. Rootman]]","[[Author/Joseph M. Rootman]]","[[Author/Pamela Kryskow]]","[[Author/Pamela Kryskow]]","[[Author/Kalin Harvey]]","[[Author/Kalin Harvey]]","[[Author/